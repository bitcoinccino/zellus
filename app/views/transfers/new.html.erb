});

// ══════════════════════════════════════
// ── QR SCANNER                      ──
// ══════════════════════════════════════
var _qrScanner = null;

function openQrScanner() {
  var overlay = document.getElementById('qr-scanner-overlay');
  if (!overlay) return;

  overlay.style.display = 'flex';
  document.body.style.overflow = 'hidden';

  // Reset status text
  document.getElementById('qr-status-title').textContent = 'Eskane yon kòd QR';
  document.getElementById('qr-status-hint').textContent = 'Mete kòd QR la nan kad la';

  // Init html5-qrcode
  _qrScanner = new Html5Qrcode("qr-reader");

  _qrScanner.start(
    { facingMode: "environment" },
    { fps: 10, qrbox: { width: 250, height: 250 }, aspectRatio: 1.0 },
    onQrScanSuccess,
    function onScanFailure() { /* silent — scanning in progress */ }
  ).catch(function(err) {
    document.getElementById('qr-status-title').textContent = 'Pa ka ouvri kamera';
    document.getElementById('qr-status-hint').textContent = 'Pèmèt aksè kamera nan navigatè ou';
    console.error("QR camera error:", err);
  });
}

function onQrScanSuccess(decodedText) {
  var value = (decodedText || '').trim();
  if (!value) return;

  // Parse ethereum: URI format
  if (value.toLowerCase().startsWith('ethereum:')) {
    value = value.replace(/^ethereum:/i, '').split(/[?@]/)[0];
  }

  var matched = false;

  // ── Zèllus cashtag: starts with $ ──
  if (/^\$[a-zA-Z0-9]{5,20}$/.test(value)) {
    var tag = value.substring(1);
    // Switch to Zèllus HTG and trigger lookup
    simulateDestSelect('zellus-htg');
    var lookupInput = document.getElementById('receiver-lookup-input');
    if (lookupInput) {
      lookupInput.value = value;
      handleReceiverLookup();
    }
    matched = true;
  }
  // ── MonCash phone: 509 + 8 digits ──
  else if (/^509\d{8}$/.test(value)) {
    simulateDestSelect('moncash-htg');
    var phoneHidden = document.getElementById('receiver-phone-hidden');
    if (phoneHidden) phoneHidden.value = value;
    // Try manual phone input
    var moncashSelect = document.getElementById('moncash-method-select');
    if (moncashSelect) {
      moncashSelect.value = 'other';
      handleMoncashMethodSelect(moncashSelect);
    }
    var phoneInput = document.getElementById('moncash-phone-input');
    if (phoneInput) phoneInput.value = value;
    matched = true;
  }
  // ── Crypto address: 0x + 40 hex chars ──
  else if (/^0x[a-fA-F0-9]{40}$/.test(value)) {
    simulateDestSelect('zellus-usdc');
    // Show manual wallet input
    var cryptoSelect = document.getElementById('crypto-select');
    if (cryptoSelect) {
      cryptoSelect.value = 'other';
      toggleManualWallet();
    } else {
      var manualWrapper = document.getElementById('manual-wallet-wrapper');
      if (manualWrapper) manualWrapper.style.display = '';
    }
    var walletInput = document.querySelector("input[name='transfer[receiver_wallet_address]']");
    if (walletInput) walletInput.value = value;
    matched = true;
  }

  if (matched) {
    // Force-enable amount field + submit button after QR scan
    var amtInput = document.getElementById('amount-visible-input');
    if (amtInput) {
      amtInput.disabled = false;
      amtInput.closest('.input-group').style.opacity = '1';
    }
    var submitBtn = document.querySelector("#transfer-form button[type='submit']");
    if (submitBtn) { submitBtn.disabled = false; submitBtn.style.opacity = '1'; }

    // Hide zero-balance warning
    var zbw = document.getElementById('zero-bal-warning');
    if (zbw) zbw.style.display = 'none';

    // Lock QR recipient — hide receiver sections, keep dropdown visible
    qrRecipientActive = true;
    ['section-zellus', 'section-zellus-usdc', 'section-moncash', 'section-bank', 'section-crypto'].forEach(function(id) {
      var el = document.getElementById(id);
      if (el) el.style.display = 'none';
    });

    // Show confirmed recipient card
    showQrConfirmedCard(value);

    // Show success feedback
    document.getElementById('qr-status-title').innerHTML = '<i class="ri-check-line me-1" style="color: #22c55e;"></i>Jwenn li!';
    document.getElementById('qr-status-hint').textContent = 'N ap fèmen kamera a...';

    // Brief delay then close
    setTimeout(function() {
      closeQrScanner();
      var amountInput = document.getElementById('amount-visible-input');
      if (amountInput) amountInput.focus();
    }, 800);
  } else {
    // Invalid QR
    document.getElementById('qr-status-title').innerHTML = '<i class="ri-error-warning-line me-1" style="color: #f59e0b;"></i>QR pa rekonèt';
    document.getElementById('qr-status-hint').textContent = 'Eseye yon kòd QR Zèllus, MonCash, oswa Base';
    // Reset after a beat so user can try again
    setTimeout(function() {
      document.getElementById('qr-status-title').textContent = 'Eskane yon kòd QR';
      document.getElementById('qr-status-hint').textContent = 'Mete kòd QR la nan kad la';
    }, 2000);
  }
}

function closeQrScanner() {
  var overlay = document.getElementById('qr-scanner-overlay');
  if (overlay) overlay.style.display = 'none';
  document.body.style.overflow = '';

  if (_qrScanner) {
    _qrScanner.stop().catch(function() {});
    _qrScanner.clear();
    _qrScanner = null;
  }
}

// Helper: programmatically switch destination dropdown
function simulateDestSelect(dest) {
  switchDestination(dest);
  var labels = {
    "zellus-htg": "HTG", "zellus-usdc": "USD", "zellus-eth": "ETH", "zellus-wbtc": "wBTC",
    "zellus-tslax": "TSLAX", "zellus-nvdax": "NVDAX", "zellus-aaplx": "AAPLX", "zellus-coinx": "COINX", "zellus-googlx": "GOOGLX"
  };
  var labelEl = document.getElementById('dest-selected-label');
  if (labelEl && labels[dest]) labelEl.textContent = labels[dest];
}

// Show the confirmed recipient card after QR scan
function showQrConfirmedCard(scannedValue) {
  var card = document.getElementById('qr-confirmed-recipient');
  var label = document.getElementById('qr-confirmed-label');
  var dest = document.getElementById('qr-confirmed-dest');
  if (!card) return;

  if (scannedValue.startsWith('$')) {
    label.textContent = scannedValue;
    dest.textContent = 'HTG';
  } else if (/^509\d{8}$/.test(scannedValue)) {
    label.textContent = scannedValue.replace(/(\d{3})(\d{4})(\d{4})/, '$1 $2 $3');
    dest.textContent = 'HTG';
  } else if (/^0x/i.test(scannedValue)) {
    label.textContent = scannedValue.substring(0, 6) + '...' + scannedValue.slice(-4);
    dest.textContent = 'USD · Base';
  } else {
    label.textContent = scannedValue;
    dest.textContent = '';
  }

  card.style.display = '';
}

// Clear QR recipient → restore normal form
function clearQrRecipient() {
  qrRecipientActive = false;

  // Hide confirmed card
  var card = document.getElementById('qr-confirmed-recipient');
  if (card) card.style.display = 'none';

  // Re-show the correct receiver section for the current destination
  switchDestination(currentDest);
}

// ── Submit button loading state ──
document.addEventListener("DOMContentLoaded", function() {
  var form = document.getElementById("transfer-form");
  if (form) {
    form.addEventListener("submit", function() {
      var btn = document.getElementById("transfer-submit-btn");
      var icon = document.getElementById("submit-icon");
      var text = document.getElementById("submit-text");
      if (btn && icon && text) {
        btn.disabled = true;
        btn.style.opacity = "0.7";
        icon.className = "ri-loader-4-line";
        icon.style.animation = "spin 60s linear infinite";
        text.textContent = "Ap trete...";
      }
    });
  }

  // Add spin keyframe
  var style = document.createElement("style");
  style.textContent = "@keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }";
  document.head.appendChild(style);
});
</script>
