  if (cartField && cartField.value && cartField.value !== '[]') {
    try {
      var cartItems = JSON.parse(cartField.value);
      if (cartItems.length > 0) {
        var subtotal = cartItems.reduce(function(sum, item) {
          return sum + (parseInt(item.quantity) || 0) * (parseFloat(item.unit_price) || 0);
        }, 0);
        // Get tax rate from URL param biz → find from receipt section
        var receiptTotal = document.querySelector('.fw-black[style*="font-size: 14px; color: var(--haiti-charcoal)"]');
        if (receiptTotal) {
