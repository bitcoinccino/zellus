// ── Unified Receiver Lookup (search-as-you-type) ──
var _htgLookupTimer = null;
var _htgLastQuery = '';

function handleReceiverLookup() {
  var input = document.getElementById("receiver-lookup-input");
  var resultDiv = document.getElementById("receiver-lookup-result");
  var icon = document.getElementById("htg-search-icon");
  var q = (input ? input.value : "").trim();

  // Reset hidden fields
  document.getElementById("receiver-cashtag-hidden").value = "";
  document.getElementById("receiver-phone-hidden").value = "";
  document.getElementById("receiver-email-hidden").value = "";
  isZellusReceiver = false;
  updateFee();

  if (_htgLookupTimer) { clearTimeout(_htgLookupTimer); _htgLookupTimer = null; }

  if (!q) {
    resultDiv.style.display = 'none';
    resultDiv.innerHTML = '';
    icon.className = 'ri-search-line';
    _htgLastQuery = '';
    return;
  }

  if (q.length < 2) {
    resultDiv.style.display = 'none';
    _htgLastQuery = '';
    return;
  }

  if (q === _htgLastQuery) return;

  icon.className = 'ri-loader-4-line ri-spin';

  _htgLookupTimer = setTimeout(function() {
    _htgLastQuery = q;

    fetch('<%= user_lookup_path %>' + '?q=' + encodeURIComponent(q), {
      headers: { 'Accept': 'application/json' }
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      icon.className = 'ri-search-line';
      resultDiv.style.display = 'block';

      if (data.found) {
        document.getElementById("receiver-cashtag-hidden").value = data.cashtag;
        if (data.has_moncash) {
          document.getElementById("receiver-phone-hidden").value = data.moncash_phone;
        }
        isZellusReceiver = true;
        updateFee();

        var avatarHtml = data.avatar_url
          ? '<img src="' + data.avatar_url + '" style="width: 32px; height: 32px; border-radius: 50%; object-fit: cover; border: 1.5px solid var(--haiti-gold);">'
          : '<div style="width: 32px; height: 32px; border-radius: 50%; background: var(--haiti-charcoal); border: 1.5px solid var(--haiti-gold); display: flex; align-items: center; justify-content: center; color: var(--haiti-gold); font-size: 13px; font-weight: 800;">' + data.display_name.charAt(0).toUpperCase() + '</div>';

        resultDiv.innerHTML = '<div class="d-flex align-items-center justify-content-between p-2 rounded-3" style="background: rgba(22,101,52,0.08);">' +
          '<div class="d-flex align-items-center gap-2">' + avatarHtml +
          '<div><div class="fw-bold" style="color: #166534; font-size: 12px;">' + data.display_name + '</div>' +
          '<div style="color: var(--haiti-olive); font-size: 10px;">$' + data.cashtag + (data.has_moncash ? ' · ' + data.moncash_phone : '') + '</div></div></div>' +
          '<button type="button" class="btn btn-sm fw-bold rounded-pill" style="background: #166534; color: #fff; font-size: 10px;" ' +
          'onclick="selectHtgReceiver(\'' + data.cashtag + '\', \'' + (data.moncash_phone || '') + '\', \'' + data.display_name.replace(/'/g, "\\'") + '\')"><i class="ri-check-line me-1"></i>Chwazi</button></div>';
      } else {
        resultDiv.innerHTML = '<div class="small fw-bold" style="color: #991b1b; font-size: 11px;"><i class="ri-close-circle-line me-1"></i>' + data.message + '</div>';
      }
    })
    .catch(function() {
      icon.className = 'ri-search-line';
      resultDiv.style.display = 'block';
      resultDiv.innerHTML = '<div class="small fw-bold" style="color: #991b1b; font-size: 11px;">Erè rechèch. Eseye ankò.</div>';
    });
  }, 300);
}

