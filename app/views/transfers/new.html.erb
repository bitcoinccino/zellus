// ── Handle amount input: sync visible → hidden (convert USDC → HTG if needed) ──
function handleAmountInput() {
  var visibleInput = document.getElementById("amount-visible-input");
  var hiddenInput = document.getElementById("transfer_amount");
  var equiv = document.getElementById("amount-htg-equivalent");
  var val = parseFloat(visibleInput.value) || 0;

  if (currentAsset === "usdc") {
    // Convert USDC to HTG for the backend
    var htgAmount = Math.round(val * USDC_HTG_RATE);
    hiddenInput.value = htgAmount > 0 ? htgAmount : "";
    if (val > 0) {
      equiv.style.display = "";
      equiv.innerHTML = '<i class="ri-exchange-line me-1"></i>≈ ' + htgAmount.toLocaleString('fr') + ' HTG';
    } else {
      equiv.innerHTML = "";
    }
  } else {
    // HTG or ETH: direct pass-through
    hiddenInput.value = val > 0 ? val : "";
    equiv.style.display = "none";
  }
}

