<% content_for :hide_navbar, true %>

<div class="container py-5" style="min-height: 100vh;">
  <div class="row justify-content-center">
    <div class="col-12 col-md-7 col-lg-5">

      <div class="text-center mb-4">
        <%= link_to new_user_session_path, title: "Tounen nan paj prensipal" do %>
          <%= image_tag "zellus_square.png", alt: "Zèllus", style: "width: 60px; height: 60px; border-radius: 14px; margin-bottom: 22px;" %>
        <% end %>
        <h1 class="fw-black mb-1" style="color: var(--haiti-charcoal); font-size: 24px; font-family: 'Space Grotesk', sans-serif;">Konekte</h1>
        <p class="mb-0 mt-2 mx-auto" style="color: var(--haiti-olive); font-size: 12px; line-height: 1.5; max-width: 320px;">
          Si imèl sa a gen yon kont Zellus deja, n ap konekte w. Si l nouvo, n ap kòmanse kreye yon nouvo kont Zellus pou ou.
        </p>
      </div>

      <div class="p-4 rounded-4" style="background: #fff; border: 1px solid rgba(46,46,56,0.08); box-shadow: 0 4px 14px rgba(46,46,56,0.06);">

        <%= form_with url: login_path, method: :post, local: true do |f| %>
          <label class="form-label small fw-bold text-uppercase" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">Imèl</label>
          <div class="input-group mb-3" style="border: 1.5px solid rgba(46,46,56,0.12); border-radius: 12px; overflow: hidden;">
            <%= f.email_field :email,
                  value: params[:email],
                  required: true,
                  autofocus: true,
                  autocomplete: "email",
                  placeholder: "ou@egzanp.com",
                  class: "form-control border-0 fw-bold shadow-none p-3",
                  style: "font-size: 14px; color: var(--haiti-charcoal);" %>
          </div>

          <div class="d-flex align-items-start gap-2 mb-3 mt-1">
            <input type="checkbox" name="terms_accepted" id="terms_accepted" required
                   class="flex-shrink-0"
                   style="width: 16px; height: 16px; margin-top: 2px; accent-color: var(--haiti-gold); cursor: pointer;">
            <label for="terms_accepted" class="mb-0" style="color: var(--haiti-olive); font-size: 11px; line-height: 1.5; cursor: pointer;">
              Mwen aksepte
              <span class="fw-bold" style="color: var(--haiti-gold);">Tèm</span>,
              <span class="fw-bold" style="color: var(--haiti-gold);">Konsantman</span>, ak
              <span class="fw-bold" style="color: var(--haiti-gold);">Politik Konfidansyalite</span> Zellus yo.
            </label>
          </div>

          <%= f.submit "Kontinye",
                class: "btn w-100 fw-bold rounded-pill py-3 border-0",
                style: "background: var(--haiti-gold); color: var(--haiti-charcoal); font-size: 13px; letter-spacing: 0.5px;" %>
        <% end %>

        <div class="text-center my-3 small" style="color: var(--haiti-olive); font-size: 11px;">
          <span style="background: #fff; padding: 0 8px; position: relative; z-index: 1;">Oswa</span>
          <hr style="margin-top: -10px; opacity: 0.15;">
        </div>

        <%= link_to user_bonid_omniauth_authorize_path, method: :post,
              class: "btn w-100 fw-bold rounded-pill py-3 border-0 d-flex align-items-center justify-content-center gap-2",
              style: "background: var(--haiti-charcoal); color: var(--haiti-gold); font-size: 13px;" do %>
          <i class="ri-shield-check-line"></i> Konekte ak BonID
        <% end %>
      </div>
    </div>
  </div>
</div>
