<div class="container py-5" style="min-height: calc(100vh - 64px);">
  <div class="row justify-content-center">
    <div class="col-12 col-md-7 col-lg-5">

      <div class="text-center mb-4">
        <div class="fw-black mb-2" style="font-family: 'Space Grotesk', sans-serif; font-size: 22px; letter-spacing: 4px; text-transform: uppercase; color: var(--haiti-gold);">Zèllus</div>
        <h1 class="fw-black mb-1" style="color: var(--haiti-charcoal); font-size: 24px; font-family: 'Space Grotesk', sans-serif;">Antre Kòd Ou</h1>
        <p class="small mb-0" style="color: var(--haiti-olive);">N voye yon kòd 6 chif nan</p>
        <div class="fw-bold" style="color: var(--haiti-charcoal); font-size: 14px;"><%= @email %></div>
      </div>

      <div class="p-4 rounded-4" style="background: #fff; border: 1px solid rgba(46,46,56,0.08); box-shadow: 0 4px 14px rgba(46,46,56,0.06);">

        <% if flash[:alert].present? %>
          <div class="p-3 mb-3 rounded-3 d-flex align-items-start gap-2"
               style="background-color: #fdf2f2; border: 1px solid #fee2e2;">
            <i class="ri-error-warning-fill" style="color: #D8000C; font-size: 16px;"></i>
            <div class="small" style="color: var(--haiti-charcoal); line-height: 1.5;"><%= flash[:alert] %></div>
          </div>
        <% end %>

        <% if flash[:notice].present? %>
          <div class="p-3 mb-3 rounded-3 d-flex align-items-start gap-2"
               style="background-color: rgba(2,115,10,0.08); border: 1px solid rgba(2,115,10,0.35);">
            <i class="ri-check-line" style="color: #02730A; font-size: 16px;"></i>
            <div class="small" style="color: var(--haiti-charcoal); line-height: 1.5;"><%= flash[:notice] %></div>
          </div>
        <% end %>

        <%= form_with url: login_verify_path, method: :post, local: true do |f| %>
          <label class="form-label small fw-bold text-uppercase" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">Kòd 6 Chif</label>
          <div class="input-group mb-3" style="border: 1.5px solid rgba(46,46,56,0.12); border-radius: 12px; overflow: hidden;">
            <span class="input-group-text border-0" style="background-color: var(--haiti-mint); color: var(--haiti-gold);">
              <i class="ri-key-2-line"></i>
            </span>
            <%= f.text_field :code,
                  required: true,
                  autofocus: true,
                  autocomplete: "one-time-code",
                  inputmode: "numeric",
                  pattern: "\\d{6}",
                  maxlength: 6,
                  placeholder: "••••••",
                  class: "form-control border-0 fw-bold shadow-none p-3 text-center",
                  style: "font-size: 22px; color: var(--haiti-charcoal); letter-spacing: 10px; font-family: 'Courier New', monospace;" %>
          </div>

          <%= f.submit "Verifye Kòd",
                class: "btn w-100 fw-bold rounded-pill py-3 border-0",
                style: "background: var(--haiti-gold); color: var(--haiti-charcoal); font-size: 13px; letter-spacing: 0.5px;" %>
        <% end %>

        <div class="text-center mt-3">
          <%= link_to "Pa resevwa kòd la? Voye yon lòt", login_path,
                class: "small fw-bold text-decoration-none",
                style: "color: var(--haiti-olive); font-size: 11px;" %>
        </div>
      </div>
    </div>
  </div>
</div>
