<%# ── Shared Business Form Partial ── %>

<%= form_with(model: @business, url: @business.new_record? ? business_path : business_path, method: @business.new_record? ? :post : :patch, local: true, class: "needs-validation") do |f| %>

  <% if @business.errors.any? %>
    <div class="rounded-3 p-3 mb-3" style="background: #fee2e2; border: 1px solid #fca5a5;">
      <div class="fw-bold mb-1" style="color: #991b1b; font-size: 13px;">
        <i class="ri-error-warning-line me-1"></i><%= pluralize(@business.errors.count, "erè") %> anpeche biznis ou anrejistre:
      </div>
      <ul class="mb-0 ps-3" style="font-size: 12px; color: #991b1b;">
        <% @business.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# ── Business Name ── %>
  <div class="mb-3">
    <label class="form-label fw-bold" style="color: var(--haiti-charcoal); font-size: 13px;">
      <i class="ri-store-2-line me-1" style="color: var(--haiti-gold);"></i>Non Biznis
    </label>
    <%= f.text_field :name, class: "form-control", placeholder: "Ex: Ti Machann Lakay", style: "border-color: var(--haiti-olive); font-size: 14px;" %>
  </div>

  <%# ── Slug ── %>
  <div class="mb-3">
    <label class="form-label fw-bold" style="color: var(--haiti-charcoal); font-size: 13px;">
      <i class="ri-link me-1" style="color: var(--haiti-gold);"></i>Lyen Piblik (slug)
    </label>
    <div class="input-group">
      <span class="input-group-text" style="background: var(--haiti-charcoal); color: var(--haiti-gold); font-size: 12px;">b/</span>
      <%= f.text_field :slug, class: "form-control", placeholder: "ti-machann-lakay", style: "border-color: var(--haiti-olive); font-size: 14px;" %>
    </div>
    <div class="form-text" style="font-size: 11px; color: var(--haiti-olive);">Sa a se lyen kliyan ou yo pral itilize: priotelus.com/b/slug-ou</div>
  </div>

  <%# ── Logo Upload ── %>
  <div class="mb-3">
    <label class="form-label fw-bold" style="color: var(--haiti-charcoal); font-size: 13px;">
      <i class="ri-image-line me-1" style="color: var(--haiti-gold);"></i>Logo Biznis
    </label>
    <% if @business.logo.attached? %>
      <div class="mb-2">
        <%= image_tag @business.logo, class: "rounded-circle", style: "width: 60px; height: 60px; object-fit: cover; border: 2px solid var(--haiti-olive);" %>
      </div>
    <% end %>
    <%= f.file_field :logo, class: "form-control", accept: "image/*", style: "border-color: var(--haiti-olive); font-size: 13px;" %>
  </div>

  <%# ── Category Picker ── %>
  <div class="mb-3">
    <label class="form-label fw-bold" style="color: var(--haiti-charcoal); font-size: 13px;">
      <i class="ri-apps-line me-1" style="color: var(--haiti-gold);"></i>Kategori
    </label>
    <div class="d-flex flex-wrap gap-2">
      <% Business::CATEGORIES.each do |key, meta| %>
        <label class="category-pill" style="cursor: pointer;">
          <%= f.radio_button :category, key, class: "btn-check", id: "cat_#{key}" %>
          <span class="d-inline-flex align-items-center gap-1 px-3 py-2 rounded-pill border"
                style="font-size: 12px; font-weight: 600; transition: all 0.2s;
                       <%= @business.category == key.to_s ? "background: var(--haiti-charcoal); color: var(--haiti-gold); border-color: var(--haiti-charcoal);" : "background: white; color: var(--haiti-charcoal); border-color: rgba(93,99,69,0.2);" %>">
            <i class="<%= meta[:icon] %>" style="font-size: 14px;"></i>
            <%= meta[:label] %>
          </span>
        </label>
      <% end %>
    </div>
  </div>

  <%# ── Description ── %>
  <div class="mb-3">
    <label class="form-label fw-bold" style="color: var(--haiti-charcoal); font-size: 13px;">
      <i class="ri-file-text-line me-1" style="color: var(--haiti-gold);"></i>Deskripsyon
    </label>
    <%= f.text_area :description, class: "form-control", rows: 3, placeholder: "Dekri biznis ou an kèk mo...", style: "border-color: var(--haiti-olive); font-size: 14px;" %>
  </div>

  <%# ── Location ── %>
  <div class="row mb-3">
    <div class="col-6">
      <label class="form-label fw-bold" style="color: var(--haiti-charcoal); font-size: 13px;">
        <i class="ri-map-pin-line me-1" style="color: var(--haiti-gold);"></i>Komin
      </label>
      <%= f.text_field :commune, class: "form-control", placeholder: "Ex: Pétion-Ville", style: "border-color: var(--haiti-olive); font-size: 14px;" %>
    </div>
    <div class="col-6">
      <label class="form-label fw-bold" style="color: var(--haiti-charcoal); font-size: 13px;">Depatman</label>
      <%= f.text_field :department, class: "form-control", placeholder: "Ex: Lwès", style: "border-color: var(--haiti-olive); font-size: 14px;" %>
    </div>
  </div>

  <%# ── Phone ── %>
  <div class="mb-3">
    <label class="form-label fw-bold" style="color: var(--haiti-charcoal); font-size: 13px;">
      <i class="ri-phone-line me-1" style="color: var(--haiti-gold);"></i>Telefòn Biznis
    </label>
    <%= f.text_field :phone, class: "form-control", placeholder: "509XXXXXXXX", style: "border-color: var(--haiti-olive); font-size: 14px;" %>
  </div>

  <%# ── Fee Rate ── %>
  <div class="mb-3">
    <label class="form-label fw-bold" style="color: var(--haiti-charcoal); font-size: 13px;">
      <i class="ri-percent-line me-1" style="color: var(--haiti-gold);"></i>To Frè (%)
    </label>
    <div class="input-group">
      <%= f.number_field :fee_rate, class: "form-control", step: 0.001, min: 0, max: 0.10, style: "border-color: var(--haiti-olive); font-size: 14px;" %>
      <span class="input-group-text" style="background: var(--haiti-cream); font-size: 12px;">defò: 1.5%</span>
    </div>
    <div class="form-text" style="font-size: 11px; color: var(--haiti-olive);">Pousantaj ou kolekte sou chak tranzaksyon (0.015 = 1.5%)</div>
  </div>

  <%# ── Tax ID ── %>
  <div class="mb-4">
    <label class="form-label fw-bold" style="color: var(--haiti-charcoal); font-size: 13px;">
      <i class="ri-government-line me-1" style="color: var(--haiti-gold);"></i>NIF (opsyonèl)
    </label>
    <%= f.text_field :tax_id, class: "form-control", placeholder: "Nimewo Idantifikasyon Fiskal", style: "border-color: var(--haiti-olive); font-size: 14px;" %>
  </div>

  <%# ── Submit ── %>
  <div class="d-grid">
    <%= f.submit(@business.new_record? ? "Kreye Biznis Mwen" : "Anrejistre Chanjman"), class: "btn btn-lg fw-bold py-3 rounded-3", style: "background: var(--haiti-charcoal); color: var(--haiti-gold); font-size: 15px;" %>
  </div>
<% end %>

<style>
  .category-pill .btn-check:checked + span {
    background: var(--haiti-charcoal) !important;
    color: var(--haiti-gold) !important;
    border-color: var(--haiti-charcoal) !important;
  }
  .category-pill:hover span {
    border-color: var(--haiti-olive) !important;
  }
</style>
