<% content_for :full_width, true %>
<div class="d-flex justify-content-center align-items-start pt-4 pb-5" style="min-height: 80vh;">
  <div class="card-base p-4 w-100" style="max-width: 560px;">

    <%# ── Header ── %>
    <div class="d-flex align-items-center gap-3 mb-3">
      <%= link_to business_path, class: "text-decoration-none" do %>
        <div class="d-flex align-items-center justify-content-center rounded-circle"
             style="width: 40px; height: 40px; background: rgba(93,99,69,0.08);">
          <i class="ri-arrow-left-line" style="font-size: 20px; color: var(--haiti-charcoal);"></i>
        </div>
      <% end %>
      <div>
        <h1 class="h5 fw-black mb-0" style="color: var(--haiti-charcoal);">Modifye Biznis</h1>
        <div style="color: var(--haiti-olive); font-size: 12px;"><%= @business.name %></div>
      </div>
    </div>

    <%# ── Progress Bar ── %>
    <div class="d-flex align-items-center gap-2 mb-4" id="biz-progress">
      <% 3.times do |i| %>
        <div class="flex-fill" style="height: 4px; border-radius: 2px; background: var(--haiti-mint); overflow: hidden;">
          <div class="biz-progress-fill" data-step="<%= i + 1 %>"
               style="height: 100%; width: 0%; background: var(--haiti-gold); border-radius: 2px; transition: width 0.3s;"></div>
        </div>
      <% end %>
      <span class="small fw-bold" id="biz-step-label" style="color: var(--haiti-olive); font-size: 11px; white-space: nowrap;">Pati 1/3</span>
    </div>

    <%= render "form" %>
  </div>
</div>
