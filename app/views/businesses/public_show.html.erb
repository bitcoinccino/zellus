<div class="container py-4" style="max-width: 600px;">

  <%# ══════════════════════════════════════ %>
  <%# ── HERO: Business Profile Card     ── %>
  <%# ══════════════════════════════════════ %>
  <div class="rounded-4 p-4 mb-3 text-center position-relative" style="background: var(--haiti-charcoal);">

    <%# ── Status Badge ── %>
    <% if @business.active? %>
      <span class="badge rounded-pill position-absolute" style="top: 16px; right: 16px; background: rgba(34,197,94,0.15); color: #22c55e; font-size: 9px;">
        <i class="ri-checkbox-circle-fill me-1"></i>VERIFYE
      </span>
    <% end %>

    <%# ── Logo ── %>
    <div class="mb-3">
      <% if @business.logo.attached? %>
        <%= image_tag @business.logo, class: "rounded-circle", style: "width: 80px; height: 80px; object-fit: cover; border: 3px solid var(--haiti-gold);" %>
      <% else %>
        <div class="d-inline-flex align-items-center justify-content-center rounded-circle"
             style="width: 80px; height: 80px; background: var(--haiti-olive);">
          <i class="<%= @business.category_icon %>" style="font-size: 40px; color: var(--haiti-gold);"></i>
        </div>
      <% end %>
    </div>

    <%# ── Name & Category ── %>
    <h1 class="h4 fw-black mb-1" style="color: white;"><%= @business.name %></h1>
    <div class="d-flex align-items-center justify-content-center gap-2 mb-2">
      <span class="badge rounded-pill" style="background: rgba(93,99,69,0.3); color: var(--haiti-gold); font-size: 11px;">
        <i class="<%= @business.category_icon %> me-1"></i><%= @business.category_label %>
      </span>
    </div>

    <% if @business.description.present? %>
      <p class="mb-3 mx-auto" style="color: rgba(255,255,255,0.7); font-size: 13px; max-width: 400px; line-height: 1.5;">
        <%= @business.description %>
      </p>
    <% end %>

    <%# ── Location & Contact ── %>
    <div class="d-flex justify-content-center gap-3 flex-wrap" style="font-size: 11px; color: rgba(255,255,255,0.5);">
      <% if @business.commune.present? %>
        <span><i class="ri-map-pin-line me-1"></i><%= @business.commune %><%= ", #{@business.department}" if @business.department.present? %></span>
      <% end %>
      <% if @business.phone.present? %>
        <span><i class="ri-phone-line me-1"></i><%= @business.phone %></span>
      <% end %>
    </div>

    <%# ── Pay Button ── %>
    <div class="mt-4">
      <% if user_signed_in? %>
        <%= link_to new_transfer_path(receiver_lookup: "$#{@owner.cashtag}", business_id: @business.id), class: "btn btn-lg px-5 py-3 rounded-3 fw-bold", style: "background: var(--haiti-gold); color: var(--haiti-charcoal); font-size: 16px;" do %>
          <i class="ri-send-plane-fill me-2"></i>Peye <%= @business.name %>
        <% end %>
      <% else %>
        <%= link_to new_user_session_path, class: "btn btn-lg px-5 py-3 rounded-3 fw-bold", style: "background: var(--haiti-gold); color: var(--haiti-charcoal); font-size: 16px;" do %>
          <i class="ri-login-box-line me-2"></i>Konekte pou Peye
        <% end %>
      <% end %>
    </div>

    <%# ── Owner Cashtag ── %>
    <% if @owner.cashtag.present? %>
      <div class="mt-3" style="color: rgba(255,255,255,0.4); font-size: 12px;">
        $<%= @owner.cashtag %>
      </div>
    <% end %>
  </div>

  <%# ══════════════════════════════════════ %>
  <%# ── PRODUCTS                         ── %>
  <%# ══════════════════════════════════════ %>
  <% if @products.any? %>
    <div class="card-base p-4">
      <h2 class="h6 fw-black mb-3" style="color: var(--haiti-charcoal);">
        <i class="ri-shopping-bag-line me-1" style="color: var(--haiti-gold);"></i>Pwodui & Sèvis
      </h2>

      <div class="row g-2">
        <% @products.each do |product| %>
          <div class="col-6">
            <div class="rounded-3 p-3 h-100" style="background: rgba(93,99,69,0.04); border: 1px solid rgba(93,99,69,0.08);">
              <% if product.image.attached? %>
                <%= image_tag product.image, class: "rounded-3 w-100 mb-2", style: "height: 120px; object-fit: cover;" %>
              <% else %>
                <div class="d-flex align-items-center justify-content-center rounded-3 mb-2"
                     style="height: 120px; background: rgba(93,99,69,0.08);">
                  <i class="ri-shopping-bag-line" style="font-size: 32px; color: var(--haiti-olive); opacity: 0.3;"></i>
                </div>
              <% end %>
              <div class="fw-bold mb-1" style="color: var(--haiti-charcoal); font-size: 13px;"><%= product.name %></div>
              <% if product.description.present? %>
                <div class="mb-2" style="color: var(--haiti-olive); font-size: 11px; line-height: 1.4;">
                  <%= truncate(product.description, length: 60) %>
                </div>
              <% end %>
              <div class="fw-black" style="color: var(--haiti-charcoal); font-size: 16px;">
                <%= number_with_delimiter(product.price.to_i) %> <small style="color: var(--haiti-olive); font-size: 11px;">HTG</small>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# ── Footer ── %>
  <div class="text-center mt-3" style="font-size: 11px; color: var(--haiti-olive);">
    <i class="ri-shield-check-line me-1"></i>Peman sekirize pa Zèllus · Priotelus
  </div>
</div>
