    <%# ── Real-time notifications: direct WebSocket (no CDN needed) ── %>
    <% if user_signed_in? %>
    <script>
    (function() {
      // ── 1. Audio setup: Web Audio API (works reliably on Safari + Chrome) ──
      var audioCtx = null;
      var audioBuffer = null;
      var audioUnlocked = false;
      var mp3Url = '<%= asset_path("zellus-noti.mp3") %>';

      // Pre-create AudioContext (Safari needs webkitAudioContext)
      try { audioCtx = new (window.AudioContext || window.webkitAudioContext)(); } catch(e) {}

      // Fetch and decode MP3 into AudioBuffer for reliable playback
      if (audioCtx) {
        fetch(mp3Url).then(function(r) { return r.arrayBuffer(); }).then(function(buf) {
          return audioCtx.decodeAudioData(buf);
        }).then(function(decoded) {
          audioBuffer = decoded;
          console.log('[Zèllus] MP3 decoded into AudioBuffer ✓');
        }).catch(function(e) {
          console.warn('[Zèllus] MP3 decode failed — will use synth fallback:', e.message);
        });
      }

      // Also keep HTML5 Audio as secondary fallback
      var chimeAudio = new Audio(mp3Url);
      chimeAudio.volume = 0.6;
      chimeAudio.preload = 'auto';

      function unlockAudio() {
        if (audioUnlocked) return;

        // Resume AudioContext (REQUIRED by Safari on every user gesture until running)
        if (audioCtx && audioCtx.state === 'suspended') {
          audioCtx.resume().then(function() {
            console.log('[Zèllus] AudioContext resumed ✓');
          }).catch(function() {});
        }

        // Also prime HTML5 Audio (Safari needs audible play from gesture)
        chimeAudio.volume = 0.01;
        var p = chimeAudio.play();
        if (p && p.then) {
          p.then(function() {
            chimeAudio.pause();
            chimeAudio.currentTime = 0;
            chimeAudio.volume = 0.6;
            audioUnlocked = true;
            console.log('[Zèllus] Audio unlocked ✓');
          }).catch(function() {
            // HTML5 Audio failed but AudioContext may work
            if (audioCtx && audioCtx.state === 'running') {
              audioUnlocked = true;
              console.log('[Zèllus] Audio unlocked (AudioContext only) ✓');
            }
          });
        }
      }

      // Listen on multiple events — Safari needs touchstart specifically
      ['click', 'touchstart', 'touchend', 'keydown', 'scroll'].forEach(function(evt) {
        document.addEventListener(evt, unlockAudio, { once: false, passive: true });
      });

      // Also try to resume AudioContext on visibility change (tab switch back)
      document.addEventListener('visibilitychange', function() {
        if (!document.hidden && audioCtx && audioCtx.state === 'suspended') {
          audioCtx.resume().catch(function() {});
        }
      });

      // ── 2. Web Audio API synth fallback (two-tone: C5 + E5) ──
      function playSynthChime() {
        try {
          var ctx = audioCtx || new (window.AudioContext || window.webkitAudioContext)();
          if (ctx.state === 'suspended') ctx.resume();
          [523.25, 659.25].forEach(function(freq, i) {
            var osc = ctx.createOscillator();
            var gain = ctx.createGain();
            osc.type = 'sine';
            osc.frequency.value = freq;
            gain.gain.setValueAtTime(0.3, ctx.currentTime + i * 0.15);
            gain.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + i * 0.15 + 0.4);
            osc.connect(gain);
            gain.connect(ctx.destination);
            osc.start(ctx.currentTime + i * 0.15);
            osc.stop(ctx.currentTime + i * 0.15 + 0.4);
          });
          console.log('[Zèllus] Synth chime played ✓');
        } catch(e) {
          console.warn('[Zèllus] Synth chime error:', e.message);
        }
      }

      // ── 3. Play chime: AudioBuffer → HTML5 Audio → Synth fallback ──
      function playBufferChime() {
        if (!audioBuffer || !audioCtx) return false;
        try {
          var source = audioCtx.createBufferSource();
          var gainNode = audioCtx.createGain();
          source.buffer = audioBuffer;
          gainNode.gain.value = 0.6;
          source.connect(gainNode);
          gainNode.connect(audioCtx.destination);
          source.start(0);
          console.log('[Zèllus] AudioBuffer chime played ✓');
          return true;
        } catch(e) {
          console.warn('[Zèllus] AudioBuffer play failed:', e.message);
          return false;
        }
      }

      function playDepositChime() {
        console.log('[Zèllus] Playing chime... (buffer=' + !!audioBuffer + ', ctx=' + (audioCtx ? audioCtx.state : 'none') + ', unlocked=' + audioUnlocked + ')');

        // If AudioContext is suspended, resume it first then play
        if (audioCtx && audioCtx.state === 'suspended') {
          audioCtx.resume().then(function() {
            console.log('[Zèllus] AudioContext resumed for chime ✓');
            if (!playBufferChime()) {
              playSynthChime();
            }
          }).catch(function() {
            playSynthChime();
          });
          return;
        }

        // Method 1: AudioBuffer via Web Audio API (most reliable)
        if (playBufferChime()) return;

        // Method 2: HTML5 Audio element
        try {
          chimeAudio.currentTime = 0;
          chimeAudio.volume = 0.6;
          var p = chimeAudio.play();
          if (p && p.then) {
            p.then(function() { console.log('[Zèllus] HTML5 Audio chime played ✓'); })
             .catch(function(e) {
              console.warn('[Zèllus] HTML5 Audio failed, trying synth:', e.message);
              playSynthChime();
            });
          }
        } catch(e) {
          console.warn('[Zèllus] HTML5 Audio error, trying synth:', e.message);
          playSynthChime();
        }
      }

      // ── 4. Notification badge bump ──
      function bumpNotificationBadge(serverCount) {
        var badge = document.querySelector('#notif-bell-badge');
        if (badge) {
          var c = serverCount || (parseInt(badge.textContent || '0', 10) + 1);
          badge.textContent = c;
          badge.style.display = c > 0 ? 'inline-block' : 'none';
          console.log('[Zèllus] Badge updated to', c);
        }
        // Also update dropdown header badge
        var dropBadge = document.getElementById('notif-dropdown-count');
        if (dropBadge) {
          dropBadge.textContent = c || serverCount;
        }
      }

      // ── 4c. Toast notification popup ──
      function showNotifToast(title, type, avatarUrl) {
        // Remove existing toast if any
        var old = document.getElementById('zellus-notif-toast');
        if (old) old.remove();

        var colors = {
          transfer_received: { bg: '#f0fdf4', border: '#bbf7d0', icon: 'ri-arrow-down-circle-line', color: '#166534' },
          transfer_completed: { bg: '#f0fdf4', border: '#bbf7d0', icon: 'ri-checkbox-circle-line', color: '#166534' },
          transfer_failed: { bg: '#fef2f2', border: '#fca5a5', icon: 'ri-close-circle-line', color: '#991b1b' },
          payment_request_received: { bg: '#FFF8E7', border: '#C5A059', icon: 'ri-money-dollar-circle-line', color: '#92400e' },
          payment_request_paid: { bg: '#f0fdf4', border: '#bbf7d0', icon: 'ri-checkbox-circle-line', color: '#166534' }
        };
        var c = colors[type] || { bg: '#FFF8E7', border: '#C5A059', icon: 'ri-notification-3-line', color: '#2E2E38' };

        var iconHtml;
        if (avatarUrl) {
          iconHtml = '<img src="' + avatarUrl + '" style="width:32px;height:32px;border-radius:50%;object-fit:cover;flex-shrink:0;border:2px solid ' + c.border + ';" alt="">';
        } else {
          iconHtml = '<i class="' + c.icon + '" style="font-size:20px;color:' + c.color + ';flex-shrink:0;"></i>';
        }

        var toast = document.createElement('div');
        toast.id = 'zellus-notif-toast';
        toast.style.cssText = 'position:fixed;top:20px;right:20px;z-index:9999;background:' + c.bg + ';border:1px solid ' + c.border + ';border-radius:14px;padding:14px 18px;max-width:340px;box-shadow:0 8px 24px rgba(0,0,0,0.15);display:flex;align-items:center;gap:10px;animation:slideInRight 0.3s ease;cursor:pointer;';
        toast.innerHTML = iconHtml +
          '<div style="font-size:13px;font-weight:600;color:#2E2E38;line-height:1.4;">' + title + '</div>';
        toast.onclick = function() { toast.remove(); window.location.href = '/notifications'; };
        document.body.appendChild(toast);

        // Auto-dismiss after 6 seconds
        setTimeout(function() {
          if (toast.parentNode) {
            toast.style.opacity = '0';
            toast.style.transition = 'opacity 0.3s';
            setTimeout(function() { if (toast.parentNode) toast.remove(); }, 300);
          }
        }, 6000);
      }

      // ── 4b. Live balance update ──
      function updateBalances(msg) {
        var b = msg.balances;
        if (!b) return;
        console.log('[Zèllus] 💰 Balance update:', b);

        // Read exchange rates from hero section data attributes
        var hero = document.getElementById('section-hero');
        if (!hero) return; // not on wallet page

        var usdHtg = parseFloat(hero.dataset.usdHtg) || 135.50;
        var btcUsd = parseFloat(hero.dataset.btcUsd) || 95000;
        var ethUsd = parseFloat(hero.dataset.ethUsd) || 3500;

        // Defensive: coerce to numbers, fallback to 0
        var bHtg  = parseFloat(b.htg)  || 0;
        var bUsd  = parseFloat(b.usd  || b.usdc) || 0;
        var bEth  = parseFloat(b.eth)  || 0;
        var bWbtc = parseFloat(b.wbtc) || 0;

        // Compute totals
        var totalHtg = bHtg + (bUsd * usdHtg) + (bWbtc * btcUsd * usdHtg) + (bEth * ethUsd * usdHtg);
        var totalUsd = bUsd + (bWbtc * btcUsd) + (bEth * ethUsd) + (bHtg / usdHtg);

        // Helper: update element text + flash green
        function setEl(id, text) {
          var el = document.getElementById(id);
          if (!el) return;
          el.textContent = text;
          el.classList.remove('tick-up');
          void el.offsetWidth; // force reflow to restart animation
          el.classList.add('tick-up');
        }

        // Helper: format number with commas
        function fmt(n) {
          return Math.floor(n).toLocaleString('en-US');
        }

        // Hero totals
        setEl('hero-htg-whole', fmt(totalHtg));
        setEl('hero-htg-dec', ('0' + (Math.floor(totalHtg * 100) % 100)).slice(-2));
        setEl('hero-usd-whole', fmt(totalUsd));
        setEl('hero-usd-dec', ('0' + (Math.floor(totalUsd * 100) % 100)).slice(-2));

        // Mini breakdown
        setEl('mini-htg-bal', fmt(bHtg));
        setEl('mini-usd-bal', bUsd.toFixed(2));
        setEl('mini-eth-bal', bEth.toFixed(4));
        setEl('mini-wbtc-bal', bWbtc.toFixed(6));

        // Asset card balances
        setEl('asset-htg-bal', bHtg.toFixed(2));
        setEl('asset-usd-bal', bUsd.toFixed(2));
        setEl('asset-wbtc-bal', bWbtc > 0 ? bWbtc.toFixed(8).replace(/0+$/, '').replace(/\.$/, '.0') : '0');
        setEl('asset-eth-bal', bEth > 0 ? bEth.toFixed(6).replace(/0+$/, '').replace(/\.$/, '.0') : '0');

        // Asset card equivalents
        setEl('asset-htg-usd', (bHtg / usdHtg).toFixed(2));
        setEl('asset-usd-htg', (bUsd * usdHtg).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}));
        setEl('asset-wbtc-usd', (bWbtc * btcUsd).toFixed(2));
        setEl('asset-eth-usd', (bEth * ethUsd).toFixed(2));

        // Notify any listeners (e.g. limits chips) that balance changed
        window.dispatchEvent(new CustomEvent('zellus:balance-updated'));
      }

      // ── 4b. BonID revocation handler — updates UI in real-time ──
      function handleBonidRevoked(msg) {
        console.log('[Zèllus] 🔴 BonID REVOKED — updating UI');

        // Update body data attribute
        document.body.dataset.bonidVerified = 'false';

        var fallbackName = msg.display_name || document.body.dataset.userDisplayName || '';

        // 1. Remove all verification badges (green dots, verified icons)
        document.querySelectorAll('.js-bonid-badge').forEach(function(el) {
          el.style.display = 'none';
        });

        // 2. Revert names to display_name (non-BonID name)
        var nameEl = document.querySelector('.js-bonid-name');
        if (nameEl) nameEl.textContent = fallbackName;

        var fullnameEl = document.querySelector('.js-bonid-fullname');
        if (fullnameEl) fullnameEl.textContent = fallbackName;

        var sidebarNameEl = document.querySelector('.js-bonid-sidebar-name');
        if (sidebarNameEl) sidebarNameEl.textContent = fallbackName;

        // 3. Hide blood type badge
        var bloodEl = document.querySelector('.js-bonid-blood');
        if (bloodEl) bloodEl.style.display = 'none';

        // 4. Hide the verified menu item in dropdown, show CTA instead
        var menuItem = document.querySelector('.js-bonid-menu-item');
        if (menuItem) menuItem.style.display = 'none';

        // Show the BonID CTA (it was hidden because user was verified)
        // We need to inject it if it doesn't exist (since ERB didn't render it)
        var existingCta = document.querySelector('.js-bonid-cta');
        if (!existingCta) {
          // Find the dropdown KONT section header and insert CTA before it
          var sectionHeaders = document.querySelectorAll('.dropdown-menu span');
          var insertBefore = null;
          sectionHeaders.forEach(function(s) {
            if (s.textContent.trim() === 'KONT') insertBefore = s.closest('li');
          });
          if (insertBefore) {
            var ctaLi = document.createElement('li');
            ctaLi.className = 'js-bonid-cta';
            ctaLi.style.cssText = 'padding: 8px 10px 4px;';
            ctaLi.innerHTML = '<a href="/bonid_verification" class="d-block text-decoration-none" style="background: linear-gradient(135deg, #00209F 0%, #0035d4 100%); border-radius: 12px; padding: 12px 14px; transition: transform 0.15s, box-shadow 0.15s;">' +
              '<div class="d-flex align-items-center gap-3">' +
              '<div style="width: 36px; height: 36px; border-radius: 50%; background: rgba(255,255,255,0.15); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">' +
              '<i class="ri-shield-check-line" style="color: #fff; font-size: 18px;"></i></div>' +
              '<div style="flex: 1;"><div class="fw-bold" style="color: #fff; font-size: 13px;">Verifye ak BonID</div>' +
              '<div style="color: rgba(255,255,255,0.65); font-size: 10px;">Debloke pi gwo limit ak fonksyon</div></div>' +
              '<i class="ri-arrow-right-s-line" style="color: rgba(255,255,255,0.5); font-size: 20px;"></i></div></a>';
            insertBefore.parentNode.insertBefore(ctaLi, insertBefore);
          }
        }

        // 5. Hide sidebar security footer
        var secFooter = document.querySelector('.js-bonid-security-footer');
        if (secFooter) secFooter.style.display = 'none';

        // 6. Show a toast notification about the revocation
        if (typeof showNotifToast === 'function') {
          showNotifToast(msg.message || 'Aksè BonID ou te revoke.', 'bonid_revoked', null);
        }

        // 7. If user is on BonID verification page or transfer page, reload to reflect changes
        if (window.location.pathname.indexOf('/bonid_verification') !== -1 ||
            window.location.pathname.indexOf('/transfers') !== -1) {
          setTimeout(function() { window.location.reload(); }, 2000);
        }
      }

      // ── 5. Direct WebSocket to ActionCable (no CDN dependency) ──
      var ws = null;
      var wsRetries = 0;
      var channelId = JSON.stringify({ channel: "NotificationChannel" });

      function connectCable() {
        var proto = location.protocol === 'https:' ? 'wss:' : 'ws:';
        var url = proto + '//' + location.host + '/cable';
        console.log('[Zèllus] Connecting to', url);

        try {
          ws = new WebSocket(url);
        } catch(e) {
          console.error('[Zèllus] WebSocket create failed:', e);
          retryConnect();
          return;
        }

        ws.onopen = function() {
          console.log('[Zèllus] WebSocket connected');
          wsRetries = 0;
          ws.send(JSON.stringify({
            command: 'subscribe',
            identifier: channelId
          }));
        };

        ws.onmessage = function(event) {
          var data;
          try { data = JSON.parse(event.data); } catch(e) { return; }

          if (data.type === 'welcome') {
            console.log('[Zèllus] ActionCable welcome received');
            return;
          }
          if (data.type === 'confirm_subscription') {
            console.log('[Zèllus] NotificationChannel subscribed ✓');
            return;
          }
          if (data.type === 'ping') return;

          // Actual notification message
          if (data.identifier === channelId && data.message) {
            console.log('[Zèllus] 🔔 Notification received:', JSON.stringify(data.message));
            if (data.message.play_sound) {
              playDepositChime();
              // Sync poll baseline so it doesn't double-play
              fetch('/notifications/poll', { credentials: 'same-origin' })
                .then(function(r) { return r.json(); })
                .then(function(d) { if (d.latest_sound_id) lastSeenSoundId = d.latest_sound_id; })
                .catch(function() {});
            }
            if (data.message.type === 'balance_update') {
              updateBalances(data.message);
            } else if (data.message.type === 'bonid_revoked') {
              handleBonidRevoked(data.message);
            } else {
              bumpNotificationBadge(data.message.unread_count);
              if (data.message.title) showNotifToast(data.message.title, data.message.type, data.message.avatar_url);
            }
          }
        };

        ws.onclose = function(event) {
          console.log('[Zèllus] WebSocket closed (code ' + event.code + ')');
          ws = null;
          retryConnect();
        };

        ws.onerror = function() {
          console.error('[Zèllus] WebSocket error');
        };
      }

      function retryConnect() {
        wsRetries++;
        if (wsRetries > 20) {
          console.warn('[Zèllus] Pausing retries (will resume on visibility/online)');
          return;
        }
        var delay = Math.min(1000 * Math.pow(2, wsRetries - 1), 30000);
        console.log('[Zèllus] Reconnecting in ' + (delay/1000) + 's...');
        setTimeout(connectCable, delay);
      }

      // ── Mobile resilience: reconnect on wake / network change ──
      function forceReconnect() {
        if (ws && ws.readyState === WebSocket.OPEN) return; // already connected
        console.log('[Zèllus] Force reconnecting (visibility/online)');
        wsRetries = 0; // reset retry counter
        if (ws) { try { ws.close(); } catch(e) {} ws = null; }
        connectCable();
      }

      document.addEventListener('visibilitychange', function() {
        if (!document.hidden) forceReconnect();
      });
      window.addEventListener('online', forceReconnect);
      window.addEventListener('focus', forceReconnect);

      // ── 6. Polling fallback: catch missed deposit sounds ──
      // If WebSocket was disconnected when the broadcast fired, the sound
      // is lost. This lightweight poll checks every 20s for new unread
      // sound-eligible notifications and plays the chime if one appeared.
      var lastSeenSoundId = 0;
      var pollTimer = null;

      function pollForMissedSounds() {
        fetch('/notifications/poll', { credentials: 'same-origin' })
          .then(function(r) { return r.json(); })
          .then(function(d) {
            if (d.latest_sound_id && d.latest_sound_id > lastSeenSoundId) {
              if (lastSeenSoundId > 0) {
                // New notification appeared since last poll — play sound
                console.log('[Zèllus] Poll detected missed sound, id=' + d.latest_sound_id);
                playDepositChime();
              }
              lastSeenSoundId = d.latest_sound_id;
            }
            // Update badge from poll too
            if (typeof d.unread_count === 'number') {
              bumpNotificationBadge(d.unread_count);
            }
          })
          .catch(function(e) {
            console.warn('[Zèllus] Poll error:', e.message);
          });
      }

      // Start polling after initial load (first poll sets baseline, doesn't trigger sound)
      setTimeout(function() {
        pollForMissedSounds();
        pollTimer = setInterval(pollForMissedSounds, 20000);
      }, 3000);

      // ── 7. Test helpers (run in browser console) ──
      // _testSound()     → play chime directly (tests audio only)
      // _testBroadcast() → hit test_sound endpoint via AJAX (tests full chain)
      window._testSound = function() {
        console.log('[Zèllus] Manual sound test...');
        playDepositChime();
      };
      window._testBroadcast = function() {
        console.log('[Zèllus] Triggering server broadcast via AJAX...');
        fetch('/wallet/test_sound', { credentials: 'same-origin' })
          .then(function(r) { return r.text(); })
          .then(function(t) { console.log('[Zèllus] Server:', t); })
          .catch(function(e) { console.error('[Zèllus] Fetch error:', e); });
      };

      connectCable();
    })();
    </script>
    <% end %>
    <%# ── Navbar modal openers: if modals exist on page, open them directly ── %>
    <script>
    (function() {
      var signinModal = document.getElementById('signin-modal');
      var registerModal = document.getElementById('register-modal');
      if (!signinModal || !registerModal) return; // Not on login page

      function openModal(modal) {
        modal.classList.add('active');
        document.body.style.overflow = 'hidden';
        setTimeout(function() {
          var field = modal.querySelector('input[type="email"]');
          if (field) field.focus();
        }, 300);
      }

      document.querySelectorAll('.js-open-signin').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
          e.preventDefault();
          openModal(signinModal);
        });
      });

      document.querySelectorAll('.js-open-register').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
          e.preventDefault();
          openModal(registerModal);
        });
      });
    })();
    </script>
  </body>
</html>
