<!DOCTYPE html>
<html>
  <head>
    <title>ZÈLLUS | Libète Finansyè Ou Kòmanse Isit La</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= action_cable_meta_tag %>
    <link rel="icon" type="image/svg+xml" href="<%= asset_path('zellus_square.svg') %>">
    <link rel="apple-touch-icon" href="<%= asset_path('zellus_square.svg') %>">

    <%# ── Preconnect hints ── %>
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <%# ── CSS ── %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.5.0/fonts/remixicon.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">

    <%# ── Cloudflare Turnstile (bot protection) ── %>
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

    <%# ── Turbo Drive disabled: app uses inline scripts that need full page loads ── %>

    <%# ── ActionCable JS removed: using direct WebSocket in footer ── %>

    <style>
      :root {
        --haiti-charcoal: #2E2E38;
        --haiti-olive: #5D6345;
        --haiti-gold: #C5A059;
        --haiti-mint: #E8EDE0;
        --haiti-cream: #F7F4E3;
      }

      body {
        background-color: var(--haiti-mint);
        color: var(--haiti-charcoal);
        font-family: 'Plus Jakarta Sans', 'Segoe UI', Roboto, -apple-system, sans-serif;
        background-image: radial-gradient(var(--haiti-olive) 0.5px, transparent 0.5px);
        background-size: 30px 30px;
        overflow-x: hidden;
        margin: 0 !important;
        padding: 0 !important;
      }

      h1, h2, h3, h4, h5, h6,
      .h1, .h2, .h3, .h4, .h5, .h6,
      .display-1, .display-2, .display-3, .display-4, .display-5, .display-6,
      .fw-black, .navbar-brand {
        font-family: 'Space Grotesk', 'Segoe UI', sans-serif;
      }

      .navbar {
        margin-bottom: 0 !important;
        z-index: 1030;
      }

      .btn-prestige {
        background-color: var(--haiti-gold);
        color: var(--haiti-charcoal);
        border: 2px solid var(--haiti-charcoal);
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
      }

      .nav-link:hover {
        color: var(--haiti-gold) !important;
      }

      .dropdown-menu {
        background-color: var(--haiti-cream);
        border: none;
        box-shadow: 8px 8px 0px var(--haiti-charcoal);
      }
      .dropdown-item {
        font-size: 13px;
        font-weight: 500 !important;
      }
      .dropdown-item:hover {
        background-color: var(--haiti-mint);
      }

      .card-base {
        background-color: var(--haiti-cream);
        border-radius: 28px;
        border: none;
      }

      .badge-soon {
        font-size: 0.6rem;
        background-color: var(--haiti-gold);
        color: var(--haiti-charcoal);
        padding: 2px 6px;
        border-radius: 4px;
        vertical-align: middle;
        margin-left: 4px;
      }

      @media (max-width: 991.98px) {
        .navbar .ms-auto {
          width: 100%;
          margin-top: 1rem;
          border-top: 1px solid rgba(255,255,255,0.1);
          padding-top: 1rem;
        }
        .navbar .dropdown-menu {
          min-width: auto !important;
          width: 100% !important;
          box-shadow: none !important;
          border-radius: 12px !important;
        }
      }

      @media (max-width: 576px) {
        .card-base { padding: 1rem !important; }
        .display-5 { font-size: 1.6rem !important; }
        h1.h5, .h5.fw-black { font-size: 1rem !important; }
      }

      /* ── Turbo progress bar ── */
      #turbo-progress {
        position: fixed; top: 0; left: 0; height: 3px; z-index: 9999;
        background: var(--haiti-gold);
        width: 0; opacity: 0;
        transition: width 0.3s ease, opacity 0.2s ease;
        pointer-events: none;
        box-shadow: 0 0 8px rgba(197,160,89,0.6);
      }
      #turbo-progress.active { opacity: 1; }

      /* ── Loading overlay (form submissions) ── */
      #loading-overlay {
        position: fixed; inset: 0; z-index: 9998;
        background: rgba(46,46,56,0.5); backdrop-filter: blur(2px);
        display: none; align-items: center; justify-content: center;
        flex-direction: column; gap: 12px;
      }
      #loading-overlay.active { display: flex; }
      #loading-overlay .spinner {
        width: 36px; height: 36px; border: 3px solid rgba(197,160,89,0.25);
        border-top-color: var(--haiti-gold); border-radius: 50%;
        animation: spin 0.7s linear infinite;
      }
      @keyframes spin { to { transform: rotate(360deg); } }
    </style>
  </head>

  <body>
    <%# ── Turbo progress bar + loading overlay ── %>
    <div id="turbo-progress"></div>
    <div id="loading-overlay"><div class="spinner"></div><div style="color: var(--haiti-gold); font-size: 13px; font-weight: 700;">Chajman...</div></div>

    <nav class="navbar navbar-expand-lg py-3 shadow-sm" style="background-color: var(--haiti-charcoal); border-bottom: 3px solid var(--haiti-gold);">
      <div class="container">
        <%= link_to root_path, class: "navbar-brand d-flex align-items-center me-4" do %>
          <%= image_tag "zellus_square.svg", size: "40x40", alt: "Zèllus", style: "border-radius: 10px;" %>
        <% end %>

        <button class="navbar-toggler border-0 shadow-none py-2 px-3" type="button" data-bs-toggle="collapse" data-bs-target="#zellusNavbarContent">
          <i class="ri-menu-3-line text-white" style="font-size: 1.5rem;"></i>
        </button>

        <div class="collapse navbar-collapse" id="zellusNavbarContent">

          <% if user_signed_in? %>
            <%# ── LOGGED-IN NAV ─────────────────────────────── %>
            <ul class="navbar-nav ms-auto mb-2 mb-lg-0 gap-1 align-items-lg-center">

              <%# ── Mobile-only nav items (matches wallet page actions) ── %>
              <li class="nav-item d-lg-none">
                <%= link_to wallet_path, class: "nav-link text-white fw-bold py-2 px-3", style: "font-size: 14px;" do %>
                  <i class="ri-wallet-3-line me-2" style="color: var(--haiti-gold);"></i> Pòtfèy
                <% end %>
              </li>
              <li class="nav-item d-lg-none">
                <%= link_to new_transfer_path, class: "nav-link text-white fw-bold py-2 px-3", style: "font-size: 14px;" do %>
                  <i class="ri-send-plane-fill me-2" style="color: var(--haiti-gold);"></i> Peye
                <% end %>
              </li>
              <li class="nav-item d-lg-none">
                <%= link_to new_payment_request_path, class: "nav-link text-white fw-bold py-2 px-3", style: "font-size: 14px;" do %>
                  <i class="ri-hand-coin-fill me-2" style="color: var(--haiti-gold);"></i> Mande
                <% end %>
              </li>
              <li class="nav-item d-lg-none">
                <%= link_to new_transaction_path, class: "nav-link text-white fw-bold py-2 px-3", style: "font-size: 14px;" do %>
                  <i class="ri-shopping-cart-line me-2" style="color: var(--haiti-gold);"></i> Achte
                <% end %>
              </li>
              <li class="nav-item d-lg-none">
                <%= link_to wallet_path(action_panel: "deposit"), class: "nav-link text-white fw-bold py-2 px-3", style: "font-size: 14px;" do %>
                  <i class="ri-download-line me-2" style="color: var(--haiti-gold);"></i> Depoze
                <% end %>
              </li>
              <li class="nav-item d-lg-none">
                <%= link_to wallet_path(action_panel: "withdraw"), class: "nav-link text-white fw-bold py-2 px-3", style: "font-size: 14px;" do %>
                  <i class="ri-logout-box-line me-2" style="color: var(--haiti-gold);"></i> Retire
                <% end %>
              </li>
              <li class="nav-item d-lg-none"><hr class="my-2" style="border-color: rgba(255,255,255,0.15);"></li>

              <%# ── Notification Bell ── %>
              <li class="nav-item dropdown ms-lg-2">
                <a href="#" role="button" data-bs-toggle="dropdown"
                   class="nav-link p-0 d-flex align-items-center justify-content-center position-relative"
                   style="width: 40px; height: 40px; border-radius: 50%; background: rgba(255,255,255,0.08); border: 1px solid rgba(197,160,89,0.3);">
                  <i class="ri-notification-3-line" style="color: var(--haiti-gold); font-size: 18px;"></i>
                  <span id="notif-bell-badge" class="position-absolute" style="top: -2px; right: -2px; background: #dc2626; color: #fff; font-size: 9px; font-weight: 800; min-width: 18px; height: 18px; line-height: 18px; text-align: center; border-radius: 50%; border: 2px solid var(--haiti-charcoal); <%= 'display: none;' if unread_notification_count == 0 %>">
                    <%= unread_notification_count %>
                  </span>
                </a>
                <ul class="dropdown-menu dropdown-menu-end shadow-lg p-2 mt-2" style="min-width: 340px; max-height: 420px; overflow-y: auto; border: none; border-radius: 16px;">
                  <li>
                    <div class="px-3 py-2 d-flex align-items-center justify-content-between">
                      <span class="fw-bold small" style="color: var(--haiti-charcoal);">Notifikasyon</span>
                      <% if unread_notification_count > 0 %>
                        <span id="notif-dropdown-count" class="badge rounded-pill" style="background: var(--haiti-charcoal); color: var(--haiti-gold); font-size: 9px;"><%= unread_notification_count %></span>
                      <% end %>
                    </div>
                  </li>
                  <li><hr class="dropdown-divider my-1"></li>
                  <% if recent_notifications_for_dropdown.any? %>
                    <% recent_notifications_for_dropdown.each do |notif| %>
                      <li>
                        <%= link_to mark_read_notification_path(notif), class: "dropdown-item rounded-3 p-2 mb-1", style: "#{'background: rgba(197,160,89,0.06);' if notif.unread?}" do %>
                          <div class="d-flex align-items-center gap-2">
                            <div style="width: 32px; height: 32px; border-radius: 50%; flex-shrink: 0; display: flex; align-items: center; justify-content: center; <%= notif.icon_color_style %>">
                              <i class="<%= notif.icon_class %>" style="font-size: 14px;"></i>
                            </div>
                            <div class="flex-grow-1" style="min-width: 0;">
                              <div class="<%= notif.unread? ? 'fw-bold' : '' %>" style="color: var(--haiti-charcoal); font-size: 12px; line-height: 1.3;">
                                <%= notif.title %>
                              </div>
                              <div style="color: var(--haiti-olive); font-size: 10px;">
                                <%= time_ago_in_words(notif.created_at) %> de sa
                              </div>
                            </div>
                            <% if notif.unread? %>
                              <div style="width: 8px; height: 8px; border-radius: 50%; background: var(--haiti-gold); flex-shrink: 0;"></div>
                            <% end %>
                          </div>
                        <% end %>
                      </li>
                    <% end %>
                    <li><hr class="dropdown-divider my-1"></li>
                    <li>
                      <div class="text-center py-2">
                        <%= link_to notifications_path, class: "small fw-bold text-decoration-none", style: "color: var(--haiti-gold);" do %>
                          W&egrave; Tout <i class="ri-arrow-right-s-line"></i>
                        <% end %>
                      </div>
                    </li>
                  <% else %>
                    <li>
                      <div class="px-3 py-4 text-center">
                        <i class="ri-notification-off-line" style="font-size: 24px; color: var(--haiti-olive); opacity: 0.4;"></i>
                        <div class="small mt-1" style="color: var(--haiti-olive);">Pa gen notifikasyon</div>
                      </div>
                    </li>
                  <% end %>
                </ul>
              </li>

              <%# ── Market Link ── %>
              <li class="nav-item ms-lg-2">
                <%= link_to rates_wallet_path, class: "nav-link d-flex align-items-center gap-1 px-3 py-2 rounded-pill",
                    style: "background: rgba(255,255,255,0.08); border: 1px solid rgba(197,160,89,0.3); color: white; font-size: 12px; font-weight: 700;" do %>
                  <i class="ri-line-chart-line" style="color: var(--haiti-gold); font-size: 15px;"></i>
                  <span>Mache Dechanj</span>
                <% end %>
              </li>

              <%# ── User Profile Pill (always visible) ── %>
              <li class="nav-item dropdown ms-lg-2">
                <a class="nav-link dropdown-toggle d-flex align-items-center gap-2 px-3 py-2 rounded-pill"
                   href="#" role="button" data-bs-toggle="dropdown"
                   style="background: rgba(255,255,255,0.08); border: 1px solid var(--haiti-gold); color: white;">
                  <% if current_user.avatar.attached? %>
                    <%= image_tag current_user.avatar, style: "width: 26px; height: 26px; border-radius: 50%; object-fit: cover; border: 1.5px solid var(--haiti-gold);", alt: "" %>
                  <% else %>
                    <span style="font-size: 1.2rem;"><%= current_user.tier_icon %></span>
                  <% end %>
                  <span class="small fw-bold"><%= current_user.bonid_verified? && current_user.bonid_full_name.present? ? current_user.bonid_first_name : current_user.display_name %></span>
                </a>
                <ul class="dropdown-menu dropdown-menu-end shadow-lg p-2 mt-2" style="min-width: 240px;">
                  <li>
                    <div class="px-3 py-2">
                      <% if current_user.bonid_verified? && current_user.bonid_full_name.present? %>
                        <div class="fw-bold" style="color: var(--haiti-charcoal);"><%= current_user.bonid_full_name %></div>
                        <div class="small" style="color: var(--haiti-olive);"><%= current_user.email %></div>
                        <% if current_user.bonid_blood_type.present? %>
                          <div class="d-flex align-items-center gap-1 mt-1">
                            <i class="ri-heart-pulse-line" style="color: #dc2626; font-size: 13px;"></i>
                            <span class="badge rounded-pill" style="background: #fef2f2; color: #991b1b; font-size: 10px; font-weight: 700;"><%= current_user.bonid_blood_type %></span>
                          </div>
                        <% end %>
                      <% else %>
                        <div class="small fw-bold" style="color: var(--haiti-charcoal);"><%= current_user.email %></div>
                      <% end %>
                      <div class="d-flex align-items-center gap-2 mt-1">
                        <span class="badge rounded-pill" style="background-color: var(--haiti-gold); color: var(--haiti-charcoal); font-size: 9px; font-weight: 800;">
                          <%= current_user.credit_tier %>
                        </span>
                        <span style="color: var(--haiti-olive); font-size: 10px;"><%= current_user.credit_score || 0 %> pwen</span>
                      </div>
                    </div>
                  </li>
                  <li><hr class="dropdown-divider my-1"></li>
                  <li>
                    <%= link_to payment_methods_path, class: "dropdown-item rounded p-3" do %>
                      <div class="fw-bold" style="color: var(--haiti-charcoal);"><i class="ri-bank-card-line me-2" style="color: var(--haiti-gold);"></i>Metòd Peman</div>
                    <% end %>
                  </li>
                  <li>
                    <%= link_to bonid_verification_path, class: "dropdown-item rounded p-3" do %>
                      <div class="fw-bold" style="color: var(--haiti-charcoal);">
                        <i class="ri-shield-check-line me-2" style="color: var(--haiti-gold);"></i>Verifye ak BonID
                        <% if current_user.bonid_verified? %>
                          <span class="badge rounded-pill ms-1" style="background: #f0fdf4; color: #166534; font-size: 8px;">Verifye</span>
                        <% end %>
                      </div>
                      <div style="color: var(--haiti-olive); font-size: 11px;">
                        <% if current_user.bonid_verified? %>
                          <%= current_user.bonid.gsub(/(.{4}).*(.{3})/, '\1••••••\2') %>
                        <% else %>
                          Verifye idantite'w pou debloke pi gwo limit kredi.
                        <% end %>
                      </div>
                    <% end %>
                  </li>
                  <li>
                    <%= link_to edit_user_registration_path, class: "dropdown-item rounded p-3" do %>
                      <div class="fw-bold" style="color: var(--haiti-charcoal);"><i class="ri-settings-3-line me-2" style="color: var(--haiti-olive);"></i>Paramèt Kont</div>
                    <% end %>
                  </li>
                  <% if current_user.email == ENV['ADMIN_EMAIL'].to_s.strip %>
                    <li>
                      <%= link_to admin_dashboard_path, class: "dropdown-item rounded p-3" do %>
                        <div class="fw-bold" style="color: var(--haiti-charcoal);"><i class="ri-dashboard-3-line me-2" style="color: var(--haiti-gold);"></i>Tablo Admin</div>
                      <% end %>
                    </li>
                  <% end %>
                  <li>
                    <%= button_to destroy_user_session_path, method: :delete, class: "dropdown-item rounded p-3 w-100 text-start border-0 bg-transparent", data: { turbo: false } do %>
                      <div class="fw-bold" style="color: #991b1b;"><i class="ri-logout-box-r-line me-2"></i>Dekonekte</div>
                    <% end %>
                  </li>
                </ul>
              </li>
            </ul>

          <% else %>
            <%# ── LOGGED-OUT NAV ────────────────────────────── %>
            <ul class="navbar-nav ms-auto mb-2 mb-lg-0 gap-1 align-items-lg-center">
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle text-white fw-bold small" href="#" role="button" data-bs-toggle="dropdown">
                  Pwodui
                </a>
                <ul class="dropdown-menu shadow-lg p-2" style="min-width: 320px;">
                  <li>
                    <%= link_to zellus_info_path, class: "dropdown-item rounded p-3" do %>
                      <div class="fw-bold" style="color: var(--haiti-charcoal);"><i class="ri-user-line me-2" style="color: var(--haiti-gold);"></i>Zellus pou Endividyèl</div>
                      <div style="color: var(--haiti-olive); font-size: 11px; white-space: normal;">Voye ak resevwa lajan gratis.</div>
                    <% end %>
                  </li>
                  <li>
                    <%= link_to zellus_info_path, class: "dropdown-item rounded p-3" do %>
                      <div class="fw-bold" style="color: var(--haiti-charcoal);"><i class="ri-store-2-line me-2" style="color: var(--haiti-gold);"></i>Zellus pou Biznis</div>
                      <div style="color: var(--haiti-olive); font-size: 11px; white-space: normal;">Aksepte peman Zèllus, voye peman dirèk, eskane kòd QR pèsonalize ou.</div>
                    <% end %>
                  </li>
                  <li>
                    <%= link_to priosol_info_path, class: "dropdown-item rounded p-3" do %>
                      <div class="fw-bold" style="color: var(--haiti-charcoal);"><i class="ri-loop-right-line me-2" style="color: var(--haiti-gold);"></i>Zellus Sòl</div>
                      <div style="color: var(--haiti-olive); font-size: 11px; white-space: normal;">Kreye Sòl ak zanmi, fanmi'w oswa kominote'w pou w ka ekonomize.</div>
                    <% end %>
                  </li>
                  <li><hr class="dropdown-divider"></li>
                  <li>
                    <%= link_to priobousad_info_path, class: "dropdown-item rounded p-3" do %>
                      <div class="fw-bold" style="color: var(--haiti-charcoal);"><i class="ri-hand-coin-line me-2" style="color: var(--haiti-gold);"></i>Zellus Bousad</div>
                      <div style="color: var(--haiti-olive); font-size: 11px; white-space: normal;">Aplike pou yon prè pou bay biznis ou bousad.</div>
                    <% end %>
                  </li>
                  <li>
                    <%= link_to prionet_info_path, class: "dropdown-item rounded p-3" do %>
                      <div class="fw-bold" style="color: var(--haiti-charcoal);"><i class="ri-medal-line me-2" style="color: var(--haiti-gold);"></i>Zellus Onèt</div>
                      <div style="color: var(--haiti-olive); font-size: 11px; white-space: normal;">Bati kredi ou ak biznis ou pou debloke plis kapital.</div>
                    <% end %>
                  </li>
                </ul>
              </li>
              <li class="nav-item"><%= link_to "Kijan Sa Mache?", "#", class: "nav-link text-white fw-bold small" %></li>
              <li class="nav-item"><%= link_to "Apwopo", "#", class: "nav-link text-white fw-bold small" %></li>
              <li class="nav-item ms-lg-2">
                <%= link_to "Konekte", new_user_session_path, class: "nav-link text-white fw-bold small" %>
              </li>
              <li class="nav-item">
                <%= link_to "Kòmanse", new_user_registration_path, class: "btn btn-prestige btn-sm px-4 rounded-pill shadow-sm", style: "text-transform: none; font-weight: 700; letter-spacing: 0.3px;" %>
              </li>
            </ul>
          <% end %>

        </div>
      </div>
    </nav>

    <%# ── Global auto-dismiss flash toast ── %>
    <% if flash[:notice].present? %>
      <div id="flash-toast" style="
        position: fixed; top: 80px; left: 50%; transform: translateX(-50%);
        z-index: 9999; background: var(--haiti-charcoal); color: var(--haiti-gold);
        padding: 10px 20px; border-radius: 50px; font-size: 12px; font-weight: 600;
        box-shadow: 0 4px 20px rgba(0,0,0,0.2); opacity: 1;
        transition: opacity 0.6s ease, transform 0.6s ease;
        pointer-events: none; max-width: 92vw; text-align: center;">
        <i class="ri-checkbox-circle-fill me-1"></i><%= flash[:notice] %>
      </div>
      <script>
        setTimeout(function() {
          var toast = document.getElementById('flash-toast');
          if (toast) {
            toast.style.opacity = '0';
            toast.style.transform = 'translateX(-50%) translateY(-10px)';
            setTimeout(function() { toast.remove(); }, 600);
          }
        }, 2500);
      </script>
    <% end %>

    <%# ── Global alert toast (tap to dismiss) ── %>
    <% if flash[:alert].present? %>
      <div id="flash-alert-toast" onclick="this.style.opacity='0'; this.style.transform='translateY(-10px)'; setTimeout(function(){ document.getElementById('flash-alert-toast')?.remove(); }, 600);" style="
        position: fixed; top: 80px; left: 16px; right: 16px;
        margin-left: auto; margin-right: auto; max-width: 500px;
        z-index: 9999; background: #7f1d1d; color: #fecaca;
        padding: 14px 20px; border-radius: 14px; font-size: 13px; font-weight: 600;
        box-shadow: 0 4px 20px rgba(0,0,0,0.3); opacity: 1;
        transition: opacity 0.6s ease, transform 0.6s ease;
        cursor: pointer; text-align: center; line-height: 1.5;">
        <i class="ri-error-warning-fill me-1"></i><%= flash[:alert] %>
