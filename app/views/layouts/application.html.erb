<!DOCTYPE html>
<html>
  <head>
    <title>Priotelus | Your Financial Freedom Starts Here</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.5.0/fonts/remixicon.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">

    <style>
      :root {
        --haiti-charcoal: #2E2E38;
        --haiti-olive: #5D6345;
        --haiti-gold: #C5A059;
        --haiti-mint: #E8EDE0;
        --haiti-cream: #F7F4E3;
      }

      body {
        background-color: var(--haiti-mint);
        color: var(--haiti-charcoal);
        font-family: 'Plus Jakarta Sans', 'Segoe UI', Roboto, -apple-system, sans-serif;
        background-image: radial-gradient(var(--haiti-olive) 0.5px, transparent 0.5px);
        background-size: 30px 30px;
        overflow-x: hidden;
        margin: 0 !important;
        padding: 0 !important;
      }

      h1, h2, h3, h4, h5, h6,
      .h1, .h2, .h3, .h4, .h5, .h6,
      .display-1, .display-2, .display-3, .display-4, .display-5, .display-6,
      .fw-black, .navbar-brand {
        font-family: 'Space Grotesk', 'Segoe UI', sans-serif;
      }

      .navbar {
        margin-bottom: 3.5rem !important;
        z-index: 1030;
      }

      .btn-prestige {
        background-color: var(--haiti-gold);
        color: var(--haiti-charcoal);
        border: 2px solid var(--haiti-charcoal);
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
      }

      .nav-link:hover {
        color: var(--haiti-gold) !important;
      }

      .dropdown-menu {
        background-color: var(--haiti-cream);
        border: 2px solid var(--haiti-gold);
        box-shadow: 8px 8px 0px var(--haiti-charcoal);
      }
      .dropdown-item:hover {
        background-color: var(--haiti-mint);
      }

      .card-base {
        background-color: var(--haiti-cream);
        border-radius: 28px;
        border: none;
        box-shadow: 20px 20px 60px #d9d6c4, -20px -20px 60px #ffffff;
      }

      .badge-soon {
        font-size: 0.6rem;
        background-color: var(--haiti-gold);
        color: var(--haiti-charcoal);
        padding: 2px 6px;
        border-radius: 4px;
        vertical-align: middle;
        margin-left: 4px;
      }

      @media (max-width: 991.98px) {
        .navbar .ms-auto {
          width: 100%;
          margin-top: 1rem;
          border-top: 1px solid rgba(255,255,255,0.1);
          padding-top: 1rem;
        }
      }
    </style>
  </head>

  <body>
    <nav class="navbar navbar-expand-lg py-3 shadow-sm" style="background-color: var(--haiti-charcoal); border-bottom: 3px solid var(--haiti-gold);">
      <div class="container">
        <%= link_to root_path, class: "navbar-brand d-flex align-items-center gap-2 text-white fw-bold me-4" do %>
          <i class="ri-shield-user-fill" style="color: var(--haiti-gold); font-size: 1.5rem;"></i>
          <span style="letter-spacing: 1px;">Priotelus</span>
        <% end %>

        <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#priotelusNavbarContent">
          <i class="ri-menu-3-line text-white" style="font-size: 1.5rem;"></i>
        </button>

        <div class="collapse navbar-collapse" id="priotelusNavbarContent">

          <% if user_signed_in? %>
            <%# ── LOGGED-IN NAV ─────────────────────────────── %>
            <ul class="navbar-nav ms-auto mb-2 mb-lg-0 gap-1 align-items-lg-center">

              <%# ── PrioLink ── %>
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle text-white fw-bold small" href="#" role="button" data-bs-toggle="dropdown">
                  <i class="ri-exchange-funds-line me-1" style="color: var(--haiti-gold);"></i> PrioLink
                </a>
                <ul class="dropdown-menu shadow-lg p-2" style="min-width: 300px;">
                  <li class="px-3 pt-2 pb-1">
                    <div style="color: var(--haiti-olive); font-size: 11px;">Achte oswa Vann USDC pou konbat enflasyon.</div>
                  </li>
                  <li><hr class="dropdown-divider my-1"></li>
                  <li>
                    <%= link_to priolink_path, class: "dropdown-item rounded p-3" do %>
                      <div class="fw-bold" style="color: var(--haiti-charcoal);"><i class="ri-dashboard-line me-2" style="color: var(--haiti-gold);"></i>Tablo PrioLink</div>
                    <% end %>
                  </li>
                  <li>
                    <%= link_to new_transaction_path, class: "dropdown-item rounded p-3" do %>
                      <div class="fw-bold" style="color: var(--haiti-charcoal);"><i class="ri-exchange-funds-line me-2" style="color: var(--haiti-gold);"></i>Achte / Vann USDC</div>
                    <% end %>
                  </li>
                  <li>
                    <%= link_to transactions_path, class: "dropdown-item rounded p-3" do %>
                      <div class="fw-bold" style="color: var(--haiti-charcoal);"><i class="ri-history-line me-2" style="color: var(--haiti-gold);"></i>Istwa Tranzaksyon</div>
                    <% end %>
                  </li>
                </ul>
              </li>

              <%# ── PrioSòl ── %>
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle text-white fw-bold small" href="#" role="button" data-bs-toggle="dropdown">
                  <i class="ri-loop-right-line me-1" style="color: var(--haiti-gold);"></i> PrioSòl
                </a>
                <ul class="dropdown-menu shadow-lg p-2" style="min-width: 300px;">
                  <li class="px-3 pt-2 pb-1">
                    <div style="color: var(--haiti-olive); font-size: 11px;">Kreye Sòl pou fè ekonomi.</div>
                  </li>
                  <li><hr class="dropdown-divider my-1"></li>
                  <li>
                    <%= link_to priosol_path, class: "dropdown-item rounded p-3" do %>
                      <div class="fw-bold" style="color: var(--haiti-charcoal);"><i class="ri-dashboard-line me-2" style="color: var(--haiti-gold);"></i>Tablo PrioSòl</div>
                    <% end %>
                  </li>
                  <li>
                    <%= link_to sol_circles_path, class: "dropdown-item rounded p-3" do %>
                      <div class="fw-bold" style="color: var(--haiti-charcoal);"><i class="ri-group-line me-2" style="color: var(--haiti-gold);"></i>Sèk Sol Mwen</div>
                    <% end %>
                  </li>
                  <li>
                    <%= link_to new_sol_circle_path, class: "dropdown-item rounded p-3" do %>
                      <div class="fw-bold" style="color: var(--haiti-charcoal);"><i class="ri-add-circle-line me-2" style="color: var(--haiti-gold);"></i>Kreye yon Sol</div>
                    <% end %>
                  </li>
                </ul>
              </li>

              <%# ── PrioBousad ── %>
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle text-white fw-bold small" href="#" role="button" data-bs-toggle="dropdown">
                  <i class="ri-hand-coin-line me-1" style="color: var(--haiti-gold);"></i> PrioBousad
                </a>
                <ul class="dropdown-menu shadow-lg p-2" style="min-width: 300px;">
                  <li class="px-3 pt-2 pb-1">
                    <div style="color: var(--haiti-olive); font-size: 11px;">Prète pou ede biznis ou dekole.</div>
                  </li>
                  <li><hr class="dropdown-divider my-1"></li>
                  <li>
                    <%= link_to priobousad_path, class: "dropdown-item rounded p-3" do %>
                      <div class="fw-bold" style="color: var(--haiti-charcoal);"><i class="ri-dashboard-line me-2" style="color: var(--haiti-gold);"></i>Tablo PrioBousad</div>
                    <% end %>
                  </li>
                  <li>
                    <%= link_to new_loan_path, class: "dropdown-item rounded p-3" do %>
                      <div class="fw-bold" style="color: var(--haiti-charcoal);"><i class="ri-hand-coin-line me-2" style="color: var(--haiti-gold);"></i>Mande yon Prè</div>
                    <% end %>
                  </li>
                </ul>
              </li>

              <%# ── PriOnèt ── %>
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle text-white fw-bold small" href="#" role="button" data-bs-toggle="dropdown">
                  <i class="ri-medal-line me-1" style="color: var(--haiti-gold);"></i> PriOnèt
                </a>
                <ul class="dropdown-menu shadow-lg p-2" style="min-width: 300px;">
                  <li class="px-3 pt-2 pb-1">
                    <div style="color: var(--haiti-olive); font-size: 11px;">Bati repitasyon'w pou debloke gwo kredi.</div>
                  </li>
                  <li><hr class="dropdown-divider my-1"></li>
                  <li>
                    <%= link_to prionet_path, class: "dropdown-item rounded p-3" do %>
                      <div class="d-flex align-items-center gap-2">
                        <span style="font-size: 1.4rem;"><%= current_user.tier_icon %></span>
                        <div>
                          <div class="fw-bold" style="color: var(--haiti-charcoal);"><%= current_user.credit_tier %> &middot; <%= current_user.credit_score || 0 %> pwen</div>
                          <div style="color: var(--haiti-olive); font-size: 11px;">Wè tablo kredi'w</div>
                        </div>
                      </div>
                      <div class="mt-2" style="height: 6px; background: #e5e7eb; border-radius: 3px; overflow: hidden;">
                        <div style="width: <%= ((current_user.credit_score || 0) * 100.0 / User::MAX_CREDIT_SCORE).round %>%; height: 100%; background: var(--haiti-gold); border-radius: 3px;"></div>
                      </div>
                    <% end %>
                  </li>
                </ul>
              </li>

              <%# ── Zèllus ── %>
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle text-white fw-bold small" href="#" role="button" data-bs-toggle="dropdown">
                  <i class="ri-flashlight-line me-1" style="color: var(--haiti-gold);"></i> Zèllus
                </a>
                <ul class="dropdown-menu shadow-lg p-2" style="min-width: 300px;">
                  <li class="px-3 pt-2 pb-1">
                    <div style="color: var(--haiti-olive); font-size: 11px;">Voye lajan bay nenpòt moun imedyatman ak yon senp nimewo telefòn oswa email.</div>
                  </li>
                  <li><hr class="dropdown-divider my-1"></li>
                  <li>
                    <%= link_to wallet_path, class: "dropdown-item rounded p-3" do %>
                      <div class="fw-bold" style="color: var(--haiti-charcoal);"><i class="ri-wallet-3-line me-2" style="color: var(--haiti-gold);"></i>Balans Zèllus</div>
                      <div style="color: var(--haiti-olive); font-size: 11px;"><%= number_to_currency(current_user.wallet_balance, unit: "HTG ", precision: 0) %></div>
                    <% end %>
                  </li>
                  <li>
                    <%= link_to new_transfer_path, class: "dropdown-item rounded p-3" do %>
                      <div class="fw-bold" style="color: var(--haiti-charcoal);"><i class="ri-send-plane-fill me-2" style="color: var(--haiti-gold);"></i>Voye Lajan</div>
                    <% end %>
                  </li>
                  <li>
                    <%= link_to payment_requests_path, class: "dropdown-item rounded p-3" do %>
                      <div class="fw-bold" style="color: var(--haiti-charcoal);"><i class="ri-links-line me-2" style="color: var(--haiti-gold);"></i>Demann</div>
                    <% end %>
                  </li>
                </ul>
              </li>

              <%# ── Plis (Metòd Peman, Admin) ── %>
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle text-white fw-bold small" href="#" role="button" data-bs-toggle="dropdown">
                  <i class="ri-more-line me-1" style="color: var(--haiti-gold);"></i>
                </a>
                <ul class="dropdown-menu dropdown-menu-end shadow-lg p-2" style="min-width: 260px;">
                  <li>
                    <%= link_to payment_methods_path, class: "dropdown-item rounded p-3" do %>
                      <div class="fw-bold" style="color: var(--haiti-charcoal);"><i class="ri-bank-card-line me-2" style="color: var(--haiti-gold);"></i>Metòd Peman</div>
                      <div style="color: var(--haiti-olive); font-size: 11px; white-space: normal;">Jere MonCash ak pòtfèy kripto ou yo.</div>
                    <% end %>
                  </li>
                  <% if current_user.email == ENV['ADMIN_EMAIL'].to_s.strip %>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                      <%= link_to admin_dashboard_path, class: "dropdown-item rounded p-3" do %>
                        <div class="fw-bold" style="color: var(--haiti-charcoal);"><i class="ri-dashboard-3-line me-2" style="color: var(--haiti-gold);"></i>Tablo Admin</div>
                        <div style="color: var(--haiti-olive); font-size: 11px; white-space: normal;">Trezò, tranzaksyon ak zouti machand.</div>
                      <% end %>
                    </li>
                  <% end %>
                </ul>
              </li>

              <%# ── User Profile Pill ── %>
              <li class="nav-item dropdown ms-lg-2">
                <a class="nav-link dropdown-toggle d-flex align-items-center gap-2 px-3 py-1 rounded-pill"
                   href="#" role="button" data-bs-toggle="dropdown"
                   style="background: rgba(255,255,255,0.08); border: 1px solid var(--haiti-gold); color: white;">
                  <span style="font-size: 1.2rem;"><%= current_user.tier_icon %></span>
                  <span class="small fw-bold"><%= current_user.email.split('@').first.capitalize %></span>
                </a>
                <ul class="dropdown-menu dropdown-menu-end mt-2" style="min-width: 220px;">
                  <li>
                    <div class="px-3 py-2">
                      <div class="small fw-bold" style="color: var(--haiti-charcoal);"><%= current_user.email %></div>
                      <div class="d-flex align-items-center gap-2 mt-1">
                        <span class="badge rounded-pill" style="background-color: var(--haiti-gold); color: var(--haiti-charcoal); font-size: 9px; font-weight: 800;">
                          <%= current_user.credit_tier %>
                        </span>
                        <span style="color: var(--haiti-olive); font-size: 10px;"><%= current_user.credit_score || 0 %> pwen</span>
                      </div>
                    </div>
                  </li>
                  <li><hr class="dropdown-divider"></li>
                  <li>
                    <%= link_to edit_user_registration_path, class: "dropdown-item fw-bold small" do %>
                      <i class="ri-settings-3-line me-2" style="color: var(--haiti-olive);"></i> Paramèt Kont
                    <% end %>
                  </li>
                  <li><hr class="dropdown-divider"></li>
                  <li>
                    <%= button_to destroy_user_session_path, method: :delete, class: "dropdown-item fw-bold small", style: "color: #991b1b;" do %>
                      <i class="ri-logout-box-r-line me-2"></i> Dekonekte
                    <% end %>
                  </li>
                </ul>
              </li>
            </ul>

          <% else %>
            <%# ── LOGGED-OUT NAV ────────────────────────────── %>
            <ul class="navbar-nav me-auto mb-2 mb-lg-0 gap-1">
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle text-white fw-bold small" href="#" role="button" data-bs-toggle="dropdown">
                  Pwodui
                </a>
                <ul class="dropdown-menu shadow-lg p-2" style="min-width: 320px;">
                  <li>
                    <%= link_to "#", class: "dropdown-item rounded p-3" do %>
                      <div class="fw-bold" style="color: var(--haiti-charcoal);"><i class="ri-exchange-funds-line me-2" style="color: var(--haiti-gold);"></i>PrioLink</div>
                      <div style="color: var(--haiti-olive); font-size: 11px; white-space: normal;">Chanje MonCash ou an USDC rapid pou pwoteje lajan'w kont enflasyon.</div>
                    <% end %>
                  </li>
                  <li>
                    <%= link_to sol_circles_path, class: "dropdown-item rounded p-3" do %>
                      <div class="fw-bold" style="color: var(--haiti-charcoal);"><i class="ri-loop-right-line me-2" style="color: var(--haiti-gold);"></i>PrioSòl</div>
                      <div style="color: var(--haiti-olive); font-size: 11px; white-space: normal;">Sistèm mityèl dijital pou fè ekonomi ak kominote'w nan yon fason modèn.</div>
                    <% end %>
                  </li>
                  <li>
                    <%= link_to "#", class: "dropdown-item rounded p-3" do %>
                      <div class="fw-bold" style="color: var(--haiti-charcoal);"><i class="ri-hand-coin-line me-2" style="color: var(--haiti-gold);"></i>PrioBousad</div>
                      <div style="color: var(--haiti-olive); font-size: 11px; white-space: normal;">Prè rapid pou ede biznis ou dekole epi jwenn kapital ou bezwen.</div>
                    <% end %>
                  </li>
                  <li>
                    <%= link_to "#", class: "dropdown-item rounded p-3" do %>
                      <div class="fw-bold" style="color: var(--haiti-charcoal);"><i class="ri-medal-line me-2" style="color: var(--haiti-gold);"></i>PriOnèt</div>
                      <div style="color: var(--haiti-olive); font-size: 11px; white-space: normal;">Bati repitasyon finansye'w pou debloke pi gwo nivo kredi nan bank lan.</div>
                    <% end %>
                  </li>
                  <li><hr class="dropdown-divider"></li>
                  <li>
                    <%= link_to "#", class: "dropdown-item rounded p-3" do %>
                      <div class="fw-bold" style="color: var(--haiti-charcoal);"><i class="ri-flashlight-line me-2" style="color: var(--haiti-gold);"></i>Zèllus <span class="badge-soon">Byento</span></div>
                      <div style="color: var(--haiti-olive); font-size: 11px; white-space: normal;">Voye lajan bay nenpòt moun imedyatman ak yon senp nimewo telefòn oswa email.</div>
                    <% end %>
                  </li>
                </ul>
              </li>
              <li class="nav-item"><%= link_to "Sou Nou", "#", class: "nav-link text-white fw-bold small" %></li>
              <li class="nav-item"><%= link_to "Kijan Li Mache", "#", class: "nav-link text-white fw-bold small" %></li>
            </ul>

            <div class="ms-auto d-flex flex-column flex-lg-row align-items-lg-center gap-3">
              <%= link_to "Konekte", new_user_session_path, class: "nav-link text-white fw-bold small" %>
              <%= link_to "Kòmanse", new_user_registration_path, class: "btn btn-prestige btn-sm px-4 rounded-pill shadow-sm", style: "text-transform: none; font-weight: 700; letter-spacing: 0.3px;" %>
            </div>
          <% end %>

        </div>
      </div>
    </nav>

    <main class="container">
      <%= yield %>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
