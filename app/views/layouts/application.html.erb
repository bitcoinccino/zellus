    <%# ── Turbo Drive: progress bar + overlay + ⚡ Lightning first-load ── %>
    <script>
    (function() {
      var bar = document.getElementById('turbo-progress');
      var overlay = document.getElementById('loading-overlay');
      var animFrame, barWidth;

      function startBar() {
        barWidth = 0;
        bar.style.width = '0%';
        bar.classList.add('active');
        (function grow() {
          barWidth += (90 - barWidth) * 0.03;
          bar.style.width = barWidth + '%';
          if (barWidth < 89) animFrame = requestAnimationFrame(grow);
        })();
      }

      function finishBar() {
        cancelAnimationFrame(animFrame);
        bar.style.width = '100%';
        setTimeout(function() {
          bar.classList.remove('active');
          bar.style.width = '0%';
        }, 250);
      }

      // ── Turbo navigation (link clicks) — overlay only after 500ms delay ──
      var navOverlayTimer = null;
      document.addEventListener('turbo:before-fetch-request', function(e) {
        if (!e.target.closest('form')) {
          startBar();
          // Only show full overlay if load takes > 500ms
          navOverlayTimer = setTimeout(function() {
            overlay.classList.add('active');
          }, 500);
        }
      });
      document.addEventListener('turbo:before-fetch-response', function() {
        clearTimeout(navOverlayTimer);
        finishBar();
        overlay.classList.remove('active');
      });
      document.addEventListener('turbo:load', function() {
        clearTimeout(navOverlayTimer);
        finishBar();
        overlay.classList.remove('active');
      });

      // ── Initial page load: ⚡ Power Charge ──
      var chargeStartTime = window.__zellusChargeStart || Date.now();

      function finishCharge() {
        var elapsed = Date.now() - chargeStartTime;
        var remaining = Math.max(0, 3500 - elapsed);
        setTimeout(function() {
          if (window.ZellusSplash) {
            window.ZellusSplash.fadeOut();
          }
        }, remaining);
      }

      if (document.readyState === 'complete') {
        finishCharge();
      } else {
        window.addEventListener('load', finishCharge);
      }

      // ── Turbo form submissions → overlay + disable button ──
      var overlayTimeout;
      document.addEventListener('turbo:submit-start', function(e) {
        overlay.classList.add('active');
        var btn = e.target.querySelector('[type="submit"], button:not([type="button"])');
        if (btn && !btn.dataset.turboDisabled) {
          btn.dataset.turboDisabled = 'true';
          btn.dataset.originalHtml = btn.innerHTML;
          btn.disabled = true;
          btn.innerHTML = '<i class="ri-loader-4-line me-1" style="animation: spin 0.7s linear infinite; display: inline-block;"></i>Chaje..';
        }
        clearTimeout(overlayTimeout);
        overlayTimeout = setTimeout(function() {
          overlay.classList.remove('active');
          document.querySelectorAll('[data-turbo-disabled]').forEach(function(b) {
            b.disabled = false;
            if (b.dataset.originalHtml) b.innerHTML = b.dataset.originalHtml;
            delete b.dataset.turboDisabled;
            delete b.dataset.originalHtml;
          });
        }, 10000);
      });

      document.addEventListener('turbo:submit-end', function(e) {
        clearTimeout(overlayTimeout);
        overlay.classList.remove('active');
        var btn = e.target.querySelector('[data-turbo-disabled]');
        if (btn) {
          btn.disabled = false;
          btn.innerHTML = btn.dataset.originalHtml;
          delete btn.dataset.turboDisabled;
          delete btn.dataset.originalHtml;
        }
      });

      // Non-Turbo form submissions: just progress bar
      document.addEventListener('submit', function(e) {
        var form = e.target;
        if (form.dataset.turbo === 'false' || form.closest('[data-turbo="false"]')) {
          startBar();
        }
      });
    })();
    </script>

    <%# ── Sidebar: collapse toggle, search filter, Ctrl+B shortcut ── %>
    <% if user_signed_in? %>
    <script>
    (function() {
      var sidebar = document.getElementById('user-sidebar');
      if (!sidebar) return;
      var toggle = document.getElementById('sidebar-toggle');
      var search = document.getElementById('sidebar-search');
      var KEY = 'zellus-sidebar-collapsed';

      // Restore saved state
      if (localStorage.getItem(KEY) === '1') sidebar.classList.add('collapsed');

      // Toggle collapse
      if (toggle) {
        toggle.addEventListener('click', function() {
          sidebar.classList.toggle('collapsed');
          localStorage.setItem(KEY, sidebar.classList.contains('collapsed') ? '1' : '0');
        });
      }

      // Ctrl+B keyboard shortcut
      document.addEventListener('keydown', function(e) {
        if ((e.ctrlKey || e.metaKey) && e.key === 'b' && !e.shiftKey && !e.altKey) {
          var tag = document.activeElement.tagName;
          if (tag === 'INPUT' || tag === 'TEXTAREA' || document.activeElement.isContentEditable) return;
          e.preventDefault();
          sidebar.classList.toggle('collapsed');
          localStorage.setItem(KEY, sidebar.classList.contains('collapsed') ? '1' : '0');
        }
      });

      // Quick search filter
      if (search) {
        var items = sidebar.querySelectorAll('.user-nav-item');
        var sections = sidebar.querySelectorAll('.user-nav-section');
        search.addEventListener('input', function() {
          var q = this.value.toLowerCase().trim();
          if (!q) {
            items.forEach(function(el) { el.style.display = ''; });
            sections.forEach(function(s) { s.style.display = ''; });
            return;
          }
          sections.forEach(function(s) {
            var any = false;
            s.querySelectorAll('.user-nav-item').forEach(function(el) {
              var label = el.querySelector('.user-nav-item-label');
              var text = label ? label.textContent.toLowerCase() : '';
              var match = text.includes(q);
              el.style.display = match ? '' : 'none';
              if (match) any = true;
            });
            s.style.display = any ? '' : 'none';
          });
        });
        // Ctrl+K to focus search
        document.addEventListener('keydown', function(e) {
          if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
            e.preventDefault();
            if (sidebar.classList.contains('collapsed')) {
              sidebar.classList.remove('collapsed');
              localStorage.setItem(KEY, '0');
            }
            search.focus();
          }
        });
        // ESC to clear search
        search.addEventListener('keydown', function(e) {
          if (e.key === 'Escape') {
            this.value = '';
            this.dispatchEvent(new Event('input'));
            this.blur();
          }
        });
      }
    })();
    </script>
    <% end %>

