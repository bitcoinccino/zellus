<!DOCTYPE html>
<html>
  <head>
    <title>ZÈLLUS Admin</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" type="image/svg+xml" href="<%= asset_path('zellus_square.svg') %>">

    <%# ── Preconnect ── %>
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <%# ── CSS ── %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.5.0/fonts/remixicon.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">

    <style>
      :root {
        --haiti-charcoal: #2E2E38;
        --haiti-olive: #5D6345;
        --haiti-gold: #C5A059;
        --haiti-mint: #E8EDE0;
        --haiti-cream: #F7F4E3;
        --admin-topbar: 56px;
        --admin-sidebar: 260px;
      }

      body {
        background-color: var(--haiti-mint);
        color: var(--haiti-charcoal);
        font-family: 'Plus Jakarta Sans', 'Segoe UI', Roboto, -apple-system, sans-serif;
        margin: 0; padding: 0;
        overflow-x: hidden;
      }

      h1, h2, h3, h4, h5, h6,
      .h1, .h2, .h3, .h4, .h5, .h6,
      .fw-black {
        font-family: 'Space Grotesk', 'Segoe UI', sans-serif;
      }

      .card-base {
        background-color: var(--haiti-cream);
        border-radius: 28px;
        border: none;
      }

      /* ── Top Bar ── */
      .admin-topbar {
        height: var(--admin-topbar);
        background: var(--haiti-charcoal);
        border-bottom: 2px solid var(--haiti-gold);
        display: flex;
        align-items: center;
        padding: 0 20px;
        position: sticky;
        top: 0;
        z-index: 1040;
      }
      .admin-topbar-brand {
        color: var(--haiti-gold);
        font-family: 'Space Grotesk', sans-serif;
        font-weight: 700;
        font-size: 18px;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .admin-topbar-brand:hover { color: var(--haiti-gold); }
      .admin-topbar-label {
        background: rgba(197,160,89,0.15);
        color: var(--haiti-gold);
        font-size: 10px;
        font-weight: 700;
        padding: 2px 8px;
        border-radius: 6px;
        letter-spacing: 1px;
        text-transform: uppercase;
      }
      .admin-topbar-back {
        color: rgba(255,255,255,0.5);
        text-decoration: none;
        font-size: 12px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 4px;
        transition: color 0.2s;
      }
      .admin-topbar-back:hover { color: var(--haiti-gold); }

      /* ── Sidebar ── */
      .admin-sidebar {
        width: var(--admin-sidebar);
        min-height: calc(100vh - var(--admin-topbar));
        background: var(--haiti-charcoal);
        position: sticky;
        top: var(--admin-topbar);
        overflow-y: auto;
        flex-shrink: 0;
        padding: 16px 0;
        border-right: 1px solid rgba(197,160,89,0.1);
      }
      .admin-nav-section {
        margin-bottom: 8px;
      }
      .admin-nav-header {
        color: rgba(255,255,255,0.35);
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        padding: 12px 20px 6px;
        display: flex;
        align-items: center;
        gap: 6px;
      }
      .admin-nav-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 9px 20px;
        color: rgba(255,255,255,0.55);
        font-size: 13px;
        font-weight: 600;
        text-decoration: none;
        border-left: 3px solid transparent;
        transition: all 0.15s ease;
      }
      .admin-nav-item i { font-size: 16px; width: 20px; text-align: center; }
      .admin-nav-item:hover {
        color: rgba(255,255,255,0.85);
        background: rgba(255,255,255,0.04);
      }
      .admin-nav-active {
        color: var(--haiti-gold) !important;
        border-left-color: var(--haiti-gold);
        background: rgba(197,160,89,0.08);
      }
      .admin-nav-active i { color: var(--haiti-gold); }

      /* Disabled sections */
      .admin-nav-disabled .admin-nav-item {
        opacity: 0.3;
        pointer-events: none;
        cursor: default;
      }
      .admin-nav-disabled .admin-nav-header { opacity: 0.4; }
      .admin-badge-soon {
        font-size: 7px;
        background: rgba(197,160,89,0.2);
        color: var(--haiti-gold);
        padding: 1px 5px;
        border-radius: 3px;
        letter-spacing: 0.5px;
      }

      /* ── Content Area ── */
      .admin-content {
        flex: 1;
        min-width: 0;
        padding: 24px;
        min-height: calc(100vh - var(--admin-topbar));
      }

      /* ── Mobile ── */
      @media (max-width: 991.98px) {
        .admin-sidebar-desktop { display: none !important; }
        .admin-content { padding: 16px; }
      }
      @media (min-width: 992px) {
        .admin-hamburger { display: none !important; }
      }

      /* ── Flash messages ── */
      .admin-flash {
        border-radius: 12px;
        padding: 12px 16px;
        font-size: 13px;
        font-weight: 600;
        margin-bottom: 16px;
        max-width: 560px;
        animation: adminFlashIn 0.3s ease-out;
      }
      @keyframes adminFlashIn {
        from { opacity: 0; transform: translateY(-8px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      /* ── Loading overlay ── */
      #loading-overlay {
        position: fixed; inset: 0; z-index: 9998;
        background: rgba(46,46,56,0.5); backdrop-filter: blur(2px);
        display: none; align-items: center; justify-content: center;
        flex-direction: column; gap: 12px;
      }
      #loading-overlay.active { display: flex; }
      #loading-overlay .spinner {
        width: 36px; height: 36px; border: 3px solid rgba(197,160,89,0.25);
        border-top-color: var(--haiti-gold); border-radius: 50%;
        animation: spin 0.7s linear infinite;
      }
      @keyframes spin { to { transform: rotate(360deg); } }

      /* ── Turbo progress bar ── */
      #turbo-progress {
        position: fixed; top: 0; left: 0; height: 3px; z-index: 9999;
        background: var(--haiti-gold);
        width: 0; opacity: 0;
        transition: width 0.3s ease, opacity 0.2s ease;
        pointer-events: none;
        box-shadow: 0 0 8px rgba(197,160,89,0.6);
      }
      #turbo-progress.active { opacity: 1; }

      @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
      }

      @media (max-width: 576px) {
        .card-base { padding: 1rem !important; }
      }
    </style>
  </head>

  <body>
    <%# ── Turbo Progress Bar ── %>
    <div id="turbo-progress"></div>

    <%# ── Loading Overlay ── %>
    <div id="loading-overlay">
      <div class="spinner"></div>
      <span style="color: var(--haiti-gold); font-size: 12px; font-weight: 700;">Chajman...</span>
    </div>

    <%# ═══════════════════════════════════════════════
        TOP BAR + SYSTEM HEALTH
        ═══════════════════════════════════════════════ %>
    <div class="admin-topbar">
      <div class="d-flex align-items-center justify-content-between w-100">
        <%# Left: Brand %>
        <div class="d-flex align-items-center gap-3">
          <%= link_to admin_root_path, class: "admin-topbar-brand" do %>
            <%= image_tag "zellus_square.svg", style: "width: 28px; height: 28px;", alt: "Zèllus" %>
            ZÈLLUS
            <span class="admin-topbar-label">Admin</span>
          <% end %>

          <%# System Health Indicators (desktop) %>
          <div class="d-none d-xl-flex align-items-center gap-3 ms-4" style="font-size: 11px;">
            <span style="color: rgba(255,255,255,0.12);">|</span>
            <%# Network %>
            <% if defined?(CryptoTransferWorker) && CryptoTransferWorker::CHAIN_ID == 8453 %>
              <span class="d-flex align-items-center gap-1">
                <i class="ri-checkbox-blank-circle-fill" style="font-size: 7px; color: #22c55e;"></i>
                <span class="fw-bold" style="color: #22c55e; font-size: 10px;">BASE</span>
              </span>
            <% else %>
              <span class="d-flex align-items-center gap-1">
                <i class="ri-checkbox-blank-circle-fill" style="font-size: 7px; color: #f59e0b;"></i>
                <span class="fw-bold" style="color: #f59e0b; font-size: 10px;">TESTNET</span>
              </span>
            <% end %>
            <span style="color: rgba(255,255,255,0.12);">|</span>
            <%# Gas %>
            <span class="d-flex align-items-center gap-1">
              <i class="ri-gas-station-line" id="healthGasIcon" style="color: var(--haiti-gold); font-size: 13px;"></i>
              <span id="healthGasValue" class="fw-bold" style="color: white;">
                <span class="placeholder-glow"><span class="placeholder rounded" style="width: 50px; height: 12px; background: rgba(255,255,255,0.15);"></span></span>
              </span>
              <span id="healthGasLow" style="display: none; color: #ef4444; font-size: 9px; font-weight: 700; animation: pulse 2s infinite;">LOW</span>
            </span>
            <span style="color: rgba(255,255,255,0.12);">|</span>
            <%# MonCash %>
            <span class="d-flex align-items-center gap-1">
              <span style="font-size: 10px; color: rgba(255,255,255,0.4);">MC:</span>
              <span id="healthMoncashValue" class="fw-bold" style="color: white;">
                <span class="placeholder-glow"><span class="placeholder rounded" style="width: 55px; height: 12px; background: rgba(255,255,255,0.15);"></span></span>
              </span>
            </span>
            <span style="color: rgba(255,255,255,0.12);">|</span>
            <%# On-chain Treasury %>
            <span class="d-flex align-items-center gap-1">
              <span style="font-size: 10px; color: rgba(255,255,255,0.4);">On-chain:</span>
              <span id="healthTreasuryValue" class="fw-bold" style="color: white;">
                <span class="placeholder-glow"><span class="placeholder rounded" style="width: 55px; height: 12px; background: rgba(255,255,255,0.15);"></span></span>
              </span>
            </span>
            <span style="color: rgba(255,255,255,0.12);">|</span>
            <%# Internal Wallet Balances %>
            <span class="d-flex align-items-center gap-1">
              <span style="font-size: 10px; color: rgba(255,255,255,0.4);">Entèn:</span>
              <span id="healthInternalValue" class="fw-bold" style="color: white;">
                <span class="placeholder-glow"><span class="placeholder rounded" style="width: 70px; height: 12px; background: rgba(255,255,255,0.15);"></span></span>
              </span>
            </span>
            <span style="color: rgba(255,255,255,0.12);">|</span>
            <%# Reserve coverage (USDC) — single-line: surplus · ratio · status %>
            <span class="d-flex align-items-center gap-1">
              <span style="font-size: 10px; color: rgba(255,255,255,0.4);">Reserve:</span>
              <span id="healthReserveValue" class="fw-bold" style="color: white;">
                <span class="placeholder-glow"><span class="placeholder rounded" style="width: 110px; height: 12px; background: rgba(255,255,255,0.15);"></span></span>
              </span>
            </span>
          </div>
        </div>

        <%# Right: Back link + hamburger %>
        <div class="d-flex align-items-center gap-3">
          <%= link_to wallet_path, class: "admin-topbar-back" do %>
            <i class="ri-arrow-left-s-line" style="font-size: 16px;"></i> Retounen nan App
          <% end %>

          <%# Mobile hamburger %>
          <button class="admin-hamburger btn btn-sm p-1" type="button" data-bs-toggle="offcanvas" data-bs-target="#adminSidebarMobile" aria-label="Menu">
            <i class="ri-menu-3-line" style="color: var(--haiti-gold); font-size: 22px;"></i>
          </button>
        </div>
      </div>
    </div>

    <%# ═══════════════════════════════════════════════
        BODY: Sidebar + Content
        ═══════════════════════════════════════════════ %>
    <div class="d-flex">
      <%# ── Desktop Sidebar ── %>
      <aside class="admin-sidebar admin-sidebar-desktop">
        <%= render "admin/shared/sidebar" %>
      </aside>

      <%# ── Mobile Offcanvas Sidebar ── %>
      <div class="offcanvas offcanvas-start" tabindex="-1" id="adminSidebarMobile" style="background: var(--haiti-charcoal); width: 280px;">
        <div class="offcanvas-header border-bottom" style="border-color: rgba(197,160,89,0.15) !important;">
          <span style="color: var(--haiti-gold); font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: 16px;">
            <i class="ri-shield-keyhole-line me-2"></i>ZÈLLUS Admin
          </span>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Fèmen"></button>
        </div>
        <div class="offcanvas-body p-0">
          <%= render "admin/shared/sidebar" %>
        </div>
      </div>

      <%# ── Main Content ── %>
      <main class="admin-content">
        <%# Flash messages %>
        <% if flash[:notice].present? %>
          <div class="admin-flash d-flex align-items-center justify-content-between" style="background: rgba(22,101,52,0.08); color: #166534; border: 1px solid rgba(22,101,52,0.15);">
            <span><i class="ri-checkbox-circle-fill me-1"></i> <%= flash[:notice] %></span>
            <button type="button" onclick="this.parentElement.remove()" style="background: none; border: none; color: #166534; font-size: 16px; cursor: pointer; padding: 0 0 0 12px; opacity: 0.6;"><i class="ri-close-line"></i></button>
          </div>
        <% end %>
        <% if flash[:alert].present? %>
          <div class="admin-flash d-flex align-items-center justify-content-between" style="background: rgba(153,27,27,0.08); color: #991b1b; border: 1px solid rgba(153,27,27,0.15);">
            <span><i class="ri-error-warning-fill me-1"></i> <%= flash[:alert] %></span>
            <button type="button" onclick="this.parentElement.remove()" style="background: none; border: none; color: #991b1b; font-size: 16px; cursor: pointer; padding: 0 0 0 12px; opacity: 0.6;"><i class="ri-close-line"></i></button>
          </div>
        <% end %>

        <script>
          document.addEventListener("DOMContentLoaded", function() {
            document.querySelectorAll(".admin-flash").forEach(function(el) {
              setTimeout(function() {
                el.style.transition = "opacity 0.4s ease, transform 0.4s ease";
                el.style.opacity = "0";
                el.style.transform = "translateY(-8px)";
                setTimeout(function() { el.remove(); }, 400);
              }, 5000);
            });
          });
        </script>

        <%= yield %>
      </main>
    </div>

    <%# ── Bootstrap JS ── %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <%# ── Turbo loading overlay ── %>
    <script>
    (function() {
      var bar = document.getElementById('turbo-progress');
      var overlay = document.getElementById('loading-overlay');

      function startBar() {
        bar.style.width = '0%';
        bar.classList.add('active');
        setTimeout(function() { bar.style.width = '40%'; }, 50);
        setTimeout(function() { bar.style.width = '70%'; }, 300);
      }
      function finishBar() {
        bar.style.width = '100%';
        setTimeout(function() { bar.classList.remove('active'); bar.style.width = '0%'; }, 300);
      }

      document.addEventListener('turbo:before-fetch-request', function(e) {
        startBar();
        if (!e.target.closest || !e.target.closest('form')) {
          overlay.classList.add('active');
        }
      });
      document.addEventListener('turbo:submit-start', function() {
        startBar();
        overlay.classList.add('active');
      });
      document.addEventListener('turbo:before-fetch-response', function() { finishBar(); overlay.classList.remove('active'); });
      document.addEventListener('turbo:load', function() { finishBar(); overlay.classList.remove('active'); });
      document.addEventListener('turbo:frame-load', function() { finishBar(); overlay.classList.remove('active'); });
    })();
    </script>

    <%# ── System Health Async Loader ── %>
    <script>
    (function() {
      fetch('<%= admin_system_health_path %>', { headers: { 'Accept': 'application/json', 'ngrok-skip-browser-warning': '1' } })
        .then(function(r) { return r.json(); })
        .then(function(d) {
          var gasEl = document.getElementById('healthGasValue');
          var gasLow = document.getElementById('healthGasLow');
          var mcEl = document.getElementById('healthMoncashValue');
          var trezEl = document.getElementById('healthTreasuryValue');
          var intEl = document.getElementById('healthInternalValue');

          if (gasEl) gasEl.textContent = d.eth_balance + ' ETH';
          if (gasLow && d.gas_low) gasLow.style.display = 'inline';
          if (mcEl) {
            if (d.moncash_error) {
              mcEl.innerHTML = '<span style="color:#ef4444;font-size:10px;">' + d.moncash_error + '</span>';
            } else {
              mcEl.textContent = 'G ' + (d.moncash_balance || 0);
            }
          }
          if (trezEl) trezEl.textContent = '$' + d.usdc_balance + ' USDC';
          if (intEl) intEl.textContent = '$' + d.internal_usdc + ' · G ' + d.internal_htg;

          var resEl = document.getElementById('healthReserveValue');
          if (resEl) {
            var surplus = (Number(d.reserve_surplus) || 0).toFixed(2);
            var sign    = d.reserve_surplus >= 0 ? '+' : '';
            var ratio   = d.reserve_ratio == null ? '—' : (d.reserve_ratio.toFixed(2) + '×');

            // Color + label per status threshold.
            var statusMap = {
              healthy:   { label: '✓ Healthy',   color: '#22c55e' },
              tight:     { label: '⚠ Tight',     color: '#f59e0b' },
              insolvent: { label: '✕ Insolvent', color: '#ef4444' }
            };
            var s = statusMap[d.reserve_status] || statusMap.healthy;

            resEl.style.color = s.color;
            resEl.textContent = sign + '$' + surplus + '  ·  ' + ratio + '  ·  ' + s.label;
          }
        })
        .catch(function() {
          var gasEl = document.getElementById('healthGasValue');
          if (gasEl) gasEl.innerHTML = '<span style="color:#ef4444;font-size:10px;">Erè</span>';
        });
    })();
    </script>
  </body>
</html>
