function clearCashinSelection() {
  var input = document.getElementById('cashinCustomer');
  input.value = '';
  input.readOnly = false;
  input.style.opacity = '1';
  document.getElementById('cashinCustomerResult').style.display = 'none';
  document.getElementById('cashinCustomerResult').innerHTML = '';
  input.focus();
}

(function() {
  var input = document.getElementById('cashinCustomer');
  if (!input) return;
  var timer = null;
  var resultEl = document.getElementById('cashinCustomerResult');
  var notFoundEl = document.getElementById('cashinCustomerNotFound');

  function hideResults() {
    resultEl.style.display = 'none';
    notFoundEl.style.display = 'none';
  }

  input.addEventListener('input', function() {
    clearTimeout(timer);
    var q = input.value.trim();
    if (q.length < 2) { hideResults(); return; }
    timer = setTimeout(function() {
      fetch('<%= user_lookup_path %>' + '?q=' + encodeURIComponent(q), {
        headers: { 'Accept': 'application/json' }
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.found) {
          var avatarHtml = data.avatar_url
            ? '<img src="' + data.avatar_url + '" style="width: 32px; height: 32px; border-radius: 50%; object-fit: cover; border: 1.5px solid var(--haiti-gold);">'
            : '<div style="width: 32px; height: 32px; border-radius: 50%; background: var(--haiti-charcoal); border: 1.5px solid var(--haiti-gold); display: flex; align-items: center; justify-content: center; color: var(--haiti-gold); font-size: 13px; font-weight: 800;">' + data.display_name.charAt(0).toUpperCase() + '</div>';
          var escapedName = data.display_name.replace(/'/g, "\\'");
          var escapedAvatar = (data.avatar_url || '').replace(/'/g, "\\'");
          var bizBadge = data.is_business
            ? '<span style="display: inline-block; background: var(--haiti-gold); color: var(--haiti-charcoal); font-size: 9px; font-weight: 800; padding: 1px 6px; border-radius: 99px; margin-left: 5px;">Biznis</span>'
            : '';
          resultEl.innerHTML =
            '<div class="d-flex align-items-center justify-content-between p-2 rounded-3" style="background: rgba(197,160,89,0.1); border: 1.5px solid var(--haiti-gold); cursor: pointer;" onclick="selectCashinCustomer(\'' + data.cashtag + '\', \'' + escapedName + '\', \'' + escapedAvatar + '\')">' +
              '<div class="d-flex align-items-center gap-2">' + avatarHtml +
              '<div>' +
                '<div class="fw-bold" style="color: var(--haiti-charcoal); font-size: 12px;">' + data.display_name + bizBadge + '</div>' +
                '<div style="color: var(--haiti-olive); font-size: 10px;">$' + data.cashtag + '</div>' +
              '</div></div>' +
              '<button type="button" class="btn btn-sm fw-bold rounded-pill" style="background: var(--haiti-gold); color: #fff; font-size: 10px;" onclick="selectCashinCustomer(\'' + data.cashtag + '\', \'' + escapedName + '\', \'' + escapedAvatar + '\')"><i class="ri-check-line me-1"></i>Chwazi</button>' +
            '</div>';
          resultEl.style.display = 'block';
          notFoundEl.style.display = 'none';
        } else {
          resultEl.style.display = 'none';
          notFoundEl.style.display = 'block';
        }
      })
      .catch(function() { hideResults(); });
    }, 400);
  });
})();

