                  <i class="ri-arrow-left-line"></i>
                </button>
                <button type="submit" class="btn flex-grow-1 fw-bold rounded-pill border-0 d-flex align-items-center justify-content-center gap-2"
                        style="background: var(--haiti-charcoal); color: var(--haiti-gold); font-size: 15px; padding: 14px 24px; letter-spacing: 0.3px;">
                  <i class="ri-check-line" style="font-size: 18px;"></i>Konfime Retrè
                </button>
              </div>
            </div>
          <% end %>
        </div>

        <%# ════════════════════════════════════ %>
        <%# ── USD (Base) WITHDRAW FORM      ── %>
        <%# ════════════════════════════════════ %>
        <div id="wd-section-kripto" style="display: none;">
          <%= form_with(url: withdraw_usd_wallet_path, method: :post, local: true, id: "withdraw-usd-form") do %>
            <input type="hidden" name="source" id="wd-usd-source-field" value="personal">

            <div id="wd-step1-usd">
              <%# ── Destination Address ── %>
              <div class="mb-1 fw-bold d-flex align-items-center gap-1" style="font-size: 11px; color: var(--haiti-olive);">
                <%= usd_logo(size: 14) %> Adrès Base destinasyon:
              </div>
              <div class="input-group mb-2">
                <span class="input-group-text border-0" style="background-color: var(--haiti-charcoal); color: var(--haiti-gold);"><i class="ri-wallet-3-line"></i></span>
                <input type="text" name="wallet_address" id="wd-usd-address" class="form-control border-0 fw-bold shadow-none p-3 bb-dark-field"
                       placeholder="0x..." pattern="0x[0-9a-fA-F]{40}" required
                       style="background-color: var(--haiti-charcoal); color: white; font-size: 12px;">
              </div>

              <%# ── Amount ── %>
              <div class="mb-1 fw-bold" style="font-size: 11px; color: var(--haiti-olive);">Montan</div>
              <div class="input-group mb-2">
                <span class="input-group-text border-0" style="background-color: var(--haiti-charcoal); color: var(--haiti-gold);"><i class="ri-money-dollar-circle-line"></i></span>
                <input type="number" name="amount" id="wd-usd-amount" class="form-control border-0 fw-bold shadow-none p-3 bb-dark-field"
                       placeholder="Montan (USD)" min="1" max="500" step="0.01" required
                       style="background-color: var(--haiti-charcoal); color: white;">
                <span class="input-group-text border-0 fw-bold" style="background-color: var(--haiti-charcoal); color: var(--haiti-olive); font-size: 11px;"><%= currency_label("usd") %></span>
              </div>
              <div class="d-flex justify-content-between mb-2">
                <span class="small" style="color: var(--haiti-olive); font-size: 10px;">Min: 1 USD</span>
                <span class="small" style="color: var(--haiti-olive); font-size: 10px;">Max: 500 USD</span>
              </div>
              <div class="d-flex align-items-center gap-2 mb-3 px-2 py-2 rounded-3" style="background: rgba(197,160,89,0.08); font-size: 10px; color: var(--haiti-olive);">
                <i class="ri-information-line" style="font-size: 14px; color: var(--haiti-gold);"></i>
                <span>Balans disponib: <strong style="color: var(--haiti-charcoal);"><%= format('%.2f', @wallet.usd_balance.to_f) %> USD</strong></span>
              </div>

              <div class="small p-2 rounded-3 mb-3" style="background: rgba(93,99,69,0.06); color: var(--haiti-olive); font-size: 10px;">
                <i class="ri-base-station-line me-1" style="color: var(--haiti-gold);"></i>Retrè USD trete sou rezo <strong>Base</strong>. Tranzaksyon konfime nan kèk minit.
              </div>

              <button type="button" onclick="showUsdcWithdrawReview()" class="btn w-100 fw-bold rounded-pill border-0 d-flex align-items-center justify-content-center gap-2"
                      style="background: var(--haiti-charcoal); color: var(--haiti-gold); font-size: 15px; padding: 14px 24px; letter-spacing: 0.3px;">
                <i class="ri-arrow-right-line" style="font-size: 18px;"></i>Kontinye
              </button>
            </div>

            <%# ── STEP 2: Review + PIN ── %>
            <div id="wd-step2-usd" style="display: none;">
              <div class="rounded-3 p-3 mb-3" style="background: rgba(197,160,89,0.08);">
                <div class="small fw-bold mb-2" style="color: var(--haiti-charcoal);">
                  <i class="ri-file-list-3-line me-1" style="color: var(--haiti-gold);"></i>Rezime Retrè USD
                </div>
                <div class="d-flex justify-content-between small mb-1">
                  <span style="color: var(--haiti-olive);">Montan</span>
                  <span id="wd-review-amount-usd" class="fw-bold" style="color: var(--haiti-charcoal);"></span>
                </div>
                <div class="d-flex justify-content-between small mb-1">
                  <span style="color: var(--haiti-olive);">Adrès</span>
                  <span id="wd-review-addr-usd" class="fw-bold" style="color: var(--haiti-charcoal); font-size: 10px; word-break: break-all;"></span>
                </div>
                <div class="d-flex justify-content-between small mb-1">
                  <span style="color: var(--haiti-olive);">Rezo</span>
                  <span class="fw-bold" style="color: var(--haiti-charcoal);">Base (L2)</span>
                </div>
                <hr class="my-2" style="border-color: var(--haiti-olive); opacity: 0.15;">
                <div class="d-flex justify-content-between small">
                  <span class="fw-bold" style="color: var(--haiti-charcoal);">Total debite</span>
                  <span id="wd-review-total-usd" class="fw-black" style="color: var(--haiti-charcoal);"></span>
                </div>
              </div>

              <div class="input-group mb-3">
                <span class="input-group-text border-0" style="background-color: var(--haiti-charcoal); color: var(--haiti-gold);"><i class="ri-lock-password-line"></i></span>
                <input type="password" name="transfer_pin" id="wd-pin-usd" class="form-control border-0 fw-bold shadow-none p-3 bb-dark-field"
                       placeholder="PIN" maxlength="4" pattern="\d{4}" required inputmode="numeric"
                       style="background-color: var(--haiti-charcoal); color: white; letter-spacing: 8px; text-align: center;">
              </div>

              <div class="d-flex gap-2">
                <button type="button" onclick="backToUsdcStep1()" class="btn flex-shrink-0 fw-bold rounded-pill border-0 px-3"
                        style="background: rgba(93,99,69,0.1); color: var(--haiti-charcoal); font-size: 14px; padding: 14px 16px;">
                  <i class="ri-arrow-left-line"></i>
                </button>
                <button type="submit" class="btn flex-grow-1 fw-bold rounded-pill border-0 d-flex align-items-center justify-content-center gap-2"
                        style="background: var(--haiti-charcoal); color: var(--haiti-gold); font-size: 15px; padding: 14px 24px; letter-spacing: 0.3px;">
                  <i class="ri-check-line" style="font-size: 18px;"></i>Konfime Retrè USD
                </button>
              </div>
            </div>
          <% end %>
        </div>

        <%# ════════════════════════════════════ %>
        <%# ── STÒK Section (DISABLED)         ── %>
        <%# ════════════════════════════════════ %>
        <div id="wd-section-stok" style="display: none;">
          <div class="text-center py-4">
            <i class="ri-lock-line ri-2x mb-2 d-block" style="color: var(--haiti-gold);"></i>
            <div class="fw-bold mb-1" style="color: var(--haiti-charcoal); font-size: 14px;">Retrè Stòk Dezaktive</div>
            <div class="small" style="color: var(--haiti-olive);">
              Fonksyon sa a ap retounen byento.
            </div>
          </div>
        </div>

        <% else %>
          <div class="text-center py-3" style="color: var(--haiti-olive);">
            <i class="ri-lock-line ri-2x mb-2 d-block" style="color: var(--haiti-gold);"></i>
            <div class="small">Ou dwe kreye yon PIN anvan ou ka retire lajan.</div>
          </div>
        <% end %>
      </div>
    </div>

    <%# ══════════════════════════════════════════ %>
    <%# ── CONVERT PANEL (Konvèti)           ── %>
    <%# ══════════════════════════════════════════ %>
    <div id="panel-convert" class="panel-slide mb-3">
      <div class="p-3 rounded-4" style="background: var(--haiti-cream); border: 1.5px solid rgba(93,99,69,0.2);">
        <div class="d-flex align-items-center justify-content-between mb-3">
          <div class="fw-black" style="color: var(--haiti-charcoal); font-size: 18px;">Konvèti</div>
          <button type="button" onclick="togglePanel('convert')" class="btn btn-sm p-0" style="color: var(--haiti-olive);">
            <i class="ri-close-line" style="font-size: 20px;"></i>
          </button>
        </div>
        <p style="color: var(--haiti-olive); font-size: 12px; margin-bottom: 14px; line-height: 1.5;">Konvèti Goud oswa Dola soti nan Pèsonèl ale nan Biznis, e vis vèsa.</p>

        <% cv_stock_meta = {
             "tslax"  => { name: "Tesla",     logo: "tslax_logo",  color: "#CC0000", accent: "rgba(204,0,0,0.08)" },
             "nvdax"  => { name: "Nvidia",    logo: "nvdax_logo",  color: "#76B900", accent: "rgba(118,185,0,0.08)" },
             "aaplx"  => { name: "Apple",     logo: "aaplx_logo",  color: "#555555", accent: "rgba(85,85,85,0.08)" },
             "coinx"  => { name: "Coinbase",  logo: "coinx_logo",  color: "#0052FF", accent: "rgba(0,82,255,0.08)" },
             "googlx" => { name: "Alphabet",  logo: "googlx_logo", color: "#4285F4", accent: "rgba(66,133,244,0.08)" }
           } %>

        <% if current_user.transfer_pin_set? %>
          <%= form_with(url: convert_wallet_path, method: :post, local: true, id: "convert-form") do %>
            <input type="hidden" name="from_asset" id="convert-from-asset" value="htg">
            <input type="hidden" name="to_asset" id="convert-to-asset" value="usd">
            <input type="hidden" name="convert_source" id="cv-source-field" value="personal">
            <input type="hidden" name="convert_dest" id="cv-dest-field" value="personal">

            <%# ── STEP 1: Source + From/To + Amount ── %>
            <div id="cv-step1">

              <%# ══ FROM: wallet + currency source dropdown ══ %>
              <% cv_personal_htg = @wallet.htg_balance.floor.to_i %>
              <% cv_personal_usd = @wallet.usd_balance.round(2) %>
              <% cv_biz_htg = @business&.total_received&.floor.to_i || 0 %>
              <% cv_biz_usd = @business&.usd_balance&.round(2) || 0 %>

              <%# ══ Conversion direction summary ══ %>
              <div id="cv-direction-summary" class="d-flex align-items-center justify-content-center gap-2 mb-3 p-2 rounded-3" style="background: rgba(197,160,89,0.08);">
                <span id="cv-dir-from-logo"><%= htg_logo_svg(size: 18) %></span>
                <span id="cv-dir-from" class="fw-bold" style="color: var(--haiti-charcoal); font-size: 14px;">HTG</span>
                <i class="ri-arrow-right-line" style="color: var(--haiti-gold); font-size: 18px;"></i>
                <span id="cv-dir-to-logo"><%= usd_logo(size: 18) %></span>
                <span id="cv-dir-to" class="fw-bold" style="color: var(--haiti-charcoal); font-size: 14px;">USD</span>
              </div>

              <%# ══ FROM / TO: stacked currency+wallet dropdowns ══ %>
              <div class="mb-3">
                <%# ── FROM dropdown ── %>
                <div style="position: relative;" class="mb-2">
                  <label class="form-label small fw-bold text-uppercase mb-1" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">
                    <i class="ri-arrow-up-circle-line me-1"></i>Soti nan
                  </label>
                  <button type="button" id="cv-from-btn" onclick="toggleCvDd('from')"
                          class="btn w-100 d-flex align-items-center justify-content-between rounded-3"
                          style="background: var(--haiti-mint); border: 1px solid rgba(46,46,56,0.1); cursor: pointer; padding: 12px 14px;">
                    <div class="d-flex align-items-center gap-2">
                      <span id="cv-from-logo"><%= htg_logo_svg(size: 18) %></span>
                      <div class="text-start">
                        <div id="cv-from-label" class="fw-bold" style="color: var(--haiti-charcoal); font-size: 12px;">HTG</div>
                        <div id="cv-from-sub" style="font-size: 9px; color: var(--haiti-olive); font-weight: 600;">Pèsonèl</div>
                      </div>
                    </div>
                    <i class="ri-arrow-down-s-line" style="color: var(--haiti-gold); font-size: 16px;"></i>
                  </button>
                  <div id="cv-from-dropdown" class="rounded-3 shadow-lg" style="display:none; position:absolute; top:100%; left:0; right:0; z-index:10; margin-top:4px; background: var(--haiti-cream); border: 1px solid rgba(46,46,56,0.1); overflow:hidden;">
                    <%# Pèsonèl group %>
                    <div class="px-2 pt-2 pb-1" style="font-size: 9px; color: var(--haiti-olive); font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase;">
                      <i class="ri-wallet-3-line me-1"></i>Pèsonèl
                    </div>
                    <button type="button" onclick="selectCvOption('from','htg','personal')" class="cv-dd-opt btn w-100 text-start border-0 px-2 py-1" data-key="htg-personal" style="background:transparent;">
                      <div class="d-flex align-items-center gap-2">
                        <%= htg_logo_svg(size: 16) %>
                        <span class="fw-bold" style="color: var(--haiti-charcoal); font-size: 12px;">HTG</span>
                        <span class="ms-auto" style="font-size: 10px; color: var(--haiti-olive); font-weight: 600;"><%= number_with_delimiter(cv_personal_htg) %></span>
                      </div>
                    </button>
                    <button type="button" onclick="selectCvOption('from','usd','personal')" class="cv-dd-opt btn w-100 text-start border-0 px-2 py-1" data-key="usd-personal" style="background:transparent;">
                      <div class="d-flex align-items-center gap-2">
                        <%= usd_logo(size: 16) %>
                        <span class="fw-bold" style="color: var(--haiti-charcoal); font-size: 12px;">USD</span>
                        <span class="ms-auto" style="font-size: 10px; color: var(--haiti-olive); font-weight: 600;"><%= cv_personal_usd %></span>
                      </div>
                    </button>
                    <div style="height:1px; background: rgba(46,46,56,0.08); margin: 4px 0;"></div>
                    <%# Biznis group %>
                    <div class="px-2 pt-1 pb-1" style="font-size: 9px; color: var(--haiti-olive); font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase;">
                      <i class="ri-store-2-line me-1"></i><%= @business&.name || "Biznis" %>
                    </div>
                    <button type="button" onclick="selectCvOption('from','htg','biznis')" class="cv-dd-opt btn w-100 text-start border-0 px-2 py-1" data-key="htg-biznis" style="background:transparent;">
                      <div class="d-flex align-items-center gap-2">
                        <%= htg_logo_svg(size: 16) %>
                        <span class="fw-bold" style="color: var(--haiti-charcoal); font-size: 12px;">HTG</span>
                        <span class="ms-auto" style="font-size: 10px; color: var(--haiti-olive); font-weight: 600;"><%= number_with_delimiter(cv_biz_htg) %></span>
                      </div>
                    </button>
                    <button type="button" onclick="selectCvOption('from','usd','biznis')" class="cv-dd-opt btn w-100 text-start border-0 px-2 py-1 mb-1" data-key="usd-biznis" style="background:transparent;">
                      <div class="d-flex align-items-center gap-2">
                        <%= usd_logo(size: 16) %>
                        <span class="fw-bold" style="color: var(--haiti-charcoal); font-size: 12px;">USD</span>
                        <span class="ms-auto" style="font-size: 10px; color: var(--haiti-olive); font-weight: 600;"><%= cv_biz_usd %></span>
                      </div>
                    </button>
                  </div>
                </div>

                <div class="text-center mb-2">
                  <i class="ri-arrow-down-line" style="color: var(--haiti-olive); font-size: 18px;"></i>
                </div>

                <%# ── TO dropdown ── %>
                <div style="position: relative;">
                  <label class="form-label small fw-bold text-uppercase mb-1" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">
                    <i class="ri-arrow-down-circle-line me-1"></i>Pou
                  </label>
                  <button type="button" id="cv-to-btn" onclick="toggleCvDd('to')"
                          class="btn w-100 d-flex align-items-center justify-content-between rounded-3"
                          style="background: var(--haiti-mint); border: 1px solid rgba(46,46,56,0.1); cursor: pointer; padding: 12px 14px;">
                    <div class="d-flex align-items-center gap-2">
                      <span id="cv-to-logo"><%= usd_logo(size: 18) %></span>
                      <div class="text-start">
                        <div id="cv-to-label" class="fw-bold" style="color: var(--haiti-charcoal); font-size: 12px;">USD</div>
                        <div id="cv-to-sub" style="font-size: 9px; color: var(--haiti-olive); font-weight: 600;">Pèsonèl</div>
                      </div>
                    </div>
                    <i class="ri-arrow-down-s-line" style="color: var(--haiti-gold); font-size: 16px;"></i>
                  </button>
                  <div id="cv-to-dropdown" class="rounded-3 shadow-lg" style="display:none; position:absolute; top:100%; left:0; right:0; z-index:10; margin-top:4px; background: var(--haiti-cream); border: 1px solid rgba(46,46,56,0.1); overflow:hidden;">
                    <%# Pèsonèl group %>
                    <div class="px-2 pt-2 pb-1" style="font-size: 9px; color: var(--haiti-olive); font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase;">
                      <i class="ri-wallet-3-line me-1"></i>Pèsonèl
                    </div>
                    <button type="button" onclick="selectCvOption('to','htg','personal')" class="cv-dd-opt btn w-100 text-start border-0 px-2 py-1" data-key="htg-personal" style="background:transparent;">
                      <div class="d-flex align-items-center gap-2">
                        <%= htg_logo_svg(size: 16) %>
                        <span class="fw-bold" style="color: var(--haiti-charcoal); font-size: 12px;">HTG</span>
                        <span class="ms-auto" style="font-size: 10px; color: var(--haiti-olive); font-weight: 600;"><%= number_with_delimiter(cv_personal_htg) %></span>
                      </div>
                    </button>
                    <button type="button" onclick="selectCvOption('to','usd','personal')" class="cv-dd-opt btn w-100 text-start border-0 px-2 py-1" data-key="usd-personal" style="background:transparent;">
                      <div class="d-flex align-items-center gap-2">
                        <%= usd_logo(size: 16) %>
                        <span class="fw-bold" style="color: var(--haiti-charcoal); font-size: 12px;">USD</span>
                        <span class="ms-auto" style="font-size: 10px; color: var(--haiti-olive); font-weight: 600;"><%= cv_personal_usd %></span>
                      </div>
                    </button>
                    <div style="height:1px; background: rgba(46,46,56,0.08); margin: 4px 0;"></div>
                    <%# Biznis group %>
                    <div class="px-2 pt-1 pb-1" style="font-size: 9px; color: var(--haiti-olive); font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase;">
                      <i class="ri-store-2-line me-1"></i><%= @business&.name || "Biznis" %>
                    </div>
                    <button type="button" onclick="selectCvOption('to','htg','biznis')" class="cv-dd-opt btn w-100 text-start border-0 px-2 py-1" data-key="htg-biznis" style="background:transparent;">
                      <div class="d-flex align-items-center gap-2">
                        <%= htg_logo_svg(size: 16) %>
                        <span class="fw-bold" style="color: var(--haiti-charcoal); font-size: 12px;">HTG</span>
                        <span class="ms-auto" style="font-size: 10px; color: var(--haiti-olive); font-weight: 600;"><%= number_with_delimiter(cv_biz_htg) %></span>
                      </div>
                    </button>
                    <button type="button" onclick="selectCvOption('to','usd','biznis')" class="cv-dd-opt btn w-100 text-start border-0 px-2 py-1 mb-1" data-key="usd-biznis" style="background:transparent;">
                      <div class="d-flex align-items-center gap-2">
                        <%= usd_logo(size: 16) %>
                        <span class="fw-bold" style="color: var(--haiti-charcoal); font-size: 12px;">USD</span>
                        <span class="ms-auto" style="font-size: 10px; color: var(--haiti-olive); font-weight: 600;"><%= cv_biz_usd %></span>
                      </div>
                    </button>
                  </div>
                </div>
              </div>
              <style>
                .cv-dd-opt:hover { background: rgba(197,160,89,0.1) !important; }
                .cv-dd-opt.active { background: rgba(197,160,89,0.15) !important; }
              </style>

              <%# ══ AMOUNT ══ %>
              <div class="mb-3">
                <label class="form-label small fw-bold text-uppercase mb-1" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">
                  <i class="ri-money-dollar-circle-line me-1"></i>Montan
                </label>
                <div class="input-group rounded-3" style="overflow: hidden; border: 1.5px solid rgba(46,46,56,0.12);">
                  <span class="input-group-text border-0" style="background-color: var(--haiti-mint); color: var(--haiti-gold); padding: 12px 14px;"><i class="ri-money-dollar-circle-line"></i></span>
                  <input type="number" name="amount" id="convert-amount" class="form-control border-0 fw-bold shadow-none"
                         placeholder="0.00" min="0.00000001" step="any" required style="background-color: var(--haiti-mint); color: var(--haiti-charcoal); font-size: 18px; padding: 12px 14px;"
                         oninput="updateConvertPreview()">
                  <span class="input-group-text border-0 fw-bold" id="convert-currency-suffix"
                        style="background-color: var(--haiti-mint); color: var(--haiti-charcoal); font-size: 13px; padding: 12px 14px;"><%= currency_label("htg") %></span>
                </div>
              </div>

              <%# ══ RATE PREVIEW ══ %>
              <div class="p-2 rounded-3 mb-3 text-center" style="background: rgba(93,99,69,0.08);">
                <span class="small fw-bold" style="color: var(--haiti-olive); font-size: 11px;">
                  <i class="ri-exchange-line me-1"></i>1 USD = <span id="convert-rate"><%= (@sell_rate || 135.50).round(2) %></span> HTG
                </span>
                <div id="convert-preview-result" class="fw-black mt-1" style="color: var(--haiti-charcoal); font-size: 14px; display: none;"></div>
              </div>

              <%# ── Daily swap limit bar (USD→HTG) ── %>
              <div class="p-2 rounded-3 mb-2" style="background: rgba(197,160,89,0.08); font-size: 11px;">
                <div class="d-flex justify-content-between">
                  <span style="color: var(--haiti-olive);">
                    <i class="ri-timer-line me-1"></i>Limit jounalye (USD → Goud)
                  </span>
                  <span class="fw-bold" style="color: var(--haiti-charcoal);">
                    $ <%= @limit_service.daily_swap_remaining.to_f.round(2) %> rete
                  </span>
                </div>
                <div class="mt-1" style="height: 4px; background: rgba(93,99,69,0.12); border-radius: 2px;">
                  <% pct = @limit_service.limits[:daily_swap_usd].to_f > 0 ? (@limit_service.daily_swap_used.to_f / @limit_service.limits[:daily_swap_usd].to_f * 100) : 0 %>
                  <div style="width: <%= [pct, 100].min %>%; height: 100%; background: var(--haiti-gold); border-radius: 2px;"></div>
                </div>
              </div>

              <%# ── Unsupported pair notice ── %>
              <div id="cv-unsupported" class="p-2 rounded-3 mb-3 text-center" style="background: rgba(197,160,89,0.1); display: none;">
                <span class="small fw-bold" style="color: var(--haiti-olive); font-size: 11px;">
                  <i class="ri-time-line me-1" style="color: var(--haiti-gold);"></i>Konvèsyon sa a ap vini byento
                </span>
              </div>

              <%# ── Daily limit chip ── %>
              <div id="convert-limit-chip" class="d-flex align-items-center justify-content-between gap-2 p-3 rounded-3 mb-3" style="background: rgba(197,160,89,0.1); border: 1.5px solid rgba(197,160,89,0.25); font-size: 13px; font-weight: 600;">
                <span style="color: var(--haiti-charcoal); line-height: 1.4;">
                  <i class="ri-time-fill me-1" style="color: var(--haiti-gold); font-size: 16px;"></i>
                  <span id="convert-limit-text">Limit jounalye: $250</span>
                </span>
                <% unless current_user.bonid_verified? %>
                  <%= link_to bonid_verification_path, class: "fw-black text-decoration-none flex-shrink-0", style: "background: var(--haiti-gold); color: var(--haiti-charcoal); font-size: 11px; padding: 4px 10px; border-radius: 99px; white-space: nowrap;" do %>
                    Verifye 2× <i class="ri-arrow-right-s-line"></i>
                  <% end %>
                <% end %>
              </div>

              <button type="button" id="cv-continue-btn" onclick="showConvertReview()" class="btn w-100 fw-black rounded-pill border-0 d-flex align-items-center justify-content-center gap-2"
                      style="background: var(--haiti-gold); color: var(--haiti-charcoal); font-family: 'Space Grotesk', sans-serif; font-size: 15px; padding: 14px 24px; letter-spacing: 0.3px;">
                <i class="ri-arrow-right-line" style="font-size: 18px;"></i>Kontinye
              </button>
            </div>

            <%# ── STEP 2: Review + PIN ── %>
            <div id="cv-step2" style="display: none;">
              <div class="rounded-3 p-3 mb-3" style="background: rgba(197,160,89,0.08);">
                <div class="small fw-bold mb-2" style="color: var(--haiti-charcoal);">
                  <i class="ri-file-list-3-line me-1" style="color: var(--haiti-gold);"></i>Rezime Konvèsyon
                </div>
                <div class="d-flex justify-content-between align-items-center small mb-1">
                  <span style="color: var(--haiti-olive);">Map Chanje Sa</span>
                  <span id="cv-review-from" class="fw-bold d-flex align-items-center gap-1" style="color: var(--haiti-charcoal);"></span>
                </div>
                <div class="d-flex justify-content-between align-items-center small mb-1">
                  <span style="color: var(--haiti-olive);">Pou Sa</span>
                  <span id="cv-review-to" class="fw-bold d-flex align-items-center gap-1" style="color: var(--haiti-charcoal);"></span>
                </div>
                <div class="d-flex justify-content-between align-items-center small mb-1">
                  <span style="color: var(--haiti-olive);">Montan</span>
                  <span id="cv-review-amount" class="fw-bold d-flex align-items-center gap-1" style="color: var(--haiti-charcoal);"></span>
                </div>
                <div class="d-flex justify-content-between align-items-center small mb-1">
                  <span style="color: var(--haiti-olive);">To</span>
                  <span id="cv-review-rate" class="fw-bold" style="color: var(--haiti-charcoal);"></span>
                </div>
                <div class="d-flex justify-content-between align-items-center small mb-1">
                  <span style="color: var(--haiti-olive);">Frè Sèvis (2%)</span>
                  <span id="cv-review-fee" class="fw-bold d-flex align-items-center gap-1" style="color: var(--haiti-charcoal);"></span>
                </div>
                <hr class="my-2" style="border-color: var(--haiti-olive); opacity: 0.15;">
                <div class="d-flex justify-content-between align-items-center small">
                  <span class="fw-bold" style="color: var(--haiti-charcoal);">Ou pral resevwa</span>
                  <span id="cv-review-receive" class="fw-black d-flex align-items-center gap-1" style="color: #22c55e;"></span>
                </div>
              </div>

              <div class="input-group mb-3" style="border: 1.5px solid rgba(46,46,56,0.12); border-radius: 12px; overflow: hidden;">
                <span class="input-group-text border-0" style="background-color: var(--haiti-mint); color: var(--haiti-gold);"><i class="ri-lock-password-line"></i></span>
                <input type="password" name="transfer_pin" id="cv-pin" class="form-control border-0 fw-bold shadow-none p-3"
                       placeholder="PIN" maxlength="4" pattern="\d{4}" required inputmode="numeric"
                       style="background-color: var(--haiti-mint); color: var(--haiti-charcoal); letter-spacing: 8px; text-align: center;">
              </div>

              <div class="d-flex gap-2">
                <button type="button" onclick="backToConvertStep1()" class="btn flex-shrink-0 fw-bold rounded-pill border-0 px-3"
                        style="background: rgba(93,99,69,0.1); color: var(--haiti-charcoal); font-size: 14px; padding: 14px 16px;">
                  <i class="ri-arrow-left-line"></i>
                </button>
                <button type="submit" id="convert-btn" class="btn flex-grow-1 fw-black rounded-pill border-0 d-flex align-items-center justify-content-center gap-2"
                        style="background: var(--haiti-gold); color: var(--haiti-charcoal); font-family: 'Space Grotesk', sans-serif; font-size: 15px; padding: 14px 24px; letter-spacing: 0.3px;">
                  <i class="ri-swap-line" style="font-size: 18px;"></i>Konvèti Kounye a
                </button>
              </div>
            </div>

          <% end %>
        <% else %>
          <div class="text-center py-3" style="color: var(--haiti-olive);">
            <i class="ri-lock-line ri-2x mb-2 d-block" style="color: var(--haiti-gold);"></i>
            <div class="small">Ou dwe kreye yon PIN anvan ou ka konvèti lajan.</div>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── Step Loader for Deposit ── %>
    <%= render "shared/step_loader", id: "deposit-loader", steps: [
      "Kounya nou prale nan MonCash…",
      "N'ap checke si gen trafik…",
      "Ah nou bon, nou prèske rive…",
      "Nou rive anbyen sou MonCash!"
    ] %>

    <%# ── Step Loader for Convert ── %>
    <%= render "shared/step_loader", id: "convert-loader", steps: [
      "N'ap bloke to a pou ou...",
      "N'ap verifye balans ou...",
      "N'ap konvèti lajan an...",
      "Konvèsyon reyisi!"
    ] %>

    <div id="section-portfolio"><%# ── portfolio section (inside main card) ── %>

    <%# ══════════════════════════════════════ %>
    <%# ── INCOMING PAYMENT REQUESTS     ──  %>
    <%# ══════════════════════════════════════ %>
    <% if @incoming_requests.any? %>
      <div id="section-incoming" class="mb-3">
        <div class="p-3 rounded-4" style="background: rgba(197,160,89,0.12); border: 1.5px solid rgba(197,160,89,0.55);">
          <div class="d-flex align-items-center gap-2 mb-2">
            <i class="ri-mail-download-line" style="color: var(--haiti-gold); font-size: 18px;"></i>
            <span class="fw-black" style="color: var(--haiti-charcoal); font-size: 14px;">
              Demann Peman
              <span class="badge rounded-pill ms-1" style="background: var(--haiti-charcoal); color: var(--haiti-gold); font-size: 10px;">
                <%= @incoming_requests.size %>
              </span>
            </span>
          </div>

          <% @incoming_requests.each do |req| %>
            <%
              # Urgency from countdown (uses model helper if available)
              hours_left = req.respond_to?(:hours_until_expiry) ? req.hours_until_expiry.to_f : nil
              urgency_color =
                if    hours_left.nil?     then "var(--haiti-olive)"
                elsif hours_left < 1      then "#991b1b"   # red
                elsif hours_left < 12     then "var(--haiti-gold)"
                else                           "var(--haiti-olive)"
                end
              amount_str =
                if req.htg?
                  "HTG #{number_with_precision(req.amount, precision: 0)}"
                else
                  "#{number_with_precision(req.amount, precision: 2)} #{req.asset == 'usd' ? 'USD' : req.asset.upcase}"
                end
              initial = req.user.display_name.to_s.strip.chars.first&.upcase || "?"
            %>
            <div class="d-flex align-items-center gap-3 p-3 rounded-3 mb-2" style="background: #ffffff; border: 1px solid rgba(46,46,56,0.06);">
              <%# Avatar circle (first letter of payer) %>
              <div class="d-flex align-items-center justify-content-center flex-shrink-0 fw-black"
                   style="width: 38px; height: 38px; border-radius: 50%; background: var(--haiti-charcoal); color: var(--haiti-gold); font-size: 14px;">
                <%= initial %>
              </div>

              <%# Body — name, note, countdown — wraps to next line on overflow %>
              <%= link_to public_payment_request_path(req.token), class: "flex-grow-1 text-decoration-none", style: "min-width: 0;" do %>
                <div class="fw-bold text-truncate" style="color: var(--haiti-charcoal); font-size: 13px;">
                  $<%= req.user.cashtag.presence || req.user.display_name %>
                  <span style="color: var(--haiti-olive); font-weight: 500;">mande ou</span>
                </div>
                <div class="d-flex align-items-center gap-1 text-truncate" style="font-size: 11px;">
                  <% if req.note.present? %>
                    <span style="color: var(--haiti-olive);"><%= req.note %></span>
                    <span style="color: rgba(46,46,56,0.25);">·</span>
                  <% end %>
                  <span class="fw-bold" style="color: <%= urgency_color %>;">
                    <i class="ri-time-line me-1"></i><%= req.expiry_countdown_label %>
                  </span>
                </div>
              <% end %>

              <%# Right — amount + Peye pill %>
              <div class="d-flex flex-column align-items-end gap-1 flex-shrink-0">
                <div class="fw-black" style="color: var(--haiti-charcoal); font-size: 14px; line-height: 1;">
                  <%= amount_str %>
                </div>
                <%= link_to public_payment_request_path(req.token),
                      class: "btn btn-sm fw-bold rounded-pill border-0 d-inline-flex align-items-center gap-1",
                      style: "background: var(--haiti-gold); color: var(--haiti-charcoal); font-size: 11px; padding: 4px 12px; line-height: 1.2;" do %>
                  Peye <i class="ri-arrow-right-s-line" style="font-size: 13px;"></i>
                <% end %>
              </div>

              <%# Dismiss (X) — neutral grey hover into red %>
              <%= button_to dismiss_payment_request_path(req.token),
                    method: :post,
                    class: "btn btn-sm p-0 border-0 bg-transparent flex-shrink-0",
                    style: "width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; color: rgba(46,46,56,0.35);",
                    title: "Kache",
                    data: { turbo_confirm: "Kache demann #{req.user.display_name}?" } do %>
                <i class="ri-close-line" style="font-size: 16px;"></i>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# ══════════════════════════════════════ %>
    <%# ── TAB SWITCHER                  ──  %>
    <%# ══════════════════════════════════════ %>
    <div id="section-tabs" class="d-flex gap-2 mt-4 mb-4" style="border-bottom: 1px solid rgba(93,99,69,0.12);">
      <button type="button" class="wallet-tab active" id="tab-btn-lajan" onclick="switchTab('lajan')">
        <i class="ri-wallet-3-line me-1"></i>Pèsonèl
      </button>
      <%# Biznis tab — BIZNIS BYENTO re-enable when ready to deploy %>
      <% if false # @business.present? %>
        <button type="button" class="wallet-tab" id="tab-btn-biznis" onclick="switchTab('biznis')">
          <i class="ri-store-2-line me-1"></i>Biznis
        </button>
      <% end %>
