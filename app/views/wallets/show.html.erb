// ── FLOAT TOP-UP MODAL              ──
// ══════════════════════════════════════
(function() {
  var form = document.getElementById('floatTopUpForm');
  if (!form) return;

  var modal = document.getElementById('floatTopUpModal');
  var btn = document.getElementById('floatTopUpSubmitBtn');
  var pinInput = document.getElementById('floatTopUpPin');
  var amountInput = document.getElementById('floatTopUpAmount');

  function checkTopUpReady() {
    var pinOk = pinInput && pinInput.value.length === 4;
    var amountOk = amountInput && parseFloat(amountInput.value) >= 100;
    btn.disabled = !(pinOk && amountOk);
  }

  if (pinInput) pinInput.addEventListener('input', checkTopUpReady);
  if (amountInput) amountInput.addEventListener('input', checkTopUpReady);

  if (modal) {
    modal.addEventListener('show.bs.modal', function() {
      document.getElementById('floatTopUpIdempotencyKey').value =
        'ftu-' + Date.now() + '-' + Math.random().toString(36).substr(2, 6);
      form.reset();
      document.getElementById('floatTopUpBtnText').style.display = '';
      document.getElementById('floatTopUpBtnSpinner').style.display = 'none';
      btn.disabled = true;
    });
  }

  form.addEventListener('submit', function(e) {
    // Validate PIN filled
    if (!pinInput || pinInput.value.length !== 4) {
      e.preventDefault();
      pinInput.focus();
      return;
    }

    btn.disabled = true;
    document.getElementById('floatTopUpBtnText').style.display = 'none';
    document.getElementById('floatTopUpBtnSpinner').style.display = '';

    // Show step loader
    if (window.ZellusLoader) {
      e.preventDefault();
      var bsModal = bootstrap.Modal.getInstance(modal);
      if (bsModal) bsModal.hide();
      ZellusLoader.start('floatTopUpLoader', form, { stepDelay: 1500 });
    }
  });
})();

