var WD_MONCASH_ICON = '<%= j moncash_logo_svg(size: 34) %>';
var WD_BANK_ICON = '<div class="d-flex align-items-center justify-content-center rounded-circle" style="width: 34px; height: 34px; min-width: 34px; background: rgba(255,255,255,0.12);"><i class="ri-bank-line" style="font-size: 17px; color: var(--haiti-gold);"></i></div>';
var WD_USD_ICON    = '<%= j usd_logo(size: 34) %>';

function selectWdDest(el) {
  var dest   = el.dataset.dest;   // 'moncash', 'bank', or 'usd'
  var value  = el.dataset.value;  // account number, 'custom', or 'external'
  var label  = el.dataset.label;  // 'MonCash', bank provider name, or 'USD (Base)'
  var detail = el.dataset.detail; // masked number or 'Adrès ekstèn'
  var holder = el.dataset.holder || '';
  var bankProvider = el.dataset.bankProvider || '';

  currentWdMethod = dest;

  // Update checkmarks
  document.querySelectorAll('#wd-dest-menu .wd-dest-check').forEach(function(c) { c.style.visibility = 'hidden'; });
  var check = el.querySelector('.wd-dest-check');
  if (check) check.style.visibility = 'visible';
  document.querySelectorAll('#wd-dest-menu .wd-src-option').forEach(function(o) { o.classList.remove('selected'); });
  el.classList.add('selected');

  // Update toggle display
  var destIcon = dest === 'moncash' ? WD_MONCASH_ICON : (dest === 'usd' ? WD_USD_ICON : WD_BANK_ICON);
  document.getElementById('wd-dest-icon').innerHTML = destIcon;
  document.getElementById('wd-dest-name').textContent = label;
  document.getElementById('wd-dest-detail').textContent = detail;

  // Show/hide form sections
  document.getElementById('wd-section-lajan').style.display  = dest === 'moncash' ? '' : 'none';
  document.getElementById('wd-section-bank').style.display   = dest === 'bank' ? '' : 'none';
  document.getElementById('wd-section-kripto').style.display  = dest === 'usd' ? '' : 'none';

  // MonCash: set hidden phone from the selected saved method
  if (dest === 'moncash') {
    document.getElementById('wd-dest-moncash-val').value = value;
  }

  // Bank: set hidden account + holder + provider from the selected saved method
  if (dest === 'bank') {
    var bankHidden     = document.getElementById('wd-dest-bank-val');
    var holderHidden   = document.getElementById('wd-dest-bank-holder');
    var providerHidden = document.getElementById('wd-dest-bank-provider');
    bankHidden.value = value;
    holderHidden.value = holder;
    if (providerHidden && bankProvider) providerHidden.value = bankProvider;
  }

  // Close dropdown
  document.getElementById('wd-dest-toggle').classList.remove('open');
  document.getElementById('wd-dest-menu').classList.remove('open');
  document.getElementById('wd-dest-chevron').style.transform = '';
}

