<script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js"></script>
<script>
var activePanel = null;
var depositQrGenerated = false;
var activeWallet = 'personal'; // 'personal' or 'biznis'

// ══════════════════════════════════════
// ── WALLET CARD TOGGLE (Apple Wallet) ──
// ══════════════════════════════════════
function toggleWalletCard(which) {
  var heroCard = document.getElementById('section-hero-card');
  var personalStrip = document.getElementById('personal-card-strip');
  var biznisStrip = document.getElementById('section-biznis-strip');
  var biznisFull = document.getElementById('section-biznis-full');

  if (!personalStrip || !biznisStrip || !biznisFull) return;

  if (which === 'biznis' && activeWallet !== 'biznis') {
    // Bring business to front, personal strip peeks below
    heroCard.style.display = 'none';
    biznisStrip.style.display = 'none';
    biznisFull.style.display = 'block';
    personalStrip.style.display = 'block';
    activeWallet = 'biznis';
    switchTab('biznis');
  } else if (which === 'personal' && activeWallet !== 'personal') {
    // Bring personal to front, business strip peeks below
    heroCard.style.display = 'block';
    personalStrip.style.display = 'none';
    biznisStrip.style.display = 'block';
    biznisFull.style.display = 'none';
    activeWallet = 'personal';
    switchTab('lajan');
  }
}

// ══════════════════════════════════════
// ── HERO MORE MENU                  ──
// ══════════════════════════════════════
function toggleHeroMenu() {
  var dd = document.getElementById('hero-menu-dropdown');
  dd.style.display = dd.style.display === 'none' ? 'block' : 'none';
}
function closeHeroMenu() {
  document.getElementById('hero-menu-dropdown').style.display = 'none';
}
// Close when tapping outside
document.addEventListener('click', function(e) {
  var menu = document.getElementById('hero-menu-dropdown');
  var btn  = document.getElementById('hero-menu-btn');
  if (menu && btn && !menu.contains(e.target) && !btn.contains(e.target)) {
    menu.style.display = 'none';
  }
});

// ══════════════════════════════════════
// ── ROBINHOOD LIVE TICKER           ──
// ══════════════════════════════════════
var RATES = {
  usd_htg:  <%= usd_htg.to_f.round(4) %>,
  btc_usd:   <%= btc_usd.to_f.round(4) %>,
  eth_usd:   <%= eth_usd.to_f.round(4) %>,
  tslax_usd: <%= (@stock_usd_rates["tslax"]  || 0).to_f.round(4) %>,
  nvdax_usd: <%= (@stock_usd_rates["nvdax"]  || 0).to_f.round(4) %>,
  aaplx_usd: <%= (@stock_usd_rates["aaplx"]  || 0).to_f.round(4) %>,
  coinx_usd: <%= (@stock_usd_rates["coinx"]  || 0).to_f.round(4) %>,
  googlx_usd: <%= (@stock_usd_rates["googlx"] || 0).to_f.round(4) %>
};
var BALS = {
  htg:  <%= htg_bal.to_f %>,
  usd: <%= usd_bal.to_f %>,
  wbtc: <%= wbtc_bal.to_f %>,
  eth:  <%= eth_bal.to_f %>
};
var BIZ_BALS = {
  htg: <%= @business ? @business.total_received.to_f : 0 %>,
  usd: <%= @business ? @business.usdc_balance.to_f : 0 %>
};

// ── Live limits (fetched from /wallet/limits.json) ──
function fmtNum(n, decimals) {
  return Number(n).toLocaleString('en-US', { minimumFractionDigits: decimals, maximumFractionDigits: decimals });
}

function colorChip(elId, used, max) {
  var chip = document.getElementById(elId);
  if (!chip) return;
  var pct = max > 0 ? (used / max) : 0;
  if (pct >= 0.9) {
    // Critical: red background
    chip.style.background = 'rgba(153,27,27,0.08)';
    chip.style.borderColor = 'rgba(153,27,27,0.3)';
  } else if (pct >= 0.7) {
    // Warning: stronger gold background
    chip.style.background = 'rgba(197,160,89,0.18)';
    chip.style.borderColor = 'rgba(197,160,89,0.45)';
  } else {
    // Safe: default gold tint
    chip.style.background = 'rgba(197,160,89,0.1)';
    chip.style.borderColor = 'rgba(197,160,89,0.25)';
  }
}

// Hide BonID upsell when chip is showing platform-pause message
// (verification doesn't help with platform liquidity issues).
function toggleUpsell(chipId, hide) {
  var chip = document.getElementById(chipId);
  if (!chip) return;
  var upsell = chip.querySelector('a');
  if (upsell) upsell.style.display = hide ? 'none' : '';
}

function refreshLimits() {
  fetch('/wallet/limits.json', { credentials: 'same-origin' })
    .then(function(r) { return r.json(); })
    .then(function(d) {
      // Deposit (Buy USD): show min/max + remaining USD
      var dt = document.getElementById('deposit-limit-text');
      if (dt) {
        if (d.buy.platform_paused && d.buy.platform_headroom_usd > 0) {
          dt.textContent = 'Maksimòm pou kounye a: $' + fmtNum(d.buy.platform_headroom_usd, 0);
        } else if (d.buy.platform_paused) {
          dt.textContent = 'Sèvis pa disponib pou kounye a';
        } else {
          dt.textContent = 'Min: ' + fmtNum(d.buy.min_htg, 0) + ' · Max: ' + fmtNum(d.buy.max_htg, 0) + ' HTG · ' +
                           '$' + fmtNum(d.buy.daily_remaining_usd, 0) + ' rete jodi a';
        }
        colorChip('deposit-limit-chip', d.buy.daily_used_usd, d.buy.daily_max_usd);
        toggleUpsell('deposit-limit-chip', d.buy.platform_paused);
      }

      // Withdraw HTG: show remaining HTG today
      var wt = document.getElementById('withdraw-limit-text');
      if (wt) {
        if (d.withdraw.platform_paused && d.withdraw.platform_headroom_htg > 0) {
          wt.textContent = 'Maksimòm pou kounye a: ' + fmtNum(d.withdraw.platform_headroom_htg, 0) + ' HTG';
        } else if (d.withdraw.platform_paused) {
          wt.textContent = 'Sèvis pa disponib pou kounye a';
        } else {
          wt.textContent = 'Ou ka retire jiska ' + fmtNum(d.withdraw.daily_remaining_htg, 0) + ' HTG jodi a';
        }
        colorChip('withdraw-limit-chip', d.withdraw.daily_used_htg, d.withdraw.daily_max_htg);
        toggleUpsell('withdraw-limit-chip', d.withdraw.platform_paused);
      }

      // Convert: show remaining USD or HTG depending on direction
      var ct = document.getElementById('convert-limit-text');
      if (ct) {
        var fromAsset = (document.getElementById('convert-from-asset') || {}).value || 'htg';
        var paused = false;
        if (fromAsset === 'htg') {
          // HTG → USD: show USD remaining
          if (d.convert.usdc_paused && d.convert.platform_headroom_usd > 0) {
            ct.textContent = 'Maksimòm pou kounye a: $' + fmtNum(d.convert.platform_headroom_usd, 0);
            paused = true;
          } else if (d.convert.usdc_paused) {
            ct.textContent = 'Sèvis pa disponib pou kounye a';
            paused = true;
          } else {
            ct.textContent = 'Limit jounalye: $' + fmtNum(d.convert.daily_max_usd, 0) +
                             ' · $' + fmtNum(d.convert.daily_remaining_usd, 0) + ' rete';
          }
          colorChip('convert-limit-chip', d.convert.daily_used_usd, d.convert.daily_max_usd);
        } else {
          // USD → HTG: show HTG remaining
          if (d.convert.htg_paused && d.convert.platform_headroom_htg > 0) {
            ct.textContent = 'Maksimòm pou kounye a: ' + fmtNum(d.convert.platform_headroom_htg, 0) + ' HTG';
            paused = true;
          } else if (d.convert.htg_paused) {
            ct.textContent = 'Sèvis pa disponib pou kounye a';
            paused = true;
          } else {
            ct.textContent = 'Limit jounalye: ' + fmtNum(d.convert.daily_max_htg, 0) + ' HTG · ' +
                             fmtNum(d.convert.daily_remaining_htg, 0) + ' rete';
          }
          colorChip('convert-limit-chip', d.convert.daily_used_htg, d.convert.daily_max_htg);
        }
        toggleUpsell('convert-limit-chip', paused);
      }
    })
    .catch(function(e) { console.warn('[limits] fetch failed', e); });
}

