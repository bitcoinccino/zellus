// USD rates for all assets (server-rendered)
var cvUsdRates = {
  htg:  <%= (@sell_rate || 135.50).to_f.round(4) %>,   // HTG per USD (sell rate)
  usd: 1.0,
  eth:  <%= (@eth_usd_rate || 3500.0).to_f.round(4) %>,  // USD per ETH
  wbtc: <%= (@btc_usd_rate || 95000.0).to_f.round(4) %>  // USD per wBTC
