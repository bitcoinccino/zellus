<script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js"></script>
<script>
var activePanel = null;
var depositQrGenerated = false;
var activeWallet = 'personal'; // 'personal' or 'biznis'

// ══════════════════════════════════════
// ── WALLET CARD TOGGLE (Apple Wallet) ──
// ══════════════════════════════════════
function toggleWalletCard(which) {
  var heroCard = document.getElementById('section-hero-card');
  var personalStrip = document.getElementById('personal-card-strip');
  var biznisStrip = document.getElementById('section-biznis-strip');
  var biznisFull = document.getElementById('section-biznis-full');

  if (!personalStrip || !biznisStrip || !biznisFull) return;

  if (which === 'biznis' && activeWallet !== 'biznis') {
