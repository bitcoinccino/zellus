// ══════════════════════════════════════
// ── Withdraw Review (Step 1 → 2)   ──
// ══════════════════════════════════════
function showWithdrawReview(section) {
  if (section === 'lajan') {
    // Validate amount
    var amountEl = document.getElementById('withdraw-amount');
    var amount = parseFloat(amountEl.value);
    if (!amount || amount < 100 || amount > 50000) {
      amountEl.focus();
      amountEl.reportValidity();
      return;
    }

    // Validate phone
    var phoneEl = document.getElementById('wd-lajan-phone');
    var phoneVal = phoneEl.value.trim();
    if (!phoneVal) {
      phoneEl.focus();
      if (phoneEl.reportValidity) phoneEl.reportValidity();
      return;
    }

    // Populate review summary
    document.getElementById('wd-review-amount-lajan').textContent = parseInt(amount).toLocaleString('fr') + ' HTG';

    // Masked phone
    var maskedPhone = phoneVal;
    if (phoneEl.tagName === 'SELECT') {
      var opt = phoneEl.options[phoneEl.selectedIndex];
      maskedPhone = opt.getAttribute('data-masked') || phoneVal;
    } else if (phoneVal.length === 11) {
      maskedPhone = '(509) •••• ' + phoneVal.slice(-4);
    }
    document.getElementById('wd-review-phone-lajan').textContent = maskedPhone;

    // Withdraw type + fee (flat 2%)
    document.getElementById('wd-review-type-lajan').textContent = 'Retrè MonCash';

    var feeRow = document.getElementById('wd-review-fee-row');
    var fee = Math.round(amount * 0.02);
    document.getElementById('wd-review-fee-lajan').textContent = fee + ' HTG';
    feeRow.style.display = 'flex';
    document.getElementById('wd-review-total-lajan').textContent = Math.round(amount + fee).toLocaleString('fr') + ' HTG';

    // Toggle steps
    document.getElementById('wd-step1-lajan').style.display = 'none';
    document.getElementById('wd-step2-lajan').style.display = '';

    // Focus PIN
    setTimeout(function() {
      var pin = document.getElementById('wd-pin-lajan');
      if (pin) pin.focus();
    }, 200);

  } else if (section === 'kripto') {
    // Validate amount
    var cryptoAmountEl = document.getElementById('wd-crypto-amount');
    var cryptoAmount = parseFloat(cryptoAmountEl.value);
    if (!cryptoAmount || cryptoAmount <= 0) {
      cryptoAmountEl.focus();
      cryptoAmountEl.reportValidity();
      return;
    }

    // Validate address
    var addrEl = document.getElementById('wd-crypto-address');
    var addr = addrEl.value.trim();
    if (!addr.match(/^0x[0-9a-fA-F]{40}$/)) {
      addrEl.focus();
      addrEl.reportValidity();
      return;
    }

    // Populate review
    var label = cryptoWithdrawLabels[currentCryptoWithdraw] || 'USD';
    document.getElementById('wd-review-asset-kripto').textContent = label;
    document.getElementById('wd-review-amount-kripto').textContent = cryptoAmount + ' ' + label;
    document.getElementById('wd-review-address-kripto').textContent = addr.slice(0, 6) + '••••' + addr.slice(-4);

    // Toggle steps
    document.getElementById('wd-step1-kripto').style.display = 'none';
    document.getElementById('wd-step2-kripto').style.display = '';

    // Focus PIN
    setTimeout(function() {
      var pin = document.getElementById('wd-pin-kripto');
      if (pin) pin.focus();
    }, 200);

  } else if (section === 'stok') {
    // Validate amount
    var stockAmountEl = document.getElementById('wd-stock-amount');
    var stockAmount = parseFloat(stockAmountEl.value);
    if (!stockAmount || stockAmount <= 0) {
      stockAmountEl.focus();
      stockAmountEl.reportValidity();
      return;
    }

    // Validate address
    var stockAddrEl = document.getElementById('wd-stock-address');
    var stockAddr = stockAddrEl.value.trim();
    if (!stockAddr.match(/^0x[0-9a-fA-F]{40}$/)) {
      stockAddrEl.focus();
      stockAddrEl.reportValidity();
      return;
    }

    // Populate review
    var stockLabel = stockWithdrawLabels[currentStockWithdraw] || currentStockWithdraw.toUpperCase();
    document.getElementById('wd-review-asset-stok').textContent = stockLabel;
    document.getElementById('wd-review-amount-stok').textContent = stockAmount + ' ' + stockLabel;
    document.getElementById('wd-review-address-stok').textContent = stockAddr.slice(0, 6) + '••••' + stockAddr.slice(-4);

    // Toggle steps
    document.getElementById('wd-step1-stok').style.display = 'none';
    document.getElementById('wd-step2-stok').style.display = '';

    // Focus PIN
    setTimeout(function() {
      var pin = document.getElementById('wd-pin-stok');
      if (pin) pin.focus();
    }, 200);
  }
}

