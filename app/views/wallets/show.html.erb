function updateFeePreview() {
  var amount = parseFloat(document.getElementById('withdraw-amount').value) || 0;
  var feeLabel = document.getElementById('fee-label');
  var detailRow = document.getElementById('fee-preview-detail');
  var receiveSpan = document.getElementById('fee-preview-receive');
  if (amount > 0) {
    var fee = Math.round(amount * 0.02);
    var receive = Math.round(amount) - fee;
    feeLabel.textContent = '- ' + fee.toLocaleString('fr') + ' HTG';
    feeLabel.style.color = '#991b1b';
    if (detailRow) detailRow.style.display = '';
    if (receiveSpan) receiveSpan.textContent = receive.toLocaleString('fr') + ' HTG';
  } else {
    feeLabel.textContent = '—';
    feeLabel.style.color = 'var(--haiti-olive)';
    if (detailRow) detailRow.style.display = 'none';
  }
}

function updateBankFeePreview() {
  var amount = parseFloat(document.getElementById('withdraw-bank-amount').value) || 0;
  var feeLabel = document.getElementById('bank-fee-label');
  if (amount > 0) {
    var fee = Math.max(Math.round(amount * 0.01), 25);
    feeLabel.textContent = fee + ' HTG frè';
  } else {
    feeLabel.textContent = '1% frè';
  }
}

