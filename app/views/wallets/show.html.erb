    personalStrip.style.borderBottomRightRadius = '0';
    biznisStrip.style.display = 'none';
    biznisFull.style.display = 'block';
    activeWallet = 'biznis';
  } else if (which === 'personal' && activeWallet !== 'personal') {
    // Bring personal to front
    heroCard.style.display = 'block';
    personalStrip.style.display = 'none';
    biznisStrip.style.display = 'block';
    biznisFull.style.display = 'none';
    activeWallet = 'personal';
  }
}

// ══════════════════════════════════════
// ── HERO MORE MENU                  ──
// ══════════════════════════════════════
function toggleHeroMenu() {
  var dd = document.getElementById('hero-menu-dropdown');
  dd.style.display = dd.style.display === 'none' ? 'block' : 'none';
}
function closeHeroMenu() {
  document.getElementById('hero-menu-dropdown').style.display = 'none';
}
// Close when tapping outside
document.addEventListener('click', function(e) {
  var menu = document.getElementById('hero-menu-dropdown');
  var btn  = document.getElementById('hero-menu-btn');
  if (menu && btn && !menu.contains(e.target) && !btn.contains(e.target)) {
    menu.style.display = 'none';
  }
});

// ══════════════════════════════════════
// ── ROBINHOOD LIVE TICKER           ──
// ══════════════════════════════════════
var RATES = {
  usdc_htg:  <%= usdc_htg.to_f.round(4) %>,
  btc_usd:   <%= btc_usd.to_f.round(4) %>,
  eth_usd:   <%= eth_usd.to_f.round(4) %>,
  tslax_usd: <%= (@stock_usd_rates["tslax"]  || 0).to_f.round(4) %>,
  nvdax_usd: <%= (@stock_usd_rates["nvdax"]  || 0).to_f.round(4) %>,
  aaplx_usd: <%= (@stock_usd_rates["aaplx"]  || 0).to_f.round(4) %>,
  coinx_usd: <%= (@stock_usd_rates["coinx"]  || 0).to_f.round(4) %>,
  googlx_usd: <%= (@stock_usd_rates["googlx"] || 0).to_f.round(4) %>
};
var BALS = {
  htg:  <%= htg_bal.to_f %>,
  usdc: <%= usdc_bal.to_f %>,
  wbtc: <%= wbtc_bal.to_f %>,
  eth:  <%= eth_bal.to_f %>
};

function microTick() {
  // Tick all rates — cents only, smooth counting
  tickRate('usdc');
  tickRate('btc');
  tickRate('eth');
  tickRate('tslax');
  tickRate('nvdax');
  tickRate('aaplx');
  tickRate('coinx');
  tickRate('googlx');

  // Asset card equivalents
  var htgUsd  = BALS.htg / RATES.usdc_htg;
  var usdcHtg = BALS.usdc * RATES.usdc_htg;
  var wbtcUsd = BALS.wbtc * RATES.btc_usd;
  var ethUsd  = BALS.eth  * RATES.eth_usd;

  tickDecimalEl('asset-htg-usd',  htgUsd);
  tickDecimalEl('asset-usdc-htg', usdcHtg);
  tickDecimalEl('asset-wbtc-usd', wbtcUsd);
  tickDecimalEl('asset-eth-usd',  ethUsd);

  // Hero decimals
  var totalHtg = BALS.htg + usdcHtg + (BALS.wbtc * RATES.btc_usd * RATES.usdc_htg) + (BALS.eth * RATES.eth_usd * RATES.usdc_htg);
  var totalUsd = BALS.usdc + (BALS.wbtc * RATES.btc_usd) + (BALS.eth * RATES.eth_usd) + (BALS.htg / RATES.usdc_htg);

  tickHeroDecimals('hero-htg-dec', totalHtg);
  tickHeroDecimals('hero-usd-dec', totalUsd);
}

function tickRate(key) {
  var decEl   = document.getElementById('rate-' + key + '-dec');
  var arrowEl = document.getElementById('rate-' + key + '-arrow');
  if (!decEl) return;

  var rateMap = {
    usdc: 'usdc_htg', btc: 'btc_usd', eth: 'eth_usd',
    tslax: 'tslax_usd', nvdax: 'nvdax_usd', aaplx: 'aaplx_usd',
    coinx: 'coinx_usd', googlx: 'googlx_usd'
  };

  var oldDec = parseInt(decEl.textContent);
  // Subtle jitter: ±1 cent only
  var centDelta = (Math.random() < 0.5 ? -1 : 1);
  var targetDec = Math.max(0, Math.min(99, oldDec + centDelta));
  var up = targetDec > oldDec;

  // Show arrow briefly
  if (arrowEl) {
    arrowEl.style.opacity = '1';
    arrowEl.className = 'tick-arrow ' + (up ? 'up' : 'down');
    arrowEl.innerHTML = up ? '&#9650;' : '&#9660;';
    setTimeout(function() { arrowEl.style.opacity = '0'; }, 3000);
  }

  // Single step update — just 1 cent, no counting animation
  decEl.textContent = ('0' + targetDec).slice(-2);
  decEl.className = 'tick-decimals ' + (up ? 'tick-up' : 'tick-down');
  setTimeout(function() { decEl.className = 'tick-decimals'; }, 1200);

  // Update RATES for sparkline accuracy (cent-only jitter)
  if (rateMap[key]) {
    var whole = Math.floor(RATES[rateMap[key]]);
    RATES[rateMap[key]] = whole + targetDec / 100;
  }
}

// ══════════════════════════════════════
// ── SPARKLINE ENGINE               ──
// ══════════════════════════════════════
var SPARK_W = 60, SPARK_H = 24, SPARK_MAX = 30;
var sparkData = {};
var sparkKeys = ['usdc','btc','eth','tslax','nvdax','aaplx','coinx','googlx'];
var sparkRateKeys = {
  usdc: 'usdc_htg', btc: 'btc_usd', eth: 'eth_usd',
  tslax: 'tslax_usd', nvdax: 'nvdax_usd', aaplx: 'aaplx_usd',
  coinx: 'coinx_usd', googlx: 'googlx_usd'
};

sparkKeys.forEach(function(k) {
  var base = RATES[sparkRateKeys[k]];
  var pts = [];
  for (var i = 0; i < 15; i++) {
    pts.push(base * (1 + (Math.random() - 0.5) * 0.004));
  }
  sparkData[k] = pts;
});

function buildSparkPath(key) {
  var pts = sparkData[key];
  if (!pts || pts.length < 2) return;
  var lineEl = document.getElementById('spark-' + key + '-line');
  var areaEl = document.getElementById('spark-' + key + '-area');
  if (!lineEl) return;

  var min = Math.min.apply(null, pts);
  var max = Math.max.apply(null, pts);
  var range = max - min || 1;
  var stepX = SPARK_W / (pts.length - 1);

  var lineParts = [];
  var areaParts = ['M0,' + SPARK_H];
  for (var i = 0; i < pts.length; i++) {
    var x = (i * stepX).toFixed(1);
    var y = (SPARK_H - ((pts[i] - min) / range) * (SPARK_H - 2) - 1).toFixed(1);
    lineParts.push((i === 0 ? 'M' : 'L') + x + ',' + y);
    areaParts.push('L' + x + ',' + y);
  }
  areaParts.push('L' + SPARK_W + ',' + SPARK_H + 'Z');

  lineEl.setAttribute('d', lineParts.join(''));
  areaEl.setAttribute('d', areaParts.join(''));
}

function sparkTick() {
  sparkKeys.forEach(function(k) {
    var val = RATES[sparkRateKeys[k]];
    sparkData[k].push(val);
    if (sparkData[k].length > SPARK_MAX) sparkData[k].shift();
    buildSparkPath(k);
  });
}

sparkKeys.forEach(function(k) { buildSparkPath(k); });

function tickHeroDecimals(elId, baseVal) {
  var el = document.getElementById(elId);
  if (!el) return;
  var oldDec = parseInt(el.textContent);
  // Subtle jitter: ±1 cent only
  var jitter = (Math.random() < 0.5 ? -1 : 1);
  var newDec = Math.max(0, Math.min(99, oldDec + jitter));
  el.textContent = ('0' + newDec).slice(-2);
  var up = newDec > oldDec;
  el.className = 'tick-decimals ' + (up ? 'tick-up' : 'tick-down');
  setTimeout(function() { el.className = 'tick-decimals'; }, 1200);
}

function tickDecimalEl(elId, val) {
  var el = document.getElementById(elId);
  if (!el) return;
  el.textContent = val.toLocaleString('en', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

// Tick every 8 seconds (slow, subtle movement)
setInterval(function() { microTick(); sparkTick(); }, 8000);
setTimeout(function() { microTick(); sparkTick(); }, 5000);

// ══════════════════════════════════════
// ── TAB SWITCHING                   ──
// ══════════════════════════════════════
function switchTab(tab) {
  var sections = {
    lajan:    document.getElementById('section-lajan'),
    biznis:   document.getElementById('section-biznis'),
    kripto:   document.getElementById('section-kripto'),
    stok:     document.getElementById('section-stok'),
    aktivite: document.getElementById('section-aktivite')
  };
  var buttons = {
    lajan:    document.getElementById('tab-btn-lajan'),
    biznis:   document.getElementById('tab-btn-biznis'),
    kripto:   document.getElementById('tab-btn-kripto'),
    stok:     document.getElementById('tab-btn-stok'),
    aktivite: document.getElementById('tab-btn-aktivite')
  };

  Object.keys(sections).forEach(function(key) {
    if (sections[key] && buttons[key]) {
      if (key === tab) {
        sections[key].style.display = '';
        buttons[key].classList.add('active');
      } else {
        sections[key].style.display = 'none';
        buttons[key].classList.remove('active');
      }
    }
  });
}

// ══════════════════════════════════════
// ── PANELS (Deposit / Withdraw)     ──
// ══════════════════════════════════════
(function() {
  var params = new URLSearchParams(window.location.search);
  var panel = params.get('action_panel');
  if (panel === 'deposit' || panel === 'withdraw' || panel === 'convert') {
    setTimeout(function() { togglePanel(panel); }, 100);
  }
})();

function togglePanel(panel) {
  var depositPanel  = document.getElementById('panel-deposit');
  var withdrawPanel = document.getElementById('panel-withdraw');
  var convertPanel  = document.getElementById('panel-convert');
  var sectionHero   = document.getElementById('section-hero');
  var sectionHeader = document.getElementById('section-header');
  var pinNotice     = document.getElementById('section-pin-notice');
  var sectionTabs   = document.getElementById('section-tabs');
  var sectionPortfolio = document.getElementById('section-portfolio');
  var sectionHeroCard  = document.getElementById('section-hero-card');

  if (activePanel === panel) {
    depositPanel.classList.remove('open');
    withdrawPanel.classList.remove('open');
    convertPanel.classList.remove('open');
    if (sectionHeroCard) sectionHeroCard.style.display = '';
    if (sectionPortfolio) sectionPortfolio.style.display = '';
    activePanel = null;
    return;
  }

  depositPanel.classList.remove('open');
  withdrawPanel.classList.remove('open');
  convertPanel.classList.remove('open');
  if (sectionHeroCard) sectionHeroCard.style.display = 'none';
  if (sectionPortfolio) sectionPortfolio.style.display = 'none';

  if (panel === 'deposit') depositPanel.classList.add('open');
  else if (panel === 'convert') convertPanel.classList.add('open');
  else withdrawPanel.classList.add('open');
  activePanel = panel;
}

function selectDepositMethod(method) {
  document.getElementById('deposit-cash-section').style.display = method === 'cash' ? 'block' : 'none';
  document.getElementById('deposit-kripto-section').style.display = method === 'kripto' ? 'block' : 'none';
  document.getElementById('dep-btn-cash').classList.toggle('selected', method === 'cash');
  document.getElementById('dep-btn-kripto').classList.toggle('selected', method === 'kripto');
  if (method === 'kripto') generateDepositQR();
}

function generateDepositQR() {
  if (depositQrGenerated) return;
  var container = document.getElementById('deposit-qr');
  if (!container) return;
  var addr = (document.getElementById('deposit-addr-text') || {}).textContent;
  if (!addr || !addr.trim()) return;
  addr = addr.trim();
  // Clear loading spinner
  container.innerHTML = '';
  // Generate QR with brand colors
  new QRCode(container, {
    text: addr,
    width: 148,
    height: 148,
    colorDark: '#2E2E38',
    colorLight: '#FFFFFF',
    correctLevel: QRCode.CorrectLevel.M
  });
  depositQrGenerated = true;
}

function toggleCustomPhone(sel) {
  var customInput = document.getElementById('wd-lajan-phone-custom');
  if (sel.value === 'custom') {
    customInput.style.display = '';
    customInput.required = true;
    customInput.name = 'moncash_phone';
    sel.name = '';
