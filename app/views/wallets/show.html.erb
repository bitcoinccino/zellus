           "aaplx"  => { name: "Apple",     logo: "aaplx_logo",  color: "#555555", accent: "rgba(85,85,85,0.08)" },
           "coinx"  => { name: "Coinbase",  logo: "coinx_logo",  color: "#0052FF", accent: "rgba(0,82,255,0.08)" },
