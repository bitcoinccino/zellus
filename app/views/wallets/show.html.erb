function updateCashinPreview() {
  var amountInput = document.getElementById('cashinAmount');
  var preview = document.getElementById('cashinPreview');
  if (!amountInput || !preview) return;

  var amount = parseFloat(amountInput.value) || 0;
  if (amount > 0) {
    var commission = Math.round(amount * 0.02);
    document.getElementById('cashinNet').textContent = 'G ' + amount.toLocaleString();
    document.getElementById('cashinCommission').textContent = '+G ' + commission.toLocaleString();
    preview.style.display = '';
  } else {
    preview.style.display = 'none';
  }
}

