    <%# ══════════════════════════════════════ %>
    <%# ── BIZNIS TAB — BIZNIS BYENTO re-enable when ready to deploy ── %>
    <%# ══════════════════════════════════════ %>
    <% if false # @business.present? %>
    <div id="section-biznis" class="mb-3" style="display: none;">
      <%# ── Section Header ── %>

      <%# Business HTG %>
      <div class="asset-card d-flex align-items-center justify-content-between rounded-3 mb-2" style="background: rgba(93,99,69,0.05); padding: 18px;">
        <div class="d-flex align-items-center gap-3">
          <%= htg_logo_svg(size: 36) %>
          <div>
            <div class="fw-bold" style="color: var(--haiti-charcoal); font-size: 14px;">HTG</div>
            <div style="color: var(--haiti-olive); font-size: 10px;">Goud Ayisyen</div>
          </div>
        </div>
        <div class="text-end">
          <div class="fw-black" style="color: var(--haiti-charcoal); font-size: 14px;">
            <%= number_with_precision(@business.total_received.to_f, precision: 2, delimiter: ",") %>
          </div>
          <div style="color: var(--haiti-olive); font-size: 10px; font-weight: 600;">
            ≈ $<%= number_with_precision(@business.total_received.to_f / usd_htg, precision: 2, delimiter: ",") %> USD
          </div>
        </div>
      </div>

      <%# Business USD %>
      <div class="asset-card d-flex align-items-center justify-content-between rounded-3 mb-3" style="background: rgba(93,99,69,0.05); padding: 18px;">
        <div class="d-flex align-items-center gap-3">
          <%= usd_logo(size: 36) %>
          <div>
            <div class="fw-bold" style="color: var(--haiti-charcoal); font-size: 14px;">USD</div>
            <div style="color: var(--haiti-olive); font-size: 10px;">Dola Ameriken</div>
          </div>
        </div>
        <div class="text-end">
          <div class="fw-black" style="color: var(--haiti-charcoal); font-size: 14px;">
            <%= number_with_precision(@business.usdc_balance.to_f, precision: 2, delimiter: ",") %>
          </div>
          <div style="color: var(--haiti-olive); font-size: 10px; font-weight: 600;">
            ≈ <%= number_with_precision(@business.usdc_balance.to_f * usd_htg, precision: 2, delimiter: ",") %> HTG
          </div>
        </div>
      </div>

      <%# ── Agent Application / "Vin Ajan" Card ── %>
      <% if !@is_agent %>
        <% case @agent_status %>
        <% when "none" %>
          <div class="rounded-3 p-3 mb-2" style="background: linear-gradient(135deg, rgba(197,160,89,0.08), rgba(93,99,69,0.05)); border: 1px dashed rgba(197,160,89,0.3);">
            <div class="mb-2" style="color: var(--haiti-olive); font-size: 11px; line-height: 1.5;">
              Ou deja gen yon biznis Zèllus pou aksepte peman. Kounye a, ou ka aplike pou vin yon <strong style="color: var(--haiti-charcoal);">Ajan</strong> — aksepte lajan kach pou lòt moun epi touche <strong style="color: var(--haiti-gold);">2% komisyon</strong> sou chak depo.
            </div>
            <div class="d-flex align-items-center justify-content-between">
              <div>
                <div class="fw-bold" style="color: var(--haiti-charcoal); font-size: 13px;">
                  <i class="ri-user-location-line me-1" style="color: var(--haiti-gold);"></i>Vin Ajan Zèllus
                </div>
                <div style="color: var(--haiti-olive); font-size: 10px;">Biznis ou rete menm jan — ajan se yon fonksyon anplis.</div>
              </div>
              <% if @agent_eligible %>
                <%= button_to apply_agent_business_path(@business), method: :post,
                    class: "btn btn-sm fw-bold rounded-pill px-3 py-2 border-0",
                    style: "background: var(--haiti-gold); color: #fff; font-size: 12px;",
                    data: { turbo_confirm: "Ou vle aplike pou vin ajan Zèllus?" } do %>
                  <i class="ri-send-plane-line me-1"></i>Aplike
                <% end %>
              <% else %>
                <span class="badge rounded-pill" style="background: rgba(93,99,69,0.1); color: var(--haiti-olive); font-size: 10px;">
                  Pa Kalifye
                </span>
              <% end %>
            </div>
            <% unless @agent_eligible %>
              <div class="mt-2 pt-2" style="border-top: 1px solid rgba(93,99,69,0.1);">
                <div style="color: var(--haiti-olive); font-size: 10px; font-weight: 600; margin-bottom: 4px;">Kondisyon pou aplike:</div>
                <% [
                  { met: @business.active?, label: "Biznis aktif" },
                  { met: @business.user&.bonid_verified?, label: "BonID verifye" },
                  { met: @business.logo.attached?, label: "Logo biznis ajoute" },
                  { met: @business.phone.present?, label: "Nimewo telefòn" },
                  { met: @business.department.present? && @business.commune.present?, label: "Adrès fizik (depatman + komin)" }
                ].each do |req| %>
                  <div style="font-size: 10px; color: <%= req[:met] ? '#166534' : '#991b1b' %>;">
                    <i class="<%= req[:met] ? 'ri-check-line' : 'ri-close-line' %> me-1"></i><%= req[:label] %>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>

        <% when "pending" %>
          <div class="rounded-3 p-3 mb-2" style="background: rgba(254,243,199,0.4); border: 1px solid rgba(146,64,14,0.15);">
            <div class="d-flex align-items-center gap-2">
              <i class="ri-time-line" style="color: #92400e; font-size: 18px;"></i>
              <div>
                <div class="fw-bold" style="color: #92400e; font-size: 13px;">Aplikasyon Ajan An Atant</div>
                <div style="color: #92400e; font-size: 10px; opacity: 0.7;">Ekip nou ap revize aplikasyon ou. Sa ka pran 1-2 jou ouvrab.</div>
              </div>
            </div>
          </div>

        <% when "rejected" %>
          <div class="rounded-3 p-3 mb-2" style="background: rgba(254,242,242,0.4); border: 1px solid rgba(153,27,27,0.15);">
            <div class="d-flex align-items-center justify-content-between">
              <div class="d-flex align-items-center gap-2">
                <i class="ri-close-circle-line" style="color: #991b1b; font-size: 18px;"></i>
                <div>
                  <div class="fw-bold" style="color: #991b1b; font-size: 13px;">Aplikasyon Pa Apwouve</div>
                  <% if @business.agent_rejected_reason.present? %>
                    <div style="color: #991b1b; font-size: 10px; opacity: 0.7;"><%= @business.agent_rejected_reason %></div>
                  <% end %>
                </div>
              </div>
              <% if @agent_eligible %>
                <%= button_to apply_agent_business_path(@business), method: :post,
                    class: "btn btn-sm fw-bold rounded-pill px-3 py-2 border-0",
                    style: "background: var(--haiti-olive); color: #fff; font-size: 11px;",
                    data: { turbo_confirm: "Ou vle aplike ankò pou vin ajan?" } do %>
                  <i class="ri-refresh-line me-1"></i>Aplike Ankò
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>

    </div>
    <% end %>

    <%# ══════════════════════════════════════ %>
    <%# ── AJAN TAB (Agent Cash-In Network) ── %>
    <%# ══════════════════════════════════════ %>
    <% if @is_agent %>
    <div id="section-ajan" class="mb-3" style="display: none;">

      <%# ── Agent Float Balance ── %>
      <div class="asset-card d-flex align-items-center justify-content-between rounded-3 mb-3" style="background: linear-gradient(135deg, rgba(197,160,89,0.10), rgba(93,99,69,0.08)); padding: 20px; border: 1px solid rgba(197,160,89,0.25);">
        <div class="d-flex align-items-center gap-3">
          <div style="width: 42px; height: 42px; border-radius: 50%; background: rgba(197,160,89,0.15); display: flex; align-items: center; justify-content: center;">
            <i class="ri-safe-2-line" style="font-size: 20px; color: var(--haiti-gold);"></i>
          </div>
          <div>
            <div style="color: var(--haiti-olive); font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">Flòt Ajan</div>
            <div class="fw-black" style="color: var(--haiti-charcoal); font-size: 22px;">
              G <%= number_with_precision(@agent_float.to_f, precision: 0, delimiter: ",") %>
            </div>
          </div>
        </div>
        <div class="d-flex gap-2 flex-wrap">
          <button type="button" class="btn btn-sm px-3 py-2" style="background: var(--haiti-charcoal); color: var(--haiti-gold); border-radius: 12px; font-weight: 700; font-size: 12px;" data-bs-toggle="modal" data-bs-target="#floatWithdrawModal">
            <i class="ri-arrow-up-circle-line me-1"></i>Retire
          </button>
          <button type="button" class="btn btn-sm px-3 py-2" style="background: var(--haiti-gold); color: #fff; border-radius: 12px; font-weight: 700; font-size: 12px;" data-bs-toggle="modal" data-bs-target="#floatTopUpModal">
            <i class="ri-add-circle-line me-1"></i>Ajoute
          </button>
        </div>
      </div>

      <%# ── Cash-In Button (customer deposits) ── %>
      <div class="mb-3">
        <button type="button" class="btn w-100 py-2" style="background: rgba(93,99,69,0.08); color: var(--haiti-charcoal); border: 1.5px dashed rgba(93,99,69,0.25); border-radius: 14px; font-weight: 700; font-size: 13px;" data-bs-toggle="modal" data-bs-target="#cashinModal">
          <i class="ri-user-location-line me-1" style="color: var(--haiti-gold);"></i>Fè Depo pou Kliyan
        </button>
      </div>

      <%# ── Today's Stats ── %>
      <div class="d-flex gap-2 mb-3">
        <div class="flex-fill rounded-3 p-3 text-center" style="background: rgba(93,99,69,0.05);">
          <div style="color: var(--haiti-olive); font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">Jodi a</div>
          <div class="fw-black" style="color: var(--haiti-charcoal); font-size: 18px;"><%= @agent_today_count %></div>
          <div style="color: var(--haiti-olive); font-size: 10px;">tranzaksyon</div>
        </div>
        <div class="flex-fill rounded-3 p-3 text-center" style="background: rgba(93,99,69,0.05);">
          <div style="color: var(--haiti-olive); font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">Volim</div>
          <div class="fw-black" style="color: var(--haiti-charcoal); font-size: 18px;">G <%= number_with_precision(@agent_today_volume.to_f, precision: 0, delimiter: ",") %></div>
          <div style="color: var(--haiti-olive); font-size: 10px;">HTG jodi a</div>
        </div>
        <div class="flex-fill rounded-3 p-3 text-center" style="background: rgba(197,160,89,0.08);">
          <div style="color: var(--haiti-olive); font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">Komisyon</div>
          <div class="fw-black" style="color: var(--haiti-gold); font-size: 18px;">G <%= number_with_precision(@agent_today_commission.to_f, precision: 0, delimiter: ",") %></div>
          <div style="color: var(--haiti-olive); font-size: 10px;">jodi a (2%)</div>
        </div>
      </div>

      <%# ── Total Commission Earned ── %>
      <div class="rounded-3 p-3 mb-3 d-flex align-items-center justify-content-between" style="background: rgba(197,160,89,0.06); border: 1px dashed rgba(197,160,89,0.3);">
        <div>
          <div style="color: var(--haiti-olive); font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">Total Komisyon Touche</div>
        </div>
        <div class="fw-black" style="color: var(--haiti-gold); font-size: 16px;">
          G <%= number_with_precision(@agent_total_commission.to_f, precision: 0, delimiter: ",") %>
        </div>
      </div>

      <%# ── Agent Kit + Signage ── %>
      <div class="rounded-3 p-3 mb-3" style="background: rgba(93,99,69,0.05); border: 1px solid rgba(93,99,69,0.1);">
        <div class="d-flex align-items-center justify-content-between mb-2">
          <div>
            <div class="fw-bold" style="color: var(--haiti-charcoal); font-size: 12px;">
              <i class="ri-printer-line me-1" style="color: var(--haiti-gold);"></i>Kit Ajan
            </div>
            <div style="color: var(--haiti-olive); font-size: 10px;">Afich, QR Code, ak etikèt kontwa.</div>
          </div>
          <%= link_to agent_kit_business_path, target: "_blank", class: "btn btn-sm fw-bold rounded-pill px-3 border-0", style: "background: var(--haiti-gold); color: #fff; font-size: 11px;" do %>
            <i class="ri-download-line me-1"></i>Telechaje PDF
          <% end %>
        </div>
        <% unless @business.signage_photo.attached? %>
          <div class="pt-2 mt-2" style="border-top: 1px dashed rgba(197,160,89,0.3);">
            <div style="color: var(--haiti-olive); font-size: 10px;" class="mb-2">
              <i class="ri-camera-line me-1" style="color: var(--haiti-gold);"></i>Pran foto afich ou pou resevwa badj <strong>"Lokasyon Verifye"</strong> sou Kat Ajan.
            </div>
            <%= form_tag upload_signage_business_path, method: :post, multipart: true, class: "d-flex align-items-center gap-2" do %>
              <%= file_field_tag :signage_photo, accept: "image/*", class: "form-control form-control-sm", style: "font-size: 10px; border: 1px solid rgba(197,160,89,0.3); border-radius: 12px;" %>
              <button type="submit" class="btn btn-sm fw-bold rounded-pill px-3 border-0 flex-shrink-0" style="background: var(--haiti-charcoal); color: var(--haiti-gold); font-size: 10px;">
                <i class="ri-upload-2-line me-1"></i>Voye
              </button>
            <% end %>
          </div>
        <% else %>
          <div class="pt-2 mt-2 d-flex align-items-center gap-2" style="border-top: 1px dashed rgba(197,160,89,0.3);">
            <i class="<%= @business.signage_verified? ? 'ri-verified-badge-fill' : 'ri-time-line' %>" style="color: <%= @business.signage_verified? ? '#166534' : 'var(--haiti-gold)' %>; font-size: 14px;"></i>
            <span style="color: var(--haiti-olive); font-size: 10px;">
              <%= @business.signage_verified? ? "Lokasyon Verifye ✓" : "Foto soumèt — ap tann verifikasyon." %>
            </span>
          </div>
        <% end %>
      </div>

      <%# ── Recent Agent Transactions ── %>
      <div class="pt-2 mb-2">
        <div style="color: var(--haiti-olive); font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 10px;">
          <i class="ri-history-line me-1" style="color: var(--haiti-gold);"></i>Dènye Tranzaksyon Ajan
        </div>
      </div>

      <% if @agent_recent_txs.any? %>
        <div style="max-height: 350px; overflow-y: auto; scrollbar-width: thin; scrollbar-color: var(--haiti-olive) transparent;">
          <% @agent_recent_txs.each do |tx| %>
            <%
              is_float = tx.float_top_up? || tx.float_withdraw?
              if tx.float_top_up?
                tx_icon = "ri-safe-2-line"
                tx_icon_bg = "rgba(197,160,89,0.12)"
                tx_icon_color = "var(--haiti-gold)"
                tx_label = "Ajoute Flòt"
              elsif tx.float_withdraw?
                tx_icon = "ri-wallet-3-line"
                tx_icon_bg = "rgba(93,99,69,0.10)"
                tx_icon_color = "var(--haiti-olive)"
                tx_label = "Retire Flòt"
              elsif tx.completed?
                tx_icon = "ri-arrow-down-line"
                tx_icon_bg = "rgba(22,101,52,0.10)"
                tx_icon_color = "#166534"
                tx_label = "$#{tx.customer.cashtag}"
              else
                tx_icon = "ri-close-line"
                tx_icon_bg = "rgba(216,0,12,0.08)"
                tx_icon_color = "#D8000C"
                tx_label = "$#{tx.customer.cashtag}"
              end
            %>
            <div class="d-flex align-items-center justify-content-between py-2 px-1" style="border-bottom: 1px solid rgba(93,99,69,0.06);">
              <div class="d-flex align-items-center gap-2">
                <div style="width: 32px; height: 32px; border-radius: 50%; background: <%= tx_icon_bg %>; display: flex; align-items: center; justify-content: center;">
                  <i class="<%= tx_icon %>" style="font-size: 14px; color: <%= tx_icon_color %>;"></i>
                </div>
                <div>
                  <div style="color: var(--haiti-charcoal); font-size: 12px; font-weight: 600;">
                    <%= tx_label %>
                  </div>
                  <div style="color: var(--haiti-olive); font-size: 10px;">
                    <%= tx.created_at.strftime("%d %b · %H:%M") %> · <%= tx.confirmation_code %>
                  </div>
                </div>
              </div>
              <div class="text-end">
                <div class="fw-bold" style="color: <%= is_float ? 'var(--haiti-gold)' : 'var(--haiti-charcoal)' %>; font-size: 13px;">
                  <%= is_float ? (tx.float_top_up? ? "+" : "−") : "" %>G <%= number_with_precision(tx.amount.to_f, precision: 0, delimiter: ",") %>
                </div>
                <% unless is_float %>
                  <div style="color: var(--haiti-gold); font-size: 10px; font-weight: 600;">
                    +G <%= number_with_precision(tx.commission_amount.to_f, precision: 0, delimiter: ",") %>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-4" style="color: var(--haiti-olive); font-size: 12px;">
          <i class="ri-inbox-line d-block mb-2" style="font-size: 28px; opacity: 0.4;"></i>
          Pa gen tranzaksyon ajan ankò
        </div>
      <% end %>

    </div>
    <% end %>

    <%# ══════════════════════════════════════ %>
    <%# ── AKTIVITE TAB (Transaction History) ── %>
    <%# ══════════════════════════════════════ %>
    <div id="section-aktivite" class="mb-3" style="display: none;">
      <%# ── Section Header ── %>
      <div class="pt-3 mb-2" style="border-top: 1px solid rgba(93,99,69,0.08);">
        <div style="color: var(--haiti-olive); font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 10px;">
          <i class="ri-history-line me-1" style="color: var(--haiti-gold);"></i>Aktivite
        </div>
      </div>
      <% if @ledger_entries.any? %>
        <%# Pre-load receiver users for transfer_out entries to avoid N+1 %>
        <%
          out_cashtags = @ledger_entries.select { |e| e.entry_type == "transfer_out" && e.reference_type == "Transfer" }
                          .map { |e| e.reference&.receiver_cashtag }.compact.uniq
          receiver_users_by_tag = out_cashtags.any? ? User.where(cashtag: out_cashtags).index_by(&:cashtag) : {}
        %>
        <div style="max-height: 400px; overflow-y: auto; scrollbar-width: thin; scrollbar-color: var(--haiti-olive) transparent;">
          <% current_group_date = nil %>
          <% @ledger_entries.each do |entry| %>
            <% next if entry.entry_type == "conversion_fee" %>

            <%# ── Date group header (Jodi a / Yè / date) ── %>
            <% entry_date = entry.created_at.to_date %>
            <% if entry_date != current_group_date %>
              <% current_group_date = entry_date %>
              <%
                group_label =
                  if    entry_date == Date.current   then "Jodi a"
                  elsif entry_date == Date.yesterday then "Yè"
                  else
                    km = %w[Jan Fev Mas Avr Me Jen Jiy Out Sep Okt Nov Des]
                    "#{entry_date.day} #{km[entry_date.month - 1]} #{entry_date.year}"
                  end
              %>
              <div class="px-3 pt-3 pb-1" style="color: var(--haiti-olive); font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">
                <%= group_label %>
              </div>
            <% end %>
            <%
              xfer = (entry.reference_type == "Transfer") ? entry.reference : nil
              is_biz = xfer&.business_id.present?
              is_transfer = %w[transfer_out transfer_in].include?(entry.entry_type) && xfer.present?

              # Determine counterparty for transfers
              if is_transfer
                if entry.entry_type == "transfer_in"
                  counterparty_user = xfer.user
                  counterparty_name = counterparty_user&.cashtag.present? ? "$#{counterparty_user.cashtag}" : (counterparty_user&.bonid_first_name || counterparty_user&.display_name || "Moun")
                else
                  if is_biz
                    counterparty_user = nil
                    counterparty_name = xfer.business&.name || xfer.receiver_display
                  else
                    counterparty_user = xfer.receiver_cashtag.present? ? receiver_users_by_tag[xfer.receiver_cashtag] : nil
                    counterparty_name = xfer.receiver_cashtag.present? ? "$#{xfer.receiver_cashtag}" : xfer.receiver_display
                  end
                end
              end

              icon_class = case entry.entry_type
                when "deposit"        then "ri-add-circle-fill"
                when "withdrawal"     then "ri-arrow-up-circle-fill"
                when "fee"            then "ri-percent-fill"
                when "instant_fee"    then "ri-flashlight-fill"
                when "refund"         then "ri-refresh-fill"
                when "conversion_out" then "ri-exchange-line"
                when "conversion_in"  then "ri-exchange-line"
                else "ri-exchange-line"
              end
              badge_type = case entry.entry_type
                when "fee", "instant_fee" then "fee"
                else entry.credit? ? "credit" : "debit"
              end
              amount_color = entry.credit? ? "#166534" : "#991b1b"
              time_full = entry.created_at.strftime("%b %d, %Y %l:%M %p").strip
              # Day is carried by the date group header above; the per-row
              # time is just relative (last hour) or clock time.
              time_short = if entry.created_at > 1.hour.ago
                  time_ago_in_words(entry.created_at) + " pase"
                else
                  entry.created_at.strftime("%l:%M %p").strip
                end
            %>
            <%= link_to entry_wallet_path(entry.token), class: "d-flex align-items-center gap-3 p-3 text-decoration-none ledger-entry-link", title: time_full do %>

              <%# ── LEFT: Avatar (transfers) or Icon badge (other) ── %>
              <% if is_transfer %>
                <% avatar_user = counterparty_user %>
                <% if is_biz && xfer.business&.logo&.attached? %>
                  <div style="width: 38px; height: 38px; border-radius: 50%; overflow: hidden; flex-shrink: 0; border: 1.5px solid var(--haiti-gold);">
                    <%= image_tag xfer.business.logo, style: "width: 100%; height: 100%; object-fit: cover;" %>
                  </div>
                <% elsif avatar_user&.avatar&.attached? %>
                  <div style="width: 38px; height: 38px; border-radius: 50%; overflow: hidden; flex-shrink: 0; border: 1.5px solid var(--haiti-gold);">
                    <%= image_tag avatar_user.avatar, style: "width: 100%; height: 100%; object-fit: cover;", alt: "" %>
                  </div>
                <% elsif avatar_user.present? %>
                  <div style="width: 38px; height: 38px; border-radius: 50%; flex-shrink: 0; display: flex; align-items: center; justify-content: center; background: var(--haiti-charcoal); border: 1.5px solid var(--haiti-gold);">
                    <i class="ri-user-fill" style="font-size: 18px; color: var(--haiti-gold);"></i>
                  </div>
                <% else %>
                  <div class="ledger-icon <%= badge_type %>">
                    <i class="<%= entry.entry_type == 'transfer_out' ? (is_biz ? 'ri-store-2-fill' : 'ri-send-plane-fill') : 'ri-download-2-fill' %>"></i>
                  </div>
                <% end %>
              <% else %>
                <div class="ledger-icon <%= badge_type %>">
                  <i class="<%= icon_class %>"></i>
                </div>
              <% end %>

              <%# ── MIDDLE: Description + time ── %>
              <div class="flex-grow-1" style="min-width: 0;">
                <%# Amount lives only in the RIGHT column now (was duplicated here). %>
                <% if is_transfer %>
                  <div class="fw-bold" style="color: var(--haiti-charcoal); font-size: 13px;">
                    <% if entry.entry_type == "transfer_out" %>
                      Ou peye <span style="color: var(--haiti-gold); font-weight: 800;"><%= counterparty_name %></span>
                    <% else %>
                      <span style="color: var(--haiti-gold); font-weight: 800;"><%= counterparty_name %></span> peye w
                    <% end %>
                  </div>
                <% else %>
                  <div class="fw-bold text-truncate" style="color: var(--haiti-charcoal); font-size: 13px;">
                    <% feed_label = case entry.entry_type
                       when "deposit"
                         entry.moncash_transaction_id.to_s.start_with?("admin-credit-") ? "Ou resevwa yon kredi" : "Ou depoze"
                       when "withdrawal"     then "Ou retire"
                       when "conversion_out"
                         ctx = entry.source_context == "biznis" ? "Biznis" : "Pèsonèl"
                         "Ou konvèti (#{ctx})"
                       when "conversion_in"
                         ctx = entry.source_context == "biznis" ? "Biznis" : "Pèsonèl"
                         "Ou resevwa (#{ctx})"
                       when "fee", "instant_fee" then "Frè"
                       when "refund"         then "Ranbousman"
                       else entry.description.to_s.truncate(35)
                       end %>
                    <%= feed_label %>
                  </div>
                <% end %>
                <div style="color: var(--haiti-olive); font-size: 10px;"><%= time_short %></div>
              </div>

              <%# ── RIGHT: Amount ── %>
              <div class="text-end flex-shrink-0">
                <div class="fw-black" style="font-size: 15px; color: <%= amount_color %>;">
                  <%# Exact amount — htg/usd: 2 decimals · crypto (wbtc/eth): 6 %>
                  <%= entry.credit? ? "+" : "-" %><%= number_to_currency(entry.amount, unit: "", precision: %w[htg usd].include?(entry.asset) ? 2 : 6) %>
                </div>
                <div style="color: var(--haiti-olive); font-size: 9px; font-weight: 600;"><%= entry.asset_label %></div>
              </div>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-5" style="color: var(--haiti-olive);">
          <i class="ri-inbox-line" style="font-size: 2.5rem; opacity: 0.4;"></i>
          <div class="mt-2 fw-bold" style="font-size: 13px;">Pa gen aktivite ankò</div>
          <div class="small" style="opacity: 0.6;">Tranzaksyon ou yo ap parèt la a.</div>
        </div>
      <% end %>
    </div>

    </div>
    </div><%# ── end card-base ── %>
    </div><%# ── end column ── %>

  </div>
</div>

