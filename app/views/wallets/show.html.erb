var cvSellRate = <%= (@sell_rate || 135.50).to_f.round(4) %>; // HTG per USD (sell rate — lower)

// Precision per asset
var cvPrecision = { htg: 2, usd: 2, eth: 6, wbtc: 8 };

// Convert amount from one asset to another via USD
function cvConvertAmount(from, to, amount) {
  if (from === to || amount <= 0) return 0;
  // Step 1: from → USD
  var usd;
  if (from === 'usd') usd = amount;
  else if (from === 'htg') usd = amount / cvBuyRate;   // user pays more HTG per USD
  else usd = amount * cvUsdRates[from];                 // ETH/wBTC × USD rate

  // Step 2: USD → to
  var result;
  if (to === 'usd') result = usd;
  else if (to === 'htg') result = usd * cvSellRate;     // user gets fewer HTG per USD
  else result = usd / cvUsdRates[to];                   // USD ÷ asset rate

  return result;
}

function cvAssetLabel(a) { return a === 'usd' ? 'USD' : a.toUpperCase(); }

function cvFormatAmount(asset, amount) {
  var p = cvPrecision[asset] || 2;
  return parseFloat(amount.toFixed(p));
}

// Get a human-readable rate string between two assets
function cvRateString(from, to) {
  if (from === 'htg' && to === 'usd') return '1 USD = ' + cvBuyRate.toFixed(2) + ' HTG';
  if (from === 'usd' && to === 'htg') return '1 USD = ' + cvSellRate.toFixed(2) + ' HTG';
  // For crypto pairs, show "1 FROM = X TO"
  var oneUnit = cvConvertAmount(from, to, 1);
  return '1 ' + cvAssetLabel(from) + ' = ' + cvFormatAmount(to, oneUnit) + ' ' + cvAssetLabel(to);
}

// ── Convert: currency+wallet picker ──
var cvFromAssetSel = 'htg', cvFromWallet = 'personal';
var cvToAssetSel = 'usd', cvToWallet = 'personal';
var cvBizName = '<%= j(@business&.name || "Biznis") %>';
var CV_HTG_LOGO = '<%= j htg_logo_svg(size: 18) %>';
var CV_USD_LOGO = '<%= j usd_logo(size: 18) %>';
var CV_HTG_SM = '<%= j htg_logo_svg(size: 14) %>';
var CV_USD_SM = '<%= j usd_logo(size: 14) %>';

function toggleCvDd(side) {
  var dd = document.getElementById('cv-' + side + '-dropdown');
  var other = side === 'from' ? 'to' : 'from';
  var otherDd = document.getElementById('cv-' + other + '-dropdown');
  if (otherDd) otherDd.style.display = 'none';
  if (dd) dd.style.display = dd.style.display === 'none' ? 'block' : 'none';
}

function selectCvOption(side, asset, wallet) {
  if (side === 'from') {
    cvFromAssetSel = asset;
    cvFromWallet = wallet;
    // Auto-flip "to" to opposite currency if same
    if (cvToAssetSel === asset) {
      cvToAssetSel = asset === 'htg' ? 'usd' : 'htg';
    }
  } else {
    cvToAssetSel = asset;
    cvToWallet = wallet;
    // Auto-flip "from" to opposite currency if same
    if (cvFromAssetSel === asset) {
      cvFromAssetSel = asset === 'htg' ? 'usd' : 'htg';
    }
  }

  // Update button displays
  updateCvBtn('from');
  updateCvBtn('to');

  // Update active highlights
  updateCvDdActive('from', cvFromAssetSel + '-' + cvFromWallet);
  updateCvDdActive('to', cvToAssetSel + '-' + cvToWallet);

  // Update hidden fields
  document.getElementById('convert-from-asset').value = cvFromAssetSel;
  document.getElementById('convert-to-asset').value = cvToAssetSel;
  document.getElementById('cv-source-field').value = cvFromWallet === 'personal' ? 'personal' : 'biznis';
  document.getElementById('cv-dest-field').value = cvToWallet === 'personal' ? 'personal' : 'biznis';

  // Update amount suffix
  var suffix = document.getElementById('convert-currency-suffix');
  if (suffix) suffix.textContent = cvFromAssetSel === 'usd' ? 'USD' : 'HTG';

  // Sync global cvFromAsset/cvToAsset for rate/preview functions
  cvFromAsset = cvFromAssetSel;
  cvToAsset = cvToAssetSel;

  // Close dropdown + refresh
  document.getElementById('cv-' + side + '-dropdown').style.display = 'none';
  updateConvertDirection();
  updateConvertPreview();
}

function updateCvBtn(side) {
  var asset = side === 'from' ? cvFromAssetSel : cvToAssetSel;
  var wallet = side === 'from' ? cvFromWallet : cvToWallet;
  var logo = document.getElementById('cv-' + side + '-logo');
  var label = document.getElementById('cv-' + side + '-label');
  var sub = document.getElementById('cv-' + side + '-sub');
  if (logo) logo.innerHTML = asset === 'usd' ? CV_USD_LOGO : CV_HTG_LOGO;
  if (label) label.textContent = asset === 'usd' ? 'USD' : 'HTG';
  if (sub) sub.textContent = wallet === 'personal' ? 'Pèsonèl' : cvBizName;

  // Update direction summary
  var dirLogo = document.getElementById('cv-dir-' + side + '-logo');
  var dirLabel = document.getElementById('cv-dir-' + side);
  if (dirLogo) dirLogo.innerHTML = asset === 'usd' ? CV_USD_LOGO : CV_HTG_LOGO;
  if (dirLabel) dirLabel.textContent = asset === 'usd' ? 'USD' : 'HTG';
}

function updateCvDdActive(side, activeKey) {
  var dd = document.getElementById('cv-' + side + '-dropdown');
  if (!dd) return;
  dd.querySelectorAll('.cv-dd-opt').forEach(function(btn) {
    btn.classList.toggle('active', btn.getAttribute('data-key') === activeKey);
  });
}

// Close dropdowns on outside click
document.addEventListener('click', function(e) {
  ['from', 'to'].forEach(function(side) {
    if (!e.target.closest('#cv-' + side + '-btn') && !e.target.closest('#cv-' + side + '-dropdown')) {
      var d = document.getElementById('cv-' + side + '-dropdown');
      if (d) d.style.display = 'none';
    }
  });
});

// Set initial active states + hidden fields
updateCvDdActive('from', 'htg-personal');
updateCvDdActive('to', 'usd-personal');
document.getElementById('convert-from-asset').value = 'htg';
document.getElementById('convert-to-asset').value = 'usd';

function updateConvertDirection() {
  var fromField = document.getElementById('convert-from-asset');
  var toField = document.getElementById('convert-to-asset');
  var unsupported = document.getElementById('cv-unsupported');
  var continueBtn = document.getElementById('cv-continue-btn');
  var amountInput = document.getElementById('convert-amount');

  // Refresh limit chip when direction changes
  if (typeof refreshLimits === 'function') refreshLimits();

  // All pairs are supported (except same asset)
  var supported = cvFromAsset !== cvToAsset;

  if (unsupported) unsupported.style.display = 'none';  // never show unsupported
  if (continueBtn) continueBtn.style.display = 'flex';
  if (amountInput) amountInput.removeAttribute('disabled');

  // Set hidden fields for form submission
  if (fromField) fromField.value = cvFromAsset;
  if (toField) toField.value = cvToAsset;

  // Update rate display
  var rateBox = document.querySelector('#cv-step1 .p-2.rounded-3.mb-3.text-center');
  if (rateBox) {
    rateBox.innerHTML = '<span class="small fw-bold" style="color: var(--haiti-olive); font-size: 11px;">' +
      '<i class="ri-exchange-line me-1"></i>' + cvRateString(cvFromAsset, cvToAsset) +
      '</span><div id="convert-preview-result" class="fw-black mt-1" style="color: var(--haiti-charcoal); font-size: 14px; display: none;"></div>';
  }
}

function updateConvertPreview() {
  var amount = parseFloat(document.getElementById('convert-amount').value) || 0;
  var resultEl = document.getElementById('convert-preview-result');
  if (!resultEl) return;

  if (amount <= 0 || cvFromAsset === cvToAsset) {
    resultEl.style.display = 'none';
    return;
  }

  var converted = cvConvertAmount(cvFromAsset, cvToAsset, amount);
  var formatted = cvFormatAmount(cvToAsset, converted);

  resultEl.textContent = '≈ ' + formatted + ' ' + cvAssetLabel(cvToAsset);
  resultEl.style.display = 'block';
}

function showConvertReview() {
  var amount = parseFloat(document.getElementById('convert-amount').value) || 0;
  if (amount <= 0) {
    document.getElementById('convert-amount').focus();
    return;
  }

  var converted = cvConvertAmount(cvFromAsset, cvToAsset, amount);
  var fee = converted * 0.02;
  var netAmount = converted - fee;
  var formattedNet = cvFormatAmount(cvToAsset, netAmount);
  var formattedFee = cvFormatAmount(cvToAsset, fee);

  var fromLogo = cvFromAsset === 'usd' ? CV_USD_SM : CV_HTG_SM;
  var toLogo = cvToAsset === 'usd' ? CV_USD_SM : CV_HTG_SM;

  document.getElementById('cv-review-from').innerHTML = fromLogo + ' ' + cvAssetLabel(cvFromAsset);
  document.getElementById('cv-review-to').innerHTML = toLogo + ' ' + cvAssetLabel(cvToAsset);
  document.getElementById('cv-review-amount').innerHTML = fromLogo + ' ' + amount + ' ' + cvAssetLabel(cvFromAsset);
  document.getElementById('cv-review-rate').textContent = cvRateString(cvFromAsset, cvToAsset);
  document.getElementById('cv-review-fee').innerHTML = toLogo + ' - ' + formattedFee + ' ' + cvAssetLabel(cvToAsset);
  document.getElementById('cv-review-receive').innerHTML = toLogo + ' ≈ ' + formattedNet + ' ' + cvAssetLabel(cvToAsset);

  document.getElementById('cv-step1').style.display = 'none';
  document.getElementById('cv-step2').style.display = 'block';
  var pin = document.getElementById('cv-pin');
  if (pin) setTimeout(function() { pin.focus(); }, 150);
}

function backToConvertStep1() {
  document.getElementById('cv-step2').style.display = 'none';
  document.getElementById('cv-step1').style.display = 'block';
  var pin = document.getElementById('cv-pin');
  if (pin) pin.value = '';
}

// ── Submit Convert with StepLoader ──
var convertForm = document.getElementById('convert-form');
if (convertForm) {
  convertForm.addEventListener('submit', function(e) {
    e.preventDefault();
    ZellusLoader.start('convert-loader', convertForm, { stepDelay: 6000 });
  });
}

// ── Live balance auto-refresh (fallback for missed WebSocket messages) ──
(function() {
  var lastBalances = null;
  var REFRESH_INTERVAL = 4000; // 4 seconds
  var balanceTimer = null;

  function fetchBalances() {
    fetch('/wallet/balances.json', { credentials: 'same-origin' })
      .then(function(r) { return r.json(); })
      .then(function(b) {
        var key = JSON.stringify(b);
        if (lastBalances && key !== lastBalances) {
          console.log('[Zèllus] 💰 Balance refresh detected change:', b);
          if (typeof updateBalances === 'function') {
            updateBalances({ balances: b });
          }
        }
        lastBalances = key;
      })
      .catch(function() {});
  }

  function startPolling() {
    if (balanceTimer) clearInterval(balanceTimer);
    fetchBalances();                                     // fetch immediately
    balanceTimer = setInterval(fetchBalances, REFRESH_INTERVAL);
  }

  // Refresh when tab becomes visible again
  document.addEventListener('visibilitychange', function() {
    if (!document.hidden) fetchBalances();
  });

  // Restart polling on Turbo navigation (keeps it alive across page visits)
  document.addEventListener('turbo:load', startPolling);

  // Start now
  startPolling();
})();
</script>
