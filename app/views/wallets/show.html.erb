// ── Deposit Step 1 → Step 2 (Review) ──
function showDepositReview() {
  var amount = document.getElementById('deposit-amount');
  var phone  = document.getElementById('deposit-moncash-phone');

  // Validate amount
  var val = parseFloat(amount.value);
  if (!val || val < 131 || val > 327678) {
    amount.focus();
    amount.reportValidity();
    return;
  }

  // Validate phone
  var phoneVal = phone.value.trim();
  if (!phoneVal) {
    phone.focus();
    if (phone.reportValidity) phone.reportValidity();
    return;
  }

  // Fill review summary
  document.getElementById('review-deposit-amount').textContent = parseInt(val).toLocaleString('fr') + ' HTG';

  // Get masked display for phone
  var maskedPhone = phoneVal;
  if (phone.tagName === 'SELECT') {
    var opt = phone.options[phone.selectedIndex];
    maskedPhone = opt.getAttribute('data-masked') || phoneVal;
  } else if (phoneVal.length === 11) {
    maskedPhone = '(509) •••• ' + phoneVal.slice(-4);
  }
  document.getElementById('review-deposit-phone').textContent = maskedPhone;

  // Show step 2, hide step 1
  document.getElementById('deposit-step-1').style.display = 'none';
  document.getElementById('deposit-step-2').style.display = '';

  // Focus PIN field
  setTimeout(function() {
    var pin = document.getElementById('deposit-pin');
    if (pin) pin.focus();
  }, 200);
}

function backToDepositStep1() {
  document.getElementById('deposit-step-2').style.display = 'none';
  document.getElementById('deposit-step-1').style.display = '';
  document.getElementById('deposit-pin').value = '';
}

