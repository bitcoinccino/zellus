        <button type="button" class="wallet-tab" id="tab-btn-ajan" onclick="switchTab('ajan')">
          <i class="ri-user-location-line me-1"></i>Ajan
        </button>
      <% end %>
      <%# Kripto tab hidden (HTG + USD only mode) %>
      <button type="button" class="wallet-tab" id="tab-btn-kripto" onclick="switchTab('kripto')" style="display:none;">
        <i class="ri-coin-line me-1"></i>Kripto
      </button>
      <%# Stòk tab hidden (HTG + USD only mode) %>
      <button type="button" class="wallet-tab" id="tab-btn-stok" onclick="switchTab('stok')" style="display:none;">
        <i class="ri-stock-line me-1"></i>Stòk
      </button>
      <button type="button" class="wallet-tab" id="tab-btn-aktivite" onclick="switchTab('aktivite')">
        <i class="ri-history-line me-1"></i>Aktivite
      </button>
    </div>

    <%# ══════════════════════════════════════ %>
    <%# ── LAJAN TAB (Assets + Rates)    ──  %>
    <%# ══════════════════════════════════════ %>
    <div id="section-lajan" class="mb-3">
      <%# Convert from the *displayed* (2-decimal) balance so a dust amount
          that shows as "0.00" doesn't show a non-zero equivalent next to it. %>
      <% htg_usd = htg_bal.round(2) / usd_htg %>
      <% usd_htg_val = usd_bal.round(2) * usd_htg %>
      <% wbtc_usd_val = wbtc_bal * btc_usd %>
      <% eth_usd_val  = eth_bal * eth_usd %>

      <%# ── Section Header (removed) ── %>

      <%# HTG %>
          <div class="asset-card d-flex align-items-center justify-content-between rounded-3 mb-2 bg-cream" style="padding: 18px;">
            <div class="d-flex align-items-center gap-3">
              <%= htg_logo_svg(size: 36) %>
              <div>
                <div class="fw-bold text-charcoal" style="font-size: 14px;">HTG</div>
              </div>
            </div>
            <div class="text-end">
              <div class="fw-black text-charcoal" style="font-size: 14px;">
                <span id="asset-htg-bal"><%= number_with_precision(htg_bal, precision: 2) %></span>
              </div>
              <div class="text-olive text-xs" style="font-weight: 600;">
                ≈ $<span id="asset-htg-usd"><%= number_with_precision(htg_usd, precision: 2) %></span> USD
              </div>
            </div>
          </div>

          <%# USD — shows HTG equivalent (moved from Kripto tab for HTG + USD only mode) %>
          <div class="asset-card d-flex align-items-center justify-content-between rounded-3 mb-2 bg-cream" style="padding: 18px;">
            <div class="d-flex align-items-center gap-3">
              <%= usd_logo(size: 36) %>
              <div>
                <div class="fw-bold text-charcoal" style="font-size: 14px;">USD</div>
              </div>
            </div>
            <div class="text-end">
              <div class="fw-black text-charcoal" style="font-size: 14px;">
                <span id="asset-usd-bal"><%= number_with_precision(usd_bal, precision: 2) %></span>
              </div>
              <div class="text-olive text-xs" style="font-weight: 600;">
                ≈ <span id="asset-usd-htg"><%= number_with_precision(usd_htg_val, precision: 2, delimiter: ",") %></span> HTG
              </div>
            </div>
          </div>

      <%# ── "Vin Ajan" promo card — paused while focusing on core wallet actions ── %>
      <% if false && !@is_agent && current_user.bonid_verified? && @business.present? %>
        <div class="rounded-3 p-3 mt-3" style="background: var(--haiti-charcoal);">
          <div class="d-flex align-items-center gap-3">
            <div class="d-flex align-items-center justify-content-center rounded-circle flex-shrink-0"
                 style="width: 40px; height: 40px; background: rgba(197,160,89,0.15);">
              <i class="ri-user-location-line" style="font-size: 20px; color: var(--haiti-gold);"></i>
            </div>
            <div class="flex-grow-1">
              <div class="fw-bold" style="font-size: 13px; color: #fff;">Vin Ajan Zèllus</div>
              <div style="font-size: 10px; color: rgba(255,255,255,0.5);">Touche 2% komisyon sou chak depo lajan kach.</div>
            </div>
            <% if @business.present? %>
              <%= link_to ajan_info_path, class: "btn btn-sm fw-bold rounded-pill px-3 border-0", style: "background: var(--haiti-gold); color: var(--haiti-charcoal); font-size: 11px; white-space: nowrap;" do %>
                Wè <i class="ri-arrow-right-s-line"></i>
              <% end %>
            <% else %>
              <%= link_to new_business_path, class: "btn btn-sm fw-bold rounded-pill px-3 border-0", style: "background: var(--haiti-gold); color: var(--haiti-charcoal); font-size: 11px; white-space: nowrap;" do %>
                Kòmanse <i class="ri-arrow-right-s-line"></i>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <%# ══════════════════════════════════════ %>
    <%# ── KRIPTO TAB — hidden (HTG + USD only mode) ── %>
    <%# ══════════════════════════════════════ %>
    <div id="section-kripto" class="mb-3" style="display: none;">
          <%# wBTC and ETH hidden (HTG + USD only mode) %>
    </div>

    <%# ══════════════════════════════════════ %>
    <%# ── STÒK TAB (Tokenized Stocks)     ── %>
    <%# ══════════════════════════════════════ %>
    <div id="section-stok" class="mb-3" style="display: none;">
      <%# ── Section Header ── %>
      <div class="pt-3 mb-2" style="border-top: 1px solid rgba(93,99,69,0.08);">
        <div style="color: var(--haiti-olive); font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 10px;">
          <i class="ri-stock-line me-1" style="color: var(--haiti-gold);"></i>Stòk Sou Rezo Base
        </div>
      </div>

      <% stock_meta = {
           "tslax"  => { name: "Tesla",     logo: "tslax_logo",  color: "#CC0000", accent: "rgba(204,0,0,0.08)" },
           "nvdax"  => { name: "Nvidia",    logo: "nvdax_logo",  color: "#76B900", accent: "rgba(118,185,0,0.08)" },
           "aaplx"  => { name: "Apple",     logo: "aaplx_logo",  color: "#555555", accent: "rgba(85,85,85,0.08)" },
           "coinx"  => { name: "Coinbase",  logo: "coinx_logo",  color: "#0052FF", accent: "rgba(0,82,255,0.08)" },
           "googlx" => { name: "Alphabet",  logo: "googlx_logo", color: "#4285F4", accent: "rgba(66,133,244,0.08)" }
         } %>
      <% stock_meta.each do |ticker, meta| %>
        <% bal = @wallet.balance_for(ticker) %>
        <% usd_rate = @stock_usd_rates[ticker] || 0 %>
        <% usd_val = bal.to_f * usd_rate.to_f %>
        <div class="stock-card d-flex align-items-center justify-content-between rounded-3 mb-2"
             style="background: <%= meta[:accent] %>; border-left: 3px solid <%= meta[:color] %>; padding: 16px;">
          <div class="d-flex align-items-center gap-3">
            <div class="stock-logo-pulse"><%= send(meta[:logo], size: 38) %></div>
            <div>
              <div class="fw-black" style="color: var(--haiti-charcoal); font-size: 14px;">
                <%= ticker.upcase %>
                <span class="stock-price-tag ms-1" style="background: <%= meta[:accent] %>; color: <%= meta[:color] %>;">
                  $<%= number_with_precision(usd_rate, precision: 2, delimiter: ",") %>
                </span>
              </div>
              <div style="color: var(--haiti-olive); font-size: 10px; font-weight: 600;"><%= meta[:name] %> · Base</div>
            </div>
          </div>
          <div class="text-end">
            <div class="fw-black" style="color: var(--haiti-charcoal); font-size: 14px;">
              <%= number_with_precision(bal, precision: 6, strip_insignificant_zeros: true) %>
            </div>
            <div style="color: var(--haiti-olive); font-size: 10px; font-weight: 600;">
              ≈ $<%= number_with_precision(usd_val, precision: 2, delimiter: ",") %> USD
            </div>
          </div>
        </div>
      <% end %>
