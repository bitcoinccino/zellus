// ── Source Dropdown Toggle ──
function toggleSrcDropdown() {
  var toggle = document.getElementById('wd-src-toggle');
  var menu   = document.getElementById('wd-src-menu');
  var chevron = document.getElementById('wd-src-chevron');
  var isOpen = menu.classList.contains('open');
  toggle.classList.toggle('open', !isOpen);
  menu.classList.toggle('open', !isOpen);
  chevron.style.transform = isOpen ? '' : 'rotate(180deg)';
}

// Close dropdown when clicking outside
document.addEventListener('click', function(e) {
  var dd = document.getElementById('wd-src-dropdown');
  if (dd && !dd.contains(e.target)) {
    document.getElementById('wd-src-toggle').classList.remove('open');
    document.getElementById('wd-src-menu').classList.remove('open');
    document.getElementById('wd-src-chevron').style.transform = '';
  }
});

function selectWdSource(src) {
  currentWdSource = src;

  // Update checkmarks in dropdown
  document.querySelectorAll('.wd-src-option').forEach(function(opt) {
    var check = opt.querySelector('.wd-src-check');
    if (opt.dataset.src === src) {
      opt.classList.add('selected');
      if (check) check.style.visibility = 'visible';
    } else {
      opt.classList.remove('selected');
      if (check) check.style.visibility = 'hidden';
    }
  });

  // Copy selected option's avatar + name + balances into toggle
  var selectedOpt = document.querySelector('.wd-src-option[data-src="' + src + '"]');
  if (selectedOpt) {
    // Avatar
    var avatarSrc = selectedOpt.querySelector('.rounded-circle');
    var avatarContainer = document.getElementById('wd-src-avatar');
    if (avatarSrc && avatarContainer) {
      var clone = avatarSrc.cloneNode(true);
      clone.style.width = '36px';
      clone.style.height = '36px';
      clone.style.minWidth = '36px';
      avatarContainer.innerHTML = clone.outerHTML;
    }
    // Name
    var toggleName = document.getElementById('wd-src-name');
    if (toggleName) toggleName.textContent = selectedOpt.dataset.name || '';

    // Balance line (HTG only)
    var htg = parseInt(selectedOpt.dataset.htg) || 0;
    var balsEl = document.getElementById('wd-src-bals');
    if (balsEl) {
      balsEl.innerHTML = WD_HTG_ICON + ' ' + htg.toLocaleString('fr') + ' HTG';
    }
  }

  // Update hidden source fields
  var sf1 = document.getElementById('wd-source-field');
  var sf2 = document.getElementById('wd-bank-source-field');
  var sf3 = document.getElementById('wd-usd-source-field');
  if (sf1) sf1.value = src;
  if (sf2) sf2.value = src;
  if (sf3) sf3.value = src;

  // Close dropdown
  document.getElementById('wd-src-toggle').classList.remove('open');
  document.getElementById('wd-src-menu').classList.remove('open');
  document.getElementById('wd-src-chevron').style.transform = '';
}

