  nvdax:  <%= @wallet.balance_for('nvdax').to_f %>,
  aaplx:  <%= @wallet.balance_for('aaplx').to_f %>,
  coinx:  <%= @wallet.balance_for('coinx').to_f %>,
  googlx: <%= @wallet.balance_for('googlx').to_f %>
};

// Logo SVGs (inline for JS rendering)
var LOGOS = {
  usdc:   '<%= j usd_logo(size: 48) %>',
  btc:    '<%= j wbtc_base_logo_svg(size: 48) %>',
  eth:    '<%= j eth_base_logo_svg(size: 48) %>',
  tslax:  '<%= j tslax_logo(size: 48) %>',
  nvdax:  '<%= j nvdax_logo(size: 48) %>',
  aaplx:  '<%= j aaplx_logo(size: 48) %>',
  coinx:  '<%= j coinx_logo(size: 48) %>',
  googlx: '<%= j googlx_logo(size: 48) %>'
};

// Market data from CoinMarketCap
var MARKET_DATA = {
<% %w[usdc btc eth tslax nvdax aaplx coinx googlx].each do |key| %>
<% md = @market_data[key] || {} %>
  <%= key %>: {
    market_cap: <%= md[:market_cap] || 0 %>,
    volume_24h: <%= md[:volume_24h] || 0 %>,
    percent_change_24h: <%= md[:percent_change_24h] || 0 %>,
    fdv: <%= md[:fdv] || 0 %>,
    circulating_supply: <%= md[:circulating_supply] || 0 %>,
    total_supply: <%= md[:total_supply] || 0 %>,
    max_supply: <%= md[:max_supply] || 0 %>,
    symbol: '<%= (md[:symbol] || key.upcase.gsub("X","")) %>'
  },
<% end %>
};

var currentAsset = 'usdc';
var changePercents = {};

// Initialize 24h change from real CMC data (fallback to simulated)
Object.keys(ASSETS).forEach(function(k) {
  var md = MARKET_DATA[k];
  if (md && md.percent_change_24h !== 0) {
    changePercents[k] = md.percent_change_24h.toFixed(2);
  } else {
    changePercents[k] = (Math.random() * 2 - 0.5).toFixed(2);
  }
});

// ══════════════════════════════════════
// ── SELECT ASSET                    ──
// ══════════════════════════════════════
function selectAsset(key) {
  // Deactivate old row
  var oldRow = document.getElementById('mkt-row-' + currentAsset);
  if (oldRow) oldRow.classList.remove('active');

  // Activate new row
  currentAsset = key;
  var newRow = document.getElementById('mkt-row-' + key);
  if (newRow) newRow.classList.add('active');

  var asset = ASSETS[key];
  var rate = RATES[asset.rateKey];
  var bal = BALS[asset.balKey] || 0;
  var change = parseFloat(changePercents[key]);
  var isUp = change >= 0;

  // Update header
  document.getElementById('detail-logo').innerHTML = LOGOS[key];
  document.getElementById('detail-name').textContent = asset.name;
  document.getElementById('detail-pair').textContent = asset.pair;

  // Update price
  document.getElementById('detail-price-prefix').textContent = asset.prefix;
  document.getElementById('detail-price-whole').textContent = numberWithDelimiter(Math.floor(rate));
  document.getElementById('detail-price-dec').textContent = ('0' + Math.floor((rate * 100) % 100)).slice(-2);
  document.getElementById('detail-price-unit').textContent = asset.unit === 'HTG' ? ' HTG' : '';

  // Update 24h change badge
  var changeBadge = document.getElementById('detail-change');
  var changeIcon = document.getElementById('detail-change-icon');
  document.getElementById('detail-change-val').textContent = (isUp ? '+' : '') + change + '%';
  changeBadge.style.background = isUp ? 'rgba(34,197,94,0.1)' : 'rgba(239,68,68,0.1)';
  changeBadge.style.color = isUp ? '#22c55e' : '#ef4444';
  changeIcon.className = isUp ? 'ri-arrow-up-line' : 'ri-arrow-down-line';

  // Build detail chart (colors set by up/down in buildDetailChart)
  buildDetailChart(key);

  // Update description + advantage
  document.getElementById('detail-desc').textContent = asset.desc;
  document.getElementById('detail-advantage').textContent = asset.advantage;

  // Update holdings stats
  var balText = bal.toFixed(asset.prec > 2 ? 6 : 2);
  if (asset.prec > 2) balText = parseFloat(balText).toString();
  document.getElementById('stat-balance').textContent = balText + ' ' + key.toUpperCase().replace('X','');

  var value;
  if (key === 'usdc') {
    value = bal * rate;
    document.getElementById('stat-value').textContent = numberWithDelimiter(value.toFixed(0)) + ' HTG';
  } else {
    value = bal * rate;
    document.getElementById('stat-value').textContent = '$' + numberWithDelimiter(value.toFixed(2));
  }

  // Update market stats from CMC
  updateMarketStats(key);

  // Rebuild chart for new asset
  buildDetailChart(key);
}

function numberWithDelimiter(n) {
  return n.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ',');
}

// Format large numbers: T/B/M/K
function formatLargeNumber(n, prefix) {
  prefix = prefix || '$';
  if (!n || n === 0) return '--';
  var abs = Math.abs(n);
  if (abs >= 1e12) return prefix + (n / 1e12).toFixed(2) + 'T';
  if (abs >= 1e9)  return prefix + (n / 1e9).toFixed(2) + 'B';
  if (abs >= 1e6)  return prefix + (n / 1e6).toFixed(2) + 'M';
  if (abs >= 1e3)  return prefix + (n / 1e3).toFixed(2) + 'K';
  return prefix + n.toFixed(2);
}

function formatSupply(n, symbol) {
  if (!n || n === 0) return '--';
  var abs = Math.abs(n);
  var formatted;
  if (abs >= 1e9)  formatted = (n / 1e9).toFixed(2) + 'B';
  else if (abs >= 1e6)  formatted = (n / 1e6).toFixed(2) + 'M';
  else if (abs >= 1e3)  formatted = numberWithDelimiter(Math.round(n));
  else formatted = n.toFixed(2);
  return formatted + (symbol ? ' ' + symbol : '');
}

function updateMarketStats(key) {
  var md = MARKET_DATA[key] || {};
  var sym = md.symbol || key.toUpperCase().replace('X','');

  document.getElementById('stat-market-cap').textContent = formatLargeNumber(md.market_cap);
  document.getElementById('stat-volume-24h').textContent = formatLargeNumber(md.volume_24h);

  // Vol/Mkt Cap ratio
  var ratio = (md.market_cap > 0) ? ((md.volume_24h / md.market_cap) * 100).toFixed(2) : '0.00';
  document.getElementById('stat-vol-mkt-ratio').textContent = ratio + '%';

  document.getElementById('stat-fdv').textContent = formatLargeNumber(md.fdv);
  document.getElementById('stat-circulating').textContent = formatSupply(md.circulating_supply, sym);
  document.getElementById('stat-max-supply').textContent = md.max_supply > 0 ? formatSupply(md.max_supply, sym) : '∞';
}

// ══════════════════════════════════════
// ── LIVE TICKER                     ──
// ══════════════════════════════════════
var interval = 600;

function microTick() {
  var keys = ['usdc','btc','eth','tslax','nvdax','aaplx','coinx','googlx'];
  keys.forEach(function(k) { tickRate(k); });

  // Update detail panel price if it matches current asset
  var asset = ASSETS[currentAsset];
  var rate = RATES[asset.rateKey];
  document.getElementById('detail-price-whole').textContent = numberWithDelimiter(Math.floor(rate));
  document.getElementById('detail-price-dec').textContent = ('0' + Math.floor((rate * 100) % 100)).slice(-2);

  // Update value stat
  var bal = BALS[asset.balKey] || 0;
  if (currentAsset === 'usdc') {
    document.getElementById('stat-value').textContent = numberWithDelimiter((bal * rate).toFixed(0)) + ' HTG';
  } else {
    document.getElementById('stat-value').textContent = '$' + numberWithDelimiter((bal * rate).toFixed(2));
  }
}

function tickRate(key) {
  var decEl   = document.getElementById('rate-' + key + '-dec');
  var arrowEl = document.getElementById('rate-' + key + '-arrow');
  if (!decEl) return;

  var rateMap = {
    usdc: 'usdc_htg', btc: 'btc_usd', eth: 'eth_usd',
    tslax: 'tslax_usd', nvdax: 'nvdax_usd', aaplx: 'aaplx_usd',
    coinx: 'coinx_usd', googlx: 'googlx_usd'
  };

  var oldDec = parseInt(decEl.textContent);
  var centDelta = Math.floor(Math.random() * 3 + 1) * (Math.random() < 0.5 ? -1 : 1);
  var targetDec = Math.max(0, Math.min(99, oldDec + centDelta));
  var up = targetDec > oldDec;

  if (arrowEl) {
    arrowEl.style.opacity = '1';
    arrowEl.className = 'tick-arrow ' + (up ? 'up' : 'down');
    arrowEl.innerHTML = up ? '&#9650;' : '&#9660;';
    setTimeout(function() { arrowEl.style.opacity = '0'; }, 2200);
  }

  var current = oldDec;
  var step = up ? 1 : -1;
  var steps = Math.abs(targetDec - oldDec);
  if (steps === 0) return;

  var counter = 0;
  var timer = setInterval(function() {
    current += step;
    decEl.textContent = ('0' + current).slice(-2);
    decEl.className = 'tick-decimals ' + (up ? 'tick-up' : 'tick-down');
    counter++;
    if (counter >= steps) {
      clearInterval(timer);
      setTimeout(function() { decEl.className = 'tick-decimals'; }, 800);
    }
  }, interval);

  if (rateMap[key]) {
    var whole = Math.floor(RATES[rateMap[key]]);
    RATES[rateMap[key]] = whole + targetDec / 100;
  }
}

// ══════════════════════════════════════
// ── SPARKLINE ENGINE (Robinhood)    ──
// ══════════════════════════════════════
var SPARK_W = 80, SPARK_H = 28, SPARK_MAX = 30;
var DETAIL_W = 500, DETAIL_H = 135;
var sparkData = {};
var chartDataCache = {};  // { key: { live:[], '1d':[], '1w':[], '1m':[], '3m':[], '1y':[] } }
var currentPeriod = '1y';
var sparkKeys = ['usdc','btc','eth','tslax','nvdax','aaplx','coinx','googlx'];
var sparkRateKeys = {
  usdc: 'usdc_htg', btc: 'btc_usd', eth: 'eth_usd',
  tslax: 'tslax_usd', nvdax: 'nvdax_usd', aaplx: 'aaplx_usd',
  coinx: 'coinx_usd', googlx: 'googlx_usd'
};

// Month/time label abbreviations
var MONTHS = ['Jan','Fev','Mas','Avr','Me','Jen','Jiy','Out','Sep','Okt','Nov','Des'];

// Volatility per asset
var VOLATILITY = {
  usdc: 0.0008, btc: 0.025, eth: 0.03,
  tslax: 0.02, nvdax: 0.025, aaplx: 0.015,
  coinx: 0.03, googlx: 0.015
};

// ── Generate jagged price data (Robinhood-style: many data points, no smoothing) ──
function generatePriceData(base, count, vol, isStable) {
  var pts = [];
  if (isStable) {
    for (var i = 0; i < count; i++) pts.push(base * (1 + (Math.random() - 0.5) * 0.003));
    return pts;
  }
  // Random walk with mean reversion toward current price
  var startFactor = { 365: 0.65, 90: 0.8, 30: 0.88, 7: 0.95, 288: 0.98, 60: 0.995 };
  var sf = startFactor[count] || 0.8;
  var price = base * (sf + Math.random() * (1 - sf));
  for (var i = 0; i < count; i++) {
    var progress = i / (count - 1);
    var target = price + (base - price) * 0.015;
    var noise = (Math.random() - 0.5) * vol * price * 2;
    price = target + noise;
    if (price < base * 0.15) price = base * 0.2;
    pts.push(price);
  }
  // Last point = current price
  pts[count - 1] = base;
  return pts;
}

// Data point counts per period
var PERIOD_POINTS = { live: 60, '1d': 288, '1w': 168, '1m': 30, '3m': 90, '1y': 365 };

// Labels config per period
var PERIOD_LABELS = {
  live:  { count: 5, gen: function() { var labels = []; var d = new Date(); for (var i = 4; i >= 0; i--) { var m = d.getMinutes() - i * 12; var h = d.getHours(); if (m < 0) { m += 60; h--; } labels.push(('0'+h).slice(-2)+':'+('0'+(m<0?0:m)).slice(-2)); } return labels; } },
  '1d':  { count: 6, gen: function() { return ['9:30','11:00','12:30','14:00','15:30','16:00']; } },
  '1w':  { count: 5, gen: function() { var labels = []; var days = ['Dim','Len','Mad','Mèk','Jed','Van','Sam']; var d = new Date(); for (var i = 6; i >= 0; i -= 2) { var dd = new Date(d); dd.setDate(d.getDate() - i); labels.push(days[dd.getDay()]); } return labels; } },
  '1m':  { count: 5, gen: function() { var labels = []; var d = new Date(); for (var i = 4; i >= 0; i--) { var dd = new Date(d); dd.setDate(d.getDate() - i * 7); labels.push(dd.getDate() + ' ' + MONTHS[dd.getMonth()].substring(0,3)); } return labels; } },
  '3m':  { count: 4, gen: function() { var labels = []; var d = new Date(); for (var i = 3; i >= 0; i--) { var dd = new Date(d); dd.setMonth(d.getMonth() - i); labels.push(MONTHS[dd.getMonth()]); } return labels; } },
  '1y':  { count: 12, gen: function() { var labels = []; var d = new Date(); for (var i = 11; i >= 0; i--) { var dd = new Date(d); dd.setMonth(d.getMonth() - i); labels.push(MONTHS[dd.getMonth()]); } return labels; } }
};

// Initialize all chart data for all assets & periods
sparkKeys.forEach(function(k) {
  var base = RATES[sparkRateKeys[k]];
  var isStable = k === 'usdc';
  var vol = VOLATILITY[k] || 0.02;

  // Small sparkline for left list
  var pts = [];
  for (var i = 0; i < 15; i++) pts.push(base * (1 + (Math.random() - 0.5) * 0.004));
  sparkData[k] = pts;

  // Detail chart data per period
  chartDataCache[k] = {};
  Object.keys(PERIOD_POINTS).forEach(function(p) {
    chartDataCache[k][p] = generatePriceData(base, PERIOD_POINTS[p], vol, isStable);
  });
});

// ── Build small sparkline (left column rows) ──
function buildSparkPath(key) {
  var pts = sparkData[key];
  if (!pts || pts.length < 2) return;
  var lineEl = document.getElementById('spark-' + key + '-line');
  var areaEl = document.getElementById('spark-' + key + '-area');
  if (!lineEl) return;

  var min = Math.min.apply(null, pts);
  var max = Math.max.apply(null, pts);
  var range = max - min || 1;
  var stepX = SPARK_W / (pts.length - 1);

  var lineParts = [];
  var areaParts = ['M0,' + SPARK_H];
  for (var i = 0; i < pts.length; i++) {
    var x = (i * stepX).toFixed(1);
    var y = (SPARK_H - ((pts[i] - min) / range) * (SPARK_H - 2) - 1).toFixed(1);
    lineParts.push((i === 0 ? 'M' : 'L') + x + ',' + y);
    areaParts.push('L' + x + ',' + y);
  }
  areaParts.push('L' + SPARK_W + ',' + SPARK_H + 'Z');

  lineEl.setAttribute('d', lineParts.join(''));
  areaEl.setAttribute('d', areaParts.join(''));
}

// ── Build detail chart (Robinhood style) ──
function buildDetailChart(key) {
  var data = chartDataCache[key];
  if (!data) return;
  var pts = data[currentPeriod];
  if (!pts || pts.length < 2) return;

  var lineEl = document.getElementById('detail-spark-line');
  var areaEl = document.getElementById('detail-spark-area');
  var refLine = document.getElementById('chart-ref-line');
  var endDot  = document.getElementById('chart-end-dot');
  if (!lineEl) return;

  var chartH = DETAIL_H;
  var min = Math.min.apply(null, pts);
  var max = Math.max.apply(null, pts);
  var range = max - min || 1;
  // Add 5% padding
  min = min - range * 0.05;
  max = max + range * 0.05;
  range = max - min;
  if (range === 0) range = 1;
  var stepX = DETAIL_W / (pts.length - 1);

  // Determine if price went up or down over period
  var openPrice = pts[0];
  var closePrice = pts[pts.length - 1];
  var isUp = closePrice >= openPrice;
  var lineColor = isUp ? '#22c55e' : '#ef4444';
  var gradAlpha = isUp ? '34,197,94' : '239,68,68';

  // Set line + gradient color
  lineEl.setAttribute('stroke', lineColor);
  document.getElementById('detail-grad-start').setAttribute('stop-color', 'rgba(' + gradAlpha + ',0.12)');
  document.getElementById('detail-grad-end').setAttribute('stop-color', 'rgba(' + gradAlpha + ',0)');

  // Build path
  var lineParts = [];
  var areaParts = ['M0,' + chartH];
  var lastX, lastY;
  for (var i = 0; i < pts.length; i++) {
    var x = (i * stepX).toFixed(1);
    var y = (chartH - ((pts[i] - min) / range) * (chartH - 8) - 4).toFixed(1);
    lineParts.push((i === 0 ? 'M' : 'L') + x + ',' + y);
    areaParts.push('L' + x + ',' + y);
    lastX = x; lastY = y;
  }
  areaParts.push('L' + DETAIL_W + ',' + chartH + 'Z');

  lineEl.setAttribute('d', lineParts.join(''));
  areaEl.setAttribute('d', areaParts.join(''));

  // Reference dotted line at opening price
  if (refLine) {
    var refY = (chartH - ((openPrice - min) / range) * (chartH - 8) - 4).toFixed(1);
    refLine.setAttribute('y1', refY);
    refLine.setAttribute('y2', refY);
  }

  // End dot at last price
  if (endDot) {
    endDot.setAttribute('cx', lastX);
    endDot.setAttribute('cy', lastY);
    endDot.setAttribute('fill', lineColor);
  }

  // Draw time labels on x-axis
  var labelsG = document.getElementById('chart-month-labels');
  if (labelsG) {
    labelsG.innerHTML = '';
    var labelCfg = PERIOD_LABELS[currentPeriod];
    if (labelCfg) {
      var labels = labelCfg.gen();
      for (var m = 0; m < labels.length; m++) {
        var xPos = (m / (labels.length - 1)) * DETAIL_W;
        var text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        text.setAttribute('x', xPos.toFixed(0));
        text.setAttribute('y', (chartH + 18).toString());
        text.setAttribute('text-anchor', m === 0 ? 'start' : (m === labels.length - 1 ? 'end' : 'middle'));
        text.textContent = labels[m];
        labelsG.appendChild(text);
      }
    }
  }
}

// ── Switch time period ──
function switchPeriod(period) {
  currentPeriod = period;
  // Update active tab
  var tabs = document.querySelectorAll('.chart-period-tab');
  tabs.forEach(function(tab) { tab.classList.remove('active'); });
  var labels = { live: 'LIVE', '1d': '1J', '1w': '1S', '1m': '1M', '3m': '3M', '1y': '1A' };
  tabs.forEach(function(tab) {
    if (tab.textContent.trim().replace(/\s/g,'').indexOf(labels[period]) >= 0 ||
        (period === 'live' && tab.textContent.indexOf('LIVE') >= 0)) {
      tab.classList.add('active');
    }
  });
  buildDetailChart(currentAsset);
}

function sparkTick() {
  sparkKeys.forEach(function(k) {
    var val = RATES[sparkRateKeys[k]];
    sparkData[k].push(val);
    if (sparkData[k].length > SPARK_MAX) sparkData[k].shift();
    buildSparkPath(k);

    // Push live price into live data
    if (chartDataCache[k] && chartDataCache[k].live) {
      chartDataCache[k].live.push(val);
      if (chartDataCache[k].live.length > 120) chartDataCache[k].live.shift();
    }
  });
  if (currentPeriod === 'live') buildDetailChart(currentAsset);
}

// ── Initialize ──
sparkKeys.forEach(function(k) { buildSparkPath(k); });
buildDetailChart('usdc');
updateMarketStats('usdc');

// Tick every 4 seconds
setInterval(function() { microTick(); sparkTick(); }, 4000);
setTimeout(function() { microTick(); sparkTick(); }, 2000);

// Slowly drift 24h change percentages (micro drift around real CMC value)
setInterval(function() {
  Object.keys(changePercents).forEach(function(k) {
    var old = parseFloat(changePercents[k]);
    changePercents[k] = (old + (Math.random() * 0.04 - 0.02)).toFixed(2);
  });
  // Update current detail panel change badge
  var c = parseFloat(changePercents[currentAsset]);
  var isUp = c >= 0;
  document.getElementById('detail-change-val').textContent = (isUp ? '+' : '') + c + '%';
  var badge = document.getElementById('detail-change');
  badge.style.background = isUp ? 'rgba(34,197,94,0.1)' : 'rgba(239,68,68,0.1)';
  badge.style.color = isUp ? '#22c55e' : '#ef4444';
  document.getElementById('detail-change-icon').className = isUp ? 'ri-arrow-up-line' : 'ri-arrow-down-line';
}, 8000);
</script>
