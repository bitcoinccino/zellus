<style>
  /* ── Robinhood flickering decimals ── */
  @keyframes flashGreen { 0% { color: #22c55e; } 100% { color: inherit; } }
  @keyframes flashRed   { 0% { color: #ef4444; } 100% { color: inherit; } }
  .tick-up   { animation: flashGreen 0.8s ease; }
  .tick-down { animation: flashRed 0.8s ease; }
  .tick-arrow { font-size: 10px; font-weight: 800; margin-left: 3px; transition: opacity 0.3s ease; }
  .tick-arrow.up   { color: #22c55e; }
  .tick-arrow.down { color: #ef4444; }

  /* ── LIVE badge pulse ── */
  @keyframes livePulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
  .live-badge { animation: livePulse 1.5s ease-in-out infinite; }

  /* ── Rate row ── */
  .mkt-row { transition: all 0.15s ease; border-radius: 12px; padding: 10px 12px; margin: 0 -12px; cursor: pointer; border-left: 3px solid transparent; }
  .mkt-row:hover { background: rgba(255,255,255,0.04); }
  .mkt-row.active { background: rgba(197,160,89,0.08); border-left-color: var(--haiti-gold); }

  /* ── Detail panel transitions ── */
  .detail-panel { transition: all 0.25s ease; }
  .detail-stat { background: var(--haiti-cream); border-radius: 14px; padding: 14px; }

  /* ── Time period tabs (Robinhood style) ── */
  .chart-period-tabs { display: flex; gap: 4px; justify-content: center; padding: 8px 0 2px; }
  .chart-period-tab {
    font-size: 11px; font-weight: 700; color: rgba(255,255,255,0.35);
    background: transparent; border: none; padding: 5px 12px; border-radius: 16px;
    cursor: pointer; transition: all 0.2s ease; letter-spacing: 0.3px;
  }
  .chart-period-tab:hover { color: rgba(255,255,255,0.6); }
  .chart-period-tab.active { background: rgba(197,160,89,0.25); color: var(--haiti-gold); }

  /* ── Chart dot pulse ── */
  @keyframes dotPulse { 0%, 100% { r: 3; opacity: 1; } 50% { r: 5; opacity: 0.6; } }
  .chart-dot { animation: dotPulse 2s ease-in-out infinite; }
</style>

<% usdc_htg = @sell_rate || 135.50 %>
<% btc_usd  = @btc_usd_rate || 95000.0 %>
<% eth_usd  = @eth_usd_rate || 3500.0 %>

<% stock_tickers = {
     "tslax"  => { name: "TSLA", full: "Tesla",    logo: "tslax_logo",  color: "#CC0000", spark_color: "204,0,0" },
     "nvdax"  => { name: "NVDA", full: "Nvidia",   logo: "nvdax_logo",  color: "#76B900", spark_color: "118,185,0" },
     "aaplx"  => { name: "AAPL", full: "Apple",    logo: "aaplx_logo",  color: "#999",    spark_color: "153,153,153" },
     "coinx"  => { name: "COIN", full: "Coinbase", logo: "coinx_logo",  color: "#0052FF", spark_color: "0,82,255" },
     "googlx" => { name: "GOOG", full: "Alphabet", logo: "googlx_logo", color: "#4285F4", spark_color: "66,133,244" }
   } %>

<div class="container" style="padding-top: 24px; padding-bottom: 40px;">

  <%# ── Page Header ── %>
  <div class="d-flex align-items-center justify-content-between mb-4">
    <div class="d-flex align-items-center gap-2">
      <h1 class="h5 fw-black mb-0" style="color: var(--haiti-charcoal);">
        <i class="ri-line-chart-line me-1" style="color: var(--haiti-gold);"></i>Mache Dechanj
      </h1>
      <span class="live-badge d-inline-flex align-items-center gap-1 rounded-pill px-2" style="background: rgba(34,197,94,0.15); font-size: 8px; font-weight: 700; color: #22c55e;">
        <span style="width: 5px; height: 5px; border-radius: 50%; background: #22c55e; display: inline-block;"></span> LIVE
      </span>
    </div>
    <%= link_to wallet_path, class: "small text-decoration-none fw-bold", style: "color: var(--haiti-olive);" do %>
      <i class="ri-arrow-left-line me-1"></i>Pòtfèy
    <% end %>
  </div>

  <div class="row g-4">

    <%# ══════════════════════════════════════════ %>
    <%# ── LEFT COLUMN: Combined Rates Card    ── %>
    <%# ══════════════════════════════════════════ %>
    <div class="col-lg-5">
      <div class="p-4 rounded-4" style="background: var(--haiti-charcoal);">

        <%# ── Kripto Header ── %>
        <div class="mb-2" style="color: rgba(255,255,255,0.3); font-size: 9px; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase;">
          <i class="ri-coin-line" style="font-size: 10px;"></i> Kripto
        </div>

        <%# USDC/HTG %>
        <div class="mkt-row active d-flex align-items-center justify-content-between mb-1" onclick="selectAsset('usdc')" id="mkt-row-usdc">
          <div class="d-flex align-items-center gap-2" style="color: rgba(255,255,255,0.6); font-size: 11px; font-weight: 600;">
            <%= usd_logo(size: 18) %> USD/HTG
            <span id="rate-usdc-arrow" class="tick-arrow" style="opacity: 0;"></span>
          </div>
          <div class="d-flex align-items-center gap-3">
            <svg id="spark-usdc" width="80" height="28" style="overflow: visible;">
              <defs><linearGradient id="sg-usdc" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="rgba(197,160,89,0.3)"/><stop offset="100%" stop-color="rgba(197,160,89,0)"/></linearGradient></defs>
              <path id="spark-usdc-area" fill="url(#sg-usdc)"/><path id="spark-usdc-line" fill="none" stroke="#C5A059" stroke-width="1.5"/>
            </svg>
            <div class="fw-black" style="color: #fff; font-size: 20px;">
              <span id="rate-usdc-whole"><%= usdc_htg.floor.to_i %></span>.<span id="rate-usdc-dec" class="tick-decimals"><%= "%02d" % ((usdc_htg * 100).floor % 100) %></span>
              <span style="color: rgba(255,255,255,0.4); font-size: 10px;">HTG</span>
            </div>
          </div>
        </div>

        <%# BTC/USD, ETH/USD, and Aksyon Tokenize hidden (HTG + USD only mode) %>

      </div>
    </div>

    <%# ══════════════════════════════════════════ %>
    <%# ── RIGHT COLUMN: Asset Detail Panel    ── %>
    <%# ══════════════════════════════════════════ %>
    <div class="col-lg-7">
      <div class="detail-panel p-4 rounded-4" style="background: white; border: 1.5px solid rgba(93,99,69,0.15);">

        <%# ── Asset Header ── %>
        <div class="d-flex align-items-center justify-content-between mb-3">
          <div class="d-flex align-items-center gap-3">
            <div id="detail-logo" style="width: 48px; height: 48px; display: flex; align-items: center; justify-content: center;">
              <%= usd_logo(size: 48) %>
            </div>
            <div>
              <div class="fw-black" id="detail-name" style="color: var(--haiti-charcoal); font-size: 20px;">USD</div>
              <div id="detail-pair" style="color: var(--haiti-olive); font-size: 12px; font-weight: 600;">USD/HTG</div>
            </div>
          </div>
          <div class="text-end">
            <div class="fw-black" id="detail-price" style="color: var(--haiti-charcoal); font-size: 28px;">
              <span id="detail-price-prefix"></span><span id="detail-price-whole"><%= usdc_htg.floor.to_i %></span>.<span id="detail-price-dec" class="tick-decimals"><%= "%02d" % ((usdc_htg * 100).floor % 100) %></span>
              <span id="detail-price-unit" style="color: var(--haiti-olive); font-size: 13px;">HTG</span>
            </div>
            <div id="detail-change" class="d-inline-flex align-items-center gap-1 rounded-pill px-2 py-1" style="background: rgba(34,197,94,0.1); font-size: 11px; font-weight: 700; color: #22c55e;">
              <i class="ri-arrow-up-line" id="detail-change-icon" style="font-size: 12px;"></i>
              <span id="detail-change-val">+0.42%</span>
            </div>
          </div>
        </div>

        <%# ── Robinhood-style Price Chart ── %>
        <div class="rounded-3 p-3 mb-3" style="background: var(--haiti-charcoal);">
          <%# ── Chart area ── %>
          <svg id="detail-spark" width="100%" height="150" viewBox="0 0 500 165" preserveAspectRatio="none" style="overflow: visible;">
            <defs>
              <linearGradient id="sg-detail" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" id="detail-grad-start" stop-color="rgba(197,160,89,0.15)"/>
                <stop offset="100%" id="detail-grad-end" stop-color="rgba(197,160,89,0)"/>
              </linearGradient>
            </defs>
            <%# ── Reference dotted line (opening price) ── %>
            <line id="chart-ref-line" x1="0" y1="60" x2="500" y2="60" stroke="rgba(255,255,255,0.12)" stroke-width="1" stroke-dasharray="3,4"/>
            <path id="detail-spark-area" fill="url(#sg-detail)"/>
            <path id="detail-spark-line" fill="none" stroke="#C5A059" stroke-width="1.5"/>
            <%# ── Current price dot ── %>
            <circle id="chart-end-dot" class="chart-dot" cx="500" cy="60" r="3" fill="#C5A059"/>
            <%# ── Time labels on x-axis ── %>
            <g id="chart-month-labels" style="font-size: 9px; fill: rgba(255,255,255,0.25); font-weight: 600;">
            </g>
          </svg>

          <%# ── Period tabs ── %>
          <div class="chart-period-tabs">
            <button class="chart-period-tab" onclick="switchPeriod('live')">
              <span style="width: 5px; height: 5px; border-radius: 50%; background: #22c55e; display: inline-block; margin-right: 3px;"></span>LIVE
            </button>
            <button class="chart-period-tab" onclick="switchPeriod('1d')">1J</button>
            <button class="chart-period-tab" onclick="switchPeriod('1w')">1S</button>
            <button class="chart-period-tab" onclick="switchPeriod('1m')">1M</button>
            <button class="chart-period-tab" onclick="switchPeriod('3m')">3M</button>
            <button class="chart-period-tab active" onclick="switchPeriod('1y')">1A</button>
          </div>
        </div>

        <%# ── Your Holdings ── %>
        <div class="pt-3 mb-3" style="border-top: 1px solid rgba(93,99,69,0.08);">
          <div style="color: var(--haiti-olive); font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 12px;">
            <i class="ri-briefcase-4-line me-1" style="color: var(--haiti-gold);"></i>Pòtfèy Mwen
          </div>
          <div class="row g-3">
            <div class="col-6">
              <div class="detail-stat text-center" style="padding: 20px;">
                <div style="color: var(--haiti-olive); font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px;">
                  <i class="ri-wallet-3-line me-1" style="color: var(--haiti-gold);"></i>Balans Ou
                </div>
                <div class="fw-black" id="stat-balance" style="color: var(--haiti-charcoal); font-size: 18px;"><%= number_with_precision(@wallet.balance_for('usdc'), precision: 2) %></div>
              </div>
            </div>
            <div class="col-6">
              <div class="detail-stat text-center" style="padding: 20px;">
                <div style="color: var(--haiti-olive); font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px;">
                  <i class="ri-exchange-dollar-line me-1" style="color: var(--haiti-gold);"></i>Valè
                </div>
                <div class="fw-black" id="stat-value" style="color: var(--haiti-charcoal); font-size: 18px;"><%= number_to_currency(@wallet.balance_for('usdc').to_f * usdc_htg, unit: "", precision: 0) %> HTG</div>
              </div>
            </div>
          </div>
        </div>

        <%# ── Market Stats (from CoinMarketCap) ── %>
        <div class="pt-3 mb-3" style="border-top: 1px solid rgba(93,99,69,0.08);">
          <div style="color: var(--haiti-olive); font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 12px;">
            <i class="ri-bar-chart-box-line me-1" style="color: var(--haiti-gold);"></i>Estatistik Mache
          </div>
          <div class="row g-3">
            <div class="col-4">
              <div class="detail-stat text-center" style="padding: 16px;">
                <div style="color: var(--haiti-olive); font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.3px; margin-bottom: 5px;">Market Cap</div>
                <div class="fw-black" id="stat-market-cap" style="color: var(--haiti-charcoal); font-size: 15px;">$0</div>
              </div>
            </div>
            <div class="col-4">
              <div class="detail-stat text-center" style="padding: 16px;">
                <div style="color: var(--haiti-olive); font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.3px; margin-bottom: 5px;">Volim 24è</div>
                <div class="fw-black" id="stat-volume-24h" style="color: var(--haiti-charcoal); font-size: 15px;">$0</div>
              </div>
            </div>
            <div class="col-4">
              <div class="detail-stat text-center" style="padding: 16px;">
                <div style="color: var(--haiti-olive); font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.3px; margin-bottom: 5px;">Vol/Mkt Cap</div>
                <div class="fw-black" id="stat-vol-mkt-ratio" style="color: var(--haiti-charcoal); font-size: 15px;">0%</div>
              </div>
            </div>
            <div class="col-4">
              <div class="detail-stat text-center" style="padding: 16px;">
                <div style="color: var(--haiti-olive); font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.3px; margin-bottom: 5px;">FDV</div>
                <div class="fw-black" id="stat-fdv" style="color: var(--haiti-charcoal); font-size: 15px;">$0</div>
              </div>
            </div>
            <div class="col-4">
              <div class="detail-stat text-center" style="padding: 16px;">
                <div style="color: var(--haiti-olive); font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.3px; margin-bottom: 5px;">Sikilasyon</div>
                <div class="fw-black" id="stat-circulating" style="color: var(--haiti-charcoal); font-size: 15px;">0</div>
              </div>
            </div>
            <div class="col-4">
              <div class="detail-stat text-center" style="padding: 16px;">
                <div style="color: var(--haiti-olive); font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.3px; margin-bottom: 5px;">Maks. Sipòt</div>
                <div class="fw-black" id="stat-max-supply" style="color: var(--haiti-charcoal); font-size: 15px;">--</div>
              </div>
            </div>
          </div>
        </div>

        <%# ── Description + Advantage ── %>
        <div class="pt-3 mb-4" style="border-top: 1px solid rgba(93,99,69,0.08);">
          <div class="p-3 rounded-3" style="background: rgba(93,99,69,0.05); border: 1px solid rgba(93,99,69,0.1);">
            <div class="mb-2">
              <div style="color: var(--haiti-olive); font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px;">
                <i class="ri-information-line me-1" style="color: var(--haiti-gold);"></i>Kisa li ye?
              </div>
              <div id="detail-desc" style="color: var(--haiti-charcoal); font-size: 13px; line-height: 1.5; font-weight: 500;">
                USD se dola ameriken dijital ki toujou vo 1 dola. Li pèmèt ou voye ak resevwa lajan san fwontyè, san ou pa bezwen yon kont labank tradisyonèl.
              </div>
            </div>
            <hr class="my-2" style="border-color: rgba(93,99,69,0.1);">
            <div>
              <div style="color: var(--haiti-olive); font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px;">
                <i class="ri-star-line me-1" style="color: var(--haiti-gold);"></i>Avantaj
              </div>
              <div id="detail-advantage" style="color: var(--haiti-charcoal); font-size: 13px; line-height: 1.5; font-weight: 500;">
                Estab tankou dola, tranzaksyon rapid sou blockchain Base, frè ba, epi ou ka konvèti l an HTG nenpòt lè.
              </div>
            </div>
          </div>
        </div>

        <%# ── Action Button ── %>
        <%= link_to wallet_path, class: "btn w-100 fw-bold rounded-pill border-0 d-flex align-items-center justify-content-center gap-2",
            style: "background: var(--haiti-charcoal); color: var(--haiti-gold); font-size: 15px; padding: 14px 24px; letter-spacing: 0.3px;" do %>
          <i class="ri-swap-line" style="font-size: 18px;"></i>Konvèti
        <% end %>

      </div>
    </div>

  </div>
</div>

<script>
