<div style="margin-bottom:20px;">
  <div style="font-size:15px; font-weight:800; color:#166534; margin-bottom:6px;">Ou Resevwa Lajan! ✓</div>
  <div style="font-size:13px; color:#5D6345;"><%= @sender_name %> te voye lajan ba ou ak Priotelus Zèllus.</div>
</div>

<div style="background:#dcfce7; border:2px solid #166534; border-radius:14px; padding:16px; margin-bottom:16px; text-align:center;">
  <div style="color:#166534; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:1px; margin-bottom:8px;">Ou Resevwa</div>
  <div style="color:#166534; font-size:28px; font-weight:900; letter-spacing:-1px;">
    <% if @transfer.crypto_transfer? && @transfer.crypto_amount.present? %>
      <%= @transfer.crypto_amount %> <%= @transfer.asset_label %>
    <% else %>
      HTG <%= format('%.0f', @transfer.net_amount.to_f) %>
    <% end %>
  </div>
  <div style="margin-top:4px;">
    <span style="display:inline-block; background:#2E2E38; color:#C5A059; font-size:10px; font-weight:800; padding:3px 10px; border-radius:10px; letter-spacing:0.5px;">
      <%= @transfer.htg_transfer? ? "MONCASH" : "REZO BASE · #{@transfer.asset_label}" %>
    </span>
  </div>
</div>

<div style="font-size:13px; color:#5D6345; line-height:1.6;">
  <% if @transfer.htg_transfer? %>
    Lajan an disponib nan kont MonCash ou kounye a. Mèsi pou konfyans ou nan Priotelus!
  <% else %>
    Lajan an nan pòtfèy ou sou rezo Base kounye a. Mèsi pou konfyans ou nan Priotelus!
  <% end %>
</div>
