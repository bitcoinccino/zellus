<div style="margin-bottom:20px;">
  <div style="font-size:15px; font-weight:800; color:#2E2E38; margin-bottom:6px;">Ou Peye <%= @receiver_display %> ~ <%= @amount_display %></div>
  <div style="font-size:13px; color:#5D6345;">Transfè #<%= @transfer.token %> — <%= @transfer.created_at.strftime("%b %d, %Y %l:%M %p").strip %></div>
</div>

<div style="background:#E8EDE0; border:2px solid #5D6345; border-radius:14px; padding:16px; margin-bottom:16px;">
  <table width="100%" cellspacing="0" cellpadding="0">
    <tr>
      <td style="color:#5D6345; font-size:12px; font-weight:600; padding-bottom:8px;">Montan Voye</td>
      <td style="color:#2E2E38; font-weight:800; text-align:right; padding-bottom:8px;"><%= @amount_display %></td>
    </tr>
    <tr>
      <td style="color:#5D6345; font-size:12px; font-weight:600; padding-bottom:8px;">Frè</td>
      <td style="font-weight:700; text-align:right; padding-bottom:8px; color:<%= @is_usdc_wallet ? '#166534' : '#D8000C' %>;">
        <%= @fee_display %>
      </td>
    </tr>
    <tr>
      <td colspan="2" style="border-top:1px dashed #5D6345; padding-top:10px;"></td>
    </tr>
    <tr>
      <td style="color:#2E2E38; font-size:13px; font-weight:900; text-transform:uppercase;">Moun ou peye ya:<br><span style="font-size:10px; font-weight:400; color:#5D6345; text-transform:none;"><%= @receiver_type %></span></td>
      <td style="color:#C5A059; font-size:18px; font-weight:900; text-align:right;"><%= @net_display %></td>
    </tr>
  </table>
</div>

<% if @is_usdc_wallet %>
  <div style="background:#f0fdf4; border:1px solid #bbf7d0; border-radius:12px; padding:12px; margin-bottom:16px;">
    <div style="color:#166534; font-size:12px; font-weight:600;">⚡ Transfè Zèllus · USD — Gratis &amp; Enstantane</div>
  </div>
<% elsif @is_crypto %>
  <div style="background:#fcfcf9; border:1px solid #d9d6c4; border-radius:12px; padding:12px; margin-bottom:16px;">
    <div style="color:#5D6345; font-size:12px; font-weight:600;">🔗 N ap voye sou rezo Base...</div>
  </div>
<% end %>

<div style="font-size:13px; color:#5D6345; line-height:1.6;">
  N ap trete transfè ou kounye a. Ou ap resevwa yon lòt imèl lè transfè a konplete.
</div>

<% if @claim_url.present? && @transfer.receiver_email.blank? %>
  <div style="margin-top:16px; background:#fcfcf9; border:1px dashed #5D6345; border-radius:12px; padding:12px;">
    <div style="color:#5D6345; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:1px; margin-bottom:6px;">Lyen Reklame</div>
    <div style="color:#2E2E38; font-size:12px; word-break:break-all;"><%= @claim_url %></div>
  </div>
<% end %>
