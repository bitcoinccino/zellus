<div style="margin-bottom:20px;">
  <div style="font-size:15px; font-weight:800; color:#166534; margin-bottom:6px;">Ou Peye <%= @receiver_display %> ✓</div>
  <div style="font-size:13px; color:#5D6345;">Transfè #<%= @transfer.token %> — <%= @transfer.completed_at&.strftime("%b %d, %Y %l:%M %p")&.strip || @transfer.updated_at.strftime("%b %d, %Y") %></div>
</div>

<div style="background:#dcfce7; border:2px solid #166534; border-radius:14px; padding:16px; margin-bottom:16px;">
  <table width="100%" cellspacing="0" cellpadding="0">
    <tr>
      <td style="color:#166534; font-size:12px; font-weight:600; padding-bottom:8px;">Montan Voye</td>
      <td style="color:#2E2E38; font-weight:800; text-align:right; padding-bottom:8px;"><%= @amount_display %></td>
    </tr>
    <tr>
      <td colspan="2" style="border-top:1px dashed #166534; padding-top:10px;"></td>
    </tr>
    <tr>
      <td style="color:#166534; font-size:12px; font-weight:600;">Moun ou peye ya:<br><span style="font-size:10px; font-weight:400; color:#5D6345;"><%= @receiver_type %></span></td>
      <td style="color:#2E2E38; font-weight:800; text-align:right;">
        <%= @transfer.receiver_name.presence || @receiver_display %><% if @transfer.receiver_name.present? && @receiver_display != "—" %><br><span style="font-size:11px; font-weight:600; color:#5D6345;"><%= @receiver_display %></span><% end %>
      </td>
    </tr>
  </table>
</div>

<% if @basescan_url.present? %>
  <div style="background:#fff; border:1px solid #d9d6c4; border-radius:12px; padding:12px; margin-bottom:16px;">
    <div style="color:#5D6345; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:1px; margin-bottom:6px;">TX Blockchain</div>
    <div style="color:#2E2E38; font-size:11px; word-break:break-all; margin-bottom:8px;"><%= @transfer.blockchain_tx_hash %></div>
    <a href="<%= @basescan_url %>" target="_blank"
       style="display:inline-block; background:#2E2E38; color:#C5A059; padding:8px 16px; border-radius:8px; font-size:12px; font-weight:700; text-decoration:none;">
      🔗 Wè sou Basescan
    </a>
  </div>
<% end %>

<% if @is_usdc_wallet %>
  <div style="background:#f0fdf4; border:1px solid #bbf7d0; border-radius:12px; padding:12px; margin-bottom:16px;">
    <div style="color:#166534; font-size:12px; font-weight:600;">⚡ Transfè Zèllus · USD — Gratis &amp; Enstantane</div>
  </div>
<% end %>

<div style="font-size:13px; color:#5D6345; line-height:1.6;">
  Transfè ou a konplete avèk siksè. Mèsi pou konfyans ou nan Zèllus!
</div>
