<div class="container py-5" style="min-height: calc(100vh - 64px);">
  <div class="row justify-content-center">
    <div class="col-12 col-md-7 col-lg-5">

      <%# ── Step indicator ── %>
      <div class="d-flex align-items-center justify-content-center gap-2 mb-4">
        <% [
          { n: 1, label: "Pwofil",   active: false, done: true  },
          { n: 2, label: "PIN",      active: true,  done: false },
          { n: 3, label: "MonCash",  active: false, done: false }
        ].each_with_index do |s, i| %>
          <div class="d-flex align-items-center gap-1">
            <div class="d-flex align-items-center justify-content-center rounded-circle fw-black"
                 style="width: 28px; height: 28px; font-size: 12px;
                        background: <%= s[:active] ? 'var(--haiti-gold)' : (s[:done] ? 'rgba(2,115,10,0.15)' : 'rgba(46,46,56,0.1)') %>;
                        color: <%= s[:active] ? 'var(--haiti-charcoal)' : (s[:done] ? '#166534' : 'var(--haiti-olive)') %>;">
              <%= s[:done] ? "✓" : s[:n] %>
            </div>
            <span class="fw-bold d-none d-sm-inline" style="font-size: 11px; color: <%= s[:active] ? 'var(--haiti-charcoal)' : 'var(--haiti-olive)' %>;">
              <%= s[:label] %>
            </span>
          </div>
          <% unless i == 2 %>
            <div style="width: 24px; height: 1px; background: rgba(46,46,56,0.15);"></div>
          <% end %>
        <% end %>
      </div>

      <div class="text-center mb-4">
        <h1 class="fw-black mb-1" style="color: var(--haiti-charcoal); font-size: 22px; font-family: 'Space Grotesk', sans-serif;">Kreye PIN Transfè</h1>
        <p class="small" style="color: var(--haiti-olive);">Yon PIN 4 chif pou apwouve transfè ak retrè.</p>
      </div>

      <div class="p-4 rounded-4" style="background: #fff; border: 1px solid rgba(46,46,56,0.08); box-shadow: 0 4px 14px rgba(46,46,56,0.06);">

        <% if flash[:alert].present? %>
          <div class="p-3 mb-3 rounded-3 d-flex align-items-start gap-2"
               style="background-color: #fdf2f2; border: 1px solid #fee2e2;">
            <i class="ri-error-warning-fill" style="color: #D8000C; font-size: 16px;"></i>
            <div class="small" style="color: var(--haiti-charcoal); line-height: 1.5;"><%= flash[:alert] %></div>
          </div>
        <% end %>

        <%= form_with url: onboarding_pin_path, method: :post, local: true do |f| %>

          <label class="form-label small fw-bold text-uppercase" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">PIN 4 Chif</label>
          <div class="input-group mb-3" style="border: 1.5px solid rgba(46,46,56,0.12); border-radius: 12px; overflow: hidden;">
            <span class="input-group-text border-0" style="background-color: var(--haiti-mint); color: var(--haiti-gold);">
              <i class="ri-lock-2-line"></i>
            </span>
            <input type="password" name="transfer_pin"
                   class="form-control border-0 fw-bold shadow-none p-3 text-center"
                   maxlength="4" pattern="\d{4}" inputmode="numeric"
                   autocomplete="new-password" autofocus required
                   placeholder="• • • •"
                   style="background-color: var(--haiti-charcoal); color: white; letter-spacing: 10px; font-size: 22px;">
          </div>

          <label class="form-label small fw-bold text-uppercase" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">Konfime PIN</label>
          <div class="input-group mb-3" style="border: 1.5px solid rgba(46,46,56,0.12); border-radius: 12px; overflow: hidden;">
            <span class="input-group-text border-0" style="background-color: var(--haiti-mint); color: var(--haiti-gold);">
              <i class="ri-shield-keyhole-line"></i>
            </span>
            <input type="password" name="transfer_pin_confirmation"
                   class="form-control border-0 fw-bold shadow-none p-3 text-center"
                   maxlength="4" pattern="\d{4}" inputmode="numeric"
                   autocomplete="new-password" required
                   placeholder="• • • •"
                   style="background-color: var(--haiti-charcoal); color: white; letter-spacing: 10px; font-size: 22px;">
          </div>

          <div class="small mb-3" style="color: var(--haiti-olive); font-size: 11px;">
            Pa pataje PIN ou ak pèsòn. Nou pa ka rekipere li si w bliye li.
          </div>

          <%= submit_tag "Kontinye",
                class: "btn w-100 fw-bold rounded-pill py-3 border-0",
                style: "background: var(--haiti-gold); color: var(--haiti-charcoal); font-size: 13px; letter-spacing: 0.5px;" %>
        <% end %>
      </div>
    </div>
  </div>
</div>
