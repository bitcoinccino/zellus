<%# ── Header ── %>
<div class="mb-4">
  <h1 class="h4 fw-black mb-1" style="color: var(--haiti-charcoal);">
    <i class="ri-pulse-line me-2" style="color: var(--haiti-gold);"></i>Tout Aktivite
  </h1>
  <p class="small mb-0" style="color: var(--haiti-olive);">Tranzaksyon, Transfè, ak Retrè Bank — tout nan yon sèl plas</p>
</div>

<%= turbo_frame_tag "activity-feed" do %>
  <%# ── Filter Bar ── %>
  <div class="card-base p-3 mb-4" style="border: 1px solid rgba(93,99,69,0.12);">
    <div class="d-flex align-items-center gap-2 flex-wrap">
      <%# Type filter tabs %>
      <% types = [
        { key: nil,               label: "Tout",        icon: "ri-pulse-line" },
        { key: "buy",             label: "Achte",       icon: "ri-arrow-down-circle-line" },
        { key: "sell",            label: "Vann",        icon: "ri-arrow-up-circle-line" },
        { key: "loan",            label: "Prè",         icon: "ri-hand-coin-line" },
        { key: "transfer",        label: "Transfè",     icon: "ri-send-plane-line" },
        { key: "bank_withdrawal", label: "Retrè Bank",  icon: "ri-bank-line" }
      ] %>
      <% current_type = params[:type].presence %>
      <% types.each do |t| %>
        <%= link_to admin_activity_path(type: t[:key], q: params[:q], date: params[:date]),
            class: "btn btn-sm rounded-pill fw-bold px-3 py-1",
            style: "font-size: 11px; #{current_type == t[:key] ? 'background: var(--haiti-charcoal); color: var(--haiti-gold);' : 'background: rgba(93,99,69,0.08); color: var(--haiti-olive);'}",
            data: { turbo_frame: "activity-feed" } do %>
          <i class="<%= t[:icon] %> me-1" style="font-size: 10px;"></i><%= t[:label] %>
        <% end %>
      <% end %>

      <%# Search + Date %>
      <div class="ms-auto d-flex gap-2">
        <%= form_tag admin_activity_path, method: :get, class: "d-flex gap-2", data: { turbo_frame: "activity-feed" } do %>
          <input type="hidden" name="type" value="<%= current_type %>">
          <input type="date" name="date" value="<%= params[:date] %>"
                 class="form-control form-control-sm shadow-none"
                 style="width: 140px; border: 1.5px solid rgba(93,99,69,0.2); background: var(--haiti-cream); font-size: 11px; border-radius: 20px; padding: 4px 10px;"
                 onchange="this.form.requestSubmit()">
          <input type="text" name="q" value="<%= params[:q] %>" placeholder="Chèche $tag, tx#, imèl..."
                 class="form-control form-control-sm shadow-none"
                 style="width: 200px; border: 1.5px solid rgba(93,99,69,0.2); background: var(--haiti-cream); font-size: 12px; border-radius: 20px; padding: 4px 14px;">
          <button type="submit" class="btn btn-sm rounded-pill px-3" style="background: var(--haiti-charcoal); color: var(--haiti-gold); font-size: 11px;">
            <i class="ri-search-line"></i>
          </button>
        <% end %>
      </div>
    </div>
  </div>

  <%# ── Activity Table ── %>
  <div class="card-base p-0 overflow-hidden" style="border: 1px solid rgba(93,99,69,0.12);">
    <% if @items.any? %>
      <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle" style="background-color: var(--haiti-cream); font-size: 13px;">
          <thead style="font-size: 10px; letter-spacing: 1px; color: var(--haiti-olive); border-bottom: 2px solid var(--haiti-olive);">
            <tr>
              <th class="ps-4">ITILIZATÈ</th>
              <th>TIP</th>
              <th>MONTAN HTG</th>
              <th>USD</th>
              <th>ESTATI</th>
              <th>DETAY</th>
              <th>DAT</th>
            </tr>
          </thead>
          <tbody class="small">
            <% @items.each do |item| %>
              <tr style="border-color: rgba(93,99,69,0.1); cursor: pointer;"
                  onclick="window.location='<%= admin_activity_detail_path(item.activity_type, item.id) %>'">
                <td class="ps-4">
                  <div class="d-flex align-items-center gap-2">
                    <% if item.user.avatar.attached? %>
                      <%= image_tag item.user.avatar, style: "width: 32px; height: 32px; border-radius: 50%; object-fit: cover; border: 2px solid rgba(93,99,69,0.12);" %>
                    <% else %>
                      <div style="width: 32px; height: 32px; border-radius: 50%; background: rgba(93,99,69,0.08); display: flex; align-items: center; justify-content: center;">
                        <i class="ri-user-line" style="color: var(--haiti-olive); font-size: 14px;"></i>
                      </div>
                    <% end %>
                    <div>
                      <div class="fw-bold" style="color: var(--haiti-charcoal); font-size: 12px;">$<%= item.user.cashtag %></div>
                    </div>
                  </div>
                </td>
                <td>
                  <span class="badge rounded-pill fw-bold" style="background: <%= item.type_bg %>; color: <%= item.type_color %>; font-size: 9px; padding: 3px 8px;">
                    <i class="<%= item.type_icon %> me-1" style="font-size: 9px;"></i><%= item.type_label %>
                  </span>
                </td>
                <td class="fw-bold" style="color: var(--haiti-charcoal); font-family: 'Space Grotesk', sans-serif; font-size: 13px;">
                  <%= number_to_currency(item.amount_htg, unit: "", precision: 2) %>
                </td>
                <td style="color: var(--haiti-olive); font-family: 'Space Grotesk', sans-serif; font-size: 11px;">
                  $<%= number_to_currency(item.amount_usd, unit: "", precision: 2) %>
                </td>
                <td>
                  <span class="badge rounded-pill fw-bold" style="background: <%= item.status_bg %>; color: <%= item.status_color %>; font-size: 10px; padding: 3px 8px;">
                    <i class="<%= item.status_icon %> me-1" style="font-size: 10px;"></i><%= item.status_label %>
                  </span>
                </td>
                <td style="color: var(--haiti-olive); font-size: 10px; max-width: 160px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                  <%= item.secondary_label %>
                </td>
                <td style="color: var(--haiti-olive); font-size: 11px; white-space: nowrap;">
                  <%= item.created_at.strftime("%d/%m/%y %H:%M") %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <%# ── Pagination ── %>
      <% if @total_pages > 1 %>
        <div class="d-flex justify-content-center gap-2 p-3" style="border-top: 1px solid rgba(93,99,69,0.1);">
          <% if @current_page > 1 %>
            <%= link_to admin_activity_path(type: params[:type], q: params[:q], date: params[:date], page: @current_page - 1),
                class: "btn btn-sm rounded-pill px-3", style: "background: rgba(93,99,69,0.08); color: var(--haiti-olive); font-size: 11px;",
                data: { turbo_frame: "activity-feed" } do %>
              <i class="ri-arrow-left-s-line"></i> Avan
            <% end %>
          <% end %>
          <span class="d-flex align-items-center px-2" style="color: var(--haiti-olive); font-size: 11px; font-weight: 600;">
            Paj <%= @current_page %> / <%= @total_pages %>
          </span>
          <% if @current_page < @total_pages %>
            <%= link_to admin_activity_path(type: params[:type], q: params[:q], date: params[:date], page: @current_page + 1),
                class: "btn btn-sm rounded-pill px-3", style: "background: rgba(93,99,69,0.08); color: var(--haiti-olive); font-size: 11px;",
                data: { turbo_frame: "activity-feed" } do %>
              Apre <i class="ri-arrow-right-s-line"></i>
            <% end %>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <div class="text-center py-5">
        <i class="ri-pulse-line ri-3x mb-3" style="color: var(--haiti-olive); opacity: 0.3;"></i>
        <p class="fw-bold mb-1" style="color: var(--haiti-charcoal);">Pa gen aktivite</p>
        <p class="small" style="color: var(--haiti-olive);">Pa gen rezilta ki matche ak filtè sa a.</p>
      </div>
    <% end %>
  </div>
<% end %>

<style>
  .table-hover tbody tr:hover { background-color: rgba(197,160,89,0.04) !important; }
  .table > :not(caption) > * > * { background-color: transparent !important; }
</style>
