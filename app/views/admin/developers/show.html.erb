<%# ── Header ── %>
<div class="mb-4 d-flex align-items-center justify-content-between">
  <div>
    <h1 class="h4 fw-black mb-1" style="color: var(--haiti-charcoal);">
      <i class="ri-code-s-slash-line me-2" style="color: var(--haiti-gold);"></i><%= @client.name %>
    </h1>
    <p class="small mb-0" style="color: var(--haiti-olive);">Kliyan API · Kreye <%= @client.created_at.strftime("%d/%m/%Y %H:%M") %></p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to admin_developers_path, class: "btn btn-sm rounded-pill px-3 fw-bold",
        style: "background: rgba(93,99,69,0.08); color: var(--haiti-olive); font-size: 11px;" do %>
      <i class="ri-arrow-left-line me-1"></i>Retounen
    <% end %>
    <button type="button" id="dev-delete-btn" class="btn btn-sm rounded-pill px-3 fw-bold"
            style="background: #fef2f2; color: #991b1b; font-size: 11px;">
      <i class="ri-delete-bin-line me-1"></i>Efase
    </button>
  </div>
</div>

<div class="row g-4">
  <%# ── Credentials Card ── %>
  <div class="col-lg-6">
    <div class="card-base p-4 h-100" style="border: 1px solid rgba(93,99,69,0.12);">
      <h2 class="h6 fw-black mb-3" style="color: var(--haiti-charcoal);">
        <i class="ri-key-line me-2" style="color: var(--haiti-gold);"></i>Kredansyèl
      </h2>

      <div class="mb-3">
        <label class="form-label small fw-bold text-uppercase" style="color: var(--haiti-olive); font-size: 10px;">CLIENT ID</label>
        <div class="d-flex align-items-center gap-2">
          <code id="client-id-val" class="flex-grow-1 p-2 rounded-3" style="background: rgba(93,99,69,0.06); font-size: 12px; word-break: break-all; color: var(--haiti-charcoal);">
            <%= @client.client_id %>
          </code>
          <button type="button" class="btn btn-sm" onclick="copyToClipboard('client-id-val')" title="Kopye"
                  style="color: var(--haiti-gold);"><i class="ri-file-copy-line"></i></button>
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label small fw-bold text-uppercase" style="color: var(--haiti-olive); font-size: 10px;">CLIENT SECRET</label>
        <div class="d-flex align-items-center gap-2">
          <code id="client-secret-val" class="flex-grow-1 p-2 rounded-3" style="background: rgba(93,99,69,0.06); font-size: 12px; word-break: break-all; color: var(--haiti-charcoal);">
            <span id="secret-masked">••••••••••••••••••••••••••••••••</span>
            <span id="secret-revealed" style="display: none;"><%= @client.client_secret %></span>
          </code>
          <button type="button" class="btn btn-sm" id="toggle-secret-btn" title="Montre/kache"
                  style="color: var(--haiti-gold);"><i class="ri-eye-line"></i></button>
          <button type="button" class="btn btn-sm" onclick="copySecret()" title="Kopye"
                  style="color: var(--haiti-gold);"><i class="ri-file-copy-line"></i></button>
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label small fw-bold text-uppercase" style="color: var(--haiti-olive); font-size: 10px;">REDIRECT URI</label>
        <code class="d-block p-2 rounded-3" style="background: rgba(93,99,69,0.06); font-size: 12px; color: var(--haiti-charcoal);">
          <%= @client.redirect_uri %>
        </code>
      </div>

      <div class="mb-3">
        <label class="form-label small fw-bold text-uppercase" style="color: var(--haiti-olive); font-size: 10px;">SCOPES</label>
        <div>
          <% @client.requested_scopes.each do |scope| %>
            <span class="badge rounded-pill mb-1" style="background: var(--haiti-mint); color: var(--haiti-olive); font-size: 10px;"><%= scope %></span>
          <% end %>
          <% if @client.requested_scopes.empty? %>
            <span class="small" style="color: var(--haiti-olive);">Pa gen scope konfigire</span>
          <% end %>
        </div>
      </div>

      <div>
        <label class="form-label small fw-bold text-uppercase" style="color: var(--haiti-olive); font-size: 10px;">ESTATI</label>
        <div>
          <% if @client.active? %>
            <span class="badge rounded-pill" style="background: #f0fdf4; color: #166534; font-size: 10px;">Aktif</span>
          <% else %>
            <span class="badge rounded-pill" style="background: #fef2f2; color: #991b1b; font-size: 10px;">Inaktif</span>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <%# ── Webhook Config Card ── %>
  <div class="col-lg-6">
    <div class="card-base p-4 h-100" style="border: 1px solid rgba(93,99,69,0.12);">
      <div class="d-flex align-items-center justify-content-between mb-3">
        <h2 class="h6 fw-black mb-0" style="color: var(--haiti-charcoal);">
          <i class="ri-webhook-line me-2" style="color: var(--haiti-gold);"></i>Webhook
        </h2>
        <% if @client.webhook_url.present? %>
          <%= button_to test_webhook_admin_developer_path(@client), method: :post,
              class: "btn btn-sm rounded-pill px-3 fw-bold",
              style: "background: rgba(29,78,216,0.08); color: #1d4ed8; font-size: 10px;" do %>
            <i class="ri-send-plane-line me-1"></i>Tès Ping
          <% end %>
        <% end %>
      </div>

      <%= form_with(model: @client, url: admin_developer_path(@client), method: :patch, local: true, class: "needs-validation") do |f| %>
        <div class="mb-3">
          <label class="form-label small fw-bold text-uppercase" style="color: var(--haiti-olive); font-size: 10px;">
            <i class="ri-link me-1"></i>WEBHOOK URL
          </label>
          <%= f.text_field :webhook_url, class: "form-control shadow-none", placeholder: "https://example.com/webhooks/zellus",
              style: "border: 2px solid var(--haiti-olive); background-color: var(--haiti-cream);" %>
        </div>

        <div class="mb-3">
          <label class="form-label small fw-bold text-uppercase" style="color: var(--haiti-olive); font-size: 10px;">
            <i class="ri-notification-line me-1"></i>EVÈNMAN
          </label>
          <div class="row g-2">
            <% WebhookService::EVENTS.each do |event| %>
              <div class="col-6">
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="oauth_client[webhook_events][]"
                         value="<%= event %>" id="evt-<%= event.tr('.', '-') %>"
                         <%= 'checked' if @client.webhook_events&.include?(event) %>>
                  <label class="form-check-label small" for="evt-<%= event.tr('.', '-') %>" style="color: var(--haiti-charcoal); font-size: 12px;">
                    <%= event %>
                  </label>
                </div>
              </div>
            <% end %>
          </div>
          <%# Hidden empty value to ensure array clears when no boxes checked %>
          <input type="hidden" name="oauth_client[webhook_events][]" value="">
        </div>

        <div class="mb-3">
          <div class="form-check form-switch">
            <%= f.check_box :webhook_active, class: "form-check-input", role: "switch", id: "webhook-active-toggle" %>
            <label class="form-check-label small fw-bold" for="webhook-active-toggle" style="color: var(--haiti-charcoal);">
              Webhook Aktif
            </label>
          </div>
        </div>

        <div class="mb-3">
          <label class="form-label small fw-bold text-uppercase" style="color: var(--haiti-olive); font-size: 10px;">WEBHOOK SECRET</label>
          <div class="d-flex align-items-center gap-2">
            <code id="webhook-secret-val" class="flex-grow-1 p-2 rounded-3" style="background: rgba(93,99,69,0.06); font-size: 11px; word-break: break-all; color: var(--haiti-charcoal);">
              <% if @client.webhook_secret.present? %>
                <span id="ws-masked">••••••••••••••••</span>
                <span id="ws-revealed" style="display: none;"><%= @client.webhook_secret %></span>
              <% else %>
                <span style="color: var(--haiti-olive);">Pa jenere ankò</span>
              <% end %>
            </code>
            <% if @client.webhook_secret.present? %>
              <button type="button" class="btn btn-sm" id="toggle-ws-btn" title="Montre/kache"
                      style="color: var(--haiti-gold);"><i class="ri-eye-line"></i></button>
            <% end %>
            <button type="button" id="regen-secret-btn" class="btn btn-sm" title="Rejenere"
                    style="color: #991b1b;"><i class="ri-refresh-line"></i></button>
          </div>
        </div>

        <button type="submit" class="btn fw-bold px-4 py-2" style="background: var(--haiti-charcoal); color: var(--haiti-gold);">
          <i class="ri-save-line me-2"></i>Anrejistre Webhook
        </button>
      <% end %>
    </div>
  </div>
</div>

<%# ── Delivery Log ── %>
<div class="card-base p-4 mt-4" style="border: 1px solid rgba(93,99,69,0.12);">
  <h2 class="h6 fw-black mb-3" style="color: var(--haiti-charcoal);">
    <i class="ri-history-line me-2" style="color: var(--haiti-gold);"></i>Istwa Delivery (<%= @deliveries.size %>)
  </h2>

  <% if @deliveries.any? %>
    <div class="table-responsive">
      <table class="table table-sm align-middle" style="font-size: 13px;">
        <thead>
          <tr style="color: var(--haiti-olive); font-size: 10px; text-transform: uppercase; letter-spacing: 1px;">
            <th>Delivery ID</th>
            <th>Evènman</th>
            <th>Estati</th>
            <th>Repons</th>
            <th>Esè</th>
            <th>Delivre</th>
            <th>Kreye</th>
          </tr>
        </thead>
        <tbody>
          <% @deliveries.each do |delivery| %>
            <tr>
              <td>
                <code class="small" style="color: var(--haiti-olive); font-size: 10px;"><%= delivery.delivery_id.first(8) %>…</code>
              </td>
              <td>
                <span class="badge rounded-pill" style="background: var(--haiti-mint); color: var(--haiti-olive); font-size: 10px;">
                  <%= delivery.event %>
                </span>
              </td>
              <td>
                <% case delivery.status %>
                <% when "delivered" %>
                  <span class="badge rounded-pill" style="background: #f0fdf4; color: #166534; font-size: 10px;">
                    <i class="ri-checkbox-circle-fill me-1"></i>Delivre
                  </span>
                <% when "pending" %>
                  <span class="badge rounded-pill" style="background: #fefce8; color: #854d0e; font-size: 10px;">
                    <i class="ri-time-line me-1"></i>Annatant
                  </span>
                <% when "failed" %>
                  <span class="badge rounded-pill" style="background: #fef2f2; color: #991b1b; font-size: 10px;">
                    <i class="ri-close-circle-fill me-1"></i>Echwe
                  </span>
                <% end %>
              </td>
              <td class="small" style="color: var(--haiti-olive);">
                <% if delivery.response_status.present? %>
                  <code style="font-size: 11px;"><%= delivery.response_status %></code>
                <% else %>
                  —
                <% end %>
              </td>
              <td class="small" style="color: var(--haiti-olive);"><%= delivery.attempts %>/<%= WebhookDelivery::MAX_ATTEMPTS %></td>
              <td class="small" style="color: var(--haiti-olive);">
                <%= delivery.delivered_at&.strftime("%d/%m %H:%M") || "—" %>
              </td>
              <td class="small" style="color: var(--haiti-olive);"><%= delivery.created_at.strftime("%d/%m %H:%M") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="text-center py-4">
      <i class="ri-history-line ri-2x mb-2" style="color: var(--haiti-olive); opacity: 0.3;"></i>
      <p class="small" style="color: var(--haiti-olive);">Pa gen delivery webhook ankò.</p>
    </div>
  <% end %>
</div>

<%# ── Delete Confirmation Modal ── %>
<div id="dev-delete-modal" style="display: none; position: fixed; inset: 0; z-index: 9999; background: rgba(46,46,56,0.6); backdrop-filter: blur(4px);">
  <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 360px;">
    <div class="card-base p-4 text-center" style="border: 2px solid #D21034; box-shadow: 0 20px 60px rgba(0,0,0,0.3);">
      <div class="mb-3">
        <div class="d-inline-flex align-items-center justify-content-center" style="width: 56px; height: 56px; border-radius: 50%; background: rgba(210,16,52,0.1);">
          <i class="ri-delete-bin-line" style="color: #D21034; font-size: 28px;"></i>
        </div>
      </div>
      <h3 class="h6 fw-black mb-1" style="color: var(--haiti-charcoal);">Efase <%= @client.name %>?</h3>
      <p class="small mb-3" style="color: var(--haiti-olive);">Aksyon sa a pa ka defèt. Tout token ak webhook ap efase.</p>
      <%= form_tag admin_developer_path(@client), method: :delete, id: "dev-delete-form" do %>
        <input type="hidden" name="transfer_pin" id="dev-del-pin-hidden" value="">
        <input type="password" id="dev-del-pin-input" maxlength="6" inputmode="numeric" pattern="[0-9]*" placeholder="PIN ••••••"
               class="form-control fw-bold shadow-none text-center mx-auto mb-3"
               style="width: 180px; border: 2px solid #D21034; background-color: var(--haiti-cream); font-size: 22px; letter-spacing: 8px; border-radius: 12px;">
        <div class="d-flex gap-2 justify-content-center">
          <button type="button" id="dev-del-cancel" class="btn fw-bold px-4 py-2 rounded-pill"
                  style="background: rgba(93,99,69,0.08); color: var(--haiti-olive); font-size: 12px;">
            Anile
          </button>
          <button type="button" id="dev-del-confirm" class="btn fw-bold px-4 py-2 rounded-pill"
                  style="background: #D21034; color: #fff; font-size: 12px;">
            <i class="ri-delete-bin-line me-1"></i>Efase
          </button>
        </div>
      <% end %>
    </div>
  </div>
</div>

<%# ── Regenerate Secret Modal ── %>
<div id="dev-regen-modal" style="display: none; position: fixed; inset: 0; z-index: 9999; background: rgba(46,46,56,0.6); backdrop-filter: blur(4px);">
  <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 360px;">
    <div class="card-base p-4 text-center" style="border: 2px solid var(--haiti-gold); box-shadow: 0 20px 60px rgba(0,0,0,0.3);">
      <div class="mb-3">
        <div class="d-inline-flex align-items-center justify-content-center" style="width: 56px; height: 56px; border-radius: 50%; background: rgba(197,160,89,0.12);">
          <i class="ri-refresh-line" style="color: var(--haiti-gold); font-size: 28px;"></i>
        </div>
      </div>
      <h3 class="h6 fw-black mb-1" style="color: var(--haiti-charcoal);">Rejenere Webhook Secret?</h3>
      <p class="small mb-3" style="color: var(--haiti-olive);">Ansyen secret la ap pa mache ankò. Mete ajou konfigirasyon sèvè ou.</p>
      <%= form_tag regenerate_secret_admin_developer_path(@client), method: :post, id: "dev-regen-form" do %>
        <input type="hidden" name="transfer_pin" id="dev-regen-pin-hidden" value="">
        <input type="password" id="dev-regen-pin-input" maxlength="6" inputmode="numeric" pattern="[0-9]*" placeholder="PIN ••••••"
               class="form-control fw-bold shadow-none text-center mx-auto mb-3"
               style="width: 180px; border: 2px solid var(--haiti-gold); background-color: var(--haiti-cream); font-size: 22px; letter-spacing: 8px; border-radius: 12px;">
        <div class="d-flex gap-2 justify-content-center">
          <button type="button" id="dev-regen-cancel" class="btn fw-bold px-4 py-2 rounded-pill"
                  style="background: rgba(93,99,69,0.08); color: var(--haiti-olive); font-size: 12px;">
            Anile
          </button>
          <button type="button" id="dev-regen-confirm" class="btn fw-bold px-4 py-2 rounded-pill"
                  style="background: var(--haiti-charcoal); color: var(--haiti-gold); font-size: 12px;">
            <i class="ri-refresh-line me-1"></i>Rejenere
          </button>
        </div>
      <% end %>
    </div>
  </div>
</div>

<style>
  .table > :not(caption) > * > * { background-color: transparent !important; }
</style>

<script>
  // ── Copy to clipboard ──
  function copyToClipboard(elementId) {
    var el = document.getElementById(elementId);
    var text = el.innerText.trim();
    navigator.clipboard.writeText(text);
  }

  function copySecret() {
    var revealed = document.getElementById('secret-revealed');
    navigator.clipboard.writeText(revealed.innerText.trim());
  }

  // ── Toggle client secret ──
  document.getElementById('toggle-secret-btn').addEventListener('click', function() {
    var masked = document.getElementById('secret-masked');
    var revealed = document.getElementById('secret-revealed');
    var icon = this.querySelector('i');
    if (revealed.style.display === 'none') {
      masked.style.display = 'none';
      revealed.style.display = 'inline';
      icon.className = 'ri-eye-off-line';
    } else {
      masked.style.display = 'inline';
      revealed.style.display = 'none';
      icon.className = 'ri-eye-line';
    }
  });

  // ── Toggle webhook secret ──
  var toggleWsBtn = document.getElementById('toggle-ws-btn');
  if (toggleWsBtn) {
    toggleWsBtn.addEventListener('click', function() {
      var masked = document.getElementById('ws-masked');
      var revealed = document.getElementById('ws-revealed');
      var icon = this.querySelector('i');
      if (revealed.style.display === 'none') {
        masked.style.display = 'none';
        revealed.style.display = 'inline';
        icon.className = 'ri-eye-off-line';
      } else {
        masked.style.display = 'inline';
        revealed.style.display = 'none';
        icon.className = 'ri-eye-line';
      }
    });
  }

  // ── Delete Modal ──
  var delModal = document.getElementById('dev-delete-modal');
  var delPinInput = document.getElementById('dev-del-pin-input');
  var delPinHidden = document.getElementById('dev-del-pin-hidden');
  var delForm = document.getElementById('dev-delete-form');

  document.getElementById('dev-delete-btn').addEventListener('click', function() {
    delModal.style.display = 'block';
    delPinInput.value = '';
    setTimeout(function() { delPinInput.focus(); }, 100);
  });

  document.getElementById('dev-del-cancel').addEventListener('click', function() {
    delModal.style.display = 'none';
  });

  document.getElementById('dev-del-confirm').addEventListener('click', function() {
    if (!delPinInput.value || delPinInput.value.length < 4) {
      delPinInput.style.borderColor = '#D21034';
      delPinInput.focus();
      return;
    }
    delPinHidden.value = delPinInput.value;
    delModal.style.display = 'none';
    delForm.submit();
  });

  delPinInput.addEventListener('keydown', function(e) {
    if (e.key === 'Enter') { e.preventDefault(); document.getElementById('dev-del-confirm').click(); }
  });

  delModal.addEventListener('click', function(e) {
    if (e.target === delModal) { delModal.style.display = 'none'; }
  });

  // ── Regenerate Secret Modal ──
  var regenModal = document.getElementById('dev-regen-modal');
  var regenPinInput = document.getElementById('dev-regen-pin-input');
  var regenPinHidden = document.getElementById('dev-regen-pin-hidden');
  var regenForm = document.getElementById('dev-regen-form');

  document.getElementById('regen-secret-btn').addEventListener('click', function() {
    regenModal.style.display = 'block';
    regenPinInput.value = '';
    setTimeout(function() { regenPinInput.focus(); }, 100);
  });

  document.getElementById('dev-regen-cancel').addEventListener('click', function() {
    regenModal.style.display = 'none';
  });

  document.getElementById('dev-regen-confirm').addEventListener('click', function() {
    if (!regenPinInput.value || regenPinInput.value.length < 4) {
      regenPinInput.style.borderColor = '#D21034';
      regenPinInput.focus();
      return;
    }
    regenPinHidden.value = regenPinInput.value;
    regenModal.style.display = 'none';
    regenForm.submit();
  });

  regenPinInput.addEventListener('keydown', function(e) {
    if (e.key === 'Enter') { e.preventDefault(); document.getElementById('dev-regen-confirm').click(); }
  });

  regenModal.addEventListener('click', function(e) {
    if (e.target === regenModal) { regenModal.style.display = 'none'; }
  });
</script>
