<%# ═══════════════════════════════════════════════════════
    Admin Sidebar Navigation
    ═══════════════════════════════════════════════════════ %>

<% active = ->(path) { request.path.start_with?(path) ? "admin-nav-active" : "" } %>

<%# ── HOME ── %>
<div class="admin-nav-section">
  <div class="admin-nav-header">HOME</div>
  <%= link_to admin_root_path, class: "admin-nav-item #{request.path == '/admin' || request.path == '/admin/dashboard' ? 'admin-nav-active' : ''}" do %>
    <i class="ri-dashboard-3-line"></i> Dashboard
  <% end %>
  <div style="margin: 4px 16px 4px; border-top: 1px solid rgba(197,160,89,0.15);"></div>
  <%= link_to admin_credit_path, class: "admin-nav-item #{active.call('/admin/credit')}" do %>
    <i class="ri-add-circle-line"></i> Kredite
  <% end %>
  <%= link_to admin_invite_codes_path, class: "admin-nav-item #{active.call('/admin/invite_codes')}" do %>
    <i class="ri-key-2-line"></i> Invite Code
  <% end %>
  <%= link_to admin_activity_path, class: "admin-nav-item #{active.call('/admin/activity')}" do %>
    <i class="ri-pulse-line"></i> Tout Aktivite
  <% end %>
</div>

<%# ── ZELLUS AJAN — paused while focusing on core wallet ops ── %>
<% if false %>
<div class="admin-nav-section">
  <div class="admin-nav-header">ZELLUS AJAN</div>
