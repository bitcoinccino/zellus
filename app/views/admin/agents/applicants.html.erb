<%# Page Title %>
<div class="mb-4">
  <h1 class="h4 fw-bold mb-0" style="color: var(--haiti-charcoal); font-family: 'Space Grotesk', sans-serif;">
    <i class="ri-user-add-line me-2" style="color: var(--haiti-gold);"></i>Aplikan Ajan
  </h1>
</div>

<%# ── Filter Tabs ── %>
<ul class="nav nav-tabs mb-4" role="tablist" style="border-bottom: 2px solid rgba(93,99,69,0.15);">
  <li class="nav-item">
    <button class="nav-link active fw-bold" data-bs-toggle="tab" data-bs-target="#tab-pending" style="font-size: 13px; color: var(--haiti-charcoal);">
      An Atant <span class="badge rounded-pill ms-1" style="background: #fef3c7; color: #92400e; font-size: 10px;"><%= @pending.count %></span>
    </button>
  </li>
  <li class="nav-item">
    <button class="nav-link fw-bold" data-bs-toggle="tab" data-bs-target="#tab-approved" style="font-size: 13px; color: var(--haiti-olive);">
      Apwouve <span class="badge rounded-pill ms-1" style="background: #f0fdf4; color: #166534; font-size: 10px;"><%= @approved.count %></span>
    </button>
  </li>
  <li class="nav-item">
    <button class="nav-link fw-bold" data-bs-toggle="tab" data-bs-target="#tab-rejected" style="font-size: 13px; color: var(--haiti-olive);">
      Rejte <span class="badge rounded-pill ms-1" style="background: #fef2f2; color: #991b1b; font-size: 10px;"><%= @rejected.count %></span>
    </button>
  </li>
  <li class="nav-item">
    <button class="nav-link fw-bold" data-bs-toggle="tab" data-bs-target="#tab-suspended" style="font-size: 13px; color: var(--haiti-olive);">
      Sispann <span class="badge rounded-pill ms-1" style="background: #fef9c3; color: #854d0e; font-size: 10px;"><%= @suspended.count %></span>
    </button>
  </li>
</ul>

<div class="tab-content">
  <%# ── Pending Tab ── %>
  <div class="tab-pane fade show active" id="tab-pending">
    <% if @pending.any? %>
      <div class="row g-3">
        <% @pending.each do |biz| %>
          <div class="col-md-6 col-lg-4">
            <div class="card-base p-3" style="border: 1px solid rgba(93,99,69,0.12);">
              <div class="d-flex align-items-center gap-3 mb-3">
                <% if biz.logo.attached? %>
                  <div style="width: 44px; height: 44px; border-radius: 50%; overflow: hidden; border: 2px solid var(--haiti-gold);">
                    <%= image_tag biz.logo, style: "width: 100%; height: 100%; object-fit: cover;" %>
                  </div>
                <% else %>
                  <div class="d-flex align-items-center justify-content-center" style="width: 44px; height: 44px; border-radius: 50%; background: var(--haiti-mint); border: 2px solid var(--haiti-gold);">
                    <i class="ri-store-2-line" style="color: var(--haiti-gold); font-size: 20px;"></i>
                  </div>
                <% end %>
                <div class="flex-fill">
                  <div class="fw-black" style="color: var(--haiti-charcoal); font-size: 14px;"><%= biz.name %></div>
                  <div style="color: var(--haiti-gold); font-size: 11px; font-weight: 700;">$<%= biz.user.cashtag %></div>
                </div>
              </div>

              <div class="mb-3" style="font-size: 11px; color: var(--haiti-olive);">
                <% if biz.category.present? %>
                  <div class="mb-1">
                    <i class="<%= biz.category_icon %> me-1"></i>
                    <span class="fw-bold"><%= biz.category_label %></span>
                  </div>
                <% end %>
                <div class="mb-1"><i class="ri-mail-line me-1"></i><%= biz.user.email %></div>
                <div class="mb-1"><i class="ri-map-pin-2-line me-1"></i><%= biz.address.presence || "—" %></div>
                <div class="mb-1"><i class="ri-road-map-line me-1"></i><%= biz.commune.presence || "—" %>, <%= biz.department.presence || "—" %></div>
                <div class="mb-1">
                  <% if biz.user.bonid_verified? %>
                    <i class="ri-verified-badge-fill me-1" style="color: #166534;"></i>
                    <span class="fw-bold" style="color: #166534;">BonID Verifye</span>
                  <% else %>
                    <i class="ri-close-circle-fill me-1" style="color: #991b1b;"></i>
                    <span class="fw-bold" style="color: #991b1b;">BonID Pa Verifye</span>
                  <% end %>
                </div>
                <div><i class="ri-calendar-line me-1"></i>Aplike: <%= biz.agent_applied_at&.strftime("%-d %b %Y") || "—" %></div>
              </div>

              <div class="d-flex gap-2">
                <%= link_to admin_agents_show_path(biz), class: "btn btn-sm flex-fill fw-bold", style: "background: var(--haiti-mint); color: var(--haiti-charcoal); border-radius: 10px; font-size: 11px;" do %>
                  <i class="ri-eye-line me-1"></i>Wè Detay
                <% end %>
                <%= button_to admin_approve_agent_path(biz), method: :post, class: "btn btn-sm fw-bold", style: "background: #166534; color: #fff; border-radius: 10px; font-size: 11px;", data: { turbo_confirm: "Apwouve #{biz.name} kòm ajan?" } do %>
                  <i class="ri-check-line"></i>
                <% end %>
                <%= button_to admin_reject_agent_path(biz), method: :post, class: "btn btn-sm fw-bold", style: "background: #991b1b; color: #fff; border-radius: 10px; font-size: 11px;", data: { turbo_confirm: "Rejte #{biz.name}?" } do %>
                  <i class="ri-close-line"></i>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-5" style="color: var(--haiti-olive);">
        <i class="ri-checkbox-circle-line d-block mb-2" style="font-size: 36px; color: #22c55e; opacity: 0.5;"></i>
        <div class="fw-bold">Pa gen aplikasyon an atant</div>
      </div>
    <% end %>
  </div>

  <%# ── Approved Tab ── %>
  <div class="tab-pane fade" id="tab-approved">
    <% if @approved.any? %>
      <div class="row g-3">
        <% @approved.each do |biz| %>
          <div class="col-md-6 col-lg-4">
            <div class="card-base p-3" style="border: 1px solid rgba(197,160,89,0.25); background: #fffef5;">
              <%# Header: Logo + Name %>
              <div class="d-flex align-items-center gap-3 mb-3">
                <% if biz.logo.attached? %>
                  <div style="width: 48px; height: 48px; border-radius: 50%; overflow: hidden; border: 2.5px solid #166534;">
                    <%= image_tag biz.logo, style: "width: 100%; height: 100%; object-fit: cover;" %>
                  </div>
                <% else %>
                  <div class="d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; border-radius: 50%; background: var(--haiti-mint); border: 2.5px solid #166534;">
                    <i class="ri-store-2-line" style="color: #166534; font-size: 22px;"></i>
                  </div>
                <% end %>
                <div class="flex-fill">
                  <div class="fw-black" style="color: var(--haiti-charcoal); font-size: 14px;"><%= biz.name %></div>
                  <div style="color: var(--haiti-gold); font-size: 11px; font-weight: 700;">$<%= biz.user.cashtag %></div>
                </div>
                <span class="badge rounded-pill" style="background: #f0fdf4; color: #166534; font-size: 9px; font-weight: 700; padding: 4px 8px;">
                  <i class="ri-checkbox-circle-fill me-1"></i>Aktif
                </span>
              </div>

              <%# Details %>
              <div class="mb-3" style="font-size: 11px; color: var(--haiti-olive);">
                <%# Business Type %>
                <% if biz.category.present? %>
                  <div class="mb-1">
                    <i class="<%= biz.category_icon %> me-1"></i>
                    <span class="fw-bold"><%= biz.category_label %></span>
                  </div>
                <% end %>

                <%# Email %>
                <div class="mb-1">
                  <i class="ri-mail-line me-1"></i><%= biz.user.email %>
                </div>

                <%# Address %>
                <div class="mb-1">
                  <i class="ri-map-pin-2-line me-1"></i><%= biz.address.presence || "—" %>
                </div>

                <%# Location %>
                <div class="mb-1">
                  <i class="ri-road-map-line me-1"></i><%= biz.commune.presence || "—" %>, <%= biz.department.presence || "—" %>
                </div>

                <%# BonID Status %>
                <div class="mb-1">
                  <% if biz.user.bonid_verified? %>
                    <i class="ri-verified-badge-fill me-1" style="color: #166534;"></i>
                    <span class="fw-bold" style="color: #166534;">BonID Verifye</span>
                  <% else %>
                    <i class="ri-close-circle-fill me-1" style="color: #991b1b;"></i>
                    <span class="fw-bold" style="color: #991b1b;">BonID Pa Verifye</span>
                  <% end %>
                </div>

                <%# Activated date %>
                <div>
                  <i class="ri-calendar-check-line me-1"></i>Aktive: <%= biz.agent_activated_at&.strftime("%-d %b %Y") || "—" %>
                </div>
              </div>

              <%# Agent Stats (if available) %>
              <% if biz.is_agent? %>
                <div class="d-flex gap-2 mb-3">
                  <div class="flex-fill text-center p-2 rounded-3" style="background: rgba(22,101,52,0.06);">
                    <div class="fw-black" style="color: var(--haiti-charcoal); font-size: 14px;">G <%= number_with_delimiter(biz.agent_float_htg.to_i) %></div>
                    <div class="small fw-bold text-uppercase" style="color: var(--haiti-olive); font-size: 8px;">Flòt</div>
                  </div>
                  <div class="flex-fill text-center p-2 rounded-3" style="background: rgba(22,101,52,0.06);">
                    <div class="fw-black" style="color: var(--haiti-charcoal); font-size: 14px;">G <%= number_with_delimiter(biz.total_commission_earned.to_i) %></div>
                    <div class="small fw-bold text-uppercase" style="color: var(--haiti-olive); font-size: 8px;">Komisyon</div>
                  </div>
                </div>
              <% end %>

              <%# Actions %>
              <div class="d-flex gap-2">
                <%= link_to admin_agents_show_path(biz), class: "btn btn-sm flex-fill fw-bold", style: "background: var(--haiti-mint); color: var(--haiti-charcoal); border-radius: 10px; font-size: 11px;" do %>
                  <i class="ri-eye-line me-1"></i>Wè Detay
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-5" style="color: var(--haiti-olive);">
        <i class="ri-user-star-line d-block mb-2" style="font-size: 36px; opacity: 0.3;"></i>
        <div class="fw-bold">Pa gen ajan apwouve ankò</div>
      </div>
    <% end %>
  </div>

  <%# ── Rejected Tab ── %>
  <div class="tab-pane fade" id="tab-rejected">
    <% if @rejected.any? %>
      <div class="row g-3">
        <% @rejected.each do |biz| %>
          <div class="col-md-6 col-lg-4">
            <div class="card-base p-3" style="border: 1px solid rgba(153,27,27,0.12); background: linear-gradient(135deg, rgba(254,242,242,0.3), transparent);">
              <div class="d-flex align-items-center gap-3 mb-3">
                <% if biz.logo.attached? %>
                  <div style="width: 44px; height: 44px; border-radius: 50%; overflow: hidden; border: 2px solid rgba(153,27,27,0.3); opacity: 0.7;">
                    <%= image_tag biz.logo, style: "width: 100%; height: 100%; object-fit: cover;" %>
                  </div>
                <% else %>
                  <div class="d-flex align-items-center justify-content-center" style="width: 44px; height: 44px; border-radius: 50%; background: #fef2f2; border: 2px solid rgba(153,27,27,0.2);">
                    <i class="ri-store-2-line" style="color: #991b1b; font-size: 20px;"></i>
                  </div>
                <% end %>
                <div class="flex-fill">
                  <div class="fw-black" style="color: var(--haiti-charcoal); font-size: 14px;"><%= biz.name %></div>
                  <div style="color: var(--haiti-gold); font-size: 11px; font-weight: 700;">$<%= biz.user.cashtag %></div>
                </div>
                <span class="badge rounded-pill" style="background: #fef2f2; color: #991b1b; font-size: 9px; font-weight: 700; padding: 4px 8px;">
                  <i class="ri-close-circle-fill me-1"></i>Rejte
                </span>
              </div>

              <%# Rejection reason %>
              <div class="p-2 rounded-3 mb-3" style="background: rgba(153,27,27,0.04); border: 1px solid rgba(153,27,27,0.08);">
                <div class="small fw-bold" style="color: #991b1b; font-size: 10px;">
                  <i class="ri-error-warning-line me-1"></i>REZON
                </div>
                <div class="small" style="color: #991b1b; font-size: 12px;"><%= biz.agent_rejected_reason || "Pa kalifye pou kounye a" %></div>
              </div>

              <div style="font-size: 11px; color: var(--haiti-olive);">
                <i class="ri-calendar-line me-1"></i>Rejte: <%= biz.updated_at.strftime("%-d %b %Y") %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-5" style="color: var(--haiti-olive);">
        <i class="ri-checkbox-circle-line d-block mb-2" style="font-size: 36px; color: #22c55e; opacity: 0.3;"></i>
        <div class="fw-bold">Pa gen aplikasyon rejte</div>
      </div>
    <% end %>
  </div>

  <%# ── Suspended Tab ── %>
  <div class="tab-pane fade" id="tab-suspended">
    <% if @suspended.any? %>
      <div class="row g-3">
        <% @suspended.each do |biz| %>
          <div class="col-md-6 col-lg-4">
            <div class="card-base p-3" style="border: 1px solid rgba(133,77,14,0.15); background: linear-gradient(135deg, rgba(254,249,195,0.15), transparent);">
              <div class="d-flex align-items-center gap-3 mb-3">
                <% if biz.logo.attached? %>
                  <div style="width: 44px; height: 44px; border-radius: 50%; overflow: hidden; border: 2px solid rgba(133,77,14,0.4); opacity: 0.8;">
                    <%= image_tag biz.logo, style: "width: 100%; height: 100%; object-fit: cover;" %>
                  </div>
                <% else %>
                  <div class="d-flex align-items-center justify-content-center" style="width: 44px; height: 44px; border-radius: 50%; background: #fef9c3; border: 2px solid rgba(133,77,14,0.3);">
                    <i class="ri-store-2-line" style="color: #854d0e; font-size: 20px;"></i>
                  </div>
                <% end %>
                <div class="flex-fill">
                  <div class="fw-black" style="color: var(--haiti-charcoal); font-size: 14px;"><%= biz.name %></div>
                  <div style="color: var(--haiti-gold); font-size: 11px; font-weight: 700;">$<%= biz.user.cashtag %></div>
                </div>
                <span class="badge rounded-pill" style="background: #fef9c3; color: #854d0e; font-size: 9px; font-weight: 700; padding: 4px 8px;">
                  <i class="ri-pause-circle-fill me-1"></i>Sispann
                </span>
              </div>

              <div class="mb-3" style="font-size: 11px; color: var(--haiti-olive);">
                <% if biz.category.present? %>
                  <div class="mb-1">
                    <i class="<%= biz.category_icon %> me-1"></i>
                    <span class="fw-bold"><%= biz.category_label %></span>
                  </div>
                <% end %>
                <div class="mb-1"><i class="ri-mail-line me-1"></i><%= biz.user.email %></div>
                <div class="mb-1"><i class="ri-map-pin-2-line me-1"></i><%= biz.address.presence || "—" %></div>
                <div class="mb-1"><i class="ri-road-map-line me-1"></i><%= biz.commune.presence || "—" %>, <%= biz.department.presence || "—" %></div>
                <div class="mb-1">
                  <% if biz.user.bonid_verified? %>
                    <i class="ri-verified-badge-fill me-1" style="color: #166534;"></i>
                    <span class="fw-bold" style="color: #166534;">BonID Verifye</span>
                  <% else %>
                    <i class="ri-close-circle-fill me-1" style="color: #991b1b;"></i>
                    <span class="fw-bold" style="color: #991b1b;">BonID Pa Verifye</span>
                  <% end %>
                </div>
                <div><i class="ri-calendar-line me-1"></i>Sispann: <%= biz.updated_at.strftime("%-d %b %Y") %></div>
              </div>

              <div class="d-flex gap-2">
                <%= link_to admin_agents_show_path(biz), class: "btn btn-sm flex-fill fw-bold", style: "background: var(--haiti-mint); color: var(--haiti-charcoal); border-radius: 10px; font-size: 11px;" do %>
                  <i class="ri-eye-line me-1"></i>Wè Detay
                <% end %>
                <%= button_to admin_reactivate_agent_path(biz), method: :post, class: "btn btn-sm flex-fill fw-bold", style: "background: #166534; color: #fff; border-radius: 10px; font-size: 11px;", data: { turbo_confirm: "Reaktive #{biz.name} kòm ajan?" } do %>
                  <i class="ri-restart-line me-1"></i>Reaktive
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-5" style="color: var(--haiti-olive);">
        <i class="ri-pause-circle-line d-block mb-2" style="font-size: 36px; opacity: 0.3;"></i>
        <div class="fw-bold">Pa gen ajan sispann</div>
      </div>
    <% end %>
  </div>
</div>

<style>
  .nav-tabs .nav-link.active {
    background: var(--haiti-cream) !important;
    color: var(--haiti-charcoal) !important;
    border-bottom: 3px solid var(--haiti-gold) !important;
  }
  .nav-tabs .nav-link:not(.active):hover {
    color: var(--haiti-charcoal) !important;
    border-bottom: 3px solid rgba(197,160,89,0.3) !important;
  }
  .table > :not(caption) > * > * { background-color: transparent !important; }
</style>
