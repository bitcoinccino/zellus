<%# ── Header ── %>
<div class="mb-4">
  <h1 class="h4 fw-black mb-1" style="color: var(--haiti-charcoal);">
    <i class="ri-exchange-line me-2" style="color: var(--haiti-gold);"></i>Aktivite Bousad
  </h1>
  <p class="small mb-0" style="color: var(--haiti-olive);">Tout tranzaksyon prè Pionye</p>
</div>

<%# ── Filters ── %>
<%= turbo_frame_tag "bousad-activity" do %>
  <div class="card-base p-3 mb-4">
    <div class="d-flex align-items-center gap-2 flex-wrap">
      <%# Status filter tabs %>
      <% statuses = [
        { key: "tout", label: "Tout" },
        { key: "pending", label: "An Atant" },
        { key: "crypto_sent", label: "Apwouve" },
        { key: "completed", label: "Konplè" },
        { key: "failed", label: "Rejte" }
      ] %>
      <% current_status = params[:status].presence || "tout" %>
      <% statuses.each do |s| %>
        <%= link_to admin_bousad_activity_path(status: s[:key], q: params[:q]),
            class: "btn btn-sm rounded-pill fw-bold px-3 py-1",
            style: "font-size: 11px; #{current_status == s[:key] ? 'background: var(--haiti-charcoal); color: var(--haiti-gold);' : 'background: rgba(93,99,69,0.08); color: var(--haiti-olive);'}",
            data: { turbo_frame: "bousad-activity" } do %>
          <%= s[:label] %>
        <% end %>
      <% end %>

      <%# Search %>
      <div class="ms-auto">
        <%= form_tag admin_bousad_activity_path, method: :get, class: "d-flex gap-2", data: { turbo_frame: "bousad-activity" } do %>
          <input type="hidden" name="status" value="<%= current_status %>">
          <input type="text" name="q" value="<%= params[:q] %>" placeholder="Chèche $tag, imèl, tx#..."
                 class="form-control form-control-sm shadow-none"
                 style="width: 200px; border: 1.5px solid rgba(93,99,69,0.2); background: var(--haiti-cream); font-size: 12px; border-radius: 20px; padding: 4px 14px;">
          <button type="submit" class="btn btn-sm rounded-pill px-3" style="background: var(--haiti-charcoal); color: var(--haiti-gold); font-size: 11px;">
            <i class="ri-search-line"></i>
          </button>
        <% end %>
      </div>
    </div>
  </div>

  <%# ── Loans Table ── %>
  <div class="card-base p-0 overflow-hidden">
    <% if @loans.any? %>
      <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle" style="background-color: var(--haiti-cream); font-size: 13px;">
          <thead style="font-size: 10px; letter-spacing: 1px; color: var(--haiti-olive); border-bottom: 2px solid var(--haiti-olive);">
            <tr>
              <th class="ps-4">ITILIZATÈ</th>
              <th>NIVO</th>
              <th>MONTAN</th>
              <th>REZON</th>
              <th>ESTATI</th>
              <th>DAT</th>
            </tr>
          </thead>
          <tbody class="small">
            <% @loans.each do |loan| %>
              <% lu = loan.user %>
              <tr style="border-color: rgba(93,99,69,0.1); cursor: pointer;" onclick="window.location='<%= admin_activity_detail_path('transaction', loan.id) %>'">
                <td class="ps-4">
                  <div class="d-flex align-items-center gap-2">
                    <% if lu.avatar.attached? %>
                      <%= image_tag lu.avatar, style: "width: 32px; height: 32px; border-radius: 50%; object-fit: cover; border: 2px solid rgba(93,99,69,0.12);" %>
                    <% else %>
                      <div style="width: 32px; height: 32px; border-radius: 50%; background: rgba(93,99,69,0.08); display: flex; align-items: center; justify-content: center;">
                        <i class="ri-user-line" style="color: var(--haiti-olive); font-size: 14px;"></i>
                      </div>
                    <% end %>
                    <div>
                      <div class="fw-bold" style="color: var(--haiti-charcoal); font-size: 12px;">$<%= lu.cashtag %></div>
                      <div style="color: var(--haiti-olive); font-size: 9px;"><%= lu.email %></div>
                    </div>
                  </div>
                </td>
                <td>
                  <span class="badge rounded-pill" style="font-size: 9px; background: rgba(93,99,69,0.08); color: var(--haiti-olive);">
                    <%= lu.tier_icon %> <%= lu.credit_tier %>
                  </span>
                </td>
                <td class="fw-bold" style="color: var(--haiti-charcoal); font-family: 'Space Grotesk', sans-serif;">
                  <%= number_to_currency(loan.fiat_amount, unit: "", precision: 0) %> HTG
                </td>
                <td style="color: var(--haiti-olive); font-size: 11px;">
                  <%= loan.loan_purpose_label.truncate(25) rescue "—" %>
                </td>
                <td>
                  <% sc = Admin::ActivityItem.status_for_transaction(loan.status) %>
                  <span class="badge rounded-pill fw-bold" style="background: <%= sc[:bg] %>; color: <%= sc[:color] %>; font-size: 10px; padding: 3px 8px;">
                    <i class="<%= sc[:icon] %> me-1" style="font-size: 10px;"></i><%= sc[:label] %>
                  </span>
                </td>
                <td style="color: var(--haiti-olive); font-size: 11px;"><%= loan.created_at.strftime("%d/%m/%y %H:%M") %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-5">
        <i class="ri-hand-coin-line ri-2x mb-2" style="color: var(--haiti-olive); opacity: 0.3;"></i>
        <p class="small" style="color: var(--haiti-olive);">Pa gen aktivite prè ki matche ak filtè sa a.</p>
      </div>
    <% end %>
  </div>
<% end %>

<style>
  .table-hover tbody tr:hover { background-color: rgba(197,160,89,0.04) !important; }
</style>
