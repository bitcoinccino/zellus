<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
  <div class="card-base p-4 w-100 shadow-lg" style="max-width: 480px;">

    <!-- Header -->
    <div class="text-center mb-4">
      <div class="d-inline-flex align-items-center justify-content-center mb-3 rounded-3"
           style="width: 60px; height: 60px; background-color: var(--haiti-charcoal);">
        <i class="ri-loop-right-line ri-xl" style="color: var(--haiti-gold);"></i>
      </div>
      <h1 class="h4 fw-black mb-1" style="color: var(--haiti-charcoal);">Kreye PrioSol</h1>
      <p class="small text-uppercase fw-bold" style="color: var(--haiti-olive); letter-spacing: 1px;">
        Kòmanse yon sèk ekonomi kominotè
      </p>
    </div>

    <% if @circle.errors.any? %>
      <div class="p-3 mb-3 rounded-3" style="background-color: #fdf2f2; border: 1px solid #fca5a5;">
        <div class="small fw-bold mb-1" style="color: #991b1b;">Pa kapab kreye sèk la</div>
        <div class="small" style="color: #991b1b;"><%= @circle.errors.full_messages.to_sentence %></div>
      </div>
    <% end %>

    <%= form_with model: @circle, url: sol_circles_path, local: true, class: "row g-3" do |f| %>

      <!-- Circle Name -->
      <div class="col-12">
        <label class="form-label small fw-bold text-uppercase" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">Non Sèk</label>
        <%= f.text_field :name, placeholder: "Ekzanp: Fon Antrepriz", maxlength: 60,
            class: "form-control fw-bold", style: "border: 2px solid var(--haiti-olive); background: var(--haiti-cream);" %>
      </div>

      <!-- Category -->
      <div class="col-12">
        <label class="form-label small fw-bold text-uppercase" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">Kalite Sol</label>
        <div class="d-flex flex-wrap gap-2">
          <% SolCircle::CATEGORY_LABELS.each do |key, label| %>
            <label class="btn btn-sm rounded-pill fw-bold" style="border: 2px solid var(--haiti-olive); background: var(--haiti-cream); color: var(--haiti-olive); font-size: 11px; cursor: pointer;">
              <%= f.radio_button :category, key, class: "d-none", data: { category_toggle: true } %>
              <i class="<%= SolCircle::CATEGORY_ICONS[key] %> me-1"></i><%= label %>
            </label>
          <% end %>
        </div>
      </div>

      <!-- Asset -->
      <div class="col-md-6">
        <label class="form-label small fw-bold text-uppercase" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">Aktif</label>
        <%= f.select :asset,
              options_for_select([["HTG (MonCash)", "htg"], ["USDC (Base)", "usdc"]], @circle.asset),
              {},
              { class: "form-select fw-bold", id: "sol_asset", style: "border: 2px solid var(--haiti-olive); background: var(--haiti-cream);" } %>
        <div class="small mt-1" style="color: var(--haiti-olive); font-size: 10px;">
          <i class="ri-information-line me-1"></i>Monnen kontribisyon ak peman
        </div>
      </div>

      <!-- Amount -->
      <div class="col-md-6">
        <label class="form-label small fw-bold text-uppercase" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">Montan Kontribisyon</label>
        <%= f.number_field :amount, step: "0.01", min: "1", placeholder: "500.00",
            class: "form-control fw-bold", id: "sol_amount",
            style: "border: 2px solid var(--haiti-olive); background: var(--haiti-cream);" %>
        <div class="small mt-1" id="amount-hint" style="color: var(--haiti-olive); font-size: 10px;">
          <i class="ri-coin-line me-1"></i><span>HTG 1,000 — 150,000</span>
        </div>
      </div>

      <!-- Duration -->
      <div class="col-md-6">
        <label class="form-label small fw-bold text-uppercase" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">Dire</label>
        <%= f.select :frequency,
              options_for_select([["3 Mwa", "three_months"], ["6 Mwa", "six_months"], ["1 Ane", "twelve_months"]], @circle.frequency || "six_months"),
              {},
              { class: "form-select fw-bold", id: "sol_frequency", style: "border: 2px solid var(--haiti-olive); background: var(--haiti-cream);" } %>
        <div class="small mt-1" style="color: var(--haiti-olive); font-size: 10px;">
          <i class="ri-time-line me-1"></i>Konbyen tan Sol la dire
        </div>
      </div>

      <!-- Target Members -->
      <div class="col-md-6">
        <label class="form-label small fw-bold text-uppercase" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">Kantite Manm</label>
        <%= f.number_field :target_members, min: 3, max: 20,
            class: "form-control fw-bold",
            style: "border: 2px solid var(--haiti-olive); background: var(--haiti-cream);" %>
        <div class="small mt-1" style="color: var(--haiti-olive); font-size: 10px;">
          <i class="ri-team-line me-1"></i>3 a 20 manm
        </div>
      </div>

      <!-- Creator Fee -->
      <div class="col-12">
        <label class="form-label small fw-bold text-uppercase" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">Frè Mèt Sol (Opsyonèl)</label>
        <%= f.select :creator_fee_percent,
              options_for_select([["0% — Pa gen frè", 0], ["1%", 1], ["2%", 2], ["3%", 3], ["5%", 5]], @circle.creator_fee_percent || 0),
              {},
              { class: "form-select fw-bold", style: "border: 2px solid var(--haiti-olive); background: var(--haiti-cream);" } %>
        <div class="small mt-1" style="color: var(--haiti-olive); font-size: 10px;">
          <i class="ri-money-dollar-circle-line me-1"></i>Pousantaj ou touche sou chak peman wonn
        </div>
      </div>

      <!-- Fee Summary -->
      <div class="col-12">
        <div class="small p-3 rounded-3" style="background-color: rgba(197, 160, 89, 0.1); border: 1px solid rgba(197, 160, 89, 0.3);">
          <div class="fw-bold text-uppercase mb-1" style="font-size: 10px; color: var(--haiti-charcoal); letter-spacing: 1px;">
            <i class="ri-percent-line me-1"></i>Estrikti Frè
          </div>
          <ul class="list-unstyled mb-0" style="font-size: 11px; color: var(--haiti-olive);">
            <li><i class="ri-arrow-right-s-line me-1"></i> Frè platfòm Priotelus: <strong>2%</strong> sou chak peman</li>
            <li><i class="ri-arrow-right-s-line me-1"></i> Frè Mèt Sol: <strong>ou chwazi</strong> anwo a (0-5%)</li>
            <li><i class="ri-arrow-right-s-line me-1"></i> Rès la ale dirèkteman bay manm ki resevwa a</li>
          </ul>
        </div>
      </div>

      <!-- How It Works -->
      <div class="col-12">
        <div class="small p-3 rounded-3" style="background-color: rgba(93, 99, 69, 0.05); border: 1px solid rgba(93, 99, 69, 0.2);">
          <div class="fw-bold text-uppercase mb-1" style="font-size: 10px; color: var(--haiti-olive); letter-spacing: 1px;">Kijan Sa Mache</div>
          <ul class="list-unstyled mb-0" style="font-size: 11px; color: var(--haiti-olive);">
            <li><i class="ri-check-line me-1"></i> Chak manm kontribye menm montan chak wonn</li>
            <li><i class="ri-check-line me-1"></i> Yon manm resevwa tout kès la chak wonn</li>
            <li><i class="ri-check-line me-1"></i> Wotasyon kontinye jiskaske tout moun resevwa</li>
            <li><i class="ri-check-line me-1"></i> Peye a lè = ogmante nivo kredi ou</li>
            <li><i class="ri-shield-check-line me-1"></i> Manke peman = penalite kredi (-25 pwen)</li>
            <li><i class="ri-error-warning-line me-1"></i> Pa ka peye ditou = retire nan Sol (-50 pwen)</li>
          </ul>
        </div>
      </div>

      <!-- Submit -->
      <div class="col-12 mt-2">
        <%= f.button class: "btn w-100 py-2 fw-bold rounded-4 border-0", style: "background-color: var(--haiti-charcoal); color: var(--haiti-gold);" do %>
          <i class="ri-add-circle-line me-1"></i> Kreye PrioSol
        <% end %>
      </div>
    <% end %>

    <div class="text-center mt-3">
      <%= link_to sol_circles_path, class: "small fw-bold text-decoration-none", style: "color: var(--haiti-olive);" do %>
        <i class="ri-arrow-left-line me-1"></i> Retounen nan Sèk Sol
      <% end %>
    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    // Category pill toggle
    var radios = document.querySelectorAll("[data-category-toggle]");
    radios.forEach(function(radio) {
      radio.addEventListener("change", function() {
        radios.forEach(function(r) {
          var label = r.closest("label");
          label.style.background = "var(--haiti-cream)";
          label.style.color = "var(--haiti-olive)";
          label.style.borderColor = "var(--haiti-olive)";
        });
        var selected = radio.closest("label");
        selected.style.background = "var(--haiti-charcoal)";
        selected.style.color = "var(--haiti-gold)";
        selected.style.borderColor = "var(--haiti-charcoal)";
      });
      if (radio.checked) { radio.dispatchEvent(new Event("change")); }
    });

    // Duration-based amount limits
    var LIMITS = {
      three_months:  { htg_min: 1000, htg_max: 50000,  usdc_min: 1, usdc_max: 1000 },
      six_months:    { htg_min: 1000, htg_max: 150000, usdc_min: 1, usdc_max: 2000 },
      twelve_months: { htg_min: 1000, htg_max: 500000, usdc_min: 1, usdc_max: 5000 }
    };

    var freqEl = document.getElementById("sol_frequency");
    var assetEl = document.getElementById("sol_asset");
    var amountEl = document.getElementById("sol_amount");
    var amountHint = document.querySelector("#amount-hint span");

    function updateLimits() {
      var freq = freqEl.value;
      var asset = assetEl.value;
      var lim = LIMITS[freq];
      if (!lim) return;

      var minAmt = asset === "htg" ? lim.htg_min : lim.usdc_min;
      var maxAmt = asset === "htg" ? lim.htg_max : lim.usdc_max;
      var unit = asset === "htg" ? "HTG" : "USDC";

      amountEl.min = minAmt;
      amountEl.max = maxAmt;
      amountHint.textContent = unit + " " + minAmt.toLocaleString() + " — " + maxAmt.toLocaleString();

      if (amountEl.value && parseFloat(amountEl.value) > maxAmt) {
        amountEl.value = maxAmt;
      }
    }

    freqEl.addEventListener("change", updateLimits);
    assetEl.addEventListener("change", updateLimits);
    updateLimits();
  });
</script>
