<div class="container py-4" style="max-width: 600px;">
  <!-- Header Card -->
  <div class="card-base p-4 mb-4 text-center">
    <div class="d-inline-flex align-items-center justify-content-center mb-3 rounded-3"
         style="width: 56px; height: 56px; background-color: var(--haiti-charcoal);">
      <i class="<%= @circle.category_icon %> ri-xl" style="color: var(--haiti-gold);"></i>
    </div>
    <div class="d-flex justify-content-center gap-2 mb-2">
      <span class="badge rounded-pill" style="background-color: var(--haiti-gold); color: var(--haiti-charcoal); font-size: 10px; font-weight: 800; letter-spacing: 0.5px;">
        <i class="<%= @circle.category_icon %> me-1"></i><%= @circle.category_label %>
      </span>
      <span class="badge rounded-pill" style="background-color: <%= @circle.status_bg %>; color: <%= @circle.status_color %>; border: 1px solid <%= @circle.status_border %>; font-size: 10px; font-weight: 800; letter-spacing: 0.5px;">
        <i class="<%= @circle.status_icon %> me-1"></i><%= @circle.status_label %>
      </span>
    </div>
    <h1 class="h4 fw-black mb-1" style="color: var(--haiti-charcoal);"><%= @circle.name %></h1>
    <p class="small mb-0" style="color: var(--haiti-olive);">Jeton Sèk: <code><%= @circle.token %></code></p>

    <div class="d-flex justify-content-center gap-4 mt-3">
      <div class="text-center">
        <div class="small fw-bold text-uppercase" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">Kontribisyon</div>
        <div class="fw-black" style="color: var(--haiti-charcoal);"><%= number_to_currency(@circle.amount, unit: @circle.htg? ? "HTG " : "USDC ") %></div>
      </div>
      <div class="text-center ps-4" style="border-left: 2px solid var(--haiti-olive);">
        <div class="small fw-bold text-uppercase" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">Dire</div>
        <div class="fw-bold" style="color: var(--haiti-charcoal);"><%= @circle.duration_months %> Mwa</div>
      </div>
      <div class="text-center ps-4" style="border-left: 2px solid var(--haiti-olive);">
        <div class="small fw-bold text-uppercase" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">Peryòd</div>
        <% if @circle.start_date %>
          <div class="fw-bold" style="color: var(--haiti-charcoal);">
            <%= @circle.start_date.strftime("%d %b %Y") %>
            <i class="ri-arrow-right-s-line" style="vertical-align: middle;"></i>
            <%= @circle.end_date.strftime("%d %b %Y") %>
          </div>
        <% else %>
          <div class="fw-bold" style="color: var(--haiti-olive);">
            <%= Date.today.strftime("%d %b %Y") %>
            <i class="ri-arrow-right-s-line" style="vertical-align: middle;"></i>
            <%= (Date.today + @circle.duration_months.months).strftime("%d %b %Y") %>
          </div>
          <div style="font-size: 9px; color: var(--haiti-gold);">
            <i class="ri-hourglass-line me-1"></i>Estimasyon — ap tann manm
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <% if @current_round %>
    <!-- Current Payout Holder -->
    <div class="card-base p-4 mb-4" style="border-left: 5px solid #166534; background-color: #f0fdf4;">
      <div class="small fw-bold text-uppercase mb-3" style="color: #166534; font-size: 10px; letter-spacing: 1px;">
        <i class="ri-medal-line me-1"></i> Resevwa Peman Wonn Sa a
      </div>
      <div class="d-flex align-items-center gap-3">
        <span style="font-size: 2.5rem;"><%= @current_round.payout_user.tier_icon %></span>
        <div>
          <div class="fw-black h5 mb-0" style="color: var(--haiti-charcoal);"><%= @current_round.payout_user.email.split('@').first %></div>
          <div class="small fw-bold" style="color: #166534;">Nivo: <%= @current_round.payout_user.credit_tier %></div>
        </div>
        <div class="ms-auto text-end">
          <div class="small fw-bold text-uppercase" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">Total Kès</div>
          <div class="fw-black h5 mb-0" style="color: var(--haiti-charcoal);"><%= number_to_currency(@circle.payout_amount, unit: @circle.htg? ? "HTG " : "USDC ") %></div>
        </div>
      </div>
    </div>
  <% else %>
    <!-- Waiting for Members -->
    <div class="card-base p-4 mb-4 text-center" style="border-left: 5px solid var(--haiti-gold); background-color: var(--haiti-cream);">
      <div class="d-inline-flex align-items-center justify-content-center mb-2 rounded-circle"
           style="width: 48px; height: 48px; background-color: var(--haiti-gold);">
        <i class="ri-hourglass-line ri-lg" style="color: var(--haiti-charcoal);"></i>
      </div>
      <div class="fw-black h5 mb-1" style="color: var(--haiti-charcoal);">Ap Tann Manm</div>
      <div class="small" style="color: var(--haiti-olive);">
        <strong><%= @circle.sol_memberships.count %></strong> / <strong><%= @circle.target_members %></strong> manm enskri.
        Sol la ap kòmanse lè tout manm rive.
      </div>
    </div>
  <% end %>

  <!-- The Rotation List -->
  <div class="card-base p-0 overflow-hidden mb-4">
    <div class="px-4 py-3" style="border-bottom: 2px solid var(--haiti-olive); background-color: var(--haiti-mint);">
      <h4 class="small fw-bold text-uppercase mb-0" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">Wotasyon Peman</h4>
    </div>

    <% @members.each do |membership| %>
      <div class="d-flex align-items-center gap-3 p-3 <%= 'fw-bold' if membership.user == current_user %>"
           style="border-bottom: 1px solid rgba(93,99,69,0.1); <%= 'background-color: var(--haiti-cream);' if membership.user == current_user %>">
        <% is_current = @current_round && membership.position == @current_round.round_number %>
        <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold"
             style="width: 32px; height: 32px; font-size: 12px;
                    background: <%= is_current ? 'var(--haiti-gold)' : 'var(--haiti-mint)' %>;
                    color: <%= is_current ? 'var(--haiti-charcoal)' : 'var(--haiti-olive)' %>;
                    border: 1px solid var(--haiti-olive);">
          <%= membership.position %>
        </div>

        <span style="font-size: 1.3rem;"><%= membership.user.tier_icon %></span>

        <div class="flex-grow-1">
          <div class="small fw-bold" style="color: var(--haiti-charcoal);">
            <%= membership.user.email.split('@').first %> <%= "(Ou)" if membership.user == current_user %>
          </div>
          <div class="small" style="color: var(--haiti-olive); font-size: 10px;">Nivo: <%= membership.user.credit_tier %></div>
        </div>

        <% if is_current %>
          <span class="badge rounded-pill" style="background-color: #dcfce7; color: #166534; font-size: 9px; font-weight: 800;">Aktyèl</span>
        <% elsif @current_round && membership.position < @current_round.round_number %>
          <i class="ri-checkbox-circle-fill" style="color: #166534;"></i>
        <% else %>
          <i class="ri-time-line" style="color: var(--haiti-olive);"></i>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Invite CTA -->
  <div class="card-base p-4 text-center">
    <div class="small fw-bold text-uppercase mb-2" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">
      <i class="ri-share-forward-line me-1"></i> Pataje Lyen Envitasyon
    </div>
    <div class="d-flex gap-2 align-items-start">
      <input type="text" class="form-control fw-bold" style="border: 2px solid var(--haiti-olive); background: var(--haiti-cream); font-size: 11px;"
             value="<%= join_sol_circle_url(@circle.token) %>" readonly id="inviteLink">
      <button class="btn btn-sm fw-bold rounded-3" style="background: var(--haiti-charcoal); color: var(--haiti-gold);"
              onclick="copyInvite(this)">
        <i class="ri-file-copy-line me-1"></i>Kopye
      </button>
    </div>
  </div>
</div>

<script>
  function copyInvite(btn) {
    var copyText = document.getElementById("inviteLink");
    copyText.select();
    if (navigator.clipboard && window.isSecureContext) {
      navigator.clipboard.writeText(copyText.value).then(function() {
        if (!btn) return;
        var original = btn.innerHTML;
        btn.innerHTML = '<i class="ri-check-line me-1"></i>Kopye';
        setTimeout(function() { btn.innerHTML = original; }, 1200);
      });
    } else {
      document.execCommand("copy");
    }
  }
</script>
