<div class="container d-flex justify-content-center" style="min-height: 80vh;">
  <div class="w-100" style="max-width: 900px;">

    <%# ── Page Header ── %>
    <div class="d-flex align-items-center justify-content-between mb-3">
      <h1 class="h5 fw-black mb-0" style="color: var(--haiti-charcoal);">
        <i class="ri-loop-right-line me-2" style="color: var(--haiti-gold);"></i>PrioSòl
      </h1>
      <%= link_to root_path, class: "small text-decoration-none fw-bold", style: "color: var(--haiti-olive);" do %>
        <i class="ri-arrow-left-line me-1"></i>Lakay
      <% end %>
    </div>
    <p class="mb-4" style="color: var(--haiti-olive); font-size: 13px;">Kreye Sòl pou fè ekonomi ak kominote'w.</p>

    <div class="row g-4">
      <%# ── LEFT: Kijan Li Mache ── %>
      <div class="col-lg-6">
        <div class="card-base p-4 h-100">
          <h5 class="fw-black mb-4" style="color: var(--haiti-charcoal);">
            <i class="ri-lightbulb-line me-2" style="color: var(--haiti-gold);"></i>Kijan Li Mache
          </h5>

          <div class="d-flex align-items-start gap-3 mb-4">
            <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; background: var(--haiti-charcoal); color: var(--haiti-gold); font-weight: 800;">1</div>
            <div>
              <div class="fw-bold" style="color: var(--haiti-charcoal); font-size: 13px;">Kreye yon Sòl</div>
              <div style="color: var(--haiti-olive); font-size: 12px;">Chwazi montan, dire (3, 6, oswa 12 mwa), ak kantite manm. Ou resevwa yon lyen pou pataje.</div>
            </div>
          </div>

          <div class="d-flex align-items-start gap-3 mb-4">
            <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; background: var(--haiti-charcoal); color: var(--haiti-gold); font-weight: 800;">2</div>
            <div>
              <div class="fw-bold" style="color: var(--haiti-charcoal); font-size: 13px;">Envite Manm</div>
              <div style="color: var(--haiti-olive); font-size: 12px;">Pataje lyen an ak zanmi, fanmi, oswa kominote'w. Lè tout manm jwenn, Sòl la aktive.</div>
            </div>
          </div>

          <div class="d-flex align-items-start gap-3 mb-4">
            <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; background: var(--haiti-charcoal); color: var(--haiti-gold); font-weight: 800;">3</div>
            <div>
              <div class="fw-bold" style="color: var(--haiti-charcoal); font-size: 13px;">Peye Chak Wonn</div>
              <div style="color: var(--haiti-olive); font-size: 12px;">Chak wonn, tout manm peye kontribisyon yo an HTG oswa USD. Premye peman an genyen.</div>
            </div>
          </div>

          <div class="d-flex align-items-start gap-3">
            <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; background: var(--haiti-charcoal); color: var(--haiti-gold); font-weight: 800;">4</div>
            <div>
              <div class="fw-bold" style="color: var(--haiti-charcoal); font-size: 13px;">Resevwa Peman</div>
              <div style="color: var(--haiti-olive); font-size: 12px;">Chak wonn, yon manm resevwa tout lajan an. Lajan an pwoteje nan eskwo jiskaske tout moun peye.</div>
            </div>
          </div>
        </div>
      </div>

      <%# ── RIGHT: Poukisa PrioSòl ── %>
      <div class="col-lg-6">
        <div class="card-base p-4 h-100">
          <h5 class="fw-black mb-4" style="color: var(--haiti-charcoal);">
            <i class="ri-star-line me-2" style="color: var(--haiti-gold);"></i>Poukisa PrioSòl?
          </h5>

          <div class="d-flex align-items-start gap-3 mb-4">
            <div class="flex-shrink-0 d-flex align-items-center justify-content-center rounded-3" style="width: 40px; height: 40px; background: rgba(197,160,89,0.12);">
              <i class="ri-group-line" style="color: var(--haiti-gold); font-size: 20px;"></i>
            </div>
            <div>
              <div class="fw-bold" style="color: var(--haiti-charcoal); font-size: 13px;">Sòl Dijital Modèn</div>
              <div style="color: var(--haiti-olive); font-size: 12px;">Menm sistèm mityèl tradisyonèl la, men dijital, transparan, ak sekirize.</div>
            </div>
          </div>

          <div class="d-flex align-items-start gap-3 mb-4">
            <div class="flex-shrink-0 d-flex align-items-center justify-content-center rounded-3" style="width: 40px; height: 40px; background: rgba(197,160,89,0.12);">
              <i class="ri-safe-2-line" style="color: var(--haiti-gold); font-size: 20px;"></i>
            </div>
            <div>
              <div class="fw-bold" style="color: var(--haiti-charcoal); font-size: 13px;">Eskwo Pwoteksyon</div>
              <div style="color: var(--haiti-olive); font-size: 12px;">Lajan an rete nan eskwo jiskaske tout manm peye. Pa gen risk pou pèdi lajan.</div>
            </div>
          </div>

          <div class="d-flex align-items-start gap-3 mb-4">
            <div class="flex-shrink-0 d-flex align-items-center justify-content-center rounded-3" style="width: 40px; height: 40px; background: rgba(197,160,89,0.12);">
              <i class="ri-coin-line" style="color: var(--haiti-gold); font-size: 20px;"></i>
            </div>
            <div>
              <div class="fw-bold" style="color: var(--haiti-charcoal); font-size: 13px;">HTG + USD</div>
              <div style="color: var(--haiti-olive); font-size: 12px;">Peye an Goud oswa an USD. Chwazi sa ki pi bon pou ou.</div>
            </div>
          </div>

          <div class="d-flex align-items-start gap-3 mb-4">
            <div class="flex-shrink-0 d-flex align-items-center justify-content-center rounded-3" style="width: 40px; height: 40px; background: rgba(197,160,89,0.12);">
              <i class="ri-medal-line" style="color: var(--haiti-gold); font-size: 20px;"></i>
            </div>
            <div>
              <div class="fw-bold" style="color: var(--haiti-charcoal); font-size: 13px;">Bati Kredi'w</div>
              <div style="color: var(--haiti-olive); font-size: 12px;">Chak peman alè ogmante pwen kredi'w pou jwenn aksè a prè nan PrioBousad.</div>
            </div>
          </div>

          <div class="mt-4">
            <%= link_to new_user_registration_path, class: "btn w-100 border-0 p-3", style: "background: var(--haiti-charcoal); color: var(--haiti-gold); font-weight: 700; font-size: 14px; border-radius: 8px;" do %>
              <i class="ri-user-add-line me-2"></i>Kreye Kont pou Kòmanse
            <% end %>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>
