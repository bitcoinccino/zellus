<div class="container py-4" style="max-width: 1060px;">

  <%# ── Back ── %>
  <a href="javascript:history.back()" class="d-inline-flex align-items-center gap-1 text-decoration-none mb-3" style="color: var(--haiti-olive); font-size: 13px; font-weight: 600;">
    <i class="ri-arrow-left-s-line" style="font-size: 18px;"></i>Retounen
  </a>

  <%# ══════════════════════════════════════════════════════ %>
  <%# ── HERO                                             ── %>
  <%# ══════════════════════════════════════════════════════ %>
  <div class="rounded-4 p-4 p-md-5 mb-4 text-center position-relative" style="background: var(--haiti-charcoal);">
    <div class="mb-3">
      <img src="<%= asset_path('zellus_square.png') %>" style="width: 56px; height: 56px; border-radius: 14px;" alt="Zellus">
    </div>
    <h1 class="fw-black mb-2" style="font-size: clamp(1.4rem, 3.5vw, 2rem); color: white;">
      <i class="ri-loop-right-line me-2" style="color: var(--haiti-gold);"></i>Zellus Sol
    </h1>
    <p class="mb-0 mx-auto" style="max-width: 480px; color: rgba(255,255,255,0.6); font-size: 14px;">
      Kreye Sol pou fe ekonomi ak kominote w.
    </p>
  </div>

  <%# ══════════════════════════════════════════════════════ %>
  <%# ── TWO-COLUMN LAYOUT                               ── %>
  <%# ══════════════════════════════════════════════════════ %>
  <div class="row g-4">

    <%# ── LEFT COLUMN ── %>
    <div class="col-lg-7">

      <%# ── Kijan Li Mache ── %>
      <div class="card-base p-4 mb-3" style="border: 2px solid rgba(197,160,89,0.2);">
        <h5 class="fw-black mb-3" style="color: var(--haiti-charcoal); font-size: 16px;">
          <i class="ri-lightbulb-line me-2" style="color: var(--haiti-gold);"></i>Kijan Li Mache
        </h5>

        <div class="d-flex align-items-start gap-3 p-3 rounded-3 mb-3" style="background: rgba(93,99,69,0.04); border: 1px solid rgba(93,99,69,0.08);">
          <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; background: var(--haiti-charcoal); color: var(--haiti-gold); font-weight: 800;">1</div>
          <div>
            <div class="fw-bold mb-1" style="color: var(--haiti-charcoal); font-size: 14px;">Kreye yon Sol</div>
            <div style="color: var(--haiti-olive); font-size: 13px; line-height: 1.7;">Chwazi montan, dire (3, 6, oswa 12 mwa), ak kantite manm. Ou resevwa yon lyen pou pataje.</div>
          </div>
        </div>

        <div class="d-flex align-items-start gap-3 p-3 rounded-3 mb-3" style="background: rgba(93,99,69,0.04); border: 1px solid rgba(93,99,69,0.08);">
          <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; background: var(--haiti-charcoal); color: var(--haiti-gold); font-weight: 800;">2</div>
          <div>
            <div class="fw-bold mb-1" style="color: var(--haiti-charcoal); font-size: 14px;">Envite Manm</div>
            <div style="color: var(--haiti-olive); font-size: 13px; line-height: 1.7;">Pataje lyen an ak zanmi, fanmi, oswa kominote w. Le tout manm jwenn, Sol la aktive.</div>
          </div>
        </div>

        <div class="d-flex align-items-start gap-3 p-3 rounded-3 mb-3" style="background: rgba(93,99,69,0.04); border: 1px solid rgba(93,99,69,0.08);">
          <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; background: var(--haiti-charcoal); color: var(--haiti-gold); font-weight: 800;">3</div>
          <div>
            <div class="fw-bold mb-1" style="color: var(--haiti-charcoal); font-size: 14px;">Peye Chak Wonn</div>
            <div style="color: var(--haiti-olive); font-size: 13px; line-height: 1.7;">Chak wonn, tout manm peye kontribisyon yo an HTG oswa USD. Premye peman an genyen.</div>
          </div>
        </div>

        <div class="d-flex align-items-start gap-3 p-3 rounded-3" style="background: rgba(93,99,69,0.04); border: 1px solid rgba(93,99,69,0.08);">
          <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; background: var(--haiti-charcoal); color: var(--haiti-gold); font-weight: 800;">4</div>
          <div>
            <div class="fw-bold mb-1" style="color: var(--haiti-charcoal); font-size: 14px;">Resevwa Peman</div>
            <div style="color: var(--haiti-olive); font-size: 13px; line-height: 1.7;">Chak wonn, yon manm resevwa tout lajan an. Lajan an pwoteje nan eskwo jiskaske tout moun peye.</div>
          </div>
        </div>
      </div>

    </div>

    <%# ── RIGHT COLUMN (Sticky) ── %>
    <div class="col-lg-5">
      <div style="position: sticky; top: 80px;">

        <%# ── Poukisa Zellus Sol? ── %>
        <div class="card-base p-4 mb-3" style="border: 2px solid rgba(197,160,89,0.2);">
          <h5 class="fw-black mb-3" style="color: var(--haiti-charcoal); font-size: 16px;">
            <i class="ri-star-line me-2" style="color: var(--haiti-gold);"></i>Poukisa Zellus Sol?
          </h5>

          <div class="d-flex align-items-start gap-3 p-3 rounded-3 mb-3" style="background: rgba(93,99,69,0.04); border: 1px solid rgba(93,99,69,0.08);">
            <div class="d-flex align-items-center justify-content-center rounded-circle flex-shrink-0" style="width: 40px; height: 40px; background: var(--haiti-charcoal);">
              <i class="ri-group-line" style="color: var(--haiti-gold); font-size: 18px;"></i>
            </div>
            <div>
              <div class="fw-bold mb-1" style="color: var(--haiti-charcoal); font-size: 14px;">Sol Dijital Moden</div>
              <div style="color: var(--haiti-olive); font-size: 12px; line-height: 1.6;">Menm sistem mityel tradisyonel la, men dijital, transparan, ak sekirize.</div>
            </div>
          </div>

          <div class="d-flex align-items-start gap-3 p-3 rounded-3 mb-3" style="background: rgba(93,99,69,0.04); border: 1px solid rgba(93,99,69,0.08);">
            <div class="d-flex align-items-center justify-content-center rounded-circle flex-shrink-0" style="width: 40px; height: 40px; background: var(--haiti-charcoal);">
              <i class="ri-safe-2-line" style="color: var(--haiti-gold); font-size: 18px;"></i>
            </div>
            <div>
              <div class="fw-bold mb-1" style="color: var(--haiti-charcoal); font-size: 14px;">Eskwo Pwoteksyon</div>
              <div style="color: var(--haiti-olive); font-size: 12px; line-height: 1.6;">Lajan an rete nan eskwo jiskaske tout manm peye. Pa gen risk pou pedi lajan.</div>
            </div>
          </div>

          <div class="d-flex align-items-start gap-3 p-3 rounded-3 mb-3" style="background: rgba(93,99,69,0.04); border: 1px solid rgba(93,99,69,0.08);">
            <div class="d-flex align-items-center justify-content-center rounded-circle flex-shrink-0" style="width: 40px; height: 40px; background: var(--haiti-charcoal);">
              <i class="ri-coin-line" style="color: var(--haiti-gold); font-size: 18px;"></i>
            </div>
            <div>
              <div class="fw-bold mb-1" style="color: var(--haiti-charcoal); font-size: 14px;">HTG + USD</div>
              <div style="color: var(--haiti-olive); font-size: 12px; line-height: 1.6;">Peye an Goud oswa an USD. Chwazi sa ki pi bon pou ou.</div>
            </div>
          </div>

          <div class="d-flex align-items-start gap-3 p-3 rounded-3" style="background: rgba(93,99,69,0.04); border: 1px solid rgba(93,99,69,0.08);">
            <div class="d-flex align-items-center justify-content-center rounded-circle flex-shrink-0" style="width: 40px; height: 40px; background: var(--haiti-charcoal);">
              <i class="ri-medal-line" style="color: var(--haiti-gold); font-size: 18px;"></i>
            </div>
            <div>
              <div class="fw-bold mb-1" style="color: var(--haiti-charcoal); font-size: 14px;">Bati Kredi w</div>
              <div style="color: var(--haiti-olive); font-size: 12px; line-height: 1.6;">Chak peman ale ogmante pwen kredi w pou jwenn akse a pre nan PrioBousad.</div>
            </div>
          </div>
        </div>

        <%# ── CTA ── %>
        <div class="card-base p-4 text-center" style="background: var(--haiti-charcoal); border: 2px solid rgba(197,160,89,0.2);">
          <h5 class="fw-black mb-2" style="color: var(--haiti-gold); font-size: 16px;">Komanse yon Sol</h5>
          <p class="mb-3" style="color: rgba(255,255,255,0.6); font-size: 13px;">Envite zanmi ou e komanse ekonomize ansanm.</p>
          <%= link_to new_user_registration_path, class: "btn fw-bold rounded-3 px-4 py-2", style: "background: var(--haiti-charcoal); color: var(--haiti-gold); font-size: 14px; border: 2px solid var(--haiti-gold);" do %>
            <i class="ri-user-add-line me-1"></i>Kreye Kont pou Komanse
          <% end %>
        </div>

      </div>
    </div>

  </div>
</div>
