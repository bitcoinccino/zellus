<div class="container d-flex justify-content-center" style="min-height: 80vh;">
  <div class="w-100" style="max-width: 900px;">

    <%# ── Page Header ── %>
    <div class="d-flex align-items-center justify-content-between mb-3">
      <h1 class="h5 fw-black mb-0" style="color: var(--haiti-charcoal);">
        <i class="ri-flashlight-line me-2" style="color: var(--haiti-gold);"></i>Zèllus
      </h1>
      <%= link_to root_path, class: "small text-decoration-none fw-bold", style: "color: var(--haiti-olive);" do %>
        <i class="ri-arrow-left-line me-1"></i>Lakay
      <% end %>
    </div>
    <p class="mb-4" style="color: var(--haiti-olive); font-size: 13px;">Voye lajan bay nenpòt moun imedyatman.</p>

    <div class="row g-4">
      <%# ── LEFT: Kijan Li Mache ── %>
      <div class="col-lg-6">
        <div class="card-base p-4 h-100">
          <h5 class="fw-black mb-4" style="color: var(--haiti-charcoal);">
            <i class="ri-lightbulb-line me-2" style="color: var(--haiti-gold);"></i>Kijan Li Mache
          </h5>

          <div class="d-flex align-items-start gap-3 mb-4">
            <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; background: var(--haiti-charcoal); color: var(--haiti-gold); font-weight: 800;">1</div>
            <div>
              <div class="fw-bold" style="color: var(--haiti-charcoal); font-size: 13px;">Depoze Lajan</div>
              <div style="color: var(--haiti-olive); font-size: 12px;">Mete HTG oswa USD nan pòtfèy Zèllus ou. Peye ak MonCash oswa depo kripto.</div>
            </div>
          </div>

          <div class="d-flex align-items-start gap-3 mb-4">
            <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; background: var(--haiti-charcoal); color: var(--haiti-gold); font-weight: 800;">2</div>
            <div>
              <div class="fw-bold" style="color: var(--haiti-charcoal); font-size: 13px;">Voye Lajan</div>
              <div style="color: var(--haiti-olive); font-size: 12px;">Voye lajan bay nenpòt moun ak $zellusTag yo, nimewo telefòn, oswa email.</div>
            </div>
          </div>

          <div class="d-flex align-items-start gap-3 mb-4">
            <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; background: var(--haiti-charcoal); color: var(--haiti-gold); font-weight: 800;">3</div>
            <div>
              <div class="fw-bold" style="color: var(--haiti-charcoal); font-size: 13px;">Mande Peman</div>
              <div style="color: var(--haiti-olive); font-size: 12px;">Kreye yon demann peman ak yon lyen pou nenpòt moun ka peye ou.</div>
            </div>
          </div>

          <div class="d-flex align-items-start gap-3">
            <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; background: var(--haiti-charcoal); color: var(--haiti-gold); font-weight: 800;">4</div>
            <div>
              <div class="fw-bold" style="color: var(--haiti-charcoal); font-size: 13px;">Retire Lajan</div>
              <div style="color: var(--haiti-olive); font-size: 12px;">Retire lajan ou sou MonCash oswa nan pòtfèy kripto ou nenpòt ki lè.</div>
            </div>
          </div>
        </div>
      </div>

      <%# ── RIGHT: Poukisa Zèllus ── %>
      <div class="col-lg-6">
        <div class="card-base p-4 h-100">
          <h5 class="fw-black mb-4" style="color: var(--haiti-charcoal);">
            <i class="ri-star-line me-2" style="color: var(--haiti-gold);"></i>Poukisa Zèllus?
          </h5>

          <div class="d-flex align-items-start gap-3 mb-4">
            <div class="flex-shrink-0 d-flex align-items-center justify-content-center rounded-3" style="width: 40px; height: 40px; background: rgba(197,160,89,0.12);">
              <i class="ri-flashlight-line" style="color: var(--haiti-gold); font-size: 20px;"></i>
            </div>
            <div>
              <div class="fw-bold" style="color: var(--haiti-charcoal); font-size: 13px;">Imedyatman</div>
              <div style="color: var(--haiti-olive); font-size: 12px;">Lajan rive nan kèk segonn. Pa gen delè bank oswa koup.</div>
            </div>
          </div>

          <div class="d-flex align-items-start gap-3 mb-4">
            <div class="flex-shrink-0 d-flex align-items-center justify-content-center rounded-3" style="width: 40px; height: 40px; background: rgba(197,160,89,0.12);">
              <i class="ri-at-line" style="color: var(--haiti-gold); font-size: 20px;"></i>
            </div>
            <div>
              <div class="fw-bold" style="color: var(--haiti-charcoal); font-size: 13px;">$ZellusTag</div>
              <div style="color: var(--haiti-olive); font-size: 12px;">Voye lajan ak yon senp $tag. Pa bezwen konnen nimewo kont.</div>
            </div>
          </div>

          <div class="d-flex align-items-start gap-3 mb-4">
            <div class="flex-shrink-0 d-flex align-items-center justify-content-center rounded-3" style="width: 40px; height: 40px; background: rgba(197,160,89,0.12);">
              <i class="ri-coin-line" style="color: var(--haiti-gold); font-size: 20px;"></i>
            </div>
            <div>
              <div class="fw-bold" style="color: var(--haiti-charcoal); font-size: 13px;">HTG + USD</div>
              <div style="color: var(--haiti-olive); font-size: 12px;">Kenbe balans ou an Goud oswa an USD. Ou chwazi.</div>
            </div>
          </div>

          <div class="d-flex align-items-start gap-3 mb-4">
            <div class="flex-shrink-0 d-flex align-items-center justify-content-center rounded-3" style="width: 40px; height: 40px; background: rgba(197,160,89,0.12);">
              <i class="ri-link" style="color: var(--haiti-gold); font-size: 20px;"></i>
            </div>
            <div>
              <div class="fw-bold" style="color: var(--haiti-charcoal); font-size: 13px;">Lyen Peman</div>
              <div style="color: var(--haiti-olive); font-size: 12px;">Kreye yon lyen pou moun peye ou san yo pa bezwen kont Zèllus.</div>
            </div>
          </div>

          <div class="mt-4">
            <%= link_to new_user_registration_path, class: "btn w-100 border-0 p-3", style: "background: var(--haiti-charcoal); color: var(--haiti-gold); font-weight: 700; font-size: 14px; border-radius: 8px;" do %>
              <i class="ri-user-add-line me-2"></i>Kreye Kont pou Kòmanse
            <% end %>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>
