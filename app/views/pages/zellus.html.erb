<div class="container py-4" style="max-width: 1060px;">

  <%# ── Back ── %>
  <a href="javascript:history.back()" class="d-inline-flex align-items-center gap-1 text-decoration-none mb-3" style="color: var(--haiti-olive); font-size: 13px; font-weight: 600;">
    <i class="ri-arrow-left-s-line" style="font-size: 18px;"></i>Retounen
  </a>

  <%# ══════════════════════════════════════════════════════ %>
  <%# ── HERO                                             ── %>
  <%# ══════════════════════════════════════════════════════ %>
  <div class="rounded-4 p-4 p-md-5 mb-4 text-center position-relative" style="background: var(--haiti-charcoal);">
    <div class="mb-3">
      <img src="<%= asset_path('zellus_square.png') %>" style="width: 56px; height: 56px; border-radius: 14px;" alt="Zellus">
    </div>
    <h1 class="fw-black mb-2" style="font-size: clamp(1.4rem, 3.5vw, 2rem); color: white;">
      <i class="ri-flashlight-fill me-2" style="color: var(--haiti-gold);"></i>Zellus Pay
    </h1>
    <p class="mb-0 mx-auto" style="max-width: 480px; color: rgba(255,255,255,0.6); font-size: 14px;">
      Voye lajan bay nenpot moun imedyatman, gratis.
    </p>
  </div>

  <%# ══════════════════════════════════════════════════════ %>
  <%# ── TWO-COLUMN LAYOUT                               ── %>
  <%# ══════════════════════════════════════════════════════ %>
  <div class="row g-4">

    <%# ── LEFT COLUMN ── %>
    <div class="col-lg-7">

      <%# ── Kijan Li Mache ── %>
      <div class="card-base p-4 mb-3" style="border: 2px solid rgba(197,160,89,0.2);">
        <h5 class="fw-black mb-3" style="color: var(--haiti-charcoal); font-size: 16px;">
          <i class="ri-lightbulb-line me-2" style="color: var(--haiti-gold);"></i>Kijan Li Mache
        </h5>

        <div class="d-flex align-items-start gap-3 p-3 rounded-3 mb-3" style="background: rgba(93,99,69,0.04); border: 1px solid rgba(93,99,69,0.08);">
          <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; background: var(--haiti-charcoal); color: var(--haiti-gold); font-weight: 800;">1</div>
          <div>
            <div class="fw-bold mb-1" style="color: var(--haiti-charcoal); font-size: 14px;">Depoze Lajan</div>
            <div style="color: var(--haiti-olive); font-size: 13px; line-height: 1.7;">Mete HTG oswa USD nan potfey Zellus ou. Peye ak MonCash oswa depo kripto.</div>
          </div>
        </div>

        <div class="d-flex align-items-start gap-3 p-3 rounded-3 mb-3" style="background: rgba(93,99,69,0.04); border: 1px solid rgba(93,99,69,0.08);">
          <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; background: var(--haiti-charcoal); color: var(--haiti-gold); font-weight: 800;">2</div>
          <div>
            <div class="fw-bold mb-1" style="color: var(--haiti-charcoal); font-size: 14px;">Voye Lajan</div>
            <div style="color: var(--haiti-olive); font-size: 13px; line-height: 1.7;">Voye lajan bay nenpot moun ak $ZellusTag yo, nimewo telefon, oswa email.</div>
          </div>
        </div>

        <div class="d-flex align-items-start gap-3 p-3 rounded-3 mb-3" style="background: rgba(93,99,69,0.04); border: 1px solid rgba(93,99,69,0.08);">
          <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; background: var(--haiti-charcoal); color: var(--haiti-gold); font-weight: 800;">3</div>
          <div>
            <div class="fw-bold mb-1" style="color: var(--haiti-charcoal); font-size: 14px;">Mande Peman</div>
            <div style="color: var(--haiti-olive); font-size: 13px; line-height: 1.7;">Kreye yon demann peman ak yon lyen pou nenpot moun ka peye ou.</div>
          </div>
        </div>

        <div class="d-flex align-items-start gap-3 p-3 rounded-3" style="background: rgba(93,99,69,0.04); border: 1px solid rgba(93,99,69,0.08);">
          <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; background: var(--haiti-charcoal); color: var(--haiti-gold); font-weight: 800;">4</div>
          <div>
            <div class="fw-bold mb-1" style="color: var(--haiti-charcoal); font-size: 14px;">Retire Lajan</div>
            <div style="color: var(--haiti-olive); font-size: 13px; line-height: 1.7;">Retire lajan ou sou MonCash oswa nan potfey kripto ou nenpot ki le.</div>
          </div>
        </div>
      </div>

    </div>

    <%# ── RIGHT COLUMN (Sticky) ── %>
    <div class="col-lg-5">
      <div style="position: sticky; top: 80px;">

        <%# ── Poukisa Zellus? ── %>
        <div class="card-base p-4 mb-3" style="border: 2px solid rgba(197,160,89,0.2);">
          <h5 class="fw-black mb-3" style="color: var(--haiti-charcoal); font-size: 16px;">
            <i class="ri-star-line me-2" style="color: var(--haiti-gold);"></i>Poukisa Zellus?
          </h5>

          <div class="d-flex align-items-start gap-3 p-3 rounded-3 mb-3" style="background: rgba(93,99,69,0.04); border: 1px solid rgba(93,99,69,0.08);">
            <div class="d-flex align-items-center justify-content-center rounded-circle flex-shrink-0" style="width: 40px; height: 40px; background: var(--haiti-charcoal);">
              <i class="ri-flashlight-line" style="color: var(--haiti-gold); font-size: 18px;"></i>
            </div>
            <div>
              <div class="fw-bold mb-1" style="color: var(--haiti-charcoal); font-size: 14px;">Imedyatman</div>
              <div style="color: var(--haiti-olive); font-size: 12px; line-height: 1.6;">Lajan rive nan kek segonn. Pa gen dele bank oswa koup.</div>
            </div>
          </div>

          <div class="d-flex align-items-start gap-3 p-3 rounded-3 mb-3" style="background: rgba(93,99,69,0.04); border: 1px solid rgba(93,99,69,0.08);">
            <div class="d-flex align-items-center justify-content-center rounded-circle flex-shrink-0" style="width: 40px; height: 40px; background: var(--haiti-charcoal);">
              <i class="ri-at-line" style="color: var(--haiti-gold); font-size: 18px;"></i>
            </div>
            <div>
              <div class="fw-bold mb-1" style="color: var(--haiti-charcoal); font-size: 14px;">$ZellusTag</div>
              <div style="color: var(--haiti-olive); font-size: 12px; line-height: 1.6;">Voye lajan ak yon senp $tag. Pa bezwen konnen nimewo kont.</div>
            </div>
          </div>

          <div class="d-flex align-items-start gap-3 p-3 rounded-3 mb-3" style="background: rgba(93,99,69,0.04); border: 1px solid rgba(93,99,69,0.08);">
            <div class="d-flex align-items-center justify-content-center rounded-circle flex-shrink-0" style="width: 40px; height: 40px; background: var(--haiti-charcoal);">
              <i class="ri-coin-line" style="color: var(--haiti-gold); font-size: 18px;"></i>
            </div>
            <div>
              <div class="fw-bold mb-1" style="color: var(--haiti-charcoal); font-size: 14px;">HTG + USD</div>
              <div style="color: var(--haiti-olive); font-size: 12px; line-height: 1.6;">Kenbe balans ou an Goud oswa an USD. Ou chwazi.</div>
            </div>
          </div>

          <div class="d-flex align-items-start gap-3 p-3 rounded-3" style="background: rgba(93,99,69,0.04); border: 1px solid rgba(93,99,69,0.08);">
            <div class="d-flex align-items-center justify-content-center rounded-circle flex-shrink-0" style="width: 40px; height: 40px; background: var(--haiti-charcoal);">
              <i class="ri-link" style="color: var(--haiti-gold); font-size: 18px;"></i>
            </div>
            <div>
              <div class="fw-bold mb-1" style="color: var(--haiti-charcoal); font-size: 14px;">Lyen Peman</div>
              <div style="color: var(--haiti-olive); font-size: 12px; line-height: 1.6;">Kreye yon lyen pou moun peye ou san yo pa bezwen kont Zellus.</div>
            </div>
          </div>
        </div>

        <%# ── CTA ── %>
        <div class="card-base p-4 text-center" style="background: var(--haiti-charcoal); border: 2px solid rgba(197,160,89,0.2);">
          <h5 class="fw-black mb-2" style="color: var(--haiti-gold); font-size: 16px;">Komanse Kounye a</h5>
          <p class="mb-3" style="color: rgba(255,255,255,0.6); font-size: 13px;">Kreye kont ou an mwens pase 2 minit.</p>
          <%= link_to new_user_registration_path, class: "btn fw-bold rounded-3 px-4 py-2", style: "background: var(--haiti-charcoal); color: var(--haiti-gold); font-size: 14px; border: 2px solid var(--haiti-gold);" do %>
            <i class="ri-user-add-line me-1"></i>Kreye Kont Gratis
          <% end %>
        </div>

      </div>
    </div>

  </div>
</div>
