<div class="container py-4" style="max-width: 1060px;">

  <%# ── Back ── %>
  <a href="javascript:history.back()" class="d-inline-flex align-items-center gap-1 text-decoration-none mb-3" style="color: var(--haiti-olive); font-size: 13px; font-weight: 600;">
    <i class="ri-arrow-left-s-line" style="font-size: 18px;"></i>Retounen
  </a>

  <%# ══════════════════════════════════════════════════════ %>
  <%# ── HERO                                             ── %>
  <%# ══════════════════════════════════════════════════════ %>
  <div class="rounded-4 p-4 p-md-5 mb-4 text-center position-relative" style="background: var(--haiti-charcoal);">
    <div class="mb-3">
      <img src="<%= asset_path('zellus_square.png') %>" style="width: 56px; height: 56px; border-radius: 14px;" alt="Zellus">
    </div>

    <% if user_signed_in? && current_user.uma_enabled? && LightsparkConfig.enabled? %>
      <h1 class="fw-black mb-3" style="font-size: clamp(1.4rem, 3.5vw, 2rem); color: white;">
        <i class="ri-money-dollar-circle-line me-2" style="color: var(--haiti-gold);"></i>Adres Ou
      </h1>
      <div class="mx-auto mb-3 px-4 py-3 rounded-4 d-inline-flex align-items-center gap-3"
           style="background: rgba(255,255,255,0.06); border: 2px solid rgba(197,160,89,0.35); cursor: pointer;"
           onclick="copyResevwaUma()" id="resevwa-uma-chip">
        <i class="ri-global-line" style="color: var(--haiti-gold); font-size: 22px;"></i>
        <span class="fw-black" style="color: var(--haiti-gold); font-size: clamp(1rem, 3vw, 1.4rem); letter-spacing: 0.3px;" id="resevwa-uma-text"><%= current_user.uma_address %></span>
        <i class="ri-file-copy-line" style="color: rgba(255,255,255,0.5); font-size: 18px;" id="resevwa-copy-icon"></i>
      </div>
      <p class="mb-0 mx-auto" style="max-width: 480px; color: rgba(255,255,255,0.6); font-size: 14px;">
        Voye adres sa a bay fanmi ou aletranje. Yo ka voye lajan ba ou direkteman depi app yo a.
      </p>
    <% else %>
      <h1 class="fw-black mb-3" style="font-size: clamp(1.4rem, 3.5vw, 2rem); color: white;">
        <i class="ri-money-dollar-circle-line me-2" style="color: var(--haiti-gold);"></i>Resevwa Lajan
      </h1>
      <p class="mb-4 mx-auto" style="max-width: 480px; color: rgba(255,255,255,0.6); font-size: 14px;">
        Resevwa lajan depi nenpot kote nan mond lan, direkteman nan potfey Zellus ou.
      </p>
      <%= link_to new_user_registration_path, class: "btn fw-bold rounded-3 px-4 py-2", style: "background: var(--haiti-charcoal); color: var(--haiti-gold); font-size: 14px; border: 2px solid var(--haiti-gold);" do %>
        <i class="ri-user-add-line me-1"></i>Kreye Kont Gratis
      <% end %>
    <% end %>
  </div>

  <%# ══════════════════════════════════════════════════════ %>
  <%# ── TWO-COLUMN LAYOUT                               ── %>
  <%# ══════════════════════════════════════════════════════ %>
  <div class="row g-4">

    <%# ── LEFT COLUMN ── %>
    <div class="col-lg-7">

      <%# ── Kijan Sa Mache ── %>
      <div class="card-base p-4 mb-3" style="border: 2px solid rgba(197,160,89,0.2);">
        <h5 class="fw-black mb-3" style="color: var(--haiti-charcoal); font-size: 16px;">
          <i class="ri-route-line me-2" style="color: var(--haiti-gold);"></i>Kijan Sa Mache
        </h5>

        <div class="d-flex align-items-start gap-3 p-3 rounded-3 mb-3" style="background: rgba(93,99,69,0.04); border: 1px solid rgba(93,99,69,0.08);">
          <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; background: var(--haiti-charcoal); color: var(--haiti-gold); font-weight: 800;">1</div>
          <div>
            <div class="fw-bold mb-1" style="color: var(--haiti-charcoal); font-size: 14px;">Kopye Adres Ou</div>
            <div style="color: var(--haiti-olive); font-size: 13px; line-height: 1.7;">Kopye adres ki anwo a epi voye li bay moun ki pral voye lajan ba ou.</div>
          </div>
        </div>

        <div class="d-flex align-items-start gap-3 p-3 rounded-3 mb-3" style="background: rgba(93,99,69,0.04); border: 1px solid rgba(93,99,69,0.08);">
          <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; background: var(--haiti-charcoal); color: var(--haiti-gold); font-weight: 800;">2</div>
          <div>
            <div class="fw-bold mb-1" style="color: var(--haiti-charcoal); font-size: 14px;">Voye l Bay Moun Nan</div>
            <div style="color: var(--haiti-olive); font-size: 13px; line-height: 1.7;">Via mesaj, WhatsApp, oswa email. Moun nan tape adres la nan app yo a.</div>
          </div>
        </div>

        <div class="d-flex align-items-start gap-3 p-3 rounded-3" style="background: rgba(93,99,69,0.04); border: 1px solid rgba(93,99,69,0.08);">
          <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; background: var(--haiti-charcoal); color: var(--haiti-gold); font-weight: 800;">3</div>
          <div>
            <div class="fw-bold mb-1" style="color: var(--haiti-charcoal); font-size: 14px;">Lajan Rive Otomatikman</div>
            <div style="color: var(--haiti-olive); font-size: 13px; line-height: 1.7;">Yo voye lajan an, li rive nan potfey ou nan kek segonn. Pa gen aksyon nesese.</div>
          </div>
        </div>
      </div>

      <%# ── Ki App Ki Mache ── %>
      <div class="card-base p-4 mb-3" style="border: 2px solid rgba(197,160,89,0.2);">
        <h5 class="fw-black mb-3" style="color: var(--haiti-charcoal); font-size: 16px;">
          <i class="ri-apps-2-line me-2" style="color: var(--haiti-gold);"></i>Ki App Ki Mache
        </h5>
        <p class="mb-3" style="color: var(--haiti-olive); font-size: 13px;">Fanmi ou aletranje ka voye lajan depi app sa yo.</p>

        <div class="row g-3">
          <div class="col-6">
            <div class="rounded-3 p-3 text-center" style="background: rgba(93,99,69,0.04); border: 1px solid rgba(93,99,69,0.08);">
              <div class="rounded-3 mx-auto d-flex align-items-center justify-content-center mb-2"
                   style="width: 48px; height: 48px; background: #7B1AF7; border-radius: 12px !important;">
                <i class="ri-flashlight-fill" style="color: #fff; font-size: 24px;"></i>
              </div>
              <div class="fw-bold" style="color: var(--haiti-charcoal); font-size: 13px;">Strike</div>
              <div style="color: var(--haiti-olive); font-size: 11px;">Lightning rapid</div>
            </div>
          </div>
          <div class="col-6">
            <div class="rounded-3 p-3 text-center" style="background: rgba(93,99,69,0.04); border: 1px solid rgba(93,99,69,0.08);">
              <div class="rounded-3 mx-auto d-flex align-items-center justify-content-center mb-2"
                   style="width: 48px; height: 48px; background: var(--haiti-charcoal); border-radius: 12px !important;">
                <i class="ri-flashlight-line" style="color: var(--haiti-gold); font-size: 24px;"></i>
              </div>
              <div class="fw-bold" style="color: var(--haiti-charcoal); font-size: 13px;">Zellus</div>
              <div style="color: var(--haiti-olive); font-size: 11px;">Itilizate Zellus a Zellus</div>
            </div>
          </div>
        </div>

        <div class="text-center mt-3">
          <span class="badge rounded-pill px-3 py-2" style="background: rgba(197,160,89,0.12); color: var(--haiti-olive); font-size: 11px; font-weight: 600;">
            <i class="ri-add-line me-1"></i>Cash App, Coinbase, Revolut ap vini byento
          </span>
        </div>
      </div>

    </div>

    <%# ── RIGHT COLUMN (Sticky) ── %>
    <div class="col-lg-5">
      <div style="position: sticky; top: 80px;">

        <%# ── Konbyen Sa Koute ── %>
        <div class="card-base p-4 mb-3" style="border: 2px solid rgba(197,160,89,0.2);">
          <h5 class="fw-black mb-3" style="color: var(--haiti-charcoal); font-size: 16px;">
            <i class="ri-scales-3-line me-2" style="color: var(--haiti-gold);"></i>Konbyen Sa Koute
          </h5>
          <p class="mb-3" style="color: var(--haiti-olive); font-size: 13px;">Konpare fre pou voye $100 USD an Ayiti.</p>

          <div class="table-responsive">
            <table class="table table-borderless mb-0" style="font-size: 13px;">
              <thead>
                <tr>
                  <th style="color: var(--haiti-olive); font-weight: 600; font-size: 11px; border-bottom: 2px solid rgba(197,160,89,0.2);">Sevis</th>
                  <th class="text-center" style="color: var(--haiti-olive); font-weight: 600; font-size: 11px; border-bottom: 2px solid rgba(197,160,89,0.2);">Fre</th>
                  <th class="text-center" style="color: var(--haiti-olive); font-weight: 600; font-size: 11px; border-bottom: 2px solid rgba(197,160,89,0.2);">Tan</th>
                </tr>
              </thead>
              <tbody>
                <tr style="background: rgba(197,160,89,0.06);">
                  <td class="fw-bold" style="color: var(--haiti-charcoal);">
                    <i class="ri-flashlight-line me-1" style="color: var(--haiti-gold);"></i>Zellus
                  </td>
                  <td class="text-center fw-bold" style="color: var(--haiti-gold);">~3.5%</td>
                  <td class="text-center fw-bold" style="color: var(--haiti-charcoal);">Imedyat</td>
                </tr>
                <tr>
                  <td class="fw-bold" style="color: var(--haiti-charcoal);">Western Union</td>
                  <td class="text-center" style="color: var(--haiti-olive);">5-8%</td>
                  <td class="text-center" style="color: var(--haiti-olive);">1-3 jou</td>
                </tr>
                <tr>
                  <td class="fw-bold" style="color: var(--haiti-charcoal);">MonCash Ajan</td>
                  <td class="text-center" style="color: var(--haiti-olive);">5-10%</td>
                  <td class="text-center" style="color: var(--haiti-olive);">Menm jou</td>
                </tr>
              </tbody>
            </table>
          </div>

          <div class="mt-3 p-3 rounded-3" style="background: rgba(93,99,69,0.04); border: 1px solid rgba(93,99,69,0.08);">
            <div class="d-flex align-items-start gap-2">
              <i class="ri-information-line flex-shrink-0" style="color: var(--haiti-gold); font-size: 16px; margin-top: 2px;"></i>
              <span style="color: var(--haiti-olive); font-size: 12px;">Fre Zellus gen ladan fre rezo Lightning. Pa gen fre kache.</span>
            </div>
          </div>
        </div>

        <%# ── FAQ ── %>
        <div class="card-base p-4 mb-3" style="border: 2px solid rgba(197,160,89,0.2);">
          <h5 class="fw-black mb-3" style="color: var(--haiti-charcoal); font-size: 16px;">
            <i class="ri-question-answer-line me-2" style="color: var(--haiti-gold);"></i>Kesyon Souvan
          </h5>

          <div class="mb-3 p-3 rounded-3" style="background: rgba(93,99,69,0.04); border: 1px solid rgba(93,99,69,0.08);">
            <div class="fw-bold mb-1" style="color: var(--haiti-charcoal); font-size: 14px;">Konbyen tan sa pran?</div>
            <div style="color: var(--haiti-olive); font-size: 13px; line-height: 1.7;">Imedyat. Depi moun nan voye lajan an, li rive nan potfey ou nan kek segonn.</div>
          </div>

          <div class="mb-3 p-3 rounded-3" style="background: rgba(93,99,69,0.04); border: 1px solid rgba(93,99,69,0.08);">
            <div class="fw-bold mb-1" style="color: var(--haiti-charcoal); font-size: 14px;">Gen yon limit?</div>
            <div style="color: var(--haiti-olive); font-size: 13px; line-height: 1.7;">Wi, limit depann sou nivo verifikasyon BonID ou. Plis ou verifye, plis ou ka resevwa.</div>
          </div>

          <div class="p-3 rounded-3" style="background: rgba(93,99,69,0.04); border: 1px solid rgba(93,99,69,0.08);">
            <div class="fw-bold mb-1" style="color: var(--haiti-charcoal); font-size: 14px;">Eske mwen bezwen fe anyen?</div>
            <div style="color: var(--haiti-olive); font-size: 13px; line-height: 1.7;">Non. Jis pataje adres ou a. Lajan rive otomatikman nan potfey Zellus ou, pa gen aksyon nesese.</div>
          </div>
        </div>

        <%# ── CTA ── %>
        <div class="card-base p-4 text-center" style="background: var(--haiti-charcoal); border: 2px solid rgba(197,160,89,0.2);">
          <h5 class="fw-black mb-2" style="color: var(--haiti-gold); font-size: 16px;">Resevwa Lajan Kounye a</h5>
          <p class="mb-3" style="color: rgba(255,255,255,0.6); font-size: 13px;">Imedyat. Pa gen biwo. Pa gen fre kache.</p>
          <% if user_signed_in? %>
            <%= link_to wallet_path, class: "btn fw-bold rounded-3 px-4 py-2", style: "background: var(--haiti-charcoal); color: var(--haiti-gold); font-size: 14px; border: 2px solid var(--haiti-gold);" do %>
              <i class="ri-wallet-3-line me-1"></i>Ale nan Potfey
            <% end %>
          <% else %>
            <%= link_to new_user_registration_path, class: "btn fw-bold rounded-3 px-4 py-2", style: "background: var(--haiti-charcoal); color: var(--haiti-gold); font-size: 14px; border: 2px solid var(--haiti-gold);" do %>
              <i class="ri-user-add-line me-1"></i>Kreye Kont Gratis
            <% end %>
          <% end %>
        </div>

      </div>
    </div>

  </div>
</div>

<%# ── Copy UMA Address JS ── %>
<script>
function copyResevwaUma() {
  var text = document.getElementById("resevwa-uma-text");
  var icon = document.getElementById("resevwa-copy-icon");
  if (!text) return;

  navigator.clipboard.writeText(text.textContent.trim()).then(function() {
    icon.className = "ri-check-line";
    icon.style.color = "#4ade80";
    text.dataset.original = text.textContent;
    text.textContent = "Kopye!";
    text.style.color = "#4ade80";

    setTimeout(function() {
      icon.className = "ri-file-copy-line";
      icon.style.color = "rgba(255,255,255,0.5)";
      text.textContent = text.dataset.original;
      text.style.color = "var(--haiti-gold)";
    }, 2000);
  });
}
</script>
