<div class="container py-4" style="max-width: 1060px;">

  <%# ── Back ── %>
  <a href="javascript:history.back()" class="d-inline-flex align-items-center gap-1 text-decoration-none mb-3" style="color: var(--haiti-olive); font-size: 13px; font-weight: 600;">
    <i class="ri-arrow-left-s-line" style="font-size: 18px;"></i>Retounen
  </a>

  <%# ══════════════════════════════════════════════════════ %>
  <%# ── HERO                                             ── %>
  <%# ══════════════════════════════════════════════════════ %>
  <div class="rounded-4 p-4 p-md-5 mb-4 text-center position-relative" style="background: var(--haiti-charcoal);">
    <div class="mb-3">
      <img src="<%= asset_path('zellus_square.png') %>" style="width: 56px; height: 56px; border-radius: 14px;" alt="Zèllus">
    </div>
    <h1 class="fw-black mb-2" style="font-size: clamp(1.4rem, 3.5vw, 2rem); color: white;">
      <i class="ri-hand-coin-line me-2" style="color: var(--haiti-gold);"></i>Zèllus Bousad
    </h1>
    <p class="mb-0 mx-auto" style="max-width: 480px; color: rgba(255,255,255,0.6); font-size: 14px;">
      Prete pou ede biznis ou dekole.
    </p>
  </div>

  <%# ══════════════════════════════════════════════════════ %>
  <%# ── TWO-COLUMN LAYOUT                               ── %>
  <%# ══════════════════════════════════════════════════════ %>
  <div class="row g-4">

    <%# ── LEFT COLUMN ── %>
    <div class="col-lg-7">

      <%# ── Kijan Li Mache ── %>
      <div class="card-base p-4 mb-3" style="border: 2px solid rgba(197,160,89,0.2);">
        <h5 class="fw-black mb-3" style="color: var(--haiti-charcoal); font-size: 16px;">
          <i class="ri-lightbulb-line me-2" style="color: var(--haiti-gold);"></i>Kijan Li Mache
        </h5>

        <div class="d-flex align-items-start gap-3 p-3 rounded-3 mb-3" style="background: rgba(93,99,69,0.04); border: 1px solid rgba(93,99,69,0.08);">
          <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; background: var(--haiti-charcoal); color: var(--haiti-gold); font-weight: 800;">1</div>
          <div>
            <div class="fw-bold mb-1" style="color: var(--haiti-charcoal); font-size: 14px;">Bati Repitasyon w</div>
            <div style="color: var(--haiti-olive); font-size: 13px; line-height: 1.7;">Patisipe nan Sol epi peye ale pou ogmante pwen kredi w. Ou bezwen omwen nivo Toutrel (300+ pwen).</div>
          </div>
        </div>

        <div class="d-flex align-items-start gap-3 p-3 rounded-3 mb-3" style="background: rgba(93,99,69,0.04); border: 1px solid rgba(93,99,69,0.08);">
          <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; background: var(--haiti-charcoal); color: var(--haiti-gold); font-weight: 800;">2</div>
          <div>
            <div class="fw-bold mb-1" style="color: var(--haiti-charcoal); font-size: 14px;">Mande yon Pre</div>
            <div style="color: var(--haiti-olive); font-size: 13px; line-height: 1.7;">Chwazi montan an baze sou nivo kredi w. Toutrel: jiska 5,000 HTG. Malfini: 25,000 HTG. Folkon: 100,000 HTG.</div>
          </div>
        </div>

        <div class="d-flex align-items-start gap-3 p-3 rounded-3 mb-3" style="background: rgba(93,99,69,0.04); border: 1px solid rgba(93,99,69,0.08);">
          <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; background: var(--haiti-charcoal); color: var(--haiti-gold); font-weight: 800;">3</div>
          <div>
            <div class="fw-bold mb-1" style="color: var(--haiti-charcoal); font-size: 14px;">Resevwa Lajan An</div>
            <div style="color: var(--haiti-olive); font-size: 13px; line-height: 1.7;">Apre apwobasyon, lajan an rive direkteman sou MonCash oswa potfey USD ou.</div>
          </div>
        </div>

        <div class="d-flex align-items-start gap-3 p-3 rounded-3" style="background: rgba(93,99,69,0.04); border: 1px solid rgba(93,99,69,0.08);">
          <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; background: var(--haiti-charcoal); color: var(--haiti-gold); font-weight: 800;">4</div>
          <div>
            <div class="fw-bold mb-1" style="color: var(--haiti-charcoal); font-size: 14px;">Ranbouse Pre A</div>
            <div style="color: var(--haiti-olive); font-size: 13px; line-height: 1.7;">Peye ale pou kontinye ogmante pwen kredi w epi jwenn akse a pi gwo montan alavni.</div>
          </div>
        </div>
      </div>

    </div>

    <%# ── RIGHT COLUMN (Sticky) ── %>
    <div class="col-lg-5">
      <div style="position: sticky; top: 80px;">

        <%# ── Poukisa Zèllus Bousad? ── %>
        <div class="card-base p-4 mb-3" style="border: 2px solid rgba(197,160,89,0.2);">
          <h5 class="fw-black mb-3" style="color: var(--haiti-charcoal); font-size: 16px;">
            <i class="ri-star-line me-2" style="color: var(--haiti-gold);"></i>Poukisa Zèllus Bousad?
          </h5>

          <div class="d-flex align-items-start gap-3 p-3 rounded-3 mb-3" style="background: rgba(93,99,69,0.04); border: 1px solid rgba(93,99,69,0.08);">
            <div class="d-flex align-items-center justify-content-center rounded-circle flex-shrink-0" style="width: 40px; height: 40px; background: var(--haiti-charcoal);">
              <i class="ri-hand-coin-line" style="color: var(--haiti-gold); font-size: 18px;"></i>
            </div>
            <div>
              <div class="fw-bold mb-1" style="color: var(--haiti-charcoal); font-size: 14px;">Pre San Bank</div>
              <div style="color: var(--haiti-olive); font-size: 12px; line-height: 1.6;">Pa bezwen kont bank oswa garanti. Repitasyon w nan Zèllus Sol se garanti w.</div>
            </div>
          </div>

          <div class="d-flex align-items-start gap-3 p-3 rounded-3 mb-3" style="background: rgba(93,99,69,0.04); border: 1px solid rgba(93,99,69,0.08);">
            <div class="d-flex align-items-center justify-content-center rounded-circle flex-shrink-0" style="width: 40px; height: 40px; background: var(--haiti-charcoal);">
              <i class="ri-arrow-up-circle-line" style="color: var(--haiti-gold); font-size: 18px;"></i>
            </div>
            <div>
              <div class="fw-bold mb-1" style="color: var(--haiti-charcoal); font-size: 14px;">Montan Ki Grandi</div>
              <div style="color: var(--haiti-olive); font-size: 12px; line-height: 1.6;">Plis ou peye ale, plis limit pre w ogmante. Jiska 100,000 HTG pou nivo Folkon.</div>
            </div>
          </div>

          <div class="d-flex align-items-start gap-3 p-3 rounded-3" style="background: rgba(93,99,69,0.04); border: 1px solid rgba(93,99,69,0.08);">
            <div class="d-flex align-items-center justify-content-center rounded-circle flex-shrink-0" style="width: 40px; height: 40px; background: var(--haiti-charcoal);">
              <i class="ri-flashlight-line" style="color: var(--haiti-gold); font-size: 18px;"></i>
            </div>
            <div>
              <div class="fw-bold mb-1" style="color: var(--haiti-charcoal); font-size: 14px;">Rapid ak Senp</div>
              <div style="color: var(--haiti-olive); font-size: 12px; line-height: 1.6;">Mande yon pre an kek klik. Lajan an rive sou MonCash oswa potfey USD ou.</div>
            </div>
          </div>
        </div>

        <%# ── Nivo Kredi Yo ── %>
        <div class="card-base p-4 mb-3" style="border: 2px solid rgba(197,160,89,0.2);">
          <h5 class="fw-black mb-3" style="color: var(--haiti-charcoal); font-size: 16px;">
            <i class="ri-route-line me-2" style="color: var(--haiti-gold);"></i>Nivo Kredi Yo
          </h5>
          <div class="rounded-4 p-3" style="background: var(--haiti-charcoal);">
            <div class="d-flex align-items-center gap-2 mb-2 pb-2" style="border-bottom: 1px solid rgba(255,255,255,0.08);">
              <span style="font-size: 1.1rem;">🕊️</span>
              <span class="fw-bold" style="color: #fff; font-size: 13px;">Toutrel</span>
              <span class="ms-auto" style="color: rgba(255,255,255,0.4); font-size: 12px;">jiska 5,000 HTG</span>
            </div>
            <div class="d-flex align-items-center gap-2 mb-2 pb-2" style="border-bottom: 1px solid rgba(255,255,255,0.08);">
              <span style="font-size: 1.1rem;">🦅</span>
              <span class="fw-bold" style="color: #fff; font-size: 13px;">Malfini</span>
              <span class="ms-auto" style="color: rgba(255,255,255,0.4); font-size: 12px;">jiska 25,000 HTG</span>
            </div>
            <div class="d-flex align-items-center gap-2">
              <span style="font-size: 1.1rem;">⚡</span>
              <span class="fw-bold" style="color: #fff; font-size: 13px;">Folkon</span>
              <span class="ms-auto" style="color: rgba(255,255,255,0.4); font-size: 12px;">jiska 100,000 HTG</span>
            </div>
          </div>
        </div>

        <%# ── CTA ── %>
        <div class="card-base p-4 text-center" style="background: var(--haiti-charcoal); border: 2px solid rgba(197,160,89,0.2);">
          <h5 class="fw-black mb-2" style="color: var(--haiti-gold); font-size: 16px;">Komanse Bati Kredi w</h5>
          <p class="mb-3" style="color: rgba(255,255,255,0.6); font-size: 13px;">Antre nan yon Sol pou deblouke akse a pre.</p>
          <%= link_to new_user_registration_path, class: "btn fw-bold rounded-3 px-4 py-2", style: "background: var(--haiti-charcoal); color: var(--haiti-gold); font-size: 14px; border: 2px solid var(--haiti-gold);" do %>
            <i class="ri-user-add-line me-1"></i>Kreye Kont pou Komanse
          <% end %>
        </div>

      </div>
    </div>

  </div>
</div>
