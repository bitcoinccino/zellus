<%# ── Commission Calculator JS ── %>
<script>
document.addEventListener("DOMContentLoaded", function() {
  const input = document.getElementById("ajan-calc-input");
  const result = document.getElementById("ajan-calc-result");
  const daily = document.getElementById("ajan-calc-daily");
  const monthly = document.getElementById("ajan-calc-monthly");

  if (!input || !result) return;

  function formatHTG(n) {
    return n.toLocaleString("fr-HT") + " HTG";
  }

  function calculate() {
    const amount = Math.max(0, parseInt(input.value) || 0);
    const commission = Math.round(amount * 0.02);
    result.textContent = formatHTG(commission);

    if (daily && monthly) {
      const perDay = 5;
      const monthlyTotal = commission * perDay * 30;
      daily.textContent = perDay;
      monthly.textContent = formatHTG(monthlyTotal);
    }
  }

  input.addEventListener("input", calculate);
  calculate();
});
</script>
