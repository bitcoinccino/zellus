<div class="container d-flex justify-content-center" style="min-height: 80vh; padding-top: 16px;">
  <div class="w-100" style="max-width: 440px;">

    <% display_name = @payment_request.payer_name.presence || "Nenpòt moun" %>
    <% clean_name = display_name.gsub(/[^\p{L}\p{N}\s]/, '').strip %>
    <% initials = clean_name.present? ? clean_name.split.map { |w| w[0] }.join.upcase.first(2) : "?" %>
    <% is_dead = @payment_request.expired? || @payment_request.canceled? || @payment_request.declined? %>
    <% asset_colors = { "htg" => "var(--haiti-gold)", "usdc" => "#0052FF", "eth" => "#627eea", "wbtc" => "#f7931a" } %>
    <% asset_color = asset_colors[@payment_request.asset] || "var(--haiti-gold)" %>

    <%# ══════════════════════════════════════════ %>
    <%# ── DARK HERO CARD (avatar + amount)     ── %>
    <%# ══════════════════════════════════════════ %>
    <div class="rounded-4 p-4 text-center position-relative" style="background: var(--haiti-charcoal);">

      <%# ── Back button ── %>
      <%= link_to payment_requests_path, class: "text-decoration-none position-absolute", style: "top: 16px; left: 16px; color: rgba(255,255,255,0.5); font-size: 20px;" do %>
        <i class="ri-arrow-left-s-line"></i>
      <% end %>

      <%# ── Status badge ── %>
      <% status_cfg = case @payment_request.status
        when "active"
          { icon: "ri-flashlight-fill", color: "#22c55e", bg: "rgba(34,197,94,0.12)", label: "Aktif" }
        when "paid"
          { icon: "ri-checkbox-circle-fill", color: "#22c55e", bg: "rgba(34,197,94,0.12)", label: "Peye" }
        when "expired"
          { icon: "ri-forbid-line", color: "#f87171", bg: "rgba(248,113,113,0.12)", label: "Echwe" }
        when "canceled"
          { icon: "ri-close-circle-line", color: "#f87171", bg: "rgba(248,113,113,0.12)", label: "Anile" }
        when "declined"
          { icon: "ri-close-circle-line", color: "#f87171", bg: "rgba(248,113,113,0.12)", label: "Refize" }
        end %>
      <div class="d-inline-flex align-items-center gap-1 px-3 py-1 rounded-pill mb-3"
           style="background: <%= status_cfg[:bg] %>; font-size: 11px; font-weight: 700; color: <%= status_cfg[:color] %>;">
        <i class="<%= status_cfg[:icon] %>" style="font-size: 12px;"></i> <%= status_cfg[:label] %>
      </div>

      <%# ── Avatar ── %>
      <div class="d-flex justify-content-center mb-2">
        <div class="d-inline-flex align-items-center justify-content-center rounded-circle"
             style="width: 56px; height: 56px; background: rgba(255,255,255,0.08); border: 2px solid var(--haiti-gold);">
          <span class="fw-black" style="color: var(--haiti-gold); font-size: 20px;"><%= initials %></span>
        </div>
      </div>

      <%# ── Payee Name ── %>
      <div class="fw-bold mb-1" style="color: white; font-size: 16px;"><%= display_name %></div>

      <%# ── Date + Note ── %>
      <div style="color: rgba(255,255,255,0.4); font-size: 11px;">
        <%= @payment_request.created_at.strftime("%b %d · %l:%M %p").strip %>
      </div>
      <% if @payment_request.note.present? %>
        <div class="d-inline-flex align-items-center gap-1 mt-1 px-2 py-1 rounded-pill"
             style="background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.5); font-size: 10px; font-weight: 600;">
          <i class="ri-price-tag-3-line" style="font-size: 10px;"></i> <%= @payment_request.note %>
        </div>
      <% end %>

      <%# ── Amount ── %>
      <div class="mt-3 mb-1">
        <span class="fw-black" style="font-size: 44px; letter-spacing: -2px; line-height: 1;
             color: <%= is_dead ? 'rgba(255,255,255,0.15)' : 'white' %>;
             <%= 'text-decoration: line-through;' if is_dead %>">
          <%= number_to_currency(@payment_request.amount, unit: "", precision: 2) %>
        </span>
      </div>
      <div class="d-inline-flex align-items-center gap-1 px-3 py-1 rounded-pill mb-4"
           style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.08);">
        <span class="fw-bold" style="color: <%= asset_color %>; font-size: 13px;"><%= @payment_request.asset.upcase %></span>
      </div>

      <% if @payment_request.active? %>
        <%# ── Action buttons ── %>
        <div class="d-flex gap-2 justify-content-center" id="pr-action-buttons">
          <button type="button" onclick="showPinPanel()"
                  class="d-flex align-items-center justify-content-center gap-2 py-2 px-4 rounded-pill border-0"
                  style="background: rgba(34,197,94,0.15); border: 1px solid rgba(34,197,94,0.25); font-size: 12px; font-weight: 700; color: #4ade80;">
            <i class="ri-checkbox-circle-line" style="font-size: 15px;"></i> Peye
          </button>

          <button type="button" onclick="showCancelConfirm()"
                  class="d-flex align-items-center justify-content-center gap-2 py-2 px-4 rounded-pill border-0"
                  style="background: rgba(248,113,113,0.12); border: 1px solid rgba(248,113,113,0.2); font-size: 12px; font-weight: 700; color: #f87171;">
            <i class="ri-close-circle-line" style="font-size: 15px;"></i> Anile
          </button>
        </div>

        <%# ── PIN confirmation for Peye (hidden by default) ── %>
        <div id="pr-pin-panel" style="display: none;" class="mt-3">
          <div class="text-center mb-2">
            <span class="small fw-bold" style="color: rgba(255,255,255,0.6); font-size: 10px; letter-spacing: 0.5px;">
              <i class="ri-lock-line me-1"></i>ANTRE PIN POU KONFIME
            </span>
          </div>
          <%= form_with url: payment_request_path(@payment_request), method: :patch, local: true, id: "sol-pay-form" do %>
            <input type="hidden" name="mark_paid" value="true">
            <input type="password" name="transfer_pin" maxlength="4" pattern="\d{4}" inputmode="numeric"
                   class="form-control text-center fw-bold rounded-3 mb-2"
                   style="font-size: 20px; letter-spacing: 8px; padding: 10px; background: rgba(255,255,255,0.06); border: 1.5px solid rgba(255,255,255,0.15); color: white;"
                   placeholder="····" required autocomplete="off" id="pr-pin-input">
            <div class="d-flex gap-2">
              <button type="button" onclick="hidePinPanel()"
                      class="flex-grow-1 py-2 rounded-pill border-0 fw-bold"
                      style="background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.5); font-size: 12px;">
                Retounen
              </button>
              <button type="submit"
                      class="flex-grow-1 py-2 rounded-pill border-0 fw-bold"
                      style="background: rgba(34,197,94,0.15); color: #4ade80; font-size: 12px;">
                <i class="ri-checkbox-circle-line me-1"></i> Konfime Peye
              </button>
            </div>
          <% end %>
        </div>

        <%# ── Cancel confirmation (hidden by default) ── %>
        <div id="pr-cancel-panel" style="display: none;" class="mt-3">
          <div class="text-center mb-3">
            <i class="ri-error-warning-line" style="font-size: 28px; color: #f87171;"></i>
            <div class="fw-bold mt-1" style="color: white; font-size: 14px;">Èske ou sèten?</div>
            <div class="small mt-1" style="color: rgba(255,255,255,0.5);">
              Demann peman sa a ap anile epi peyè a ap resevwa yon notifikasyon.
            </div>
          </div>
          <%= form_with url: payment_request_path(@payment_request), method: :patch, local: true do %>
            <input type="hidden" name="cancel" value="true">
            <textarea name="cancel_note" rows="2" required
                      class="form-control border-0 rounded-3 mb-3"
                      style="background: rgba(255,255,255,0.08); color: white; font-size: 12px; resize: none;"
                      placeholder="Rezon pou anile (obligatwa)..."></textarea>
            <div class="d-flex gap-2">
              <button type="button" onclick="hideCancelConfirm()"
                      class="flex-grow-1 py-2 rounded-pill border-0 fw-bold"
                      style="background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.5); font-size: 12px;">
                Non
              </button>
              <button type="submit"
                      class="flex-grow-1 py-2 rounded-pill border-0 fw-bold"
                      style="background: rgba(248,113,113,0.15); color: #f87171; font-size: 12px;">
                <i class="ri-close-circle-line me-1"></i> Wi, Anile
              </button>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <%# ── Decline note from payer ── %>
    <% if @payment_request.declined? && @payment_request.cancel_note.present? %>
      <div class="card-base p-4 mt-3">
        <div class="d-flex align-items-start gap-2">
          <i class="ri-chat-quote-line flex-shrink-0" style="color: #f87171; font-size: 18px; margin-top: 1px;"></i>
          <div>
            <div class="fw-bold text-uppercase" style="color: #991b1b; font-size: 9px; letter-spacing: 1px; margin-bottom: 3px;">Rezon Refize</div>
            <div class="fw-semibold" style="color: var(--haiti-charcoal); font-size: 13px; line-height: 1.4;"><%= @payment_request.cancel_note %></div>
          </div>
        </div>
      </div>
    <% end %>

    <%# ══════════════════════════════════════════ %>
    <%# ── RECEIPT CARD                         ── %>
    <%# ══════════════════════════════════════════ %>
    <div class="card-base p-4 mt-3">

      <% if @payment_request.paid? && @payment_transfer.present? %>
        <%# ══════════════════════════════════════════ %>
        <%# ── PAYMENT RECEIVED (wallet-to-wallet)  ── %>
        <%# ══════════════════════════════════════════ %>
        <div class="p-3 rounded-4 mb-4" style="background: rgba(34,197,94,0.06); border: 1px solid rgba(34,197,94,0.15);">
          <div class="fw-bold text-uppercase mb-3" style="color: #22c55e; font-size: 10px; letter-spacing: 1px;">
            <i class="ri-checkbox-circle-fill me-1"></i>Peman Resevwa
          </div>

          <div class="d-flex justify-content-between align-items-center small mb-1">
            <span style="color: var(--haiti-olive);">Peye pa</span>
            <span class="fw-bold" style="color: var(--haiti-charcoal);"><%= @payment_transfer.user.display_name %></span>
          </div>
          <div class="d-flex justify-content-between align-items-center small mb-1">
            <span style="color: var(--haiti-olive);">Montan</span>
            <span class="fw-bold" style="color: #22c55e;">
              + <%= number_with_precision(@payment_transfer.amount, precision: 2) %> <%= @payment_request.asset.upcase %>
            </span>
          </div>
          <div class="d-flex justify-content-between align-items-center small mb-1">
            <span style="color: var(--haiti-olive);">Metòd</span>
            <span class="fw-bold" style="color: var(--haiti-charcoal);">
              <i class="ri-wallet-3-line me-1" style="font-size: 11px;"></i>Pòtfèy Zèllus
            </span>
          </div>
          <div class="d-flex justify-content-between align-items-center small mb-1">
            <span style="color: var(--haiti-olive);">Frè</span>
            <span class="fw-bold" style="color: #22c55e;">Gratis</span>
          </div>
          <div class="d-flex justify-content-between align-items-center small">
            <span style="color: var(--haiti-olive);">Dat peman</span>
            <span class="fw-bold" style="color: var(--haiti-charcoal);">
              <%= @payment_transfer.funded_at&.strftime("%d/%m/%Y · %l:%M %p")&.strip || @payment_transfer.updated_at.strftime("%d/%m/%Y · %l:%M %p").strip %>
            </span>
          </div>
        </div>

      <% elsif @payment_request.paid? %>
        <%# ── Manually marked as paid ── %>
        <div class="p-3 rounded-4 mb-4" style="background: rgba(34,197,94,0.06); border: 1px solid rgba(34,197,94,0.15);">
          <div class="fw-bold text-uppercase mb-2" style="color: #22c55e; font-size: 10px; letter-spacing: 1px;">
            <i class="ri-checkbox-circle-fill me-1"></i>Peman Resevwa
          </div>
          <div class="small" style="color: var(--haiti-charcoal);">
            <i class="ri-edit-line me-1" style="color: var(--haiti-olive);"></i>
            Make kòm peye manyèlman · <%= @payment_request.updated_at.strftime("%d/%m/%Y · %l:%M %p").strip %>
          </div>
        </div>

      <% elsif @payment_request.active? %>
        <%# ── Primary CTA: Share ── %>
        <%= link_to public_payment_request_path(@payment_request.token), target: "_blank",
            class: "btn w-100 py-3 fw-bold rounded-4 border-0 d-flex align-items-center justify-content-center gap-2 mb-4 text-decoration-none shadow-sm",
            style: "background: var(--haiti-gold); color: var(--haiti-charcoal); font-size: 14px; letter-spacing: 0.3px;" do %>
          <i class="ri-share-forward-line" style="font-size: 18px;"></i> Pataje Lyen Peman
        <% end %>

        <%# ── Copy link row ── %>
        <div class="d-flex align-items-center gap-2 p-2 rounded-3 mb-4" style="background: rgba(93,99,69,0.06); border: 1px dashed rgba(93,99,69,0.2);">
          <i class="ri-link me-1" style="color: var(--haiti-olive); font-size: 14px; flex-shrink: 0;"></i>
          <div class="text-truncate" style="color: var(--haiti-olive); font-size: 11px; font-family: monospace;" id="pr-link-text"><%= public_payment_request_url(@payment_request.token) rescue "#{request.base_url}/r/#{@payment_request.token}" %></div>
          <button type="button" onclick="copyLink()" class="btn p-1 border-0 flex-shrink-0" style="color: var(--haiti-olive);">
            <i class="ri-file-copy-line" style="font-size: 16px;" id="pr-link-copy-icon"></i>
          </button>
        </div>
      <% end %>

      <%# ── Details ── %>
      <div class="fw-bold text-uppercase mb-3" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">
        <i class="ri-file-list-3-line me-1"></i>Detay
      </div>

      <div class="d-flex justify-content-between align-items-center py-2" style="border-bottom: 1px solid rgba(93,99,69,0.08);">
        <span style="color: var(--haiti-olive); font-size: 12px;">Estati</span>
        <span class="d-inline-flex align-items-center gap-1 fw-bold" style="color: <%= status_cfg[:color] %>; font-size: 12px;">
          <i class="<%= status_cfg[:icon] %>" style="font-size: 11px;"></i> <%= status_cfg[:label] %>
        </span>
      </div>
      <div class="d-flex justify-content-between align-items-center py-2" style="border-bottom: 1px solid rgba(93,99,69,0.08);">
        <span style="color: var(--haiti-olive); font-size: 12px;">Montan</span>
        <span class="fw-bold" style="color: var(--haiti-charcoal); font-size: 12px;"><%= number_to_currency(@payment_request.amount, unit: "", precision: 2) %> <%= @payment_request.asset.upcase %></span>
      </div>
      <div class="d-flex justify-content-between align-items-center py-2" style="border-bottom: 1px solid rgba(93,99,69,0.08);">
        <span style="color: var(--haiti-olive); font-size: 12px;">Dat</span>
        <span class="fw-bold" style="color: var(--haiti-charcoal); font-size: 12px;"><%= @payment_request.created_at.strftime("%d/%m/%Y · %l:%M %p").strip %></span>
      </div>
      <div class="d-flex justify-content-between align-items-center py-2 mb-3">
        <span style="color: var(--haiti-olive); font-size: 12px;">Ref</span>
        <div class="d-flex align-items-center gap-1">
          <span class="fw-bold" style="color: var(--haiti-charcoal); font-size: 11px; font-family: monospace;" id="pr-token-text">#<%= @payment_request.token.upcase %></span>
          <button type="button" onclick="copyToken()" class="btn p-0 border-0" style="color: var(--haiti-olive); line-height: 1;">
            <i class="ri-file-copy-line" style="font-size: 14px;" id="pr-copy-icon"></i>
          </button>
        </div>
      </div>

    </div>

  </div>
</div>

<%# ── Step Loader for Sol Payment ── %>
<%= render "shared/step_loader", id: "sol-pay-loader", steps: [
  "N'ap verifye balans ou...",
  "N'ap depoze nan eskwo...",
  "Peman reyisi!"
] %>

<script>
function hideAllPanels() {
  document.getElementById('pr-action-buttons').style.display = 'none';
  document.getElementById('pr-pin-panel').style.display = 'none';
  document.getElementById('pr-cancel-panel').style.display = 'none';
  var input = document.getElementById('pr-pin-input');
  if (input) input.value = '';
}

function showPinPanel() {
  hideAllPanels();
  document.getElementById('pr-pin-panel').style.display = 'block';
  var input = document.getElementById('pr-pin-input');
  if (input) input.focus();
}

function hidePinPanel() {
  hideAllPanels();
  document.getElementById('pr-action-buttons').style.display = 'flex';
}

function showCancelConfirm() {
  hideAllPanels();
  document.getElementById('pr-cancel-panel').style.display = 'block';
}

function hideCancelConfirm() {
  hideAllPanels();
  document.getElementById('pr-action-buttons').style.display = 'flex';
}

function copyToken() {
  var text = document.getElementById('pr-token-text').textContent;
  copyToClipboard(text, 'pr-copy-icon');
}

function copyLink() {
  var text = document.getElementById('pr-link-text').textContent;
  copyToClipboard(text, 'pr-link-copy-icon');
}

function copyToClipboard(text, iconId) {
  var icon = document.getElementById(iconId);
  function onSuccess() {
    if (!icon) return;
    icon.className = 'ri-check-line';
    icon.style.color = '#166534';
    setTimeout(function() {
      icon.className = 'ri-file-copy-line';
      icon.style.color = '';
    }, 1200);
  }

  if (navigator.clipboard && window.isSecureContext) {
    navigator.clipboard.writeText(text).then(onSuccess).catch(function(){});
    return;
  }

  var ta = document.createElement('textarea');
  ta.value = text;
  ta.style.position = 'fixed';
  ta.style.left = '-9999px';
  document.body.appendChild(ta);
  ta.select();
  try { document.execCommand('copy'); onSuccess(); } catch(e) {}
  document.body.removeChild(ta);
}

// ── Submit with StepLoader ──
document.addEventListener("DOMContentLoaded", function() {
  var form = document.getElementById("sol-pay-form");
  if (form) {
    form.addEventListener("submit", function(e) {
      e.preventDefault();
      ZellusLoader.start('sol-pay-loader', form, { stepDelay: 6000 });
    });
  }
});
</script>
