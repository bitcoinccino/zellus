<div class="mt-4 pt-3 d-flex flex-column gap-2 text-center" style="border-top: 1px dashed var(--haiti-olive);">
  <%- if controller_name != 'sessions' %>
    <%= link_to new_session_path(resource_name), class: "text-decoration-none small fw-bold", style: "color: var(--haiti-olive);" do %>
      <i class="ri-login-box-line me-1"></i> Konekte
    <% end %>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <%= link_to new_registration_path(resource_name), class: "text-decoration-none small fw-bold", style: "color: var(--haiti-olive);" do %>
      <i class="ri-user-add-line me-1"></i> Kreye Kont
    <% end %>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <%= link_to new_password_path(resource_name), class: "text-decoration-none small fw-bold", style: "color: var(--haiti-olive);" do %>
      <i class="ri-key-2-line me-1"></i> Bliye modpas ou?
    <% end %>
  <% end %>

  <%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <%= link_to new_confirmation_path(resource_name), class: "text-decoration-none small fw-bold", style: "color: var(--haiti-olive);" do %>
      <i class="ri-mail-send-line me-1"></i> Revoye konfimasyon
    <% end %>
  <% end %>

  <%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
    <%= link_to new_unlock_path(resource_name), class: "text-decoration-none small fw-bold", style: "color: var(--haiti-olive);" do %>
      <i class="ri-lock-unlock-line me-1"></i> Revoye enstriksyon deblokin
    <% end %>
  <% end %>
</div>
