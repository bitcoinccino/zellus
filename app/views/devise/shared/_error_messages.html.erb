<% if resource.errors.any? %>
  <%# Single-line alert: skip the "X errors prohibited..." header and the
      auto-prepended attribute name (full_messages) so the validator's
      Kreyòl text reads cleanly. Multiple errors fall back to a list. %>
  <div class="p-3 mb-4 rounded-3 d-flex align-items-start gap-2"
       style="background-color: #fdf2f2; border: 1px solid #fee2e2;"
       role="alert"
       data-turbo-temporary>
    <i class="ri-error-warning-fill" style="color: #D8000C; font-size: 16px; line-height: 1.4;"></i>
    <div class="small" style="color: var(--haiti-charcoal); line-height: 1.5;">
      <% if resource.errors.count == 1 %>
        <%= resource.errors.first.message %>
      <% else %>
        <ul class="mb-0 ps-3" style="margin-top: 2px;">
          <% resource.errors.each do |err| %>
            <li><%= err.message %></li>
          <% end %>
        </ul>
      <% end %>
    </div>
  </div>
<% end %>
