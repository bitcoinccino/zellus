<%# Sidebar visible for logged-out users %>
<%
  begin
    hero_buy_rate = RateService.buy_rate
    hero_sell_rate = RateService.sell_rate
    hero_rates_updated_at = RateService.usd_htg_rate_updated_at
  rescue StandardError
    hero_buy_rate = 135.50
    hero_rates_updated_at = Time.current
  end
%>

<style>
  /* Hide navbar border & shadow so hero is flush */
  .navbar { border-bottom: none !important; box-shadow: none !important; }
  body { background-color: var(--haiti-charcoal) !important; background-image: none !important; }
  main { margin: 0; padding: 0; }

  .bon-hero-full {
    background: var(--haiti-charcoal);
    color: white;
    overflow: hidden;
    position: relative;
  }

  .bon-hero-full::before,
  .bon-hero-full::after {
    content: "";
    position: absolute;
    border-radius: 999px;
    background: rgba(197, 160, 89, 0.1);
    filter: blur(2px);
  }
  .bon-hero-full::before { width: 300px; height: 300px; top: -100px; right: -60px; }
  .bon-hero-full::after { width: 250px; height: 250px; bottom: -80px; left: -50px; }

  .bon-pill {
    border: 1px solid rgba(197, 160, 89, 0.35);
    background: rgba(247, 244, 227, 0.06);
    color: #fff;
    border-radius: 999px;
    padding: 6px 12px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .bon-chip {
    background: rgba(255,255,255,0.06);
    color: rgba(255,255,255,0.75);
    border: 1px solid rgba(197, 160, 89, 0.2);
    border-radius: 999px;
    padding: 6px 14px;
    font-size: 12px;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .bon-rate-badge {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(197, 160, 89, 0.25);
    border-radius: 14px;
    padding: 14px 20px;
    display: inline-flex;
    align-items: center;
    gap: 16px;
  }

  .bon-signin-card {
    background: var(--haiti-cream);
    border-radius: 22px;
    box-shadow: 0 8px 32px rgba(46, 46, 56, 0.12);
  }

  .bb-dark-field { color: #fff !important; }
  .bb-dark-field::placeholder { color: rgba(255,255,255,0.4) !important; opacity: 1; font-weight: 400 !important; }

  @media (max-width: 768px) {
    .bon-hero-full .display-5 { font-size: 1.8rem !important; }
    .bon-rate-badge { flex-direction: column; text-align: center; gap: 8px !important; }
    .bon-hero-full .bon-signin-card { margin-left: 0 !important; }
  }
  @media (max-width: 480px) {
    .bon-hero-full .display-5 { font-size: 1.4rem !important; }
    .bon-chip { font-size: 11px; padding: 4px 10px; }
  }
</style>

<section class="bon-hero-full">
  <div class="container py-5">
    <div class="row align-items-center g-5 position-relative" style="z-index: 1;">

      <%# ── LEFT: VALUE PROP ── %>
      <div class="col-lg-6">
        <div class="bon-pill mb-3">
          <i class="ri-shield-check-line" style="color: var(--haiti-gold);"></i>
          LIBÈTE FINANSYÈ OU KÒMANSE ISIT LA
        </div>

        <h1 class="display-5 mb-3" style="letter-spacing: -1px; line-height: 1.05;">
          <span class="d-block fw-black"><span style="color: var(--haiti-gold);">Zèllus</span> ede'w</span>
          <span class="d-block fw-black" style="overflow: hidden; height: 1.15em;">
            <span id="rotatingText" style="display: inline-block; transition: transform 0.5s ease, opacity 0.4s ease;"></span>
          </span>
        </h1>

        <p class="mb-4" style="color: rgba(255,255,255,0.8); max-width: 520px; font-size: 1.05rem; line-height: 1.6;">
          Kòmanse jodi a pou konstwi richès jenerasyonèl pou ou menm ak fanmi ou.
        </p>

        <%# ── Live Rate Chart ── %>
        <div class="mb-4" style="width: 100%; max-width: 400px;">
          <div class="bon-rate-badge" style="flex-direction: column; align-items: stretch; gap: 10px; width: 100%;">
            <div class="d-flex align-items-center justify-content-between">
              <div>
                <div class="text-uppercase fw-bold" style="font-size: 9px; letter-spacing: 1px; color: rgba(255,255,255,0.5);">USD / HTG</div>
                <div class="fw-black" style="font-size: 1.3rem;">
                  <span id="hero-rate-value"><%= hero_buy_rate %></span>
                  <span class="ms-1" style="font-size: 11px; color: rgba(255,255,255,0.4);">HTG</span>
                </div>
              </div>
              <div class="text-end">
                <div id="hero-rate-arrow" style="font-size: 11px; font-weight: 700; color: rgba(255,255,255,0.5);">
                  <i class="ri-subtract-line"></i> 0.00
                </div>
                <% if hero_rates_updated_at %>
                  <div style="font-size: 9px; color: rgba(255,255,255,0.4);"><i class="ri-time-line me-1"></i>LIVE</div>
                <% end %>
              </div>
            </div>
            <div style="height: 60px; width: 100%; overflow: hidden;">
              <svg id="hero-sparkline" width="100%" height="60" preserveAspectRatio="none" viewBox="0 0 360 60">
                <defs>
                  <linearGradient id="sparkGrad" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="rgba(197,160,89,0.25)"/>
                    <stop offset="100%" stop-color="rgba(197,160,89,0)"/>
                  </linearGradient>
                </defs>
                <path id="spark-area" fill="url(#sparkGrad)" d="" />
                <path id="spark-line" fill="none" stroke="#C5A059" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="" />
                <circle id="spark-dot" r="3" fill="#C5A059" cx="0" cy="0" style="filter: drop-shadow(0 0 4px rgba(197,160,89,0.6));" />
              </svg>
            </div>
          </div>
        </div>

        <div class="d-flex flex-wrap gap-2 mb-3">
          <span class="bon-chip"><i class="ri-repeat-line" style="color: var(--haiti-gold);"></i> MonCash → USD</span>
          <span class="bon-chip"><i class="ri-group-fill" style="color: var(--haiti-gold);"></i> Sòl Dijital</span>
          <span class="bon-chip"><i class="ri-line-chart-line" style="color: var(--haiti-gold);"></i> Bati Kredi</span>
        </div>

        <div class="d-inline-flex align-items-center gap-2" style="font-size: 12px; color: rgba(255,255,255,0.6);">
          <i class="ri-map-pin-fill" style="color: var(--haiti-gold);"></i>
          <span>Disponib kounye a nan <strong style="color: #fff;">Côtes-de-Fer</strong></span>
        </div>
      </div>

      <%# ── RIGHT: SIGN IN CARD ── %>
      <div class="col-lg-6">
        <div class="bon-signin-card p-4 p-md-5" style="max-width: 480px; margin-left: auto;">
          <div class="text-center mb-4">
            <h2 class="h5 fw-black mb-1 text-uppercase" style="color: var(--haiti-charcoal); letter-spacing: 0.5px;">Konekte Kont Ou</h2>
            <p class="small mb-0" style="color: var(--haiti-olive);">Antre nan kont Zèllus ou</p>
          </div>

          <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
            <div class="mb-3">
              <label class="small fw-bold text-uppercase mb-1" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">IMÈL</label>
              <div class="input-group">
                <span class="input-group-text border-0" style="background-color: var(--haiti-charcoal); color: var(--haiti-gold);">
                  <i class="ri-mail-fill"></i>
                </span>
                <%= f.email_field :email, autofocus: true, placeholder: "non@egzanp.com",
                    class: "form-control border-0 fw-bold shadow-none p-3 bb-dark-field",
                    style: "background-color: var(--haiti-charcoal); color: white;" %>
              </div>
            </div>

            <div class="mb-4">
              <label class="small fw-bold text-uppercase mb-1" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">MODPAS</label>
              <div class="input-group">
                <span class="input-group-text border-0" style="background-color: var(--haiti-charcoal); color: var(--haiti-gold);">
                  <i class="ri-lock-2-fill"></i>
                </span>
                <%= f.password_field :password, placeholder: "••••••••",
                    class: "form-control border-0 fw-bold shadow-none p-3 bb-dark-field",
                    style: "background-color: var(--haiti-charcoal); color: white;" %>
              </div>
            </div>

            <%= f.submit "KONEKTE", class: "btn w-100 py-3 fw-bold border-0 text-uppercase",
                style: "background: var(--haiti-charcoal); color: var(--haiti-gold); border-radius: 8px; letter-spacing: 1px; font-size: 14px;" %>
          <% end %>

          <div class="d-flex align-items-center gap-2 my-3">
            <div class="flex-fill" style="height: 1px; background: var(--haiti-olive); opacity: 0.15;"></div>
            <span class="small fw-bold text-uppercase" style="color: var(--haiti-olive); font-size: 10px;">Oswa</span>
            <div class="flex-fill" style="height: 1px; background: var(--haiti-olive); opacity: 0.15;"></div>
          </div>

          <%# ── BonID Loading Overlay (hidden by default) ── %>
          <div id="bonid-loading" style="display: none; position: absolute; inset: 0; background: var(--haiti-cream); border-radius: 22px; z-index: 10; flex-direction: column; align-items: center; justify-content: center; gap: 16px;">
            <div style="width: 48px; height: 48px; border: 3px solid rgba(197,160,89,0.2); border-top-color: var(--haiti-gold); border-radius: 50%; animation: bonidSpin 1s linear infinite;"></div>
            <p class="fw-bold mb-0 text-center px-3" style="color: var(--haiti-charcoal); font-size: 14px; max-width: 280px; line-height: 1.5;">
              N'ap konekte ou ak BonID pou verifye identite'w
            </p>
            <div style="font-size: 11px; color: var(--haiti-olive); opacity: 0.7;">
              <i class="ri-shield-check-fill me-1" style="color: var(--haiti-gold);"></i>Koneksyon sekirize
            </div>
          </div>
          <style>@keyframes bonidSpin { to { transform: rotate(360deg); } }</style>

          <%= button_to user_bonid_omniauth_authorize_path, method: :post, id: "bonid-form", class: "btn w-100 border-0 p-3", style: "background: var(--haiti-charcoal); color: var(--haiti-gold); font-weight: 700; font-size: 14px; border-radius: 8px; opacity: 0.6;" do %>
            <i class="ri-shield-check-fill me-2"></i>Konekte ak BonID
          <% end %>

          <script>
            (function() {
              var form = document.getElementById('bonid-form');
              if (!form) return;
              var parentForm = form.closest('form');
              if (!parentForm) return;

              parentForm.addEventListener('submit', function(e) {
                e.preventDefault();
                var card = document.querySelector('.bon-signin-card');
                if (card) card.style.position = 'relative';
                var overlay = document.getElementById('bonid-loading');
                if (overlay) overlay.style.display = 'flex';
                setTimeout(function() { parentForm.submit(); }, 600);
              });
            })();
          </script>

          <div class="text-center mt-3">
            <span class="small" style="color: var(--haiti-olive);">Pa gen kont?</span>
            <%= link_to "Kreye yonn la", new_user_registration_path, class: "small fw-bold text-decoration-none", style: "color: var(--haiti-charcoal);" %>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<%# ══════════════════════════════════════ %>
<%# ── FOOTER                          ── %>
<%# ══════════════════════════════════════ %>
