            <% end %>
          </li>
          <li class="mb-2">
            <%= link_to ajan_info_path, class: "text-decoration-none", style: "color: rgba(255,255,255,0.7);" do %>
              <i class="ri-user-location-fill me-1" style="font-size: 12px;"></i>Zèllus Ajan
            <% end %>
          </li>
          <%# ── Zèllus Sòl / Bousad / Onèt Byento — re-enable when ready to deploy ── %>
          <% if false %>
          <li class="mb-2">
            <%= link_to priosol_info_path, class: "text-decoration-none", style: "color: rgba(255,255,255,0.7);" do %>
              <i class="ri-loop-right-fill me-1" style="font-size: 12px;"></i>Zèllus Sòl <span class="badge-soon">Byento</span>
            <% end %>
          </li>
          <li class="mb-2">
            <%= link_to priobousad_info_path, class: "text-decoration-none", style: "color: rgba(255,255,255,0.7);" do %>
