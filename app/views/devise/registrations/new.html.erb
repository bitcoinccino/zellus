    <div class="row g-4">

      <%# ── Col 1: Zèllus ── %>
      <div class="col-lg-3 col-md-6">
        <div class="mb-3">
          <%= image_tag "zellus_square.png", size: "32x32", alt: "Zèllus", style: "border-radius: 8px;" %>
        </div>
        <p style="color: rgba(255,255,255,0.6); font-size: 13px; line-height: 1.6;">
          Libète finansyè ou kòmanse isit la.
        </p>
        <p style="color: rgba(255,255,255,0.45); font-size: 11px; font-style: italic;">
          <i class="ri-heart-fill me-1" style="color: var(--haiti-gold); font-size: 10px;"></i>Bati ak lanmou nan Côtes-de-Fer
