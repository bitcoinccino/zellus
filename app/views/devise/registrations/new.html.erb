        <div class="d-flex gap-3">
          <a href="https://x.com/zellus" target="_blank" class="d-flex align-items-center justify-content-center rounded-circle"
             style="width: 36px; height: 36px; background: rgba(255,255,255,0.08); border: 1px solid rgba(197,160,89,0.25); color: #fff; text-decoration: none;">
            <i class="ri-twitter-x-fill" style="font-size: 16px;"></i>
          </a>
        </div>
      </div>

    </div>
  </div>
</footer>

<script>
  (function() {
    var words = ["Ekonomize", "Bati Kredi", "Bay Biznis Bousad", "Konbat Lavi Chè", "Konbat Ensekirite"];
    var el = document.getElementById('rotatingText');
    var i = 0;
    function show() {
      el.style.transform = 'translateY(100%)';
      el.style.opacity = '0';
      setTimeout(function() {
        el.textContent = words[i];
        el.style.transform = 'translateY(0)';
        el.style.opacity = '1';
        i = (i + 1) % words.length;
      }, 400);
    }
    show();
    setInterval(show, 3000);
  })();
</script>

<script>
  (function() {
    var BASE = <%= hero_buy_rate %>;
    var MAX_POINTS = 60;
    var points = [];
    var prevRate = BASE;

    for (var s = 0; s < 20; s++) {
      points.push(BASE * (1 + (Math.random() - 0.5) * 0.0006));
    }

    var rateEl = document.getElementById('hero-rate-value');
    var arrowEl = document.getElementById('hero-rate-arrow');
    var lineEl = document.getElementById('spark-line');
    var areaEl = document.getElementById('spark-area');
    var dotEl = document.getElementById('spark-dot');
    var W = 360, H = 60;

    function buildPath() {
      if (points.length < 2) return;
      var min = Math.min.apply(null, points);
      var max = Math.max.apply(null, points);
      var range = max - min || 0.01;
      var pad = 4;

      var coords = [];
      for (var i = 0; i < points.length; i++) {
        var x = (i / (MAX_POINTS - 1)) * W;
        var y = pad + ((max - points[i]) / range) * (H - pad * 2);
        coords.push([x, y]);
      }

      var d = 'M' + coords[0][0] + ',' + coords[0][1];
      for (var j = 1; j < coords.length; j++) {
        d += ' L' + coords[j][0] + ',' + coords[j][1];
      }
      lineEl.setAttribute('d', d);

      var areaD = d + ' L' + coords[coords.length - 1][0] + ',' + H + ' L' + coords[0][0] + ',' + H + ' Z';
      areaEl.setAttribute('d', areaD);

      var last = coords[coords.length - 1];
      dotEl.setAttribute('cx', last[0]);
      dotEl.setAttribute('cy', last[1]);
    }

    function tick() {
      var newRate = prevRate * (1 + (Math.random() - 0.5) * 0.0006);
      points.push(newRate);
      if (points.length > MAX_POINTS) points.shift();

      rateEl.textContent = newRate.toFixed(2);

      var diff = newRate - prevRate;
      var color = diff >= 0 ? '#4ade80' : '#f87171';
      var icon = diff >= 0 ? 'ri-arrow-up-s-fill' : 'ri-arrow-down-s-fill';
      arrowEl.innerHTML = '<i class="' + icon + '" style="color:' + color + ';"></i> <span style="color:' + color + ';">' + (diff >= 0 ? '+' : '') + diff.toFixed(2) + '</span>';

      prevRate = newRate;
      buildPath();
    }

    buildPath();
    setInterval(tick, 3000);
  })();
</script>

<script>
  var cashtagTimer;
  var cashtagInput = document.getElementById('user_cashtag');
  var cashtagResult = document.getElementById('cashtag-availability');
  if (cashtagInput) {
    cashtagInput.addEventListener('input', function() {
      clearTimeout(cashtagTimer);
      var tag = this.value.replace(/^\$/, '').toLowerCase().replace(/[^a-z0-9]/g, '');
      this.value = tag;
      if (tag.length < 5) {
        cashtagResult.innerHTML = tag.length > 0 ? '<span style="color: var(--haiti-olive);">Minimòm 5 karaktè</span>' : '';
        return;
      }
      cashtagResult.innerHTML = '<span style="color: var(--haiti-olive);"><i class="ri-loader-4-line me-1"></i>Ap verifye...</span>';
      cashtagTimer = setTimeout(function() {
        fetch('/users/check_cashtag?cashtag=' + encodeURIComponent(tag))
          .then(function(r) { return r.json(); })
          .then(function(d) {
            if (d.available) {
              cashtagResult.innerHTML = '<span style="color: #166534;"><i class="ri-check-line me-1"></i>' + d.message + '</span>';
            } else {
              cashtagResult.innerHTML = '<span style="color: #991b1b;"><i class="ri-close-line me-1"></i>' + d.message + '</span>';
            }
          });
      }, 300);
    });
  }
</script>

<script>
  (function() {
    var nextBtn = document.getElementById('reg-next-btn');
    var backBtn = document.getElementById('reg-back-btn');
    var step1 = document.getElementById('reg-step-1');
    var step2 = document.getElementById('reg-step-2');
    var bonidSection = document.getElementById('reg-bonid-section');
    var cardTitle = document.querySelector('.bon-signin-card h2');
    var cardSub = document.querySelector('.bon-signin-card h2 + p');

    nextBtn.addEventListener('click', function() {
      // Validate step 1 fields
      var email = document.querySelector('#reg-form input[type="email"]');
      var cashtag = document.getElementById('user_cashtag');
      var password = document.querySelector('#reg-form input[type="password"]');

      if (!email.value || !email.validity.valid) { email.focus(); return; }
      if (!cashtag.value || cashtag.value.length < 5) { cashtag.focus(); return; }
      if (!password.value || password.value.length < 6) { password.focus(); return; }

      // Transition to step 2
      step1.style.display = 'none';
      bonidSection.style.display = 'none';
      step2.style.display = 'block';
      cardTitle.textContent = 'Kòd Envitasyon';
      cardSub.textContent = 'Yon dènye etap pou fini';
      document.getElementById('invite_code_field').focus();
    });

    backBtn.addEventListener('click', function() {
      step2.style.display = 'none';
      step1.style.display = 'block';
      bonidSection.style.display = 'block';
      cardTitle.textContent = 'Kreye Kont';
      cardSub.textContent = 'Enskri pou kòmanse ak Zèllus';
    });
  })();
</script>
