<div class="mb-4">
  <h2 class="fw-bold" style="color: var(--haiti-charcoal);">
    <i class="ri-medal-line me-2" style="color: var(--haiti-gold);"></i>PriOnèt
  </h2>
  <p class="mb-0" style="color: var(--haiti-olive);">Bati repitasyon'w pou debloke gwo kredi.</p>
</div>

<div class="row g-4">
  <%# ── LEFT: Kijan Li Mache ── %>
  <div class="col-lg-6">
    <div class="card border-0 shadow-sm h-100" style="background: var(--haiti-cream); border-radius: 16px;">
      <div class="card-body p-4">
        <h5 class="fw-bold mb-4" style="color: var(--haiti-charcoal);">
          <i class="ri-lightbulb-line me-2" style="color: var(--haiti-gold);"></i>Kijan Li Mache
        </h5>

        <div class="d-flex align-items-start gap-3 mb-4">
          <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; background: var(--haiti-gold); color: var(--haiti-charcoal); font-weight: 800;">1</div>
          <div>
            <div class="fw-bold" style="color: var(--haiti-charcoal);">Antre nan yon Sòl</div>
            <div style="color: var(--haiti-olive); font-size: 13px; font-weight: 400;">Kreye oswa jwenn yon Sòl nan PrioSòl. Chak peman alè ogmante pwen'w.</div>
          </div>
        </div>

        <div class="d-flex align-items-start gap-3 mb-4">
          <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; background: var(--haiti-gold); color: var(--haiti-charcoal); font-weight: 800;">2</div>
          <div>
            <div class="fw-bold" style="color: var(--haiti-charcoal);">Peye Alè</div>
            <div style="color: var(--haiti-olive); font-size: 13px; font-weight: 400;">Chak peman alè = <strong>+15 pwen</strong>. Peman an reta = <strong>-25 pwen</strong>. Defò = <strong>-50 pwen</strong>.</div>
          </div>
        </div>

        <div class="d-flex align-items-start gap-3 mb-4">
          <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; background: var(--haiti-gold); color: var(--haiti-charcoal); font-weight: 800;">3</div>
          <div>
            <div class="fw-bold" style="color: var(--haiti-charcoal);">Fini Sòl La</div>
            <div style="color: var(--haiti-olive); font-size: 13px; font-weight: 400;">Lè ou fini yon Sòl nèt, ou resevwa yon <strong>+50 pwen</strong> bonis.</div>
          </div>
        </div>

        <div class="d-flex align-items-start gap-3">
          <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; background: var(--haiti-gold); color: var(--haiti-charcoal); font-weight: 800;">4</div>
          <div>
            <div class="fw-bold" style="color: var(--haiti-charcoal);">Monte Nivo</div>
            <div style="color: var(--haiti-olive); font-size: 13px; font-weight: 400;">Plis pwen = pi gwo nivo = aksè a pi gwo prè nan PrioBousad.</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# ── RIGHT: Eta Aktyèl ── %>
  <div class="col-lg-6">
    <div class="card border-0 shadow-sm h-100" style="background: white; border-radius: 16px;">
      <div class="card-body p-4">
        <h5 class="fw-bold mb-4" style="color: var(--haiti-charcoal);">
          <i class="ri-pie-chart-line me-2" style="color: var(--haiti-gold);"></i>Pwen Kredi'w
        </h5>

        <%# Big score display %>
        <div class="text-center p-4 rounded-3 mb-4" style="background: var(--haiti-mint);">
          <span style="font-size: 3rem;"><%= current_user.tier_icon %></span>
          <div class="fw-bold fs-2 mt-1" style="color: var(--haiti-charcoal);"><%= @score %></div>
          <div style="color: var(--haiti-olive); font-size: 13px; font-weight: 400;">sou <%= User::MAX_CREDIT_SCORE %> pwen</div>
          <div class="mt-2" style="height: 8px; background: #e5e7eb; border-radius: 4px; overflow: hidden; max-width: 250px; margin: 0 auto;">
            <div style="width: <%= (@score * 100.0 / User::MAX_CREDIT_SCORE).round %>%; height: 100%; background: var(--haiti-gold); border-radius: 4px;"></div>
          </div>
          <div class="mt-2">
            <span class="badge rounded-pill px-3 py-1" style="background: var(--haiti-gold); color: var(--haiti-charcoal); font-weight: 800;"><%= @tier %></span>
          </div>
        </div>

        <%# Tier roadmap %>
        <div class="fw-bold small mb-3" style="color: var(--haiti-charcoal);">Wout Nivo Yo</div>
        <% User::TIER_THRESHOLDS.each do |tier_name, threshold| %>
          <% is_current = current_user.credit_tier == tier_name %>
          <% is_passed = @score >= threshold %>
          <div class="d-flex align-items-center gap-2 py-2 <%= is_current ? 'px-2 rounded-2' : '' %>" style="<%= is_current ? 'background: var(--haiti-mint);' : '' %>">
            <i class="<%= is_passed ? 'ri-checkbox-circle-fill' : 'ri-checkbox-blank-circle-line' %>" style="color: <%= is_passed ? 'var(--haiti-gold)' : '#ccc' %>; font-size: 1.1rem;"></i>
            <div class="flex-fill">
              <span class="fw-bold small" style="color: var(--haiti-charcoal);"><%= tier_name %></span>
              <span style="color: var(--haiti-olive); font-size: 11px;"> &middot; <%= threshold %>+ pwen</span>
            </div>
            <% if is_current && current_user.credit_tier != "Fokon" %>
              <span style="color: var(--haiti-gold); font-size: 11px; font-weight: 700;"><%= @next_tier_points %> rete</span>
            <% elsif is_current && current_user.credit_tier == "Fokon" %>
              <span style="color: var(--haiti-gold); font-size: 11px; font-weight: 700;">Somè!</span>
            <% end %>
          </div>
        <% end %>

        <%# Stats %>
        <div class="row g-2 mt-3">
          <div class="col-6">
            <div class="p-2 rounded-3 text-center" style="background: var(--haiti-mint);">
              <div style="color: var(--haiti-olive); font-size: 10px;">Sòl Aktif</div>
              <div class="fw-bold" style="color: var(--haiti-charcoal);"><%= @active_sols %></div>
            </div>
          </div>
          <div class="col-6">
            <div class="p-2 rounded-3 text-center" style="background: var(--haiti-mint);">
              <div style="color: var(--haiti-olive); font-size: 10px;">Sòl Fini</div>
              <div class="fw-bold" style="color: var(--haiti-charcoal);"><%= @completed_sols %></div>
            </div>
          </div>
        </div>

        <div class="mt-4">
          <%= link_to priosol_path, class: "btn btn-prestige w-100 rounded-pill" do %>
            <i class="ri-loop-right-line me-2"></i>Ale nan PrioSòl pou Ogmante Pwen
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
