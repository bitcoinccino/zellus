<div class="container d-flex justify-content-center" style="min-height: 80vh;">
  <div class="w-100" style="max-width: 900px;">

    <%# ── Page Header ── %>
    <div class="d-flex align-items-center justify-content-between mb-3">
      <h1 class="h5 fw-black mb-0" style="color: var(--haiti-charcoal);">
        <i class="ri-medal-line me-2" style="color: var(--haiti-gold);"></i>PriOnèt
      </h1>
      <%= link_to root_path, class: "small text-decoration-none fw-bold", style: "color: var(--haiti-olive);" do %>
        <i class="ri-arrow-left-line me-1"></i>Lakay
      <% end %>
    </div>
    <p class="mb-4" style="color: var(--haiti-olive); font-size: 13px;">Bati repitasyon'w pou debloke gwo kredi.</p>

    <div class="row g-4">
      <%# ── LEFT: Kijan Li Mache ── %>
      <div class="col-lg-6">
        <div class="card-base p-4 h-100">
          <h5 class="fw-black mb-4" style="color: var(--haiti-charcoal);">
            <i class="ri-lightbulb-line me-2" style="color: var(--haiti-gold);"></i>Kijan Li Mache
          </h5>

          <div class="d-flex align-items-start gap-3 mb-4">
            <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; background: var(--haiti-charcoal); color: var(--haiti-gold); font-weight: 800;">1</div>
            <div>
              <div class="fw-bold" style="color: var(--haiti-charcoal); font-size: 13px;">Antre nan yon Sòl</div>
              <div style="color: var(--haiti-olive); font-size: 12px;">Kreye oswa jwenn yon Sòl nan PrioSòl. Chak peman alè ogmante pwen'w.</div>
            </div>
          </div>

          <div class="d-flex align-items-start gap-3 mb-4">
            <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; background: var(--haiti-charcoal); color: var(--haiti-gold); font-weight: 800;">2</div>
            <div>
              <div class="fw-bold" style="color: var(--haiti-charcoal); font-size: 13px;">Peye Alè</div>
              <div style="color: var(--haiti-olive); font-size: 12px;">Chak peman alè = <strong>+15 pwen</strong>. Peman an reta = <strong>-25 pwen</strong>. Defò = <strong>-50 pwen</strong>.</div>
            </div>
          </div>

          <div class="d-flex align-items-start gap-3 mb-4">
            <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; background: var(--haiti-charcoal); color: var(--haiti-gold); font-weight: 800;">3</div>
            <div>
              <div class="fw-bold" style="color: var(--haiti-charcoal); font-size: 13px;">Fini Sòl La</div>
              <div style="color: var(--haiti-olive); font-size: 12px;">Lè ou fini yon Sòl nèt, ou resevwa yon <strong>+50 pwen</strong> bonis.</div>
            </div>
          </div>

          <div class="d-flex align-items-start gap-3">
            <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; background: var(--haiti-charcoal); color: var(--haiti-gold); font-weight: 800;">4</div>
            <div>
              <div class="fw-bold" style="color: var(--haiti-charcoal); font-size: 13px;">Monte Nivo</div>
              <div style="color: var(--haiti-olive); font-size: 12px;">Plis pwen = pi gwo nivo = aksè a pi gwo prè nan PrioBousad.</div>
            </div>
          </div>
        </div>
      </div>

      <%# ── RIGHT: Pwen Kredi ── %>
      <div class="col-lg-6">
        <div class="card-base p-4 h-100">
          <h5 class="fw-black mb-4" style="color: var(--haiti-charcoal);">
            <i class="ri-pie-chart-line me-2" style="color: var(--haiti-gold);"></i>Pwen Kredi'w
          </h5>

          <%# Big score display %>
          <div class="text-center p-4 rounded-4 mb-4" style="background: var(--haiti-charcoal);">
            <div class="d-flex justify-content-center mb-1">
              <div style="width: 60px; height: 60px; border-radius: 50%; overflow: hidden; border: 2px solid var(--haiti-gold); display: flex; align-items: center; justify-content: center; background: rgba(255,255,255,0.08);">
                <% if current_user.avatar.attached? %>
                  <%= image_tag current_user.avatar, style: "width: 100%; height: 100%; object-fit: cover;", alt: "" %>
                <% else %>
                  <span style="font-size: 2rem;"><%= current_user.tier_icon %></span>
                <% end %>
              </div>
            </div>
            <div class="fw-black mt-1" style="color: #fff; font-size: 44px; letter-spacing: -2px; line-height: 1;"><%= @score %></div>
            <div style="color: rgba(255,255,255,0.45); font-size: 12px;">sou <%= User::MAX_CREDIT_SCORE %> pwen</div>
            <div class="mx-auto mt-2" style="max-width: 180px; height: 6px; background: rgba(255,255,255,0.12); border-radius: 3px; overflow: hidden;">
              <div style="width: <%= (@score * 100.0 / User::MAX_CREDIT_SCORE).round %>%; height: 100%; background: var(--haiti-gold); border-radius: 3px;"></div>
            </div>
            <div class="mt-2">
              <span class="badge rounded-pill px-3 py-1" style="background: var(--haiti-gold); color: var(--haiti-charcoal); font-weight: 800;"><%= @tier %></span>
            </div>
          </div>

          <%# Tier roadmap %>
          <div class="small fw-bold text-uppercase mb-2" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">
            <i class="ri-route-line me-1"></i>Wout Nivo Yo
          </div>
          <% User::TIER_THRESHOLDS.each do |tier_name, threshold| %>
            <% is_current = current_user.credit_tier == tier_name %>
            <% is_passed = @score >= threshold %>
            <div class="d-flex align-items-center gap-2 p-2 rounded-3 mb-1" style="<%= is_current ? 'background: rgba(93,99,69,0.08);' : '' %>">
              <i class="<%= is_passed ? 'ri-checkbox-circle-fill' : 'ri-checkbox-blank-circle-line' %>" style="color: <%= is_passed ? 'var(--haiti-gold)' : 'rgba(93,99,69,0.25)' %>; font-size: 1.1rem;"></i>
              <div class="flex-fill">
                <span class="fw-bold" style="color: var(--haiti-charcoal); font-size: 12px;"><%= tier_name %></span>
                <span style="color: var(--haiti-olive); font-size: 10px;"> &middot; <%= threshold %>+ pwen</span>
              </div>
              <% if is_current && @tier != "Fokon" %>
                <span style="color: var(--haiti-gold); font-size: 10px; font-weight: 700;"><%= @next_tier_points %> rete</span>
              <% elsif is_current && @tier == "Fokon" %>
                <span style="color: var(--haiti-gold); font-size: 10px; font-weight: 700;">Somè!</span>
              <% end %>
            </div>
          <% end %>

          <%# Stats %>
          <div class="d-flex gap-2 mt-3">
            <div class="flex-fill p-2 rounded-3 text-center" style="background: rgba(93,99,69,0.05);">
              <div class="fw-bold" style="color: var(--haiti-charcoal); font-size: 18px;"><%= @active_sols %></div>
              <div style="color: var(--haiti-olive); font-size: 10px;">Sòl Aktif</div>
            </div>
            <div class="flex-fill p-2 rounded-3 text-center" style="background: rgba(93,99,69,0.05);">
              <div class="fw-bold" style="color: var(--haiti-charcoal); font-size: 18px;"><%= @completed_sols %></div>
              <div style="color: var(--haiti-olive); font-size: 10px;">Sòl Fini</div>
            </div>
          </div>

          <div class="mt-4">
            <%= link_to priosol_path, class: "btn w-100 rounded-pill py-2", style: "background: var(--haiti-charcoal); color: var(--haiti-gold); font-weight: 700; font-size: 13px;" do %>
              <i class="ri-loop-right-line me-2"></i>Ale nan PrioSòl pou Ogmante Pwen
            <% end %>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>
