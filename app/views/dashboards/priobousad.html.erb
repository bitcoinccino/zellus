<div class="container d-flex justify-content-center" style="min-height: 80vh;">
  <div class="w-100" style="max-width: 900px;">

    <%# ── Page Header ── %>
    <div class="d-flex align-items-center justify-content-between mb-3">
      <h1 class="h5 fw-black mb-0" style="color: var(--haiti-charcoal);">
        <i class="ri-hand-coin-line me-2" style="color: var(--haiti-gold);"></i>PrioBousad
      </h1>
      <%= link_to root_path, class: "small text-decoration-none fw-bold", style: "color: var(--haiti-olive);" do %>
        <i class="ri-arrow-left-line me-1"></i>Lakay
      <% end %>
    </div>
    <p class="mb-4" style="color: var(--haiti-olive); font-size: 13px;">Prète pou ede biznis ou dekole.</p>

    <div class="row g-4">
      <%# ── LEFT: Kijan Li Mache ── %>
      <div class="col-lg-6">
        <div class="card-base p-4 h-100">
          <h5 class="fw-black mb-4" style="color: var(--haiti-charcoal);">
            <i class="ri-lightbulb-line me-2" style="color: var(--haiti-gold);"></i>Kijan Li Mache
          </h5>

          <div class="d-flex align-items-start gap-3 mb-4">
            <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; background: var(--haiti-charcoal); color: var(--haiti-gold); font-weight: 800;">1</div>
            <div>
              <div class="fw-bold" style="color: var(--haiti-charcoal); font-size: 13px;">Bati Repitasyon'w</div>
              <div style="color: var(--haiti-olive); font-size: 12px;">Patisipe nan Sòl epi peye alè pou ogmante pwen kredi'w. Ou bezwen omwen nivo Toutrèl (300+ pwen).</div>
            </div>
          </div>

          <div class="d-flex align-items-start gap-3 mb-4">
            <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; background: var(--haiti-charcoal); color: var(--haiti-gold); font-weight: 800;">2</div>
            <div>
              <div class="fw-bold" style="color: var(--haiti-charcoal); font-size: 13px;">Mande yon Prè</div>
              <div style="color: var(--haiti-olive); font-size: 12px;">Chwazi montan an baze sou nivo kredi'w. Toutrèl: jiska 5,000 HTG. Malfini: 25,000 HTG. Fokon: 100,000 HTG.</div>
            </div>
          </div>

          <div class="d-flex align-items-start gap-3 mb-4">
            <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; background: var(--haiti-charcoal); color: var(--haiti-gold); font-weight: 800;">3</div>
            <div>
              <div class="fw-bold" style="color: var(--haiti-charcoal); font-size: 13px;">Resevwa Lajan An</div>
              <div style="color: var(--haiti-olive); font-size: 12px;">Apre apwobasyon, lajan an rive dirèkteman sou MonCash oswa pòtfèy USD ou.</div>
            </div>
          </div>

          <div class="d-flex align-items-start gap-3">
            <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; background: var(--haiti-charcoal); color: var(--haiti-gold); font-weight: 800;">4</div>
            <div>
              <div class="fw-bold" style="color: var(--haiti-charcoal); font-size: 13px;">Ranbouse Prè A</div>
              <div style="color: var(--haiti-olive); font-size: 12px;">Peye alè pou kontinye ogmante pwen kredi'w epi jwenn aksè a pi gwo montan alavni.</div>
            </div>
          </div>
        </div>
      </div>

      <%# ── RIGHT: Eligibilite ── %>
      <div class="col-lg-6">
        <div class="card-base p-4 h-100">
          <h5 class="fw-black mb-4" style="color: var(--haiti-charcoal);">
            <i class="ri-pie-chart-line me-2" style="color: var(--haiti-gold);"></i>Eligibilite'w
          </h5>

          <%# Credit tier display %>
          <div class="p-3 rounded-4 mb-3" style="background: var(--haiti-charcoal);">
            <div class="d-flex align-items-center gap-3">
              <div style="width: 40px; height: 40px; border-radius: 50%; overflow: hidden; border: 1.5px solid var(--haiti-gold); display: flex; align-items: center; justify-content: center; flex-shrink: 0; background: rgba(255,255,255,0.08);">
                <% if current_user.avatar.attached? %>
                  <%= image_tag current_user.avatar, style: "width: 100%; height: 100%; object-fit: cover;", alt: "" %>
                <% else %>
                  <span style="font-size: 1.3rem;"><%= current_user.tier_icon %></span>
                <% end %>
              </div>
              <div class="flex-fill">
                <div class="fw-bold" style="color: #fff;"><%= current_user.credit_tier %></div>
                <div style="color: rgba(255,255,255,0.45); font-size: 11px;"><%= current_user.credit_score || 0 %> / <%= User::MAX_CREDIT_SCORE %> pwen</div>
                <div class="mt-1" style="height: 6px; background: rgba(255,255,255,0.12); border-radius: 3px; overflow: hidden;">
                  <div style="width: <%= ((current_user.credit_score || 0) * 100.0 / User::MAX_CREDIT_SCORE).round %>%; height: 100%; background: var(--haiti-gold); border-radius: 3px;"></div>
                </div>
              </div>
            </div>
          </div>

          <%# Loan limit %>
          <div class="d-flex justify-content-between align-items-center p-3 rounded-4 mb-3" style="background: var(--haiti-charcoal);">
            <div>
              <div style="color: rgba(255,255,255,0.45); font-size: 11px; text-transform: uppercase; letter-spacing: 1px;">Limit Prè'w</div>
              <div class="fw-black" style="color: #fff; font-size: 28px;">
                <% if current_user.loan_limit > 0 %>
                  <%= number_to_currency(current_user.loan_limit, unit: "", precision: 0) %>
                  <span style="font-size: 14px; color: rgba(255,255,255,0.5);">HTG</span>
                <% else %>
                  <span style="color: rgba(255,255,255,0.35); font-size: 14px;">Pa disponib ankò</span>
                <% end %>
              </div>
            </div>
            <i class="ri-hand-coin-line" style="font-size: 2rem; color: var(--haiti-gold);"></i>
          </div>

          <% if current_user.loan_limit > 0 %>
            <div class="mt-4">
              <%= link_to new_loan_path, class: "btn w-100 rounded-pill py-2", style: "background: var(--haiti-charcoal); color: var(--haiti-gold); font-weight: 700; font-size: 13px;" do %>
                <i class="ri-hand-coin-line me-2"></i>Mande yon Prè
              <% end %>
            </div>
          <% else %>
            <div class="p-3 rounded-4" style="background-color: rgba(197,160,89,0.12); border: 1px solid rgba(197,160,89,0.55);">
              <div class="d-flex align-items-start gap-2">
                <i class="ri-lock-line flex-shrink-0" style="color: var(--haiti-gold); font-size: 18px; margin-top: 2px;"></i>
                <div>
                  <div class="fw-bold" style="color: var(--haiti-charcoal); font-size: 12px;">Ou bezwen nivo Toutrèl (300+ pwen) pou mande yon prè.</div>
                  <div style="color: var(--haiti-olive); font-size: 11px;" class="mt-1">Patisipe nan PrioSòl epi peye alè pou ogmante pwen'w.</div>
                </div>
              </div>
              <div class="mt-3">
                <%= link_to priosol_path, class: "btn w-100 rounded-pill py-2", style: "background: rgba(93,99,69,0.1); border: 1.5px solid rgba(93,99,69,0.25); color: var(--haiti-charcoal); font-weight: 700; font-size: 13px;" do %>
                  <i class="ri-loop-right-line me-1"></i>Ale nan PrioSòl
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

  </div>
</div>
