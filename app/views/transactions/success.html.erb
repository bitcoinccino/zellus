<div class="container d-flex justify-content-center align-items-center" style="min-height: 85vh;">
  <div class="card-base p-4 w-100 shadow-lg text-center" style="max-width: 440px;">

    <div class="mb-4">
      <div class="d-inline-flex align-items-center justify-content-center mb-3"
           style="width: 70px; height: 70px; background-color: #166534; border-radius: 20px; transform: rotate(-5deg); box-shadow: 4px 4px 0px var(--haiti-charcoal);">
        <i class="ri-checkbox-circle-fill ri-2x text-white" style="transform: rotate(5deg);"></i>
      </div>
      <h1 class="h4 fw-black mb-1 text-uppercase" style="color: var(--haiti-charcoal); letter-spacing: -0.5px;">Mèsi! Peman Resevwa</h1>
      <p class="small mb-0" style="color: var(--haiti-olive);">N'ap transfere USD ou nan pòtfèy ou sou <strong>Base</strong> kounye a.</p>
    </div>

    <div class="p-4 mb-4 rounded-4 text-start" style="background-color: var(--haiti-mint); border: 2px solid var(--haiti-olive);">
      <div class="d-flex justify-content-between mb-3">
        <span class="small fw-bold text-uppercase" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">Estati Lòd</span>
        <span class="badge rounded-pill" style="background-color: #fef3c7; color: #92400e; font-size: 10px; font-weight: 800; letter-spacing: 0.5px;">
          <%= @transaction.status.humanize.upcase %>
        </span>
      </div>
      <div class="d-flex justify-content-between">
        <span class="small fw-bold text-uppercase" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">Pòtfèy Resevè</span>
        <code style="color: var(--haiti-charcoal); font-size: 11px;"><%= @transaction.destination_address.truncate(18) %></code>
      </div>
    </div>

    <% if @transaction.blockchain_tx_hash.present? %>
      <%= link_to basescan_tx_url(@transaction.blockchain_tx_hash), target: "_blank",
          class: "btn w-100 py-3 fw-bold rounded-4 shadow-sm border-0 d-flex align-items-center justify-content-center gap-2",
          style: "background-color: var(--haiti-charcoal); color: var(--haiti-gold); font-size: 14px; letter-spacing: 0.5px;" do %>
        <i class="ri-external-link-line"></i> Wè Resi sou Basescan
      <% end %>
    <% else %>
      <div class="p-4 rounded-4" style="background-color: rgba(93,99,69,0.08); border: 1px dashed var(--haiti-olive);">
        <div class="d-inline-block mb-3" style="width: 32px; height: 32px; border: 3px solid var(--haiti-gold); border-top-color: transparent; border-radius: 50%; animation: spin 1s linear infinite;"></div>
        <div class="small fw-bold text-uppercase" style="color: var(--haiti-olive); letter-spacing: 0.5px;">Ap trete sou Rezo Base...</div>
        <p class="small mt-2 mb-0" style="color: var(--haiti-olive); font-size: 10px;">Sa anjeneral pran mwens pase 60 segonn.</p>
      </div>
      <style>@keyframes spin { to { transform: rotate(360deg); } }</style>
    <% end %>

    <%= link_to root_path, class: "btn btn-link text-decoration-underline small fw-bold mt-3",
        style: "color: var(--haiti-olive); font-size: 12px;" do %>
      <i class="ri-arrow-left-line me-1"></i> Retounen Lakay
    <% end %>
  </div>
</div>
