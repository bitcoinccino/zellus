<div class="container d-flex justify-content-center align-items-center" style="min-height: 85vh;">
  <div class="card p-4 w-100 border-0 shadow-lg"
       style="max-width: <%= @transaction.sell? ? '960px' : '440px' %>; border-radius: 28px; background-color: #F7F4E3; box-shadow: 20px 20px 60px #d9d6c4, -20px -20px 60px #ffffff !important;">

    <!-- Header -->
    <div class="text-center mb-4">
      <% if @transaction.completed? %>
        <div class="d-inline-flex align-items-center justify-content-center mb-3" style="width: 70px; height: 70px; background-color: #166534; border-radius: 20px; transform: rotate(-5deg); box-shadow: 4px 4px 0px #2E2E38;">
          <i class="ri-checkbox-circle-fill ri-2x text-white" style="transform: rotate(5deg);"></i>
        </div>
        <h2 class="h4 fw-black mb-1 text-uppercase" style="color: #2E2E38; letter-spacing: -0.5px;">Transfè Konplè</h2>
      <% elsif @transaction.payout_failed? %>
        <div class="d-inline-flex align-items-center justify-content-center mb-3" style="width: 70px; height: 70px; background-color: #c2410c; border-radius: 20px; transform: rotate(-5deg); box-shadow: 4px 4px 0px #2E2E38;">
          <i class="ri-error-warning-fill ri-2x text-white" style="transform: rotate(5deg);"></i>
        </div>
        <h2 class="h4 fw-black mb-1 text-uppercase" style="color: #2E2E38; letter-spacing: -0.5px;">Depo Resevwa</h2>
        <p class="small mb-0" style="color: #9a3412; font-size: 11px; font-weight: 700;"><%= @transaction.crypto_currency.upcase %> konfime sou Base, men peman MonCash bezwen reesye/revizyon sipò.</p>
      <% elsif @transaction.failed? %>
        <div class="d-inline-flex align-items-center justify-content-center mb-3" style="width: 70px; height: 70px; background-color: #991b1b; border-radius: 20px; transform: rotate(-5deg); box-shadow: 4px 4px 0px #2E2E38;">
          <i class="ri-close-circle-fill ri-2x text-white" style="transform: rotate(5deg);"></i>
        </div>
        <h2 class="h4 fw-black mb-1 text-uppercase" style="color: #2E2E38; letter-spacing: -0.5px;">Transfè Echwe</h2>
      <% elsif @transaction.paid? %>
        <div class="d-inline-flex align-items-center justify-content-center mb-3" style="width: 70px; height: 70px; background-color: #92400e; border-radius: 20px; transform: rotate(-5deg); box-shadow: 4px 4px 0px #2E2E38;">
          <i class="ri-loader-4-line ri-2x text-white" style="transform: rotate(5deg);"></i>
        </div>
        <h2 class="h4 fw-black mb-1 text-uppercase" style="color: #2E2E38; letter-spacing: -0.5px;">Peman Resevwa</h2>
        <p class="small mb-0" style="color: #92400e; font-size: 11px; font-weight: 700;">Ap voye <%= @transaction.crypto_currency.upcase %> nan pòtfèy ou...</p>
      <% elsif @transaction.crypto_sent? %>
        <div class="d-inline-flex align-items-center justify-content-center mb-3" style="width: 70px; height: 70px; background-color: #92400e; border-radius: 20px; transform: rotate(-5deg); box-shadow: 4px 4px 0px #2E2E38;">
          <i class="ri-send-plane-fill ri-2x text-white" style="transform: rotate(5deg);"></i>
        </div>
        <h2 class="h4 fw-black mb-1 text-uppercase" style="color: #2E2E38; letter-spacing: -0.5px;"><%= @transaction.crypto_currency.upcase %> Voye</h2>
        <p class="small mb-0" style="color: #92400e; font-size: 11px; font-weight: 700;">Ap tann konfimasyon blockchain...</p>
      <% else %>
        <div class="d-inline-flex align-items-center justify-content-center mb-3" style="width: 70px; height: 70px; background-color: #5D6345; border-radius: 20px; transform: rotate(-5deg); box-shadow: 4px 4px 0px #2E2E38;">
          <i class="ri-shield-user-fill ri-2x text-white" style="transform: rotate(5deg);"></i>
        </div>
        <h2 class="h4 fw-black mb-1 text-uppercase" style="color: #2E2E38; letter-spacing: -0.5px;">Verifye Transfè</h2>
      <% end %>
      <p style="color: #5D6345; font-size: 11px; font-weight: 700; letter-spacing: 1px;" class="text-uppercase">
        <i class="ri-hashtag me-1"></i> TX #<%= @transaction.id %>
        &nbsp;&middot;&nbsp;
        <%= @transaction.created_at.strftime("%b %d, %Y") %>
      </p>
    </div>

    <% if (@transaction.failed? || @transaction.payout_failed?) && @transaction.failure_reason.present? %>
      <% failure_box_style = if @transaction.payout_failed?
          "background-color: #fff7ed; border: 1px solid #fdba74;"
        else
          "background-color: #fdf2f2; border: 1px solid #fca5a5;"
        end %>
      <% failure_icon_color = @transaction.payout_failed? ? "#c2410c" : "#991b1b" %>
      <% failure_heading = @transaction.payout_failed? ? "Estati Peman" : "Rezon Echèk" %>
      <div class="p-3 mb-4 d-flex align-items-start gap-2" style="<%= failure_box_style %> border-radius: 16px;">
        <i class="ri-error-warning-fill mt-1" style="color: <%= failure_icon_color %>; flex-shrink: 0;"></i>
        <div>
          <span class="d-block fw-black text-uppercase" style="color: <%= failure_icon_color %>; font-size: 10px; letter-spacing: 0.5px;"><%= failure_heading %></span>
          <span style="color: #2E2E38; font-size: 12px; font-weight: 600;"><%= @transaction.friendly_failure_reason %></span>
          <% if @transaction.payout_failed? && @transaction.sell? && @transaction.blockchain_tx_hash.present? %>
            <div class="mt-1" style="color: #7c2d12; font-size: 11px; font-weight: 600;">
              Depo <%= @transaction.crypto_currency.upcase %> ou resevwa sou Base. Peman HTG nan MonCash poko fini.
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <% masked_moncash_phone = @transaction.moncash_phone.to_s.gsub(/\d(?=\d{4})/, "•") %>

    <div class="mb-4">
      <% if @transaction.sell? %>
        <div class="row g-3">
          <div class="col-lg-5">
            <!-- Amount Box -->
            <div class="p-4 h-100" style="background-color: #E8EDE0; border: 2px solid #5D6345; border-radius: 20px; position: relative; overflow: hidden;">
              <div class="d-flex justify-content-between mb-2">
                <span style="color: #5D6345; font-size: 12px; font-weight: 600;">Ou Voye</span>
                <span style="color: #2E2E38; font-weight: 800;"><%= @transaction.crypto_amount %> <%= @transaction.crypto_currency.upcase %></span>
              </div>
              <div class="d-flex justify-content-between mb-3">
                <span style="color: #5D6345; font-size: 12px; font-weight: 600;">Frè Sèvis (2%)</span>
                <span style="color: #D8000C; font-weight: 700; font-size: 13px;">- <%= number_to_currency(@transaction.fee_amount, unit: "HTG ", precision: 2) %></span>
              </div>

              <div class="pt-3" style="border-top: 1px dashed #5D6345;">
                <div class="d-flex justify-content-between align-items-center">
                  <span style="color: #2E2E38; font-weight: 900; font-size: 14px;" class="text-uppercase">Ou Resevwa</span>
                  <div class="text-end">
                    <span class="h2 mb-0 fw-black d-block" style="color: #5D6345; letter-spacing: -1.5px;">
                      <%= number_with_precision(@transaction.fiat_amount, precision: 2) %> <small style="font-size: 14px; letter-spacing: 0;">HTG</small>
                    </span>
                    <span class="badge" style="background-color: #C5A059; color: #2E2E38; font-size: 9px; font-weight: 800; letter-spacing: 0.5px;">
                      <i class="ri-smartphone-line me-1"></i> PEMAN MONCASH
                    </span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="col-lg-7">
            <!-- Destination / Receiving Details -->
            <div class="p-3 h-100" style="background-color: #fff; border-radius: 18px; border: 1px solid #d9d6c4;">
              <div class="d-flex align-items-center mb-2">
                <i class="ri-smartphone-fill me-2" style="color: #C5A059;"></i>
                <span class="text-uppercase fw-bold" style="color: #5D6345; font-size: 10px; letter-spacing: 0.1em;">Nimewo Peman MonCash</span>
              </div>
              <div class="p-2 rounded" style="background-color: #fcfcf9; border-left: 3px solid #ef233c;">
                <code style="color: #2E2E38; font-size: 11px; word-break: break-all; font-weight: 600;"><%= masked_moncash_phone %></code>
              </div>
              <div class="mt-2 d-flex align-items-start" style="color: #5D6345; font-size: 10px;">
                <i class="ri-information-fill me-1 mt-1"></i>
                <span>Peman HTG ap voye nan nimewo MonCash sa a apre transfè <%= @transaction.crypto_currency.upcase %> ou konfime.</span>
              </div>

              <div class="mt-3 p-2 rounded" style="background-color: #fcfcf9; border-left: 3px solid #C5A059;">
                <div class="d-flex justify-content-between align-items-center gap-2 mb-1">
                  <div class="small fw-bold text-uppercase" style="color: #5D6345; font-size: 9px; letter-spacing: 0.08em;">Adrès Depo <%= @transaction.crypto_currency.upcase %> (Trezò)</div>
                  <button type="button"
                          class="btn btn-sm py-1 px-2 fw-bold rounded-3"
                          style="background-color: #2E2E38; color: #C5A059; font-size: 10px;"
                          onclick="copyTreasuryAddress('<%= j @transaction.destination_address.to_s %>', this)">
                    <i class="ri-file-copy-line me-1"></i>Kopye
                  </button>
                </div>
                <code style="color: #2E2E38; font-size: 10px; word-break: break-all; font-weight: 600;"><%= @transaction.destination_address %></code>
                <div class="mt-2 d-flex align-items-center gap-3 flex-wrap">
                  <img
                    src="https://quickchart.io/qr?size=140&text=<%= ERB::Util.url_encode(@transaction.destination_address.to_s) %>"
                    alt="QR code for treasury Base address"
                    width="96"
                    height="96"
                    style="border-radius: 10px; border: 1px solid #d9d6c4; background: #fff; padding: 4px;">
                  <div class="small" style="color: #5D6345; font-size: 10px; line-height: 1.3;">
                    <div class="fw-bold text-uppercase mb-1" style="letter-spacing: 0.08em;">Rezo Base Sèlman</div>
                    <div><i class="ri-instance-line me-1"></i>Voye <strong><%= @transaction.crypto_currency.upcase %> sou Base</strong> sèlman</div>
                    <div><i class="ri-error-warning-line me-1"></i>Pa voye lòt jeton</div>
                    <div><i class="ri-qr-code-line me-1"></i>Eskane QR pou evite erè kopi</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% else %>
      <!-- Amount Box -->
      <div class="p-4 mb-3" style="background-color: #E8EDE0; border: 2px solid #5D6345; border-radius: 20px; position: relative; overflow: hidden;">
        <div class="d-flex justify-content-between mb-2">
          <span style="color: #5D6345; font-size: 12px; font-weight: 600;">Ou Voye</span>
          <% if @transaction.sell? %>
            <span style="color: #2E2E38; font-weight: 800;"><%= @transaction.crypto_amount %> <%= @transaction.crypto_currency.upcase %></span>
          <% else %>
            <span style="color: #2E2E38; font-weight: 800;"><%= number_to_currency(@transaction.fiat_amount, unit: "HTG ", precision: 0) %></span>
          <% end %>
        </div>
        <div class="d-flex justify-content-between mb-3">
          <span style="color: #5D6345; font-size: 12px; font-weight: 600;">Frè Sèvis (2%)</span>
          <span style="color: #D8000C; font-weight: 700; font-size: 13px;">- <%= number_to_currency(@transaction.fee_amount, unit: "HTG ", precision: 2) %></span>
        </div>

        <div class="pt-3" style="border-top: 1px dashed #5D6345;">
          <div class="d-flex justify-content-between align-items-center">
            <span style="color: #2E2E38; font-weight: 900; font-size: 14px;" class="text-uppercase">Ou Resevwa</span>
            <div class="text-end">
              <span class="h2 mb-0 fw-black d-block" style="color: #5D6345; letter-spacing: -1.5px;">
                <% if @transaction.sell? %>
                  <%= number_with_precision(@transaction.fiat_amount, precision: 2) %> <small style="font-size: 14px; letter-spacing: 0;">HTG</small>
                <% else %>
                  <%= @transaction.crypto_amount %> <small style="font-size: 14px; letter-spacing: 0;"><%= @transaction.crypto_currency.upcase %></small>
                <% end %>
              </span>
              <span class="badge" style="background-color: #C5A059; color: #2E2E38; font-size: 9px; font-weight: 800; letter-spacing: 0.5px;">
                <% if @transaction.sell? %>
                  <i class="ri-smartphone-line me-1"></i> PEMAN MONCASH
                <% else %>
                  <i class="ri-instance-line me-1"></i> REZO BASE
                <% end %>
              </span>
            </div>
          </div>
        </div>
      </div>

      <!-- Destination / Receiving Details -->
      <div class="p-3 mb-3" style="background-color: #fff; border-radius: 18px; border: 1px solid #d9d6c4;">
        <div class="d-flex align-items-center mb-2">
          <i class="<%= @transaction.sell? ? 'ri-smartphone-fill' : 'ri-wallet-3-fill' %> me-2" style="color: #C5A059;"></i>
          <span class="text-uppercase fw-bold" style="color: #5D6345; font-size: 10px; letter-spacing: 0.1em;">
            <%= @transaction.sell? ? "Nimewo Peman MonCash" : "Pòtfèy Resevè" %>
          </span>
        </div>
        <div class="p-2 rounded" style="background-color: #fcfcf9; border-left: 3px solid #C5A059;">
          <code style="color: #2E2E38; font-size: 11px; word-break: break-all; font-weight: 600;">
            <%= @transaction.sell? ? masked_moncash_phone : @transaction.destination_address %>
          </code>
        </div>
        <% if !@transaction.pending? %>
          <div class="mt-2 d-flex align-items-start" style="color: #5D6345; font-size: 10px;">
            <i class="ri-information-fill me-1 mt-1"></i>
            <span>Adrès sa a te verifye nan moman soumisyon an.</span>
          </div>
        <% else %>
          <div class="mt-2 d-flex align-items-start" style="color: #5D6345; font-size: 10px;">
            <i class="ri-information-fill me-1 mt-1"></i>
            <span>Verifikasyon final nesesè. Transfè nan move adrès pa ka retounen.</span>
          </div>
        <% end %>
      </div>
      <% end %>

      <!-- Blockchain TX hash (shown once available) -->
      <% if @transaction.blockchain_tx_hash.present? %>
        <div class="p-3 mb-3" style="background-color: #fff; border-radius: 18px; border: 1px solid #d9d6c4;">
          <div class="d-flex align-items-center mb-2">
            <i class="ri-links-line me-2" style="color: #C5A059;"></i>
            <span class="text-uppercase fw-bold" style="color: #5D6345; font-size: 10px; letter-spacing: 0.1em;">Tranzaksyon Blockchain</span>
          </div>
          <div class="p-2 rounded" style="background-color: #fcfcf9; border-left: 3px solid #C5A059;">
            <code style="color: #2E2E38; font-size: 11px; word-break: break-all; font-weight: 600;"><%= @transaction.blockchain_tx_hash %></code>
          </div>
          <div class="mt-2">
            <%= link_to basescan_tx_url(@transaction.blockchain_tx_hash), target: "_blank",
                class: "text-decoration-none small fw-bold d-inline-flex align-items-center gap-1",
                style: "color: #5D6345; font-size: 11px;" do %>
              <i class="ri-external-link-line"></i> Wè sou Basescan
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- Payment Method -->
      <div class="d-flex align-items-center p-3 mb-4" style="background-color: #fdf2f2; border-radius: 18px; border: 1px solid #fee2e2;">
        <div class="d-flex align-items-center justify-content-center rounded-3 me-3 shadow-sm"
             style="width: 44px; height: 44px; background: linear-gradient(135deg, #d90429, #ef233c);">
          <span class="fw-black text-white" style="font-size: 11px; letter-spacing: 0.5px;">MC</span>
        </div>
        <div>
          <span class="d-block fw-bold small d-flex align-items-center gap-1" style="color: #2E2E38;">
            Pòtfèy MonCash
            <span class="badge rounded-pill" style="background-color: #ef233c; color: #fff; font-size: 8px; letter-spacing: 0.5px;">MonCash</span>
          </span>
          <span style="color: #5D6345; font-size: 11px; font-weight: 600;">Pasrèl Digicel Otorize</span>
        </div>
        <% status_style = case @transaction.status
          when "completed"             then "color: #166534; background-color: #dcfce7; border-color: #166534;"
          when "paid", "crypto_sent"   then "color: #92400e; background-color: #fef3c7; border-color: #92400e;"
          when "payout_failed"         then "color: #7c2d12; background-color: #ffedd5; border-color: #c2410c;"
          when "failed"                then "color: #991b1b; background-color: #fee2e2; border-color: #991b1b;"
          else                              "color: #5D6345; background-color: transparent; border-color: #5D6345;"
          end %>
        <span class="badge rounded-pill border ms-auto" style="<%= status_style %> font-size: 10px; font-weight: 800; letter-spacing: 0.5px;">
          <%= @transaction.status.upcase %>
        </span>
      </div>

      <!-- Actions -->
      <div class="d-grid gap-2">
        <% if @transaction.pending? %>
          <% if @transaction.sell? %>
            <div class="p-3 rounded-4" style="background-color: rgba(93,99,69,0.08); border: 1px dashed var(--haiti-olive);">
              <div class="small fw-bold text-uppercase mb-2" style="color: #5D6345; font-size: 10px; letter-spacing: 0.08em;">
                <i class="ri-links-line me-1"></i> Soumèt TX Hash Depo Base Ou
              </div>
              <div class="small mb-2" style="color: #5D6345; font-size: 10px;">
                Apre ou voye <%= @transaction.crypto_currency.upcase %> nan adrès trezò a sou Base, kole hash tranzaksyon an pou nou ka verifye epi lage HTG nan MonCash.
              </div>
              <%= form_with url: submit_sell_tx_hash_transaction_path(@transaction), method: :post, local: true, class: "d-grid gap-2" do %>
                <%= text_field_tag :sell_deposit_tx_hash, @transaction.blockchain_tx_hash,
                    placeholder: "0x... (Base transaction hash)",
                    class: "form-control fw-bold",
                    style: "border: 2px solid var(--haiti-olive); background: var(--haiti-cream); font-size: 12px;",
                    required: true,
                    pattern: "0x[a-fA-F0-9]{64}" %>
                <button type="submit"
                    class="btn border-0 py-3 fw-bold rounded-4 shadow-lg d-flex align-items-center justify-content-center gap-2"
                    style="background-color: #2E2E38; color: #C5A059;">
                  <i class="ri-arrow-up-circle-line"></i> Soumèt TX Hash Depo
                </button>
              <% end %>
            </div>
          <% else %>
            <%= button_to pay_transaction_path(@transaction), method: :post,
                class: "btn border-0 py-3 fw-bold rounded-4 shadow-lg d-flex align-items-center justify-content-center gap-2",
                style: "background-color: #2E2E38; color: #C5A059;" do %>
              <i class="ri-flashlight-fill"></i> Konfime & Lage Lajan
            <% end %>
          <% end %>
          <% if @transaction.buy? && (Rails.env.development? || current_user.email == ENV['ADMIN_EMAIL'].to_s.strip) %>
            <%= button_to manual_confirm_transaction_path(@transaction), method: :post,
                class: "btn py-2 fw-bold rounded-4 d-flex align-items-center justify-content-center gap-2",
                style: "background-color: #fff7ed; color: #92400e; border: 1px dashed #f59e0b;" do %>
              <i class="ri-tools-fill"></i> Konfimasyon Manyèl (Dev/Admin)
            <% end %>
          <% end %>
          <%= link_to "Anile Tranzaksyon", new_transaction_path,
              class: "btn btn-link text-decoration-underline small fw-bold",
              style: "color: #5D6345; font-size: 12px;" %>
        <% else %>
          <%= link_to transactions_path,
              class: "btn py-3 fw-bold rounded-4 d-flex align-items-center justify-content-center gap-2",
              style: "background-color: #2E2E38; color: #C5A059; border: 2px solid #2E2E38;" do %>
            <i class="ri-history-line"></i> Retounen nan Istwa
          <% end %>
          <%= link_to new_transaction_path,
              class: "btn btn-link text-decoration-underline small fw-bold",
              style: "color: #5D6345; font-size: 12px;" do %>
            <i class="ri-add-line me-1"></i> Nouvo Tranzaksyon
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<script>
function copyTreasuryAddress(address, btn) {
  if (!address) return;

  const onSuccess = () => {
    if (!btn) return;
    const original = btn.innerHTML;
    btn.innerHTML = '<i class="ri-check-line me-1"></i>Kopye';
    setTimeout(() => { btn.innerHTML = original; }, 1200);
  };

  if (navigator.clipboard && window.isSecureContext) {
    navigator.clipboard.writeText(address).then(onSuccess).catch(() => {});
    return;
  }

  const tmp = document.createElement('textarea');
  tmp.value = address;
  document.body.appendChild(tmp);
  tmp.select();
  try { document.execCommand('copy'); onSuccess(); } catch (e) {}
  document.body.removeChild(tmp);
}
</script>
