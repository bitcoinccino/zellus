<div style="margin-bottom:20px;">
  <% if @success %>
    <div style="font-size:15px; font-weight:800; color:#166534; margin-bottom:6px;">Ranbousman Otomatik Fè ✅</div>
  <% else %>
    <div style="font-size:15px; font-weight:800; color:#991b1b; margin-bottom:6px;">Ranbousman Otomatik Echwe ⚠️</div>
  <% end %>
  <div style="font-size:13px; color:#5D6345;">Prè #<%= @loan.id %> — <%= Time.current.strftime("%b %d, %Y") %></div>
</div>

<div style="background:#E8EDE0; border:2px solid #5D6345; border-radius:14px; padding:16px; margin-bottom:16px;">
  <table width="100%" cellspacing="0" cellpadding="0">
    <tr>
      <td style="color:#5D6345; font-size:12px; font-weight:600; padding-bottom:8px;">Montan Debite</td>
      <td style="color:#2E2E38; font-weight:800; text-align:right; padding-bottom:8px;">HTG <%= format('%.0f', @loan.loan_total_repayable.to_f) %></td>
    </tr>
    <tr>
      <td style="color:#5D6345; font-size:12px; font-weight:600; padding-bottom:8px;">Sous</td>
      <td style="color:#2E2E38; font-weight:800; text-align:right; padding-bottom:8px;">Pòtfèy Zèllus</td>
    </tr>
  </table>
</div>

<% if @success %>
  <div style="background:#f0fdf4; border:1px solid #bbf7d0; border-radius:12px; padding:12px; margin-bottom:16px;">
    <div style="color:#166534; font-size:12px; font-weight:700;">
      ✅ Ranbousman otomatik fè ak siksè! +50 bònis pwen PrioNet ajoute.
    </div>
  </div>
<% else %>
  <div style="background:#fdf2f2; border:1px solid #fca5a5; border-radius:12px; padding:12px; margin-bottom:16px;">
    <div style="color:#991b1b; font-size:12px; font-weight:700;">
      ❌ Balans pòtfèy ou pa sifi pou ranbousman otomatik. Tanpri peye manyèlman pou evite penalite.
    </div>
  </div>
<% end %>
