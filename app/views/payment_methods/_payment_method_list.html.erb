<% if methods.any? %>
  <div class="d-grid gap-3">
    <% methods.each do |pm| %>
      <div class="p-3 rounded-4" style="background-color: var(--haiti-charcoal);">
        <div class="d-flex justify-content-between align-items-start mb-2">
          <div>
            <div class="fw-bold" style="color: var(--haiti-gold); font-size: 13px;">
              <% if pm.provider == "zellus" %>
                <i class="ri-flashlight-line me-1"></i>
              <% elsif kind == :mobile %>
                <i class="ri-smartphone-line me-1"></i>
              <% elsif kind == :bank %>
                <i class="ri-bank-line me-1"></i>
              <% else %>
                <i class="ri-wallet-3-line me-1"></i>
              <% end %>
              <%= pm.display_label %>
            </div>
            <div class="small mt-1" style="color: rgba(255,255,255,0.6);">
              <% if kind == :mobile %>
                <% if pm.provider == "zellus" %>
                  $<%= pm.account_number %>
                <% else %>
                  <%= pm.account_number %>
                <% end %>
              <% elsif kind == :bank %>
                <%= pm.masked_bank_account %><% if pm.account_holder_name.present? %> · <%= pm.account_holder_name %><% end %>
              <% else %>
                <%= [pm.network&.humanize, pm.asset&.upcase].compact.join(' · ') %>
              <% end %>
            </div>
            <% if kind == :crypto && pm.wallet_address.present? %>
              <code class="small" style="color: rgba(255,255,255,0.5); font-size: 10px;"><%= pm.masked_wallet_address %></code>
            <% end %>
          </div>
          <span class="badge rounded-pill fw-bold" style="<%= pm.active? ? 'background-color: #dcfce7; color: #166534;' : 'background-color: rgba(255,255,255,0.15); color: rgba(255,255,255,0.5);' %> font-size: 9px; letter-spacing: 0.5px;">
            <%= pm.active? ? 'AKTIF' : 'INAKTIF' %>
          </span>
        </div>

        <%= form_with model: pm, url: payment_method_path(pm), method: :patch, local: true, class: "d-flex gap-2 align-items-end" do |f| %>
          <%= f.hidden_field :category %>
          <%= f.hidden_field :provider %>
          <% if pm.crypto_wallet? %>
            <%= f.hidden_field :network %>
            <%= f.hidden_field :asset %>
          <% end %>

          <div class="flex-fill">
            <label class="form-label small fw-bold text-uppercase" style="color: rgba(255,255,255,0.4); font-size: 9px; letter-spacing: 0.5px;">Etikèt</label>
            <%= f.text_field :label, class: "form-control form-control-sm border-0 fw-bold shadow-none bb-dark-field",
                style: "background-color: rgba(255,255,255,0.1); color: white; font-size: 12px;" %>
          </div>

          <div class="flex-fill">
            <% if pm.mobile_wallet? %>
              <label class="form-label small fw-bold text-uppercase" style="color: rgba(255,255,255,0.4); font-size: 9px; letter-spacing: 0.5px;">
                <%= pm.provider == "zellus" ? "$Zellustag" : "Nimewo" %>
              </label>
              <%= f.text_field :account_number, class: "form-control form-control-sm border-0 fw-bold shadow-none bb-dark-field",
                  style: "background-color: rgba(255,255,255,0.1); color: white; font-size: 12px;" %>
            <% elsif pm.bank_account? %>
              <label class="form-label small fw-bold text-uppercase" style="color: rgba(255,255,255,0.4); font-size: 9px; letter-spacing: 0.5px;">Nimewo Kont</label>
              <%= f.text_field :bank_account_number, class: "form-control form-control-sm border-0 fw-bold shadow-none bb-dark-field",
                  style: "background-color: rgba(255,255,255,0.1); color: white; font-size: 12px;" %>
            <% else %>
              <label class="form-label small fw-bold text-uppercase" style="color: rgba(255,255,255,0.4); font-size: 9px; letter-spacing: 0.5px;">Adrès</label>
              <%= f.text_field :wallet_address, class: "form-control form-control-sm border-0 fw-bold shadow-none bb-dark-field",
                  style: "background-color: rgba(255,255,255,0.1); color: white; font-size: 11px;" %>
            <% end %>
          </div>

          <div class="d-flex gap-1">
            <%= f.button class: "btn btn-sm border-0 fw-bold rounded-3 px-2", style: "background-color: var(--haiti-gold); color: var(--haiti-charcoal);" do %>
              <i class="ri-save-3-line"></i>
            <% end %>
          </div>
        <% end %>

        <div class="mt-2 d-flex justify-content-between align-items-center">
          <div class="form-check form-switch">
            <%= form_with model: pm, url: payment_method_path(pm), method: :patch, local: true, style: "display: inline;" do |f| %>
              <%= f.hidden_field :category %>
              <%= f.hidden_field :provider %>
              <%= f.hidden_field :active, value: !pm.active? %>
              <%= f.button class: "btn btn-sm border-0 p-0", style: "color: rgba(255,255,255,0.4); font-size: 11px;" do %>
                <i class="<%= pm.active? ? 'ri-toggle-fill' : 'ri-toggle-line' %> me-1"></i><%= pm.active? ? 'Dezaktive' : 'Aktive' %>
              <% end %>
            <% end %>
          </div>
          <%= button_to payment_method_path(pm), method: :delete,
              class: "btn btn-sm border-0 p-0",
              style: "color: #fca5a5; font-size: 11px;" do %>
            <i class="ri-delete-bin-line me-1"></i>Retire
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="text-center py-4">
    <i class="<%= kind == :mobile ? 'ri-smartphone-line' : kind == :bank ? 'ri-bank-line' : 'ri-wallet-3-line' %> d-block mb-2" style="font-size: 2rem; color: var(--haiti-olive); opacity: 0.3;"></i>
    <div class="small fw-bold text-uppercase" style="color: var(--haiti-olive); letter-spacing: 1px; opacity: 0.5; font-size: 10px;">
      Pa gen <%= kind == :mobile ? 'pòtfèy mobil' : kind == :bank ? 'kont bank' : 'pòtfèy kripto' %> ankò
    </div>
  </div>
<% end %>
