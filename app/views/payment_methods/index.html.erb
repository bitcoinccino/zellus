<style>
  .bb-dark-field {
    color: #fff !important;
  }
  .bb-dark-field::placeholder {
    color: rgba(255, 255, 255, 0.5) !important;
    opacity: 1;
    font-weight: 400 !important;
  }
  .bb-dark-select {
    color: #fff !important;
  }
  .bb-dark-select option {
    background: #fff;
    color: #111827;
  }
</style>

<div class="container py-4" style="max-width: 960px;">

  <%# ── Header ── %>
  <div class="text-center mb-4">
    <div class="d-inline-flex align-items-center justify-content-center mb-2 rounded-3"
      style="width: 48px; height: 48px; background-color: var(--haiti-charcoal);">
      <i class="ri-bank-card-line ri-lg" style="color: var(--haiti-gold);"></i>
    </div>
    <h1 class="h5 fw-black mb-0" style="color: var(--haiti-charcoal);">Metòd Peman</h1>
    <p class="small mb-0" style="color: var(--haiti-olive);">Anrejistre pòtfèy mobil ak kripto pou peman pi rapid</p>
  </div>

  <div class="row g-4">

    <%# ══════════ LEFT COLUMN: Add Form ══════════ %>
    <div class="col-lg-5">
      <div class="card-base p-4 shadow-lg">
        <div class="small fw-bold text-uppercase mb-3" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">
          <i class="ri-add-circle-line me-1"></i>Ajoute Metòd Peman
        </div>

        <% if @payment_method.errors.any? %>
          <div class="alert alert-danger rounded-3 mb-3" style="background: #fdf2f2; border: 1px solid #fca5a5; color: #991b1b; font-size: 12px;">
            <i class="ri-error-warning-fill me-1"></i><%= @payment_method.errors.full_messages.to_sentence %>
          </div>
        <% end %>

        <%= form_with model: @payment_method, url: payment_methods_path, local: true, class: "d-grid gap-3", id: "new-payment-method-form" do |f| %>
          <%= f.hidden_field :active, value: true %>

          <%# ── Category ── %>
          <div>
            <label class="form-label small fw-bold text-uppercase" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">Kategori</label>
            <%= f.select :category,
                  options_for_select([["Pòtfèy Mobil", "mobile_wallet"], ["Pòtfèy Kripto", "crypto_wallet"], ["Kont Bank", "bank_account"]], @payment_method.category || "mobile_wallet"),
                  {},
                  { class: "form-select border-0 fw-bold shadow-none p-3 bb-dark-select", id: "payment-method-category",
                    style: "background-color: var(--haiti-charcoal); color: white;",
                    onchange: "togglePaymentMethodFields()" } %>
          </div>

          <%# ── Label ── %>
          <div>
            <label class="form-label small fw-bold text-uppercase" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">
              Etikèt <span class="text-lowercase fw-normal">(opsyonèl)</span>
            </label>
            <div class="input-group">
              <span class="input-group-text border-0" style="background-color: var(--haiti-charcoal); color: var(--haiti-gold);">
                <i class="ri-price-tag-3-line"></i>
              </span>
              <%= f.text_field :label, placeholder: "egz. MonCash Mwen",
                  class: "form-control border-0 fw-bold shadow-none p-3 bb-dark-field",
                  style: "background-color: var(--haiti-charcoal); color: white;" %>
            </div>
          </div>

          <%# ── Mobile Wallet Fields ── %>
          <div id="mobile-wallet-fields">
            <label class="form-label small fw-bold text-uppercase" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">Founisè</label>
            <%= f.select :provider,
                  options_for_select([["Zèllus", "zellus"], ["MonCash", "moncash"]], @payment_method.provider || "zellus"),
                  {},
                  { class: "form-select border-0 fw-bold shadow-none p-3 bb-dark-select", id: "payment-method-provider",
                    style: "background-color: var(--haiti-charcoal); color: white;",
                    onchange: "toggleMobileProvider()" } %>

            <%# ── Zèllus: $zellustag ── %>
            <div id="zellus-fields" class="mt-3">
              <label class="form-label small fw-bold text-uppercase" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">$Zellustag</label>
              <div class="input-group">
                <span class="input-group-text border-0 fw-bold" style="background-color: var(--haiti-charcoal); color: var(--haiti-gold); font-size: 16px;">$</span>
                <%= f.text_field :account_number, placeholder: "nonpa", maxlength: 20, autocomplete: "off",
                    class: "form-control border-0 fw-bold shadow-none p-3 bb-dark-field",
                    style: "background-color: var(--haiti-charcoal); color: white;",
                    id: "payment-method-account-number" %>
              </div>
              <div class="small mt-1" style="color: var(--haiti-olive); font-size: 10px;">
                <i class="ri-flashlight-line me-1"></i>Antre $zellustag resevè a (5-20 karaktè)
              </div>
            </div>

            <%# ── MonCash: phone number ── %>
            <div id="moncash-fields" class="mt-3" style="display: none;">
              <label class="form-label small fw-bold text-uppercase" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">Nimewo MonCash</label>
              <div class="input-group">
                <span class="input-group-text border-0" style="background-color: var(--haiti-charcoal); color: var(--haiti-gold);">
                  <i class="ri-phone-line"></i>
                </span>
                <input type="text" name="payment_method[account_number]" placeholder="50912345678"
                       class="form-control border-0 fw-bold shadow-none p-3 bb-dark-field"
                       style="background-color: var(--haiti-charcoal); color: white;"
                       id="payment-method-moncash-number">
              </div>
              <div class="small mt-1" style="color: var(--haiti-olive); font-size: 10px;">
                <i class="ri-information-line me-1"></i>Nou nòmalize nan fòma Ayiti (509 + 8 chif).
              </div>
            </div>
          </div>

          <%# ── Crypto Wallet Fields ── %>
          <div id="crypto-wallet-fields" style="display:none;">
            <div class="row g-3">
              <div class="col-6">
                <label class="form-label small fw-bold text-uppercase" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">Rezo</label>
                <%= f.select :network, options_for_select([["Base", "base"]], @payment_method.network || "base"), {},
                    { class: "form-select border-0 fw-bold shadow-none p-3 bb-dark-select",
                      style: "background-color: var(--haiti-charcoal); color: white;",
                      id: "payment-method-network" } %>
              </div>
              <div class="col-6">
                <label class="form-label small fw-bold text-uppercase" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">Aktif</label>
                <%# ETH and WBTC hidden (HTG + USD only mode) %>
                <%= f.select :asset, options_for_select([["USD", "usdc"]], @payment_method.asset || "usdc"), {},
                    { class: "form-select border-0 fw-bold shadow-none p-3 bb-dark-select",
                      style: "background-color: var(--haiti-charcoal); color: white;",
                      id: "payment-method-asset" } %>
              </div>
            </div>
            <div class="mt-3">
              <label class="form-label small fw-bold text-uppercase" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">Adrès Pòtfèy</label>
              <div class="input-group">
                <span class="input-group-text border-0" style="background-color: var(--haiti-charcoal); color: var(--haiti-gold);">
                  <i class="ri-wallet-3-line"></i>
                </span>
                <%= f.text_field :wallet_address, placeholder: "0x...",
                    class: "form-control border-0 fw-bold shadow-none p-3 bb-dark-field",
                    style: "background-color: var(--haiti-charcoal); color: white;",
                    id: "payment-method-wallet-address" %>
              </div>
              <div class="small mt-1" style="color: var(--haiti-olive); font-size: 10px;">
                <i class="ri-information-line me-1"></i>Itilize yon adrès EVM konpatib ak Base.
              </div>
            </div>
          </div>

          <%# ── Bank Account Fields ── %>
          <div id="bank-account-fields" style="display:none;">
            <div class="mb-3">
              <label class="form-label small fw-bold text-uppercase" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">Bank</label>
              <div class="input-group">
                <span class="input-group-text border-0" style="background-color: var(--haiti-charcoal); color: var(--haiti-gold);">
                  <i class="ri-bank-line"></i>
                </span>
                <input type="text" value="UNIBANK" readonly
                       class="form-control border-0 fw-bold shadow-none p-3 bb-dark-field"
                       style="background-color: var(--haiti-charcoal); color: white; opacity: 0.7;">
                <%= f.hidden_field :provider, value: "unibank", id: "payment-method-bank-provider" %>
              </div>
            </div>
            <div class="mb-3">
              <label class="form-label small fw-bold text-uppercase" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">Nimewo Kont</label>
              <div class="input-group">
                <span class="input-group-text border-0" style="background-color: var(--haiti-charcoal); color: var(--haiti-gold);">
                  <i class="ri-hashtag"></i>
                </span>
                <%= f.text_field :bank_account_number, placeholder: "egz. 175-1021-1750802",
                    class: "form-control border-0 fw-bold shadow-none p-3 bb-dark-field",
                    style: "background-color: var(--haiti-charcoal); color: white;",
                    id: "payment-method-bank-account-number" %>
              </div>
            </div>
            <div>
              <label class="form-label small fw-bold text-uppercase" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">
                Non sou Kont <span class="text-lowercase fw-normal">(opsyonèl)</span>
              </label>
              <div class="input-group">
                <span class="input-group-text border-0" style="background-color: var(--haiti-charcoal); color: var(--haiti-gold);">
                  <i class="ri-user-line"></i>
                </span>
                <%= f.text_field :account_holder_name, placeholder: "egz. Jean Pierre",
                    class: "form-control border-0 fw-bold shadow-none p-3 bb-dark-field",
                    style: "background-color: var(--haiti-charcoal); color: white;",
                    id: "payment-method-account-holder" %>
              </div>
            </div>
          </div>

          <%# ── Submit ── %>
          <div class="mt-1">
            <%= f.button class: "btn w-100 py-3 fw-bold rounded-4 shadow-sm border-0 d-flex align-items-center justify-content-center gap-2",
                style: "background-color: var(--haiti-charcoal); color: var(--haiti-gold); font-size: 14px; letter-spacing: 0.5px;" do %>
              <i class="ri-save-3-line"></i> Anrejistre
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <%# ══════════ RIGHT COLUMN: Registered Methods ══════════ %>
    <div class="col-lg-7">
      <div class="card-base p-4 shadow-lg">
        <div class="small fw-bold text-uppercase mb-3" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">
          <i class="ri-bank-card-line me-1" style="color: var(--haiti-gold);"></i>Metòd Anrejistre
        </div>

        <%# ── Mobile Wallets ── %>
        <div class="small fw-bold text-uppercase mb-2" style="color: rgba(255,255,255,0.5); font-size: 9px; letter-spacing: 0.5px; background-color: var(--haiti-charcoal); padding: 8px 12px; border-radius: 8px;">
          <i class="ri-smartphone-line me-1" style="color: var(--haiti-gold);"></i>Pòtfèy Mobil
        </div>
        <div class="mb-3">
          <%= render partial: "payment_method_list", locals: { methods: @mobile_wallet_methods, kind: :mobile } %>
        </div>

        <%# ── Crypto Wallets ── %>
        <div class="small fw-bold text-uppercase mb-2 mt-3" style="color: rgba(255,255,255,0.5); font-size: 9px; letter-spacing: 0.5px; background-color: var(--haiti-charcoal); padding: 8px 12px; border-radius: 8px;">
          <i class="ri-wallet-3-line me-1" style="color: var(--haiti-gold);"></i>Pòtfèy Kripto
        </div>
        <div class="mb-3">
          <%= render partial: "payment_method_list", locals: { methods: @crypto_wallet_methods, kind: :crypto } %>
        </div>

        <%# ── Bank Accounts ── %>
        <div class="small fw-bold text-uppercase mb-2 mt-3" style="color: rgba(255,255,255,0.5); font-size: 9px; letter-spacing: 0.5px; background-color: var(--haiti-charcoal); padding: 8px 12px; border-radius: 8px;">
          <i class="ri-bank-line me-1" style="color: var(--haiti-gold);"></i>Kont Bank
        </div>
        <%= render partial: "payment_method_list", locals: { methods: @bank_account_methods, kind: :bank } %>
      </div>
    </div>

  </div>

  <%# ── Back Link ── %>
  <div class="text-center mt-4">
    <%= link_to zellus_path, class: "small text-decoration-none fw-bold", style: "color: var(--haiti-olive);" do %>
      <i class="ri-arrow-left-line me-1"></i>Retounen nan Zèllus
    <% end %>
  </div>

</div>

<script>
function togglePaymentMethodFields() {
  var category = document.getElementById('payment-method-category');
  var mobile = document.getElementById('mobile-wallet-fields');
  var crypto = document.getElementById('crypto-wallet-fields');
  var bank   = document.getElementById('bank-account-fields');
  var wallet = document.getElementById('payment-method-wallet-address');
  var network = document.getElementById('payment-method-network');
  var asset = document.getElementById('payment-method-asset');
  var bankAcct = document.getElementById('payment-method-bank-account-number');
  var bankHolder = document.getElementById('payment-method-account-holder');
  var bankProvider = document.getElementById('payment-method-bank-provider');
  if (!category || !mobile || !crypto || !bank) return;

  var val = category.value;
  var isMobile = val === 'mobile_wallet';
  var isCrypto = val === 'crypto_wallet';
  var isBank   = val === 'bank_account';

  mobile.style.display = isMobile ? '' : 'none';
  crypto.style.display = isCrypto ? '' : 'none';
  bank.style.display   = isBank   ? '' : 'none';

  if (wallet) wallet.required = isCrypto;
  if (network) network.disabled = !isCrypto;
  if (asset) asset.disabled = !isCrypto;
  if (bankAcct) bankAcct.required = isBank;
  if (bankProvider) bankProvider.disabled = !isBank;

  if (isMobile) toggleMobileProvider();
}

function toggleMobileProvider() {
  var provider = document.getElementById('payment-method-provider');
  var zellusFields = document.getElementById('zellus-fields');
  var moncashFields = document.getElementById('moncash-fields');
  var zellusInput = document.getElementById('payment-method-account-number');
  var moncashInput = document.getElementById('payment-method-moncash-number');
  if (!provider) return;

  var isZellus = provider.value === 'zellus';
  if (zellusFields) zellusFields.style.display = isZellus ? '' : 'none';
  if (moncashFields) moncashFields.style.display = isZellus ? 'none' : '';

  if (zellusInput) {
    zellusInput.disabled = !isZellus;
    zellusInput.name = isZellus ? 'payment_method[account_number]' : '';
  }
  if (moncashInput) {
    moncashInput.disabled = isZellus;
    moncashInput.name = isZellus ? '' : 'payment_method[account_number]';
  }
}

document.addEventListener('DOMContentLoaded', function() {
  togglePaymentMethodFields();
});
</script>
