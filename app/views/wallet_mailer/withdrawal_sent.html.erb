<div style="margin-bottom:20px;">
  <div style="font-size:15px; font-weight:800; color:#2E2E38; margin-bottom:6px;">Retrè Voye ✓</div>
  <div style="font-size:13px; color:#5D6345;">Tranzaksyon ou sou rezo Base.</div>
</div>

<div style="background:#E8EDE0; border:2px solid #5D6345; border-radius:14px; padding:16px; margin-bottom:16px; text-align:center;">
  <div style="color:#5D6345; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:1px; margin-bottom:8px;">Montan Retire</div>
  <div style="color:#991b1b; font-size:28px; font-weight:900; letter-spacing:-1px;">
    - <%= @amount_display %>
  </div>
  <div style="margin-top:4px;">
    <span style="display:inline-block; background:#2E2E38; color:#C5A059; font-size:10px; font-weight:800; padding:3px 10px; border-radius:10px; letter-spacing:0.5px;">
      REZO BASE · USD
    </span>
  </div>
</div>

<div style="background:#fff; border:1px solid #d9d6c4; border-radius:12px; padding:12px; margin-bottom:16px;">
  <table width="100%" cellspacing="0" cellpadding="0">
    <tr>
      <td style="color:#5D6345; font-size:12px; font-weight:600; padding-bottom:8px;">Adrès Resevè</td>
      <td style="color:#2E2E38; font-weight:700; text-align:right; padding-bottom:8px; font-size:12px;"><%= @address_short %></td>
    </tr>
    <tr>
      <td style="color:#5D6345; font-size:12px; font-weight:600;">Frè</td>
      <td style="color:#166534; font-weight:700; text-align:right; font-size:12px;">Gratis (0%)</td>
    </tr>
  </table>
</div>

<% if @basescan_url.present? %>
  <div style="background:#fff; border:1px solid #d9d6c4; border-radius:12px; padding:12px; margin-bottom:16px;">
    <div style="color:#5D6345; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:1px; margin-bottom:6px;">TX Blockchain</div>
    <div style="color:#2E2E38; font-size:11px; word-break:break-all; margin-bottom:8px;"><%= @tx_hash %></div>
    <a href="<%= @basescan_url %>" target="_blank"
       style="display:inline-block; background:#2E2E38; color:#C5A059; padding:8px 16px; border-radius:8px; font-size:12px; font-weight:700; text-decoration:none;">
      🔗 Wè sou Basescan
    </a>
  </div>
<% end %>

<div style="font-size:13px; color:#5D6345; line-height:1.6;">
  USD ou voye sou rezo Base. Tranzaksyon an ap konfime nan kèk minit.
</div>
