<div style="margin-bottom:20px;">
  <div style="font-size:15px; font-weight:800; color:#991b1b; margin-bottom:6px;">Demann <%= @amount_display %> Anile</div>
  <div style="font-size:13px; color:#5D6345;">Demann #<%= @payment_request.id %> — <%= @payment_request.updated_at.strftime("%b %d, %Y") %></div>
</div>

<div style="background:#fee2e2; border:2px solid #991b1b; border-radius:14px; padding:16px; margin-bottom:16px;">
  <table width="100%" cellspacing="0" cellpadding="0">
    <tr>
      <td style="color:#991b1b; font-size:12px; font-weight:600; padding-bottom:8px;">Montan Mande</td>
      <td style="color:#2E2E38; font-weight:800; text-align:right; padding-bottom:8px;"><%= @amount_display %></td>
    </tr>
    <tr>
      <td style="color:#991b1b; font-size:12px; font-weight:600; padding-bottom:8px;">Lajan</td>
      <td style="color:#2E2E38; font-weight:700; text-align:right; padding-bottom:8px;"><%= @payment_request.asset_label %></td>
    </tr>
    <% if @payment_request.payer_name.present? %>
      <tr>
        <td style="color:#991b1b; font-size:12px; font-weight:600;">Peyè</td>
        <td style="color:#2E2E38; font-weight:600; text-align:right;"><%= @payment_request.payer_name %></td>
      </tr>
    <% end %>
    <tr>
      <td colspan="2" style="border-top:1px dashed #991b1b; padding-top:10px;"></td>
    </tr>
    <tr>
      <td style="color:#991b1b; font-size:13px; font-weight:900; text-transform:uppercase;">Estati</td>
      <td style="color:#991b1b; font-size:18px; font-weight:900; text-align:right;">ANILE</td>
    </tr>
  </table>
</div>

<div style="font-size:13px; color:#5D6345; line-height:1.6;">
  Demann peman ou te anile. Ou ka kreye yon nouvo demann nenpòt lè.
</div>
