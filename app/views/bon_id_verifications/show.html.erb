<div class="container py-4" style="max-width: 480px;">
  <div class="card-base p-4 w-100" style="border: 1px solid rgba(46,46,56,0.05);">

    <%# ── Page Header ── %>
    <div class="d-flex align-items-center justify-content-between mb-3">
      <h1 class="h5 fw-black mb-0" style="color: var(--haiti-charcoal); font-family: 'Space Grotesk', sans-serif;">Verifye ak BonID</h1>
      <%= link_to root_path, class: "small text-decoration-none fw-bold", style: "color: var(--haiti-olive);" do %>
        <i class="ri-arrow-left-line me-1"></i>Lakay
      <% end %>
    </div>

    <% if current_user.bonid_verified? %>
      <%# ══════════════════════════════════════ %>
      <%# ── VERIFIED STATE                 ──  %>
      <%# ══════════════════════════════════════ %>
      <div class="p-5 rounded-4 mb-4 text-center" style="background: var(--haiti-charcoal);">
        <% if current_user.bonid_photo_url.present? %>
          <img src="<%= current_user.bonid_photo_url %>" alt="Foto" class="rounded-circle mb-3" style="width: 80px; height: 80px; object-fit: cover; border: 3px solid var(--haiti-gold);">
        <% else %>
          <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 80px; height: 80px; background: rgba(197,160,89,0.15);">
            <i class="ri-shield-check-fill" style="font-size: 2.5rem; color: var(--haiti-gold);"></i>
          </div>
        <% end %>
        <div class="fw-bold text-uppercase mb-1" style="color: rgba(255,255,255,0.45); font-size: 11px; letter-spacing: 1.5px;">Verifye</div>
        <div class="fw-black" style="color: #fff; font-size: 22px; line-height: 1.2; font-family: 'Space Grotesk', sans-serif;">
          <%= current_user.bonid_full_name || current_user.display_name %>
        </div>
        <div style="border-top: 1px solid rgba(255,255,255,0.10); margin: 10px auto; width: 60%;"></div>
        <div style="color: var(--haiti-gold); font-size: 13px; font-weight: 700;">
          <i class="ri-fingerprint-line me-1"></i><%= current_user.bonid %>
        </div>
        <div class="mt-2" style="color: rgba(255,255,255,0.35); font-size: 11px;">
          Verifye <%= current_user.bonid_verified_at.strftime("%d %b %Y") %>
        </div>
      </div>

      <%# ── Verification Benefits ── %>
      <div class="mb-3">
        <div class="small fw-bold text-uppercase mb-2" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">
          <i class="ri-gift-line me-1" style="color: var(--haiti-gold);"></i>Avantaj Verifikasyon
        </div>
        <div class="d-flex align-items-center gap-3 p-3 rounded-3 mb-2" style="background: var(--haiti-mint); border: 1px solid transparent; transition: border-color 0.2s;" onmouseover="this.style.borderColor='var(--haiti-gold)'" onmouseout="this.style.borderColor='transparent'">
          <i class="ri-checkbox-circle-fill" style="color: #166534; font-size: 18px;"></i>
          <span style="color: var(--haiti-charcoal); font-size: 13px; font-weight: 600;">Limit kredi 2x pi gwo</span>
        </div>
        <div class="d-flex align-items-center gap-3 p-3 rounded-3 mb-2" style="background: var(--haiti-mint); border: 1px solid transparent; transition: border-color 0.2s;" onmouseover="this.style.borderColor='var(--haiti-gold)'" onmouseout="this.style.borderColor='transparent'">
          <i class="ri-checkbox-circle-fill" style="color: #166534; font-size: 18px;"></i>
          <span style="color: var(--haiti-charcoal); font-size: 13px; font-weight: 600;">Limit transfè jounalye pi wo</span>
        </div>
        <div class="d-flex align-items-center gap-3 p-3 rounded-3 mb-2" style="background: var(--haiti-mint); border: 1px solid transparent; transition: border-color 0.2s;" onmouseover="this.style.borderColor='var(--haiti-gold)'" onmouseout="this.style.borderColor='transparent'">
          <i class="ri-checkbox-circle-fill" style="color: #166534; font-size: 18px;"></i>
          <span style="color: var(--haiti-charcoal); font-size: 13px; font-weight: 600;">Konfyans pi wo nan PrioSòl</span>
        </div>
      </div>

    <% else %>
      <%# ══════════════════════════════════════ %>
      <%# ── UNVERIFIED STATE               ──  %>
      <%# ══════════════════════════════════════ %>
      <div class="p-4 rounded-4 mb-4 text-center" style="background: var(--haiti-charcoal);">
        <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 72px; height: 72px; background: rgba(197,160,89,0.15);">
          <i class="ri-shield-check-line" style="font-size: 2.2rem; color: var(--haiti-gold);"></i>
        </div>
        <div class="fw-black mb-2" style="color: #fff; font-size: 16px; font-family: 'Space Grotesk', sans-serif;">Kisa BonID ye?</div>
        <div style="color: rgba(255,255,255,0.6); font-size: 12px; max-width: 320px; margin: 0 auto; line-height: 1.6;">
          <strong style="color: var(--haiti-gold);">BonID</strong> se yon idantite dijital prive an Ayiti. Li pèmèt ou verifye tèt ou
          <strong style="color: rgba(255,255,255,0.8);">yon sèl fwa</strong> san ale nan okenn biwo, san voye imèl, san tann SMS.
        </div>
        <div style="margin: 12px auto; border-top: 1px solid rgba(255,255,255,0.08); width: 60%;"></div>
        <div style="color: rgba(255,255,255,0.4); font-size: 11px;">
          <i class="ri-time-line me-1"></i>Verifye nan mwens pase 2 minit
        </div>
      </div>

      <%# ── Benefits Preview (unlock cards) ── %>
      <div class="mb-4">
        <div class="small fw-bold text-uppercase mb-2" style="color: var(--haiti-olive); font-size: 10px; letter-spacing: 1px;">
          <i class="ri-gift-line me-1" style="color: var(--haiti-gold);"></i>Sa'w ap Debloke
        </div>
        <%# Sòl / Bousad / Ajan benefits dropped while those features are paused. %>
        <% [
          "Limit kredi 2× pi gwo",
          "Limit transfè jounalye pi wo",
          "Pa bezwen al nan biwo ni voye imèl"
        ].each do |benefit| %>
          <div class="d-flex align-items-center gap-3 p-3 rounded-3 mb-2" style="background: var(--haiti-mint); border: 1px solid transparent; transition: border-color 0.2s;" onmouseover="this.style.borderColor='var(--haiti-gold)'" onmouseout="this.style.borderColor='transparent'">
            <i class="ri-lock-2-line" style="color: var(--haiti-gold); font-size: 18px;"></i>
            <span style="color: var(--haiti-charcoal); font-size: 13px; font-weight: 600;"><%= benefit %></span>
          </div>
        <% end %>
      </div>

      <%# ── BonID Connect Button (Gold Primary) ── %>
      <%= link_to "#{BonIdService.web_url}/citizens/otp_sign_in?from_partner=zellus&lang=ht", id: "bonid-connect-btn", class: "btn w-100 rounded-pill py-3 mb-3 fw-black d-flex align-items-center justify-content-center gap-2", style: "background: var(--haiti-gold); color: var(--haiti-charcoal); font-family: 'Space Grotesk', sans-serif; font-size: 15px; border: none;" do %>
        <i class="ri-shield-check-fill" style="font-size: 20px;"></i>Konekte ak BonID
      <% end %>

      <%= render "shared/step_loader", id: "bonid-loader", steps: [
        "N ap voye'w sou BonID...",
        "Pou'w ka verifye tèt ou."
      ] %>

      <script>
        document.getElementById('bonid-connect-btn').addEventListener('click', function(e) {
          e.preventDefault();
          var url = this.href;
          ZellusLoader.start('bonid-loader', null, { stepDelay: 2500 });
          setTimeout(function() { window.location.href = url; }, 5500);
        });
      </script>

      <div class="text-center mb-3" style="font-size: 12px;">
        <span style="color: var(--haiti-olive);">Pa gen BonID?</span>
        <%= link_to "#{BonIdService.web_url}/citizens/sign_up?lang=ht&partner=zellus", target: "_blank", rel: "noopener", style: "color: var(--haiti-gold); font-weight: 700; text-decoration: none;" do %>
          Kreye youn <i class="ri-external-link-line" style="font-size: 11px;"></i>
        <% end %>
      </div>

      <div class="text-center" style="color: var(--haiti-olive); font-size: 11px;">
        <i class="ri-lock-line me-1"></i>Done ou yo pwoteje epi an sekirite.
      </div>
    <% end %>

  </div>
</div>
