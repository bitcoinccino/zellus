<div class="container d-flex justify-content-center align-items-start py-3" style="min-height: 80vh; background: var(--haiti-cream);">
  <div class="w-100" style="max-width: 600px;">

    <%# ── Back Link ── %>
    <div class="mb-3">
      <%= link_to wallet_path, class: "small text-decoration-none fw-bold", style: "color: var(--haiti-olive);" do %>
        <i class="ri-arrow-left-line me-1"></i>Retounen nan Potfey
      <% end %>
    </div>

    <%# ── Header ── %>
    <div class="d-flex align-items-center justify-content-between mb-3">
      <h5 class="fw-black mb-0" style="color: var(--haiti-charcoal);">
        <i class="ri-notification-3-line me-1" style="color: var(--haiti-gold);"></i>
        Notifikasyon
      </h5>
      <% if @notifications.any?(&:unread?) %>
        <%= link_to mark_all_read_notifications_path, class: "btn btn-sm rounded-pill px-3 border-0 fw-bold",
            style: "background: var(--haiti-charcoal); color: var(--haiti-gold); font-size: 11px;" do %>
          <i class="ri-check-double-line me-1"></i>Make tout kòm li
        <% end %>
      <% end %>
    </div>

    <%# ── Notification List ── %>
    <div class="rounded-4 overflow-hidden" style="background: white; border: 1px solid rgba(93,99,69,0.1);">
      <% if @notifications.any? %>
        <% @notifications.each do |notif| %>
          <%= link_to mark_read_notification_path(notif),
              class: "d-flex align-items-center gap-3 px-3 py-3 text-decoration-none notif-row",
              style: "border-bottom: 1px solid rgba(93,99,69,0.08); #{'background: rgba(197,160,89,0.04);' if notif.unread?} transition: background 0.15s ease;" do %>

            <%# ── Icon ── %>
            <div style="width: 38px; height: 38px; border-radius: 50%; flex-shrink: 0; display: flex; align-items: center; justify-content: center; <%= notif.icon_color_style %>">
              <i class="<%= notif.icon_class %>" style="font-size: 16px;"></i>
            </div>

            <%# ── Text ── %>
            <div class="flex-grow-1" style="min-width: 0;">
              <div class="<%= notif.unread? ? 'fw-bold' : '' %>" style="color: var(--haiti-charcoal); font-size: 13px; line-height: 1.3;">
                <%= notif.title %>
              </div>
              <% if notif.body.present? %>
                <div class="text-truncate" style="color: var(--haiti-olive); font-size: 11px; max-width: 400px;">
                  <%= notif.body %>
                </div>
              <% end %>
              <div style="color: var(--haiti-olive); font-size: 10px; margin-top: 2px;">
                <%= time_ago_in_words(notif.created_at) %> de sa
              </div>
            </div>

            <%# ── Unread Dot ── %>
            <% if notif.unread? %>
              <div style="width: 8px; height: 8px; border-radius: 50%; background: var(--haiti-gold); flex-shrink: 0;"></div>
            <% end %>
          <% end %>
        <% end %>
      <% else %>
        <div class="px-3 py-5 text-center">
          <i class="ri-notification-off-line" style="font-size: 32px; color: var(--haiti-olive); opacity: 0.3;"></i>
          <div class="mt-2" style="color: var(--haiti-olive); font-size: 13px;">Pa gen notifikasyon anko</div>
        </div>
      <% end %>
    </div>

  </div>
</div>

<style>
  .notif-row:hover {
    background: rgba(93,99,69,0.04) !important;
  }
</style>
